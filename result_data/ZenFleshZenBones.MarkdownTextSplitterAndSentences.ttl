    neo:id "3ee15312c65b6ee83dca8c3f6366f682"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 3, sentence number 1 on page 21"^^xsd:string ;
    neo:text "O-nami felt he should go to a Zen master for help."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4671 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_13,
