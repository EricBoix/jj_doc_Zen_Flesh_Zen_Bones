@prefix ex: <http://example.org/graph/> .
@prefix neo: <http://example.org/neo4j/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_0 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_5 ;
    neo:id "79557bbb331195392ac43c0c60fa590e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 1, sentence number 1 on page 7"^^xsd:string ;
    neo:text "101 Zen Stories was first published in 1919 by Rider and Company, London, and David McKay Company, Philadelphia."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1001 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "79965267557485c60a614331f501fbe8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 13, sentence number 1 on page 38"^^xsd:string ;
    neo:text "‘What is that?’ asked Mokurai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1002 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1004,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "3941b792d32032c6b971eb0be9f79e6f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 13, sentence number 2 on page 38"^^xsd:string ;
    neo:text "That is the sound of dripping water, but not the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1005 a neo:Document ;
    neo:id "dfd1b7ca29e42ac62dd9b8b02479c7c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 13, sentence number 3 on page 38"^^xsd:string ;
    neo:text "Try again.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1006 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1007,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "420e613042049331e3b363f77536b598"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 14, sentence number 1 on page 38"^^xsd:string ;
    neo:text "In vain Toyo meditated to hear the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1008 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "e917ec0221301c1882210d1afe407a56"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 14, sentence number 2 on page 38"^^xsd:string ;
    neo:text "He heard the sighing of the wind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_101 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_102,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_104,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_105,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_106,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "5a1c8fd134c3ab6aa00218565fdd3b3c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 17, sentence number 2 on page 8"^^xsd:string ;
    neo:text "The reader may judge for himself, for he has here for the first time in one book the experiences of Zen, the mind problems, the stages of awareness and a similar teaching predating Zen by centuries."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1010 a neo:Document ;
    neo:id "7e02cefc3f228bc20cdbcbe36edf8063"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 14, sentence number 3 on page 38"^^xsd:string ;
    neo:text "But the sound was rejected."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1011 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1012,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "aaa037e59c37a955316f339807166ec3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 15, sentence number 1 on page 38"^^xsd:string ;
    neo:text "He heard the cry of an owl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1013 a neo:Document ;
    neo:id "dd4596265e6b1eed141f079319f51293"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 15, sentence number 2 on page 38"^^xsd:string ;
    neo:text "This also was refused."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1014 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1015,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_978 ;
    neo:id "ae4d54437d7a91a65363521d20b03f62"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 16, sentence number 1 on page 38"^^xsd:string ;
    neo:text "The sound of one hand was not the locusts."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1016 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "2389952af740304c641d923048b99039"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 17, sentence number 1 on page 39"^^xsd:string ;
    neo:text "For more than ten times Toyo visited Mokurai with different sounds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1017 a neo:Document ;
    neo:id "ee2cf86265dc90af250d0385444fc312"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 17, sentence number 2 on page 39"^^xsd:string ;
    neo:text "All were wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1018 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_978 ;
    neo:id "d80869da9b16a4b68e32a7791713cea2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 17, sentence number 3 on page 39"^^xsd:string ;
    neo:text "For almost a year he pondered what the sound of one hand might be."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1019 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1020,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "865687bdc55ac7e27d782fdd1b173a20"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 18, sentence number 1 on page 39"^^xsd:string ;
    neo:text "At last little Toyo entered true meditation and transcended all sounds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1021 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1022,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "8c2e7311881e42a6fe2fc07aa7f10704"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 18, sentence number 2 on page 39"^^xsd:string ;
    neo:text "‘I could collect no more,’ he explained later.’ so I reached the soundless sound.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1023 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1024,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "5c246dd3cae195215d0770881439cb4e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 19, sentence number 1 on page 39"^^xsd:string ;
    neo:text "Toyo had realized the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1025 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1026,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_388,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_660 ;
    neo:id "f5368253726c7c5c25b7feb9445e5eeb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 1, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Soyen Shaku, the first Zen teacher to come to America, said: ‘My heart burns like fire but my eyes are as cold as dead ashes.’ He made the following rules, which he practiced every day of his life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1027 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_298,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_795 ;
    neo:id "221330a299869c808e3cec719a1dbf4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 2, sentence number 1 on page 40"^^xsd:string ;
    neo:text "In the morning before dressing, light incense and meditate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1028 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1029,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555 ;
    neo:id "b62cbcfdbfece9eea428a1143442e375"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 3, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Retire at a regular hour."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1030 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1031,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284 ;
    neo:id "6b15a5dce1ffd789b2fa1f4c7a1ae748"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 3, sentence number 2 on page 40"^^xsd:string ;
    neo:text "Partake of food at regular intervals."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1032 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1033,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1034 ;
    neo:id "39e3656a0dac912b0c8fc0b79f9af811"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 3, sentence number 3 on page 40"^^xsd:string ;
    neo:text "Eat with moderation and never to the point of satisfaction."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1035 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1036,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1037 ;
    neo:id "f2db046688ff1e311ee579a01646f7d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 4, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Receive a guest with the same attitude you have when alone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1038 a neo:Document ;
    neo:id "0bcb303954aa6f87f09edebdaa5b8cfc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 4, sentence number 2 on page 40"^^xsd:string ;
    neo:text "When alone, maintain the same attitude you have in receiving guests."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1039 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1040,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1041,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1042 ;
    neo:id "30984645f2c483c65a8fd1584bc9708f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 5, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Watch what you say, and whatever you say, practice it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1043 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1044,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555 ;
    neo:id "8568728ed9fdbbd499617bdc5c617e98"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 6, sentence number 1 on page 40"^^xsd:string ;
    neo:text "When an opportunity comes do not let it pass by, yet always think twice before acting."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1045 a neo:Document ;
    neo:id "e2a6b64147d30b4e825e64134cb04402"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 7, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Do not regret the past."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1046 a neo:Document ;
    neo:id "2ecece852890af87e93870c9fe8eb44b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 7, sentence number 2 on page 40"^^xsd:string ;
    neo:text "Look to the future."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1047 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1048,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "766448524b7cff9822c5e05f3ba02357"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 8, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Have the fearless attitude of a hero and the loving heart of a child."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1051 a neo:Document ;
    neo:id "4de792721f7d7f5f0a58b0b99d10f3e3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 9, sentence number 1 on page 40"^^xsd:string ;
    neo:text "Upon retiring sleep as if you had entered your last sleep."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1052 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1053,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1054 ;
    neo:id "3e1b38089a1fb1a770bb42d22382bb01"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. My Heart Burns Like Fire, paragraph number 9, sentence number 2 on page 40"^^xsd:string ;
    neo:text "Upon awakening, leave your bed behind you instantly as if you had cast away a pair of old shoes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1055 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1056,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1057,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_925 ;
    neo:id "2795a28c1a7b281bb216af99b92485d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Eshun’s Departure, paragraph number 1, sentence number 1 on page 41"^^xsd:string ;
    neo:text "When Eshun, the Zennun, was past sixty and about to leave the world, she asked some monks to pile up wood in the yard."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1058 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1059,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "691f2adc26ede959d30b914da2f55328"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Eshun’s Departure, paragraph number 2, sentence number 1 on page 41"^^xsd:string ;
    neo:text "Seating herself firmly in the center of the funeral pyre, she had it set fire around the edges."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1060 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1061,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "b7c44ae14b47553163165fa61eebb540"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Eshun’s Departure, paragraph number 3, sentence number 1 on page 41"^^xsd:string ;
    neo:text "‘O nun!’ shouted the monk, ‘is it hot in there?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1062 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1063,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411 ;
    neo:id "4679507c7dcc8a9e925590bd3ddce281"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Eshun’s Departure, paragraph number 4, sentence number 1 on page 41"^^xsd:string ;
    neo:text "‘Such a matter would concern only a stupid person like yourself,’ answered Eshun."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1064 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1065,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "20cfdfbddad8126aac77e7bf201f1d6f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Eshun’s Departure, paragraph number 5, sentence number 1 on page 41"^^xsd:string ;
    neo:text "The flames arose, and she passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1066 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1067,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1068,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "cd878a14983d1a23a5177331641632ef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 1, sentence number 1 on page 42"^^xsd:string ;
    neo:text "A farmer requested a Tendai priest to recite sutras for his wife, who had died."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1069 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1067,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1070 ;
    neo:id "b6b816c9069b2fe92d5490d48fdd0d8d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 1, sentence number 2 on page 42"^^xsd:string ;
    neo:text "After the recitation was over the farmer asked: ‘Do you think my wife will gain merit from this?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_107 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_109,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_111 ;
    neo:id "987d8d4240ce7c5fad7493a8ef3ef895"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 18, sentence number 1 on page 8"^^xsd:string ;
    neo:text "The problem of our mind, relating conscious to preconscious awareness takes us deep into everyday living."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1072 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1073,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "a0c229d7c6e91b6de35a509e9dbe7ec7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 2, sentence number 1 on page 42"^^xsd:string ;
    neo:text "‘Not only your wife but all sentient beings will benefit from the recitation of sutras,’ answered the priest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1074 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1067,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1073,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "4220b65cc274aa354231a596d53a85d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 3, sentence number 1 on page 42"^^xsd:string ;
    neo:text "‘If you say all sentient beings will benefit,’ said the farmer, ‘my wife may be very weak and others will take advantage of her, getting the benefit she should have."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1075 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "b3f9a15aa090a0934397d7bd964f753c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 3, sentence number 2 on page 42"^^xsd:string ;
    neo:text "So please recite sutras just for her.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1077 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1078,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1079,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1080,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_704 ;
    neo:id "efd95e1e3a04fc64afc2374ce3aac68f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 4, sentence number 1 on page 42"^^xsd:string ;
    neo:text "The priest explained that it was the desire of a Buddhist to offer blessings and wish merit for every living being."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1081 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1067,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "00b50038a2a3f8709830756fa6578a91"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 5, sentence number 1 on page 42"^^xsd:string ;
    neo:text "That is a fine teaching,’ concluded the farmer, ‘but please make one exception."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1082 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1083,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "7a94baed5187ba766dc608284dbcb9c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 5, sentence number 2 on page 42"^^xsd:string ;
    neo:text "I have a neighbor who is rough and mean to me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1084 a neo:Document ;
    neo:id "466b2211a551cc96cf83c7a03fce687c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Reciting Sutras, paragraph number 5, sentence number 3 on page 42"^^xsd:string ;
    neo:text "Just exclude him from all those sentient beings.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1085 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "8e54e07b28d181630b637d947d1e5f55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 1, sentence number 1 on page 43"^^xsd:string ;
    neo:text "Suiwo, the disciple of Hakuin, was a good teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1087 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1088,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "f72145711f1776c4a00c7d2aef6b38cf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 1, sentence number 2 on page 43"^^xsd:string ;
    neo:text "During one summer seclusion period, a pupil came to him from a southern island of Japan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1089 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1090,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "7657b5b7dc9741c20c20864197865e85"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 2, sentence number 1 on page 43"^^xsd:string ;
    neo:text "Suiwo gave him the problem: ‘Hear the sound of one hand.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1091 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1092,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "079e278a6e915822467685591702d16d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 3, sentence number 1 on page 43"^^xsd:string ;
    neo:text "The pupil remained three years but could not pass this test."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1093 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dafbe55dd0cff118df0afd50e09da2e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 3, sentence number 2 on page 43"^^xsd:string ;
    neo:text "One night he came in tears to Suiwo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1094 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_981 ;
    neo:id "1a21bd420e37ea35c0b43fd65c6eed24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 3, sentence number 3 on page 43"^^xsd:string ;
    neo:text "‘I must return south in shame and embarrassment,’ he said, ‘for I cannot solve my problem.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1096 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086 ;
    neo:id "729d29971fb301894483206fbe3ae211"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 4, sentence number 1 on page 43"^^xsd:string ;
    neo:text "‘Wait one week more and meditate constantly,’ advised Suiwo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1097 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "188a89d54f1770918ffc298da1342391"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 4, sentence number 2 on page 43"^^xsd:string ;
    neo:text "Still no enlightenment came to the pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1098 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086 ;
    neo:id "18a051910396078c7e11786518150c85"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 4, sentence number 3 on page 43"^^xsd:string ;
    neo:text "Try for another week,’ said Suiwo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1099 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "1e4b42eb2448c6f71254a8ab62602765"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 4, sentence number 4 on page 43"^^xsd:string ;
    neo:text "The pupil obeyed, but in vain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1100 a neo:Document ;
    neo:id "8cca8ca3173fe7b09c81c71a0ea982d2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 5, sentence number 1 on page 43"^^xsd:string ;
    neo:text "‘Still another week.’ Yet this was of no avail."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1101 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1086,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1102 ;
    neo:id "1bd328fe861bf199357daba5e6151268"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 5, sentence number 2 on page 43"^^xsd:string ;
    neo:text "In despair the student begged to be released, but Suiwo requested another meditation of five day."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1103 a neo:Document ;
    neo:id "eb448fdf08e8b92b9445c5685c4a0f00"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 5, sentence number 3 on page 43"^^xsd:string ;
    neo:text "They were without result."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1104 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "1277b0e83966a09016d442d3bfd75bfd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 5, sentence number 4 on page 43"^^xsd:string ;
    neo:text "Then he said: ‘Mediate for three day longer, then if you fail to attain enlightenment, you had better kill yourself.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1106 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1107,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "715db7ca9fbff8528fbe30f5d2222fdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Three Days More, paragraph number 6, sentence number 1 on page 43"^^xsd:string ;
    neo:text "On the second day the pupil was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1108 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1109,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_605 ;
    neo:id "c14c45f0aa204d040d012e748e6d9e40"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 1, sentence number 1 on page 44"^^xsd:string ;
    neo:text "Provided he makes and wins an argument about Buddhism with those who live there any wandering monk can remain in a Zen temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1111 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "3ccfbb8ede4091ee92557cd28bdcff9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 1, sentence number 2 on page 44"^^xsd:string ;
    neo:text "If he is defeated, he has to move on."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1114 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1115,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1116,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1117,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "53ce05aab8035d64fbf2d1aefd90730e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 2, sentence number 1 on page 44"^^xsd:string ;
    neo:text "In a temple in the northern part of Japan two brothers monks were dwelling together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1118 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1119,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1120 ;
    neo:id "910a6e76d2ca4bc7c8f5a9823840ff7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 2, sentence number 2 on page 44"^^xsd:string ;
    neo:text "The elder one was learned, but the younger one was stupid and had but one eye."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_112 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_114,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_115 ;
    neo:id "c066171b18752ce7e7545c36c2d9683f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 18, sentence number 2 on page 8"^^xsd:string ;
    neo:text "Dare we open our doors to the source of am being?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1121 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1122,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1124,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "25c4589972bfb51d040a2cb53f2c28eb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 3, sentence number 1 on page 44"^^xsd:string ;
    neo:text "A wandering monk came and asked for lodging properly challenging them to a debate about the sublime teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1125 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1126,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1127 ;
    neo:id "6742c3f381734df24f44429506da0225"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 3, sentence number 2 on page 44"^^xsd:string ;
    neo:text "The elder brother, tired that day from much studying, told the younger one to take his place."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1129 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "38d033a2915fa6c372fc2e89f1df57a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 3, sentence number 3 on page 44"^^xsd:string ;
    neo:text "‘Go and request the dialogue in silence,’ he cautioned."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1132 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1133,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1134,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_276 ;
    neo:id "a8bad5e3aac43f39a469cad56259f4c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 4, sentence number 1 on page 44"^^xsd:string ;
    neo:text "So the young monk and the strange went to the shrine and sat down."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1135 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1126,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1137 ;
    neo:id "03e2c96a28d1479dba3de3619e77a6d0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 4, sentence number 2 on page 44"^^xsd:string ;
    neo:text "Shortly afterwards the traveler rose and went in to the elder brother and said: ‘Your young brother is a wonderful fellow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1138 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "71e0870ef3a152eda9487823ed95f61e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 4, sentence number 3 on page 44"^^xsd:string ;
    neo:text "He defeated me.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1140 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1119 ;
    neo:id "7cba8cfae92b8030bd788882a9562d4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 5, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Relate the dialogue to me,’ said the elder one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1141 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "e21d534bd1da05ed21e1282cc958cee0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 6, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Well,’ explained the traveler,’ first I held up one finger, representing Buddha, the enlightened one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1142 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1143,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "890d46c639e40636713662f88bc6148d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 6, sentence number 2 on page 44"^^xsd:string ;
    neo:text "So he held up two fingers, signifying Buddha and his teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1144 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1143,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_565,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "8a8bc14e40734bb85a6029f393218477"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 6, sentence number 3 on page 44"^^xsd:string ;
    neo:text "I held up three fingers representing Buddha, his teaching, and his followers living the harmonious life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1145 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1146,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1147,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "2a9b593887aedfe55beb2c93f72bba52"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 6, sentence number 4 on page 44"^^xsd:string ;
    neo:text "Then he shook his clenched fist in my face, indicating that all three come from one realization."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1149 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136 ;
    neo:id "9458010cfa459efe166b15d4c33459a3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 7, sentence number 1 on page 44"^^xsd:string ;
    neo:text "Thus he won and so I have no right to remain here.’ With this, the traveler left."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1150 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1126,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1127 ;
    neo:id "130afa0b34b830a0fd7fe0e7a08b435e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 8, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Where is that fellow?’ asked the younger one, running in to his elder brother."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1151 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "0b9dd9a69e3ee1e6997eb3bad24373c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 9, sentence number 1 on page 44"^^xsd:string ;
    neo:text "“I understand you won the debate.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1152 a neo:Document ;
    neo:id "ff7947309d3007bb59d0dc25fb5278a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 10, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Won nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1153 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "b5588fa499a08e8375d34b21f3a9b97e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 10, sentence number 2 on page 44"^^xsd:string ;
    neo:text "I’m going to beat him up.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1154 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1155 ;
    neo:id "dfbe0d283123fb87565e5c2f8afeb9a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 11, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Tell me the subject of the debate,’ asked the elder one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1156 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1157,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "fabdca9b6040f9f85f3a376a80d149f5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 12, sentence number 1 on page 44"^^xsd:string ;
    neo:text "‘Why, the minute he saw me he held up one finger, insulting me by insinuating that I have only one eye."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1159 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "a603fd34cf6f6303375e2c57c0179bad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 12, sentence number 2 on page 44"^^xsd:string ;
    neo:text "Since he was a stranger I thought I would be polite to him, so I held up two fingers congratulating him that he her two eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_116 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_70,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_86 ;
    neo:id "a40b755f3a15c19c34759a2570a03bf1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 18, sentence number 3 on page 8"^^xsd:string ;
    neo:text "What are flesh and bones for?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1161 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1162,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1163,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1164 ;
    neo:id "f6100e969cc12f96817ed2a7aeaf6f4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 12, sentence number 3 on page 44"^^xsd:string ;
    neo:text "Then the impolite wretch held up three fingers, suggesting that between us we only have three eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1165 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_391,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_392 ;
    neo:id "b3d166306e8b5d9a2f2fdca2fd7263f0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Trading Dialogue for Lodging, paragraph number 12, sentence number 4 on page 44"^^xsd:string ;
    neo:text "So I got mad and started to punch him, bur he ran out and that ended it.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1167 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1168,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "e2d0194339462d7d7f8669bf545ddb8c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 1, sentence number 1 on page 46"^^xsd:string ;
    neo:text "After Bankei had passed away, a blind man who lived near the master’s temple told a friend: ‘Since I am blind, I cannot watch a person’s face, so I must judge his character by the sound of his voice."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_117 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_118 ;
    neo:id "a4601c055947f2aca75dac711b637d55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 19, sentence number 1 on page 8"^^xsd:string ;
    neo:text "PAUL REPS"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1170 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1171,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1172,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1173,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "aaafbd8edb1470ff55965484d4ed9bc4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 1, sentence number 2 on page 46"^^xsd:string ;
    neo:text "Ordinarily when I hear someone congratulate another upon his happiness or success, I also hear a secret tone of envy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1174 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1175,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1176 ;
    neo:id "2bd17b4bd5459177f965d6bd89a9115e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 1, sentence number 3 on page 46"^^xsd:string ;
    neo:text "When condolence is expressed for the misfortune of another."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1177 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1178,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "be87025f0dcb3e78aa3377db615179fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 1, sentence number 4 on page 46"^^xsd:string ;
    neo:text "I hear pleasure and satisfaction as if the one condoling was really glad there was something left to gain in his own world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1179 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1181,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "b1fd101812d50d7b1dff93e7f20527d0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 2, sentence number 1 on page 46"^^xsd:string ;
    neo:text "‘In all my experience however, Bankei’s voice was always sincere."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1182 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1171,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1183,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "482b704b899a06d6ac89edfc995544e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. The Voice of Happiness, paragraph number 2, sentence number 2 on page 46"^^xsd:string ;
    neo:text "Whenever he expressed happiness, I heard nothing but happiness, and whenever he expressed sorrow, sorrow was all I heard.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1184 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30 ;
    neo:id "a3a78bc84bcdfd3e7a5eac31559636e3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 1, sentence number 1 on page 47"^^xsd:string ;
    neo:text "Daiju visited the master Baso in China."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1187 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186 ;
    neo:id "206ac4a5ccf75922ffdb68c93c5cfdd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 1, sentence number 2 on page 47"^^xsd:string ;
    neo:text "Baso asked: ‘What do you seek?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_119 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_118,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_51 ;
    neo:id "ad1bb71b51ca54164cb449c2e5fcff0d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10 BULLS, paragraph number 2, sentence number 1 on page 182"^^xsd:string ;
    neo:text "Transcribed by Nyogen Senzaki and Paul Reps"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1190 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "2837fe6ef2e919e1530b71fb3d53e2f3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 2, sentence number 1 on page 47"^^xsd:string ;
    neo:text "‘Enlightenment,’ replied Daiju."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1191 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1192,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "3fdc097be901dbff0191115325a6ba96"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 3, sentence number 1 on page 47"^^xsd:string ;
    neo:text "‘You have your own treasure house."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1193 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186 ;
    neo:id "685138124cb38a1a140ba9150aa16e6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 3, sentence number 2 on page 47"^^xsd:string ;
    neo:text "Why do you search outside?’ Baso asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1194 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1192 ;
    neo:id "58190b36c36adde284c6274f01f9fad0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 4, sentence number 1 on page 47"^^xsd:string ;
    neo:text "Daiju inquired : ‘Where is my treasure house?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1195 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1192 ;
    neo:id "6928b13abc386bb86119f633c17b6ebb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 5, sentence number 1 on page 47"^^xsd:string ;
    neo:text "Baso answered: ‘What you me asking me is your treasure house.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1196 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1185 ;
    neo:id "1869a3af7d0c1b2704190b0589e8d37b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 6, sentence number 1 on page 47"^^xsd:string ;
    neo:text "Daiju was enlightened!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1197 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "15b5e0eb1ea5e4332b824cdf98ab2d9f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 6, sentence number 2 on page 47"^^xsd:string ;
    neo:text "Ever after he urged his friends:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1198 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1192,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1199 ;
    neo:id "fa0deb94f98d59d2226d2af82974f9e8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Open Your Own Treasure House, paragraph number 7, sentence number 1 on page 47"^^xsd:string ;
    neo:text "‘Open your own treasure house and use those treasures.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_12 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_13,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_14,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_15 ;
    neo:id "9118afb328c528f1a04965d8bf5d237f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 2, sentence number 1 on page 7"^^xsd:string ;
    neo:text "The Gateless Gate was first published in 1934 by John Murray, Los Angeles."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1200 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1201,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1202,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "7dbb99940a7b075af6c188213e522535"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 1, sentence number 1 on page 48"^^xsd:string ;
    neo:text "When the nun Chiyono studied Zen under Bukko of Engarku she was unable to attain the fruits of meditation for a long time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1203 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1205,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1206,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "4219406cf5d6e9dcdd0bbbdff6978690"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 2, sentence number 1 on page 48"^^xsd:string ;
    neo:text "At last one moonlit night she was carrying water in an old pail bound with bamboo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1207 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1201,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1206,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1208 ;
    neo:id "e543ec659cf365b6185fe1f12bd6a55d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 2, sentence number 2 on page 48"^^xsd:string ;
    neo:text "The bamboo broke and the bottom fell out of the pail, and at that moment Chiyono was set free!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1209 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576 ;
    neo:id "a84e37bcb723634f0155c1689fba0a69"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 3, sentence number 1 on page 48"^^xsd:string ;
    neo:text "In commemoration, she wrote a poem:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_121 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_122,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_124,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_125,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33 ;
    neo:id "508ab9a41458329c3d82f4b303f72a6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 2, sentence number 1 on page 11"^^xsd:string ;
    neo:text "These stories were transcribed into English from a book called the Shaseki-shu (Collection of Stone and Sand), written late in the thirteenth century by the Japanese Zen teacher Muju (the ‘non-dweller), and from anecdotes of Zen monks taken from various books published in Japan around the turn of the present century."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1210 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1205,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "477548c9f5fbdd9187fd164be80d5e1c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 4, sentence number 1 on page 48"^^xsd:string ;
    neo:text "In this way and that I tried to save the old pail"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1211 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1212 ;
    neo:id "b69008fb3c2987de0b6d2a64a54d43cd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 5, sentence number 1 on page 48"^^xsd:string ;
    neo:text "Since the bamboo strip was weakening and about to break"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1215 a neo:Document ;
    neo:id "40330411ffb80ecaa612353b04c43345"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 6, sentence number 1 on page 48"^^xsd:string ;
    neo:text "Until at last the bottom fell out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1216 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1208,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "a0f73cb827d3247582b9e6f3e0af38e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 7, sentence number 1 on page 48"^^xsd:string ;
    neo:text "No more water in the Pail!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1217 a neo:Document ;
    neo:id "b53acb083c10be90861feba83cf745cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. No Water, No Moon, paragraph number 8, sentence number 1 on page 48"^^xsd:string ;
    neo:text "No more moon in the water!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1218 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1220,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "944e4f276d2de8db0317bf30a99d9178"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 1, sentence number 1 on page 49"^^xsd:string ;
    neo:text "Keichu, the great Zen teacher of the Meiji era, was the head of Tofuku, a cathedral in Kyoto."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1221 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "be5bddabf4077f725813571bc2e5b8a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 1, sentence number 2 on page 49"^^xsd:string ;
    neo:text "One day the governor of Kyoto called upon him for the first time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1223 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1224,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1225,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "34d6bd40edc3b75ee2938cda81184233"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 2, sentence number 1 on page 49"^^xsd:string ;
    neo:text "His attendant presented the card of the governor, which read: Kitagaki, Governor of Kyoto."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1226 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_451 ;
    neo:id "44df1d190f800fee59f254e437f0f13c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 3, sentence number 1 on page 49"^^xsd:string ;
    neo:text "‘I have no business with such a fellow.’ said Keichu to his attendant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1227 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_405 ;
    neo:id "6c664ef7ebbc9c902af2b0c713f49064"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 3, sentence number 2 on page 49"^^xsd:string ;
    neo:text "Tell him to get out of here.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1228 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_451 ;
    neo:id "a05b308e07732dfd88b633938622c889"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 4, sentence number 1 on page 49"^^xsd:string ;
    neo:text "The attendant carried the card back with apologies."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1230 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1231,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "e4861deb132bf5d9b216f73e927678f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 4, sentence number 2 on page 49"^^xsd:string ;
    neo:text "‘That was my error,’ said the governor and with a pencil he scratched out the words Governor of Kyoto."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1232 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "6458fcbdf568256bb8793a202302ed06"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 4, sentence number 3 on page 49"^^xsd:string ;
    neo:text "‘Ask your teacher again.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1233 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1224,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1234 ;
    neo:id "a930caf197adecd65f5ab856be1fe7ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 5, sentence number 1 on page 49"^^xsd:string ;
    neo:text "‘Oh, is that Kitagaki?’ exclaimed the teacher when he saw the card."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1235 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_443 ;
    neo:id "7ddb029adef68ad113a136d00e8e8449"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. Calling Card, paragraph number 5, sentence number 2 on page 49"^^xsd:string ;
    neo:text "‘I want to see that fellow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1236 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1237,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1238,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1240 ;
    neo:id "7db210e4e1997fd49e156b3ef5dc7862"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Everything is Best, paragraph number 1, sentence number 1 on page 50"^^xsd:string ;
    neo:text "When Banzan was walking through a market he overheard a conversation between a butcher and his customer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1241 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1242 ;
    neo:id "f13cb572f15d56dcef3fc9d4e8fc8529"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Everything is Best, paragraph number 2, sentence number 1 on page 50"^^xsd:string ;
    neo:text "‘Give me the best piece of meat you have,’ said the customer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1243 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1238,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1244 ;
    neo:id "734bec3c0356143f84d33ff2a79dff5c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Everything is Best, paragraph number 3, sentence number 1 on page 50"^^xsd:string ;
    neo:text "‘Everything in my shop is the best,’ replied me butcher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1245 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_856 ;
    neo:id "b63d0de330fa1b8ca3155ab00d58ae45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Everything is Best, paragraph number 3, sentence number 2 on page 50"^^xsd:string ;
    neo:text "“You cannot find here any piece of meat that is not the best.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1248 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1237,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "dd30af12b90c4fbc56eb35c322da66d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Everything is Best, paragraph number 4, sentence number 1 on page 50"^^xsd:string ;
    neo:text "At these words Banzan became enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1249 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1250,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1251 ;
    neo:id "881d49bd3ad664a9c603d08f9a860ad1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 1, sentence number 1 on page 51"^^xsd:string ;
    neo:text "A lord asked Takuan, a Zen teacher to suggest how he might pass the time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1252 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1254,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "ae69fb40dde85a80ff3f1e0d2f1164b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 1, sentence number 2 on page 51"^^xsd:string ;
    neo:text "He felt his day very long attending his office and sitting stiffly to receive the homage of others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1255 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1256,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_304 ;
    neo:id "a9f18f5e56b11c0007e9235b0b0debbf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 2, sentence number 1 on page 51"^^xsd:string ;
    neo:text "Takuan wrote eight Chinese characters and gave them to the man:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1257 a neo:Document ;
    neo:id "57ae7945d5d4406f706d0e5c64a2c9f0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 3, sentence number 1 on page 51"^^xsd:string ;
    neo:text "Not twice this day"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1258 a neo:Document ;
    neo:id "23bc47a69e4cec09889b3e2bb264a30d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 4, sentence number 1 on page 51"^^xsd:string ;
    neo:text "Inch time foot gem"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1259 a neo:Document ;
    neo:id "72c97de05952a471fdb915630df34c6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 5, sentence number 1 on page 51"^^xsd:string ;
    neo:text "This day will not come again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_126 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_128 ;
    neo:id "5d70a0b06b3d8f1b2c734714e4aab1df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 3, sentence number 1 on page 11"^^xsd:string ;
    neo:text "For Orientals, more interested in being than in business the self- discovered man has been the most worthy of respect."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1260 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1261,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1262 ;
    neo:id "17fadfd67a560c060f21f43d2076e7d8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. Inch Time Foot Gem, paragraph number 6, sentence number 1 on page 51"^^xsd:string ;
    neo:text "Each minute is worth a priceless gem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1263 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1264,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1266 ;
    neo:id "ce5e0d7398f0106910a81be32c7028c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 1, sentence number 1 on page 52"^^xsd:string ;
    neo:text "Mokusen Hiki was living in a temple in the province of Tamba."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1267 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1268,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1269 ;
    neo:id "c10a5a695e0ed90baaa71655e6eb35e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 1, sentence number 2 on page 52"^^xsd:string ;
    neo:text "One of his adherents complained of the stinginess of his wife."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1270 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1271,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1272 ;
    neo:id "0ca13ba695ba65fd6416f25946cc6e37"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 1, sentence number 3 on page 52"^^xsd:string ;
    neo:text "Mokusen visited the adherent’s wife and showed her his clenched fist before her face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1274 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242 ;
    neo:id "f5bdf985758ed32b054e9cd0cb1e1329"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 2, sentence number 1 on page 52"^^xsd:string ;
    neo:text "‘What do you mean by that?’ asked the surprised woman."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1275 a neo:Document ;
    neo:id "41446f08d5d7d00ae393343dfe554cf9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 3, sentence number 1 on page 52"^^xsd:string ;
    neo:text "‘Suppose my fist were always like that."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1276 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "89f03d5ac6510ed7ec40a19d0b31e307"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 3, sentence number 2 on page 52"^^xsd:string ;
    neo:text "What would you call it?’ he asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1277 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242 ;
    neo:id "2dbf3372743bf5ec6769eac48fd07e55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 4, sentence number 1 on page 52"^^xsd:string ;
    neo:text "‘Deformed,’ replied the woman."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1278 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "7d20a20dc70e5f8353819e0081e82c15"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 5, sentence number 1 on page 52"^^xsd:string ;
    neo:text "Then he opened his hand flat in her face and asked: ‘Suppose it were always like that."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1279 a neo:Document ;
    neo:id "47548d7475bd50dcbf54e1b73888f0d2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 5, sentence number 2 on page 52"^^xsd:string ;
    neo:text "What then?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1280 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "82c5c7c67d7eda77975fec824c9b926d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 6, sentence number 1 on page 52"^^xsd:string ;
    neo:text "‘Another kind of deformity,’ said the wife."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1281 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1271,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "93b428057d99f47ecce7babc9d8070f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 7, sentence number 1 on page 52"^^xsd:string ;
    neo:text "‘If you understand that much,’ finished Mokusen, ‘you are a good wife.’ Then he left."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1282 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "288a8dbe3b93a5d378119244885b6731"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. Mokusen’s Hand, paragraph number 8, sentence number 1 on page 52"^^xsd:string ;
    neo:text "After his visit, this wife helped her husband to distribute as well as to save."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1283 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1284 ;
    neo:id "abac7fcf474084588811d30da16117d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 1, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Mokugen was never known to smile until his last day on earth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1285 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1286,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dfc88f283e65d55481b0538a9390dba7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 1, sentence number 2 on page 53"^^xsd:string ;
    neo:text "When his time came to pass away he said to his faithful ones: ‘You have studied under me for more than ten years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1287 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1288,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "401ec03344e62a9f63cb8be2ad308e15"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 1, sentence number 3 on page 53"^^xsd:string ;
    neo:text "Show me your real interpretation of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1289 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1290,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "cb8561c7787ad43fa2d762e1f4679117"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 1, sentence number 4 on page 53"^^xsd:string ;
    neo:text "Whoever expresses this most clearly shall be my successor and receive my robe and bowl.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1293 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "2d4c02ad23ab7089bda138d43852d78a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 2, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Everyone watched Mokugen’s severe face but no one answered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1294 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "26e2c53a48232897e3d14ca88786e1a5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 3, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Encho, a disciple who bad been with his teacher for a long time, moved near the bedside."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1297 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1298,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "95397906974bec8fb503376874bfc5d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 3, sentence number 2 on page 53"^^xsd:string ;
    neo:text "He pushed forward the medicine cup a few inches."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1299 a neo:Document ;
    neo:id "91a83879400cd7290985cc75f2e742a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 3, sentence number 3 on page 53"^^xsd:string ;
    neo:text "This was his answer to the command."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1300 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "28c8c6bdb19ce4f8d192ee47dd681747"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 4, sentence number 1 on page 53"^^xsd:string ;
    neo:text "The teacher’s face became even more severe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1301 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "69df20e39a530c2148a2c6d613ba2fdb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 4, sentence number 2 on page 53"^^xsd:string ;
    neo:text "‘Is that all you understand?’ he asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1302 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211 ;
    neo:id "c87ccc6cb8180f2a4206481a32a4346b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Encho reached out and moved the cup back again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1303 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1304 ;
    neo:id "2ac627a7d10b56a9aad2b3180340f9c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 2 on page 53"^^xsd:string ;
    neo:text "A beautiful smile broke ova the features of Mokugen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1305 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "b2a324d1daa8bc9c214b8e2d097206c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 3 on page 53"^^xsd:string ;
    neo:text "‘You rascal,’ he told Encho."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1306 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "4f53b84c110e9090d257eccb20c34ef7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 4 on page 53"^^xsd:string ;
    neo:text "‘You worked with me ten years and have not yet seen my whole body."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1307 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292 ;
    neo:id "20ba2daabdca3f038b78f85af26fc0a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 5 on page 53"^^xsd:string ;
    neo:text "Take the robe and bowl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1308 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "ad24982a1bf4eed17a40319f37da26df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. A Smile in His Lifetime, paragraph number 5, sentence number 6 on page 53"^^xsd:string ;
    neo:text "They belong to you.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1309 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_374 ;
    neo:id "bf93d6ad2857f57af0749294f92405ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 1, sentence number 1 on page 54"^^xsd:string ;
    neo:text "Zen students are with their masters at last ten years before they presume to teach others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_131 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "7379b3fff72b39b9bcf95a5167f3566b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 4, sentence number 1 on page 11"^^xsd:string ;
    neo:text "Such a man proposes to open his consciousness just as the Buddha did."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1311 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1312,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203 ;
    neo:id "7f579285d4c9f3dab5b99246bb0b37e4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 1, sentence number 2 on page 54"^^xsd:string ;
    neo:text "Nan-in was visited by Tenno, who, having passed his apprenticeship, had become a teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1313 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1312,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1314,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1315 ;
    neo:id "4a3945b0d159608e2b5b5b06625ad2e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 1, sentence number 3 on page 54"^^xsd:string ;
    neo:text "The day happened to be rainy, so Tenno wore wooden clogs and carried an umbrella."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1316 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1314,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1317,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203 ;
    neo:id "6065a37765470d77e29ecf7033da8241"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 1, sentence number 4 on page 54"^^xsd:string ;
    neo:text "After greeting him Nan- in remarked: ‘I suppose you left your wooden clogs in the vestibule."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1318 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1315,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1319 ;
    neo:id "d2a226cc811c0dbe8b249c21c502b669"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 1, sentence number 5 on page 54"^^xsd:string ;
    neo:text "I want to know if your umbrella is on the right or left side of the clogs.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1320 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1312 ;
    neo:id "65d5bff38acc13947f745e8f31106723"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 2, sentence number 1 on page 54"^^xsd:string ;
    neo:text "Tenno, confused, had no instant answer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1321 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "ffa5149af2a4ff91fa561a4aefd18592"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 2, sentence number 2 on page 54"^^xsd:string ;
    neo:text "He realized that he was unable to carry his Zen every minute."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1322 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "609e6de0712f029b04a4a018ae51f78d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Every-Minute Zen, paragraph number 2, sentence number 3 on page 54"^^xsd:string ;
    neo:text "He became Nan-in’s pupil, and he studied six more years to accomplish his every-minute Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1323 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1324,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "d477e70af369e71cf3de0b407332a68d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 1, sentence number 1 on page 55"^^xsd:string ;
    neo:text "Subhuti was Buddha’s disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1325 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1326,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1328,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "634bd5f1893ab3ba981a9c41c076f979"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 1, sentence number 2 on page 55"^^xsd:string ;
    neo:text "He was able to understand the potency of emptiness, the viewpoint that nothing exists accept in its relationship of subjectivity and objectivity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1329 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1324,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_436 ;
    neo:id "31f93574da99ff5eb084b938c4658487"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 2, sentence number 1 on page 55"^^xsd:string ;
    neo:text "One day Subhuti, in a mood of sublime emptiness was sitting under a tree."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_133 a neo:Document ;
    neo:id "cfc3f19831b056f6bce87a481b63a785"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 5, sentence number 1 on page 11"^^xsd:string ;
    neo:text "These are stories about such self-discoveries."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1330 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492 ;
    neo:id "dfe7c53b917acdeb83962c04648a650a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 2, sentence number 2 on page 55"^^xsd:string ;
    neo:text "Flowers began to fall about him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1331 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1332,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "355e5d1e44c07bd27d58415222fb92be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 3, sentence number 1 on page 55"^^xsd:string ;
    neo:text "‘We are praising you for your discourse on emptiness,’ the gods whispered to him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1333 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1324 ;
    neo:id "9cefeb0bfa9f0c185e0749dce6b1b69f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 4, sentence number 1 on page 55"^^xsd:string ;
    neo:text "‘But I have not spoken of emptiness,’ said Subhuti."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1334 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1326,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1332,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "51f39d8cc5a390e70db22622804cb14a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 5, sentence number 1 on page 55"^^xsd:string ;
    neo:text "‘You have not spoken of emptiness, we have not heard emptiness,’ responded the gods."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1335 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1324,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1336,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288 ;
    neo:id "6b986c3a37de425a68ef87b4535a0fb5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Flower Shower, paragraph number 5, sentence number 2 on page 55"^^xsd:string ;
    neo:text "This is the true emptiness.’ And blossoms showered upon Subhuti as rain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1337 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1339,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "41552423fbae27c1c25291107dca9eb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 1, sentence number 1 on page 56"^^xsd:string ;
    neo:text "Tetsugen, a devotee of Zen in Japan, decided to publish the sutras, which at that time were available only in Chinese."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_134 a neo:Document ;
    neo:id "3df50ea4ef2c0905853dda83ee1f159b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 6, sentence number 1 on page 11"^^xsd:string ;
    neo:text "The following is adapted from the preface to the first edition of these stories in English."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1340 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1341,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1343 ;
    neo:id "27d411c8c44ac3e5f0f02ece9643fdb2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 1, sentence number 2 on page 56"^^xsd:string ;
    neo:text "The books were to be printed with wood block in an edition of seven thousand copies, a tremendous undertaking."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1344 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338 ;
    neo:id "d0cf0ccf426732c1f4745152224f1009"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 2, sentence number 1 on page 56"^^xsd:string ;
    neo:text "Tetsugen began by traveling and collecting donations for this purpose."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1347 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1348,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1349,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_749 ;
    neo:id "f64e57bcc947178ef0fbff8b12a5aac8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 2, sentence number 2 on page 56"^^xsd:string ;
    neo:text "A few sympathizers would give him a hundred pieces of gold, but most of the time he received only small coins."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_135 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "0ece41acdbe023f5e63cdd5908ec0acc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 7, sentence number 1 on page 11"^^xsd:string ;
    neo:text "Zen might be called the inner art and design of the Orient."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1350 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1351,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4cc0464afc7fce939837e4f1f2e0a82e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 2, sentence number 3 on page 56"^^xsd:string ;
    neo:text "He thanked each donor with equal gratitude."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1352 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1353 ;
    neo:id "95547273c400934534c078f359029d93"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 2, sentence number 4 on page 56"^^xsd:string ;
    neo:text "After ten yens Tetsugen had enough money to begin his task."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1355 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1356,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1357 ;
    neo:id "a8865369c1ed94d7d7d028205f0d4d2e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 3, sentence number 1 on page 56"^^xsd:string ;
    neo:text "It happened that it that time the Uji River overflowed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1358 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1359 ;
    neo:id "f6c2383f58241cdaf80987d01831c6f4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 3, sentence number 2 on page 56"^^xsd:string ;
    neo:text "Famine followed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1360 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1361,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198 ;
    neo:id "ef8f00aa688aec13a91dac7edca5edc7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 3, sentence number 3 on page 56"^^xsd:string ;
    neo:text "Tetsugen took the funds he had collected for the book and spent them to save others from starvation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1362 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "68cbb79600b7dba427f1a9e41e056a97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 3, sentence number 4 on page 56"^^xsd:string ;
    neo:text "Then he began again his work of collecting."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1365 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1366,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1367 ;
    neo:id "0e00317210f31e9a9e3032757f153ef4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 4, sentence number 1 on page 56"^^xsd:string ;
    neo:text "Several years afterwards an epidemic spread over the country."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1368 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1369 ;
    neo:id "1ea2484ad27083f8d91222c8de18fbe2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 4, sentence number 2 on page 56"^^xsd:string ;
    neo:text "Tetsugen gave away what he had collected, to help his people."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_137 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "e6a651d534c1e6612805ae0078f7eb4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 7, sentence number 2 on page 11"^^xsd:string ;
    neo:text "It was rooted in China by Bodhidharma, who came from India in the sixth century, and was carried eastward into Japan by the twelfth century."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1371 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1372,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1374,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4e8a5580347fe815fc633aca6ad3ce11"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 5, sentence number 1 on page 56"^^xsd:string ;
    neo:text "For a third time he started his work, and after twenty years his wish was fulfilled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1375 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1376,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1377,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1378,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "21f69e16cedef15e8d1cd0a9acb610ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 5, sentence number 2 on page 56"^^xsd:string ;
    neo:text "The printing blocks which produced the first edition of sutras can be seen today in the Obaku monastery in Kyoto."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1379 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1380,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "25addce22d051a6f7309423f67fdc35e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. Publishing the Sutras, paragraph number 6, sentence number 1 on page 56"^^xsd:string ;
    neo:text "The Japanese tell their children that Tetsugen made three sets of sutras, and that the first two invisible sets surpass even the last."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_138 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_140,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_141,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "32a81fcd5b07e40c7b483e79a5e0f33c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 7, sentence number 3 on page 11"^^xsd:string ;
    neo:text "It has been described as: ‘A special teaching without scriptures, beyond words and letters, pointing to the mind essence of man seeing directly into one’s nature, attaining enlightenment.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1382 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412 ;
    neo:id "0c391b74cab012a4a3dd1d87ed4391d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 1, sentence number 1 on page 57"^^xsd:string ;
    neo:text "Gisho was ordained as a nun when she was ten years old."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1385 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "73bab96101415dbf3c2639a5433c8f61"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 1, sentence number 2 on page 57"^^xsd:string ;
    neo:text "She received training just as the little boys did."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1386 a neo:__Entity__ ;
    neo:RECEIVED_TRAINING ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1387 ;
    neo:id "Little Boys"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1388 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1389,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1390,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "23b1ea91b52f4a38efcd2f773f75a187"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 1, sentence number 3 on page 57"^^xsd:string ;
    neo:text "When she reached the age of sixteen she traveled from one Zen master to another, studying with them all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1391 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1392,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1393,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "d80f8d3f7e442deae763ce68db8d3383"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 2, sentence number 1 on page 57"^^xsd:string ;
    neo:text "She remained three years with Unzan, six years with Gukei, but was unable to obtain a clear vision."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1394 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1395,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "61794cbb7270d58c8877bb73947ed31c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 2, sentence number 2 on page 57"^^xsd:string ;
    neo:text "At last she went to me master Inzan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1396 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1395,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "67796ca2da44177308a141111cce9483"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 3, sentence number 1 on page 57"^^xsd:string ;
    neo:text "Inzan showed her no distinction at all on account of her sex."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1397 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1398,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "1662c3f80d8351fbb4a2fb8aa8a40f1a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 3, sentence number 2 on page 57"^^xsd:string ;
    neo:text "He scolded her like a thunderstorm."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1399 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "8f3e7dba694d26c38ff2f1c67f98b091"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 3, sentence number 3 on page 57"^^xsd:string ;
    neo:text "He cuffed her to awaken her inner nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1400 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1395 ;
    neo:id "4ddf3ca8d82e77dc38c74faf71b9a809"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 4, sentence number 1 on page 57"^^xsd:string ;
    neo:text "Gisho remained with Inzan thirteen years and then she found that which she was seeking!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1401 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1395,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576 ;
    neo:id "810f1b204b96a32a118223bab3818534"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 5, sentence number 1 on page 57"^^xsd:string ;
    neo:text "In her honor, Inzan wrote a poem:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1402 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1403,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412 ;
    neo:id "cfc865b624b6f276dac3af61c56c4cd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 6, sentence number 1 on page 57"^^xsd:string ;
    neo:text "This nun studied thirteen years under my guidance."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1404 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_961 ;
    neo:id "df079f079905aa494bc59852f6f2b76d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 7, sentence number 1 on page 57"^^xsd:string ;
    neo:text "In the evening she considered the deepest koans,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1405 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_961 ;
    neo:id "1666d29b05670251ce500d4a8e0f9e4b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 8, sentence number 1 on page 57"^^xsd:string ;
    neo:text "In the morning she was wrapped in other koans."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1406 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1339,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1407 ;
    neo:id "ac613325a9935fb47cbefde31c2ee090"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 9, sentence number 1 on page 57"^^xsd:string ;
    neo:text "The Chinese nun Tetsuma surpassed all before her,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1408 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1409 ;
    neo:id "ec1d04b3d5e5629de68d0f9b23b01cb5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 10, sentence number 1 on page 57"^^xsd:string ;
    neo:text "And since Mujaku none has been so genuine as this Gisho!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1410 a neo:Document ;
    neo:id "fbd352fcfb9d5b68f546abbd0d22f0f6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 11, sentence number 1 on page 57"^^xsd:string ;
    neo:text "Yet there are many more gates for her to pass through."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1411 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1412,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "d223c01a6e0193f93205363ec9f30130"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 12, sentence number 1 on page 57"^^xsd:string ;
    neo:text "She should receive still more blows from my iron fist."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1413 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1414,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1415,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1416 ;
    neo:id "18f0dad2e0d334a5150b07032baf45a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. Gisho’s Work, paragraph number 13, sentence number 1 on page 57"^^xsd:string ;
    neo:text "After Gisho was enlightened she went to the province of Banshu, started her own Zen temple and taught two hundred other nuns until she passed away one year in the month of August."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1417 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1418 ;
    neo:id "fb5a677c0fe07887f3be269ed9bc6b32"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 1, sentence number 1 on page 58"^^xsd:string ;
    neo:text "The master Soya Shaku passed from this world when he was sixty-one years of age."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1420 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1421,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "e89fa693a1d84822b47f218a544a9dc7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 1, sentence number 2 on page 58"^^xsd:string ;
    neo:text "Fulfilling his life’s work, he left a great teaching, far richer than that of most Zen masters."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1423 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_466 ;
    neo:id "5d9db1cf71f919e2f7eb84c931c52fab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 1, sentence number 3 on page 58"^^xsd:string ;
    neo:text "His pupils used to sleep in the daytime during midsummer, and while he overlooked this he himself never wasted a minute."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1424 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1425,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "e618b545604cca7b15b88c622d1b0d87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 2, sentence number 1 on page 58"^^xsd:string ;
    neo:text "When he was but twelve year old he was already studying Tendai philosophical speculation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1426 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "0f3185d2395c483e1f2cadd2e2e3fa4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 2, sentence number 2 on page 58"^^xsd:string ;
    neo:text "One summer day the air had been so sultry that Little Soyen stretched his legs and went to sleep while his teacher was away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1428 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1429,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7859c34d8c000ba36795bb7cb2b90756"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 3, sentence number 1 on page 58"^^xsd:string ;
    neo:text "Three hours passed when, suddenly waking he hard his master enter, but it was too late."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_143 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_144,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "ecae0ad7fc7bb197bf739c818c51be13"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 8, sentence number 1 on page 11"^^xsd:string ;
    neo:text "Zen was known as Ch’an in China."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1430 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1431,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a070fe9556f0beb2773cfc18c28c11d4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 3, sentence number 2 on page 58"^^xsd:string ;
    neo:text "There he lay, sprawled across the doorway."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1432 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1433,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_465 ;
    neo:id "8110c191e93577ef4fcfa0da7af275cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 4, sentence number 1 on page 58"^^xsd:string ;
    neo:text "‘I beg your pardon, I beg your pardon,’ his teacher whispered, stepping carefully over Soyen’s body as if it were that of some distinguished guest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1434 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1433 ;
    neo:id "833e27ec39dcabf633156624aa3ac7fb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Sleeping in the Dayime, paragraph number 4, sentence number 2 on page 58"^^xsd:string ;
    neo:text "After this, Soyen never slept again in the afternoon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1436 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1026,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "125feede554ab5b796803667adefbf13"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 1, sentence number 1 on page 59"^^xsd:string ;
    neo:text "‘Our schoolmaster used to take a nap every afternoon,’ related a disciple of Soyen Shaku."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1438 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1439,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1440,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1441,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1442,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1443,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1444,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dad80a3fb5b6f280d02f4d32760b1911"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 1, sentence number 2 on page 59"^^xsd:string ;
    neo:text "‘We children asked him why he did it and he told us: ‘I go to dreamland to meet the old sages just as Confucius did.’ When Confucius slept, he would dream of ancient sages and later tell his followers about them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1445 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1446 ;
    neo:id "583da929a6142e1514ea8b9cb198bb5f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 2, sentence number 1 on page 59"^^xsd:string ;
    neo:text "‘It was extremely hot one day so some of us took a nap."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1449 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1446 ;
    neo:id "38f778b15ab3bea465694a9409503707"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 2, sentence number 2 on page 59"^^xsd:string ;
    neo:text "Our schoolmaster scolded us."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_145 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_146,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_147,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "603e47fb202490aecfb218a8dfed6b02"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 8, sentence number 2 on page 11"^^xsd:string ;
    neo:text "The Ch’an-Zen masters, instead of being followers of the Buddha, aspire to be his friends and to place themselves in the same responsive relationship with the universe, as did Buddha and Jesus."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1450 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1440,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1441,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1451 ;
    neo:id "40f1bf7fe4b8a5040c62287483e5bfed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 2, sentence number 3 on page 59"^^xsd:string ;
    neo:text "“We went to dreamland to meet the ancient sages the same as Confucius did,” we explained."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1453 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1454,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1455 ;
    neo:id "0962318480e66df3c6c026cde1bcfea8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 2, sentence number 4 on page 59"^^xsd:string ;
    neo:text "“What was the message from those sages?” our schoolmaster demanded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1456 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1440,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1454 ;
    neo:id "58db56d7d5c2da5b9c99d7187d11d1d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. In Dreamland, paragraph number 2, sentence number 5 on page 59"^^xsd:string ;
    neo:text "One of us replied: “We went to dreamland and met the sages and asked than if our schoolmaster came there every afternoon, but they said they had never seen any such fellow.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1457 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "9c8d6fae7a6ed2e3825b2aeadb1ad2c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 1, sentence number 1 on page 60"^^xsd:string ;
    neo:text "Joshu began the study of Zen when he was sixty years old and continued until he was eighty, when he realized Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1458 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "8b987a7bc6e9d31f241ec08b9753ef4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 2, sentence number 1 on page 60"^^xsd:string ;
    neo:text "He taught from the age of eighty until he was one hundred and twenty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1462 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "3b3c5d3a58d639effc420d48976c8cbc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 2, sentence number 2 on page 60"^^xsd:string ;
    neo:text "A student once asked him: ‘If I haven’t anything in my mind, what shall I do?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1463 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "c7023c3cfc46209db357114c0d8975b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 3, sentence number 1 on page 60"^^xsd:string ;
    neo:text "Joshu replied: ‘Throw it out.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1466 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1467 ;
    neo:id "548d86eca8d767f98cd10e289b78ff55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 4, sentence number 1 on page 60"^^xsd:string ;
    neo:text "‘But if I haven’t anything how on I throw it out?’ continued the questioner."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1468 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "a84cc1d1bd12efb587896e83ac4efc02"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Joshu’s Zen, paragraph number 5, sentence number 1 on page 60"^^xsd:string ;
    neo:text "‘Well,’ said Joshu, ‘then carry it out.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1469 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1470,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "edfef85c58c2f7c8e698eb6bcbef29ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 1, sentence number 1 on page 61"^^xsd:string ;
    neo:text "When Mamiya, who later became a well-known preacher, went to a teacher for personal guidance, he was asked to explain the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1471 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1024,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1470 ;
    neo:id "2894f95dc70be22255a338b9be231dd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 2, sentence number 1 on page 61"^^xsd:string ;
    neo:text "Mamiya concentrated upon what the sound of one hand might be."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1472 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "820e5a78993b8164141850ded41dcdbf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 2, sentence number 2 on page 61"^^xsd:string ;
    neo:text "‘You are not working hard enough,’ his teacher told him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1473 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1474,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1475,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_322,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "2ce36762e8701ef2856ed554c7f63ab0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 2, sentence number 3 on page 61"^^xsd:string ;
    neo:text "‘You are too attached to food, wealth, things, and that sound."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1476 a neo:Document ;
    neo:id "f6e04d0d0726fb49e4d0d5e77e39dc49"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 2, sentence number 4 on page 61"^^xsd:string ;
    neo:text "It would he better if you died."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1477 a neo:Document ;
    neo:id "e55edd2957bf517dd483633ac60d98f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 2, sentence number 5 on page 61"^^xsd:string ;
    neo:text "That would solve the problem.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1478 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1470,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "a0a4294f45aedb8c2f36deea0e58cec7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 3, sentence number 1 on page 61"^^xsd:string ;
    neo:text "The next time Mamiya appeared before his teacher he was again asked what he had to show regarding the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1479 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1470 ;
    neo:id "e09c95a655bba6cae0a0eb8d345f76aa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 3, sentence number 2 on page 61"^^xsd:string ;
    neo:text "Mamiya at once fell over as if he were dead."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1480 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1481,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "c294d41334dd01e7917506cd2bd4c949"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 4, sentence number 1 on page 61"^^xsd:string ;
    neo:text "‘You are dead all right’ observed the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1482 a neo:Document ;
    neo:id "9ad59b4a699ebb02f67aacc328f28d2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 4, sentence number 2 on page 61"^^xsd:string ;
    neo:text "‘But how about that sound?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1483 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1470 ;
    neo:id "26169ed04f41b0b4d85dba26618f818e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 5, sentence number 1 on page 61"^^xsd:string ;
    neo:text "‘I haven’t solved that yet,’ replied Mamiya, looking up."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1484 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "e23d4c15936edb8612bbd14adf71af38"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Dead Man’s Answer, paragraph number 5, sentence number 2 on page 61"^^xsd:string ;
    neo:text "‘Dead men do not speak,’ said the teacher.’ Get out!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1485 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_388 ;
    neo:id "896464a74a0bdd3598b08bb1474ce0a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 1, sentence number 1 on page 62"^^xsd:string ;
    neo:text "Tosui was a well-known Zen teacher of his time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1487 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1488,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "2956acfb69148edfdb5385273b35d6ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 1, sentence number 2 on page 62"^^xsd:string ;
    neo:text "He had lived in several temples and taught in various provinces."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1489 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1490,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_383 ;
    neo:id "8ca5ecdc6f1aaa4891c48e4c10933138"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 2, sentence number 1 on page 62"^^xsd:string ;
    neo:text "The last temple he visited accumulated so many adherents that Tosui told them he was going to quit the lecture business entirely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_149 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "0b81d8a99b8eb01bc4b5119791bee377"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 8, sentence number 3 on page 11"^^xsd:string ;
    neo:text "Zen is not a sect but an experience."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1491 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dc7d88e653890461b700db5661cdbd4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 2, sentence number 2 on page 62"^^xsd:string ;
    neo:text "He advised them to disperse and to go wherever they desired."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1493 a neo:Document ;
    neo:id "91b23bfecdba3cf777a69222dce41e4c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 2, sentence number 3 on page 62"^^xsd:string ;
    neo:text "After that no one could find any trace of him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1494 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1495,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1496,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "207ca2de991292105d2a3a70e945e6be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 3, sentence number 1 on page 62"^^xsd:string ;
    neo:text "Three years later one of his disciple discovered him living with some beggars under a bridge in Kyoto."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1498 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "38bd55df4f35349c9443f474fcbdd98c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 3, sentence number 2 on page 62"^^xsd:string ;
    neo:text "He at once implored Tosui to teach him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1499 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486 ;
    neo:id "5ee9a5b07d6e0931efbfbbc4a2a7c5c7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 4, sentence number 1 on page 62"^^xsd:string ;
    neo:text "‘If you can do as I do for even a couple of days, I might,’ Tosui replied."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_150 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_151,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_152,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "db342691a6c1f756a0aae4c725e68328"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 9, sentence number 1 on page 11"^^xsd:string ;
    neo:text "The Zen habit of self-searching through meditation to realize one’s true nature, with disregard of formalism, with insistence on self-discipline and simplicity of living, ultimately won the support of the nobility and ruling classes in Japan and the profound respect of all levels of philosophical thought in the Orient."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1501 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1502,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1503 ;
    neo:id "e0c4de00d97fc3dddcc93dbae66c613a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 5, sentence number 1 on page 62"^^xsd:string ;
    neo:text "So the former disciple dressed as a beggar and spent a day with Tosui."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1504 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1357,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1503 ;
    neo:id "ca984a9601f17d2422edbcc3eb9dcb73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 5, sentence number 2 on page 62"^^xsd:string ;
    neo:text "The following day one of the beggars died."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1505 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1506,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "f49acb08052cb010988ebc180e2aac8a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 5, sentence number 3 on page 62"^^xsd:string ;
    neo:text "Tosui and his pupil carried the body off at midnight and buried it on a mountainside."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1507 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1508,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "5d2df41d6f44b0dd71738c9e12a0bdd3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 5, sentence number 4 on page 62"^^xsd:string ;
    neo:text "After that they returned to their shelter under the bridge."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1509 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "90f25ec646c054e2f414716ad9f8b6d8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 6, sentence number 1 on page 62"^^xsd:string ;
    neo:text "Tosui slept soundly the remainder of the night, but the disciple could not sleep."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1510 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_298 ;
    neo:id "d605c349b3acc565e90db5c9b6f244de"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 6, sentence number 2 on page 62"^^xsd:string ;
    neo:text "When morning came Tosui said: ‘We do not have to beg food today."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1511 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "83196f7af7d7a6ab83035d46010b4c71"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 6, sentence number 3 on page 62"^^xsd:string ;
    neo:text "Our dead friend has left some over there.’ But the disciple was unable to eat a single bite of it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1512 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486 ;
    neo:id "bdd98a3d8d933c231d0090042cdf1906"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 7, sentence number 1 on page 62"^^xsd:string ;
    neo:text "‘I have said you could not do as I.’ concluded Tosui."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1513 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "54e3773b5a39d66cf035b932d20a3242"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Zen in a Beggar’s Life, paragraph number 7, sentence number 2 on page 62"^^xsd:string ;
    neo:text "‘Get out of here and do not bother me again.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1514 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1515,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1516,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_514,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "b934f415ad77d5496e609b2e40210673"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 1, sentence number 1 on page 63"^^xsd:string ;
    neo:text "One evening as Shichiri Kojun was reciting sutras a thief with a sharp sword entered, demanding either his money or his life, Shichiri told him: ‘Do not disturb me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1517 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1518,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265 ;
    neo:id "c9bafde13ab2bd3fd45c323228b0e771"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 1, sentence number 2 on page 63"^^xsd:string ;
    neo:text "You an find the money in that drawer.’ Then he resumed his recitation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1519 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "9369028c4767e5a1ec9eaf5f333d7e0e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 2, sentence number 1 on page 63"^^xsd:string ;
    neo:text "A little while afterwards he stopped and called: ‘Don’t take it all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1520 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1521,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "7d62814784346898be3d2b639fc42f9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 2, sentence number 2 on page 63"^^xsd:string ;
    neo:text "I need some to pay taxes with tomorrow.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1522 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1523,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265 ;
    neo:id "cad1b608dbb71f1cb7f297ea3cc75abd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 3, sentence number 1 on page 63"^^xsd:string ;
    neo:text "The intruder gathered up most of the money and started to leave."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1524 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1526 ;
    neo:id "38822fc774f60cf1aba24889070a85c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 3, sentence number 2 on page 63"^^xsd:string ;
    neo:text "‘Thank a person when you receive a gift,’ Shichiri added."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1527 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "85d08d162fce3209b98852ca3fe099a7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 4, sentence number 1 on page 63"^^xsd:string ;
    neo:text "The man thanked him and made off."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1528 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_443 ;
    neo:id "0e9f1d7f00ba4935ea45a76bbacf20d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 5, sentence number 1 on page 63"^^xsd:string ;
    neo:text "A few days afterwards the fellow was caught and confessed, among others, the offence against Shichiri."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1529 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_304 ;
    neo:id "04142ac5d34ffb9deaad0f429a2aefd9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 5, sentence number 2 on page 63"^^xsd:string ;
    neo:text "When Shichiri was called as a witness he said: ‘This man is no thief, at least as far as I am concerned."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_153 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_154,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_155 ;
    neo:id "446680601d94a88a2eac6da60c49e194"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 10, sentence number 1 on page 11"^^xsd:string ;
    neo:text "The Noh dramas are Zen stories."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1530 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "e47eeb6568f850efe807654c82c1edf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 5, sentence number 3 on page 63"^^xsd:string ;
    neo:text "I gave him the money and he thanked me for it.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1531 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1532 ;
    neo:id "64b3b9f53bca08f012ace792b2fab776"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. The Thief Who Became a Disciple, paragraph number 6, sentence number 1 on page 63"^^xsd:string ;
    neo:text "After he had finished his prison term, the men went to Shichiri and became his disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1533 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "d4ae48f4799dac10ed8eef05b82ea259"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 1, sentence number 1 on page 64"^^xsd:string ;
    neo:text "When Bankei held his seclusion weeks of meditation, pupils from many parts of Japan came to attend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1534 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1535,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "c66fba05efef84094c39c9c5a28a2d80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 1, sentence number 2 on page 64"^^xsd:string ;
    neo:text "During one of the gatherings a pupil was caught stealing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1536 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1537,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1538,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "ec5e5e72d80c27db60b8419e016f1d38"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 1, sentence number 3 on page 64"^^xsd:string ;
    neo:text "The matter was reported to Bankei with the request that the culprit be expelled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1539 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1540,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "e9f6a8dfbcfc922c1f176f2a87544c15"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 2, sentence number 1 on page 64"^^xsd:string ;
    neo:text "Bankei ignored the case."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1541 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "65207478025c0d29c720b6b4698336b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 3, sentence number 1 on page 64"^^xsd:string ;
    neo:text "Later the pupil was caught in a similar act, and again Bankei disregarded the matter."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1542 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_514,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "0a7d7b60410115599742edfb5f060369"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 3, sentence number 2 on page 64"^^xsd:string ;
    neo:text "This angered the other pupils, who drew up a petition asking for the dismissal of the thief, stating that otherwise they would leave in a body."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1544 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "a9f1526be6ee11c2c570305044825234"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 1 on page 64"^^xsd:string ;
    neo:text "When Bankei had read the petition he called everyone before him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1545 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4353877cead6e083560ec36212df9644"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 2 on page 64"^^xsd:string ;
    neo:text "‘You are wise brothers,’ he told them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1546 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1547,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_407 ;
    neo:id "161fd788d4657231f09da768e2df562b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 3 on page 64"^^xsd:string ;
    neo:text "‘You know what is right and what is not right."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1548 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "f68ecc552a36b52f7446eff7a1cf08ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 4 on page 64"^^xsd:string ;
    neo:text "You may go somewhere else to study if you wish, but this poor brother does not even know right from wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1549 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "859e29f5257e276ac8755f5980e38dbb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 5 on page 64"^^xsd:string ;
    neo:text "Who will teach him if I do not?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1550 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1551,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "298b25037068b7b6394554125540f8a5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 4, sentence number 6 on page 64"^^xsd:string ;
    neo:text "I am going to keep him here even if all the rest of you leave.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1552 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1553,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1554,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "80444bb199acbe765ca29ce663c5bb86"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 5, sentence number 1 on page 64"^^xsd:string ;
    neo:text "A torrent of tears cleansed the face of the brother who had stolen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1555 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1556,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1557 ;
    neo:id "87b9173bae9727aefaa6c9f3c7199d33"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Right and Wrong, paragraph number 5, sentence number 2 on page 64"^^xsd:string ;
    neo:text "All the desire to steal had vanished."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1558 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1559,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1560,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c60553dd515a1eb8eeab3d4ab2cec729"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 1, sentence number 1 on page 65"^^xsd:string ;
    neo:text "During the Kamkura period, Shinkan studied Tendai six years and then studied Zen seven years; then he went to China and contemplated Zen for thirteen years more."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_156 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_157,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_162,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_163,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_164,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_165 ;
    neo:id "21ae27f6a22de223e32bd7e04fab0c53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 10, sentence number 2 on page 11"^^xsd:string ;
    neo:text "Zen spirit has come to mean not only peace and understanding, but devotion to art and to work, the rich unfolding of contentment, opening the door to insight, the expression of innate beauty, the intangible charm of incompleteness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1562 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33 ;
    neo:id "9691cc2e7b8478593fe0856d5104027f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 2, sentence number 1 on page 65"^^xsd:string ;
    neo:text "When he returned to Japan many desired to interview him and asked obscure questions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1564 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1559,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1565 ;
    neo:id "a38b36cd6f7745d6fc12578b34176e9f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 2, sentence number 2 on page 65"^^xsd:string ;
    neo:text "But when Shinkan received visitors, which was infrequently, he seldom answered their questions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1566 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1559,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1567,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1568 ;
    neo:id "a9e11eca8b5cbde54fe154d5c15cef57"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 3, sentence number 1 on page 65"^^xsd:string ;
    neo:text "One day a fifty-year-old student of enlightenment said to Shinkan: ‘I have studied the Tendai school of thought since I was a little boy, but one thing in it I cannot understand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1569 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1570,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1571 ;
    neo:id "ff6e16e125648cf791c1f63ba4469afa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 3, sentence number 2 on page 65"^^xsd:string ;
    neo:text "Tendai claims that even the grass and trees will become enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1572 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "d50b0b30c101a18f060d7820ac52b851"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 3, sentence number 3 on page 65"^^xsd:string ;
    neo:text "To me this seems very strange.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1573 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1559,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1570,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1571 ;
    neo:id "3d21cfa0ef53ad914cdccefa5160f73f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 4, sentence number 1 on page 65"^^xsd:string ;
    neo:text "‘Of what use is it to discuss how grass and trees become enlightened?’ asked Shinkan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1574 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1575 ;
    neo:id "3604ebe33f168aa39ecb37a8154c3984"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 4, sentence number 2 on page 65"^^xsd:string ;
    neo:text "The question is how you yourself can become so."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1576 a neo:Document ;
    neo:id "2d71899d40763faecd91e17f7595739e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 4, sentence number 3 on page 65"^^xsd:string ;
    neo:text "Did you ever consider that!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1577 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1578 ;
    neo:id "92d00cbb4443aa4a2f99f5e16a9c5231"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 5, sentence number 1 on page 65"^^xsd:string ;
    neo:text "‘I never thought of it in that way,’ marveled the old man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1579 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1559 ;
    neo:id "4ff827596c1bc33a8d629aba5c3fa152"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. How Grass and Trees Become Enlightened, paragraph number 5, sentence number 2 on page 65"^^xsd:string ;
    neo:text "Then go home and think it over,’ finished Shinkan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1580 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "e06b82148f7e13e07fbde1da0d108927"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 1, sentence number 1 on page 66"^^xsd:string ;
    neo:text "Gessen was an artist monk."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1583 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "b8c35f729b6913bb7cd15ffc836cb1d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 1, sentence number 2 on page 66"^^xsd:string ;
    neo:text "Before he would start a drawing or painting he always insisted upon being paid in advance and his fees were high."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1586 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1587 ;
    neo:id "e4b67ff6b6e5b754b18c16179151784b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 1, sentence number 3 on page 66"^^xsd:string ;
    neo:text "He was known as the ‘Stingy Artist’."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1588 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1589,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1590,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "9ecdfc0f7fe1dd150decb3b5694a6567"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 2, sentence number 1 on page 66"^^xsd:string ;
    neo:text "A geisha once gave him a commission for a painting."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1591 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581 ;
    neo:id "73373f864f7a64774c9a37082338e94d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 2, sentence number 2 on page 66"^^xsd:string ;
    neo:text "‘How much can you pay?’ inquired Gessen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1592 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "79c0b9a86fe7ed32e97d7e6b09ee7fd5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 2, sentence number 3 on page 66"^^xsd:string ;
    neo:text "‘Whatever you charge,’ replied the girl, ‘but I want you to do the work in front of me.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1593 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1589 ;
    neo:id "127bd055f57a5810ee54b7488f5b21b9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 3, sentence number 1 on page 66"^^xsd:string ;
    neo:text "So on a certain day Gessen was called by the geisha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1594 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1595,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_537 ;
    neo:id "313d44a46f65dd8c625bc941895c331d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 3, sentence number 2 on page 66"^^xsd:string ;
    neo:text "She was holding a feast for her patron."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1596 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1590 ;
    neo:id "18d60a291c6840d19c7ab492e18923a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 1 on page 66"^^xsd:string ;
    neo:text "Gessen with fine brushwork did the painting."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1597 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1598,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "9c7a58024a48e6856f8d5725d36e8767"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 2 on page 66"^^xsd:string ;
    neo:text "When it was completed he asked the highest sum of his time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1599 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "d03108e0e607143e5778f39f6e637988"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 3 on page 66"^^xsd:string ;
    neo:text "He received his pay."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_16 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_17,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_18,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_19,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_20,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_21,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_22 ;
    neo:id "9c3723f4323712bfec0747eb499678d2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 2, sentence number 2 on page 7"^^xsd:string ;
    neo:text "It is a collection of problems, called koan that Zen teachers use in guiding their students toward release, first recorded by a Chinese master in the year 1228."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1601 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1589,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1602 ;
    neo:id "405d74d0401d369a38b4871226cc17c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 4 on page 66"^^xsd:string ;
    neo:text "Then the geisha turned to her patron, saying: ‘All this artist wants is money."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1603 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1604,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_378 ;
    neo:id "3125a166af8a14decf0596623f5f53b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 5 on page 66"^^xsd:string ;
    neo:text "His paintings are fine but his mind is dirty: money has caused it to become muddy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1605 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1372,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1606 ;
    neo:id "9d24e591c21a27a66e19bb20eee9f596"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 6 on page 66"^^xsd:string ;
    neo:text "Drawn by such a filthy mind his work is not fit to exhibit."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1607 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1608,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "f58f17f2a2e2fddb2da6a04c34889e8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 4, sentence number 7 on page 66"^^xsd:string ;
    neo:text "It is just about good enough for one of my petticoats.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1609 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1608,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1610,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "47ff94542cca2fafed6cb3eb69e73162"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 5, sentence number 1 on page 66"^^xsd:string ;
    neo:text "Removing her skirt, she then asked Gessen to do another picture on the back of her petticoat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1611 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581 ;
    neo:id "b558941811eb06fbb852931d424aacfa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 6, sentence number 1 on page 66"^^xsd:string ;
    neo:text "‘How much will you pay?’ asked Gessen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1612 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "6349fdd709474fb4ab2fcf57c9ae8106"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 7, sentence number 1 on page 66"^^xsd:string ;
    neo:text "‘Oh, any amount,’ answered the girl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1613 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_796 ;
    neo:id "f38f648395864d574c878e117a59d460"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 8, sentence number 1 on page 66"^^xsd:string ;
    neo:text "Gessen named a fancy price, painted the picture in the manner requested and went away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1614 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581 ;
    neo:id "ce216d9715401bbea0611ce274926346"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 9, sentence number 1 on page 66"^^xsd:string ;
    neo:text "It was learned later that Gessen had these reasons for desiring money."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1615 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1359,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1616 ;
    neo:id "6683be3bd71003111c50f702b1cb73c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 10, sentence number 1 on page 66"^^xsd:string ;
    neo:text "A ravaging famine often visited his province."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1617 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1618,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1619,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1620,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1621 ;
    neo:id "b56bb5d48e8469804e8a0f53fd6103cc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 10, sentence number 2 on page 66"^^xsd:string ;
    neo:text "The rich would not help the poor, so Gessen had a secret warehouse, unknown to anyone, which he kept filled with grain prepared for these emergencies."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1622 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1623,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1624,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1625,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_229 ;
    neo:id "1c23fac93a8e6a1e61fcdd343a57c5a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 11, sentence number 1 on page 66"^^xsd:string ;
    neo:text "From his village to the National Shrine the road was in very poor condition and many travelers suffered while traversing it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1626 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1627,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "6aa173a7256fd17af970ea8864138b7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 11, sentence number 2 on page 66"^^xsd:string ;
    neo:text "He desired to build a better road."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1628 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1629,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "9467f346524fd228e01c734fa178d9bb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 12, sentence number 1 on page 66"^^xsd:string ;
    neo:text "His teacher had passed away without realizing his wish build a temple and Gessen wished to complete this temple for him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1630 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1631 ;
    neo:id "96ab944310803dcc9d7328188c2565d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. The Stingy Artist, paragraph number 13, sentence number 1 on page 66"^^xsd:string ;
    neo:text "After Gessen had accomplished his three wishes he threw away his brushes and artist’s materials and retiring to the mountains never painted again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1632 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1633,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1634,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1635,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1636 ;
    neo:id "dde15a705f49091b514c01a52ffcbb99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 1, sentence number 1 on page 68"^^xsd:string ;
    neo:text "Sen no Rikyu, a tea-master, wished to hang a flower basket on a column."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1637 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1638,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4f5be375ec24a2aec95bf29908821303"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 1, sentence number 2 on page 68"^^xsd:string ;
    neo:text "He asked a carpenter to help him, directing the man to place it a little higher or lower, to the right or left, until he had found exactly the right spot."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1639 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1633,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640 ;
    neo:id "c060f06c652efd381d19b2010f0c2c6a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 1, sentence number 3 on page 68"^^xsd:string ;
    neo:text "That’s the place,’ said Sen no Rikyu finally."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1641 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1638,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1642,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "91a4fd6fb2cd3eb02cf24f267451a75c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 2, sentence number 1 on page 68"^^xsd:string ;
    neo:text "The carpenter, to test the master, marked the spot and then pretended he had forgotten."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1643 a neo:Document ;
    neo:id "0a9de7bc2b696a39bd71108121a3ef17"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 2, sentence number 2 on page 68"^^xsd:string ;
    neo:text "Was this the place?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1644 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1636,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1638 ;
    neo:id "c386a8539b8bc7177e444628f95777fd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 2, sentence number 3 on page 68"^^xsd:string ;
    neo:text "‘Was this the place, perhaps?’ the carpenter kept asking, pointing to various places on the column."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1645 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1634,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1638 ;
    neo:id "471baa8501bc6329edf053e89d6b2768"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Accurate Proportion, paragraph number 3, sentence number 1 on page 68"^^xsd:string ;
    neo:text "But so accurate was the tea-master’s sense of proportion that it was not until the carpenter reached the identical spot again that its location was approved."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1646 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1647,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1648,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "1695417ca6a60c7110382ad5527b31ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 1, sentence number 1 on page 69"^^xsd:string ;
    neo:text "A nun who was searching for enlightenment made a statue of Buddha and covered it with gold leaf."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1649 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1650,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "9e2f18dfab64aa1fdae891f709062c36"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 1, sentence number 2 on page 69"^^xsd:string ;
    neo:text "Wherever she went she carried this golden Buddha with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1651 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1652,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "510de34d06d35c6b0d4c3754bccbb53b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 2, sentence number 1 on page 69"^^xsd:string ;
    neo:text "Years passed and, still carrying her Buddha, the nun came to live in a small temple in a country where there were many Buddha’s, each one with its own particular shrine."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1653 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1654,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_795 ;
    neo:id "2c0ea5c18b88365c677f0c380364ea02"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 3, sentence number 1 on page 69"^^xsd:string ;
    neo:text "The nun wished to burn incense before her golden Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1655 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1647,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1656,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1657,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1658,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "241ae73dff79b4bb728bffc17f5e13a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 3, sentence number 2 on page 69"^^xsd:string ;
    neo:text "Not liking the idea of the perfume straying to the others, she devised a funnel through which the smoke would ascend only to her statue."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1659 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1650,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1660 ;
    neo:id "160ecdd4f66dcd1939fa233e12b07cec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. Black-Nosed Buddha, paragraph number 3, sentence number 3 on page 69"^^xsd:string ;
    neo:text "This blackened the nose of the Golden Buddha making it especially ugly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_166 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c84dbfa429a98d36fc76404423cd6d55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 10, sentence number 3 on page 11"^^xsd:string ;
    neo:text "Zen carries many meanings, none of them, entirely definable."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1662 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663 ;
    neo:id "a9ea053ac56997a38e14ee457fb21447"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 1, sentence number 1 on page 70"^^xsd:string ;
    neo:text "The Buddhist nun known as Ryonen was born in 1797."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1665 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1666,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "502078ffd13576599907cc8efef8e759"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 1, sentence number 2 on page 70"^^xsd:string ;
    neo:text "She was a granddaughter of the famous Japanese warrior Shingen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1667 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1668,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1669,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "f54889ffd63c5e50444b9506d1cbbb26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 2, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Her poetical genius and alluring beauty were such that at seventeen she was serving the empress as one of the ladies of the court."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_167 a neo:Document ;
    neo:id "38ded48330cf9a023c0673694d3bd1d0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 10, sentence number 4 on page 11"^^xsd:string ;
    neo:text "If they a defined they are not Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1670 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "730f9602a52cc19b2db6f2b3b8eb0b2a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 2, sentence number 2 on page 70"^^xsd:string ;
    neo:text "Even at such a youthful age fame awaited her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1671 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "53d9e3e92aaf57761e006d959e8f6362"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 3, sentence number 1 on page 70"^^xsd:string ;
    neo:text "The beloved emperor died suddenly and Ryonen’s hopeful dreams vanished."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1672 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1673,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1674,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "4d2f3521b409614cd8ac7a8a7abe800e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 3, sentence number 2 on page 70"^^xsd:string ;
    neo:text "She became acutely aware of the impermanency of life in this world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1675 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "d9ccbffdd35ccabbf59896c915b0ecb3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 3, sentence number 3 on page 70"^^xsd:string ;
    neo:text "I was then that she desired to study Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1676 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_640 ;
    neo:id "d440abc65d5a79b8f6b99272a34ea546"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 4, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Her relatives disagreed, however, and practically forced her into marriage."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1677 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412 ;
    neo:id "65ae373ceed03a9fdbb8c06e61d96f78"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 4, sentence number 2 on page 70"^^xsd:string ;
    neo:text "With a promise that she might become a nun after she had borne three children."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1678 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663 ;
    neo:id "1fa831bfcaf8d839088415388946f90f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 4, sentence number 3 on page 70"^^xsd:string ;
    neo:text "Ryonen assented."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1679 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "1574f2ccb4f8615339472b757980279a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 4, sentence number 4 on page 70"^^xsd:string ;
    neo:text "Before she was twenty-five she had accomplished this condition."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_168 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_170,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_171,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_172,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "f2c91d0da1e46667e491f3c22031b00a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 11, sentence number 1 on page 11"^^xsd:string ;
    neo:text "It has been said that if you have Zen in your life, you have no fear, no doubt, no unnecessary craving, and no extreme emotion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1680 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_640 ;
    neo:id "71bc61452f4b8a3b582b79a8dbb43bf7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 5, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Then her husband and relatives could no longer dissuade her from her desire."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1681 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663 ;
    neo:id "45938519db1fd9dbfa945bb1e3f9716a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 5, sentence number 2 on page 70"^^xsd:string ;
    neo:text "She shaved her had took the name of Ryonen which means to realize clearly, and stated on her pilgrimage."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1684 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1685,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_227,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "0f08bd8d0222d394a03f5c091d126d94"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 5, sentence number 3 on page 70"^^xsd:string ;
    neo:text "She came to the city of Edo and asked Tetsugyu to accept her as a disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1686 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "69fb20ad19d01460dad42c0f56bb7107"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 5, sentence number 4 on page 70"^^xsd:string ;
    neo:text "At one glance the master rejected her because she was too beautiful."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1687 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1688 ;
    neo:id "58d89d12da83e6aceeab0d39abf26f3e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 6, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Ryonen then went to another master, Hakuo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1689 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1688,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "b32bde8f74327854715c357c8113b9e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 6, sentence number 2 on page 70"^^xsd:string ;
    neo:text "Hakuo refused her for the same reason, saying that her beauty would only make trouble."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1690 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1691 ;
    neo:id "ee5af35b36e607d363ea30c11cc3a47a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 6, sentence number 3 on page 70"^^xsd:string ;
    neo:text "Ryonen obtained a hot iron and placed it against her face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1692 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "46d1b914240b7a1787f1524322283360"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 6, sentence number 4 on page 70"^^xsd:string ;
    neo:text "In a few moments her beauty had vanished forever."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1694 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1688,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "33b2ea67c002151b82fa0af93b888fdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 7, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Hakuo then accepted her as a disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1695 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1696 ;
    neo:id "a47e0a8c96af34dea2b4d816f471b799"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 8, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Commemorating this occasion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1698 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1699,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576 ;
    neo:id "03df34da6d7db0bea00192e6cd236cdb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 8, sentence number 2 on page 70"^^xsd:string ;
    neo:text "Ryonen wrote a poem on the back of a little mirror:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1700 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1701,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_795 ;
    neo:id "9f78f0ae2a844935c62727746e7578c7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 9, sentence number 1 on page 70"^^xsd:string ;
    neo:text "In the service of my Empress I burned incense to perfume my exquisite clothes,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1702 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1703 ;
    neo:id "499f9fec68eb08f9daeed4cf0edac60f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 10, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Now as a homeless mendicant I burn my face to enter a Zen temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1704 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1663 ;
    neo:id "aba226c1a0d8b1e0d708b2631b832f09"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 11, sentence number 1 on page 70"^^xsd:string ;
    neo:text "When Ryonen was about to pass from this world she wrote another poem:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1705 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1707,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1708 ;
    neo:id "0b577f754b4447c09a971becbcc3b1ea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 12, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Sixty-six times have these eyes beheld the changing scene of autumn."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1709 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1710,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "b386387ec3a2683c2be9753c3cf8442f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 13, sentence number 1 on page 70"^^xsd:string ;
    neo:text "I have had enough about moonlight,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1711 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1181,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1713 ;
    neo:id "7da00efee9ad09fad0a631f4662155d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 50. Ryonen’s Clear Realization, paragraph number 14, sentence number 1 on page 70"^^xsd:string ;
    neo:text "Ask no more. Only listen to the voice of pines and cedars when no wind stirs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1714 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1715,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1716,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1717,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1718,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1719,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1720,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "39bfdeae8ec10e7cfeef22a2569394be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 1, sentence number 1 on page 72"^^xsd:string ;
    neo:text "The cook monk Dairyo, at Bankei’s monastery, decided that he would take good care of his old teacher’s health and give him only fresh miso, a paste of soy beans mixed with wheat and yeast that often ferments."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1721 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1716,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "77e2f00584e0d5721c35339f0690b867"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 1, sentence number 2 on page 72"^^xsd:string ;
    neo:text "Bankei, noticing that he was being served better miso than his pupils, asked: ‘Who is the cook today?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1723 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1715 ;
    neo:id "8d69040437beed3365dab1bb904399ed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 2, sentence number 1 on page 72"^^xsd:string ;
    neo:text "Dairyo was sent before him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1724 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1725,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "168f56f183ccc35199f166f85b6e1f7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 2, sentence number 2 on page 72"^^xsd:string ;
    neo:text "Bankei learned that according to his age and position he should eat only fresh miso."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1726 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_980 ;
    neo:id "c24793432a5436c584885b84b8de4549"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 2, sentence number 3 on page 72"^^xsd:string ;
    neo:text "So he said to the cook: Then you think I shouldn’t eat at all.’ With this he entered his room and locked the door."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1727 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1715,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "76022c520821c42efbeec565c8c3e08f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 3, sentence number 1 on page 72"^^xsd:string ;
    neo:text "Dairyo, sitting outside the door, asked his teacher’s pardon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1728 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "931c134a019596c8bc32d4de99a97a53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 3, sentence number 2 on page 72"^^xsd:string ;
    neo:text "Bankei would not answer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1729 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1715,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "944ba3dadd203366a82b2cbf67b17beb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 3, sentence number 3 on page 72"^^xsd:string ;
    neo:text "For seven days Dairyo sit outside and Bankei within."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_173 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_174,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_175,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "44111ea061d886a806647d1dbe035941"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 11, sentence number 2 on page 11"^^xsd:string ;
    neo:text "Neither illiberal attitudes nor egotistical actions trouble you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1732 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1733,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1734,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "a4a733041c0c3b9f67b7c1f1c88f0167"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 4, sentence number 1 on page 72"^^xsd:string ;
    neo:text "Finally in desperation an adherent called loudly to Bankei: ‘You may be all right old teacher, but this young disciple here has to eat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1735 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284 ;
    neo:id "0b087bc7861a2a7fd7816aaf6d08ac73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 4, sentence number 2 on page 72"^^xsd:string ;
    neo:text "He cannot go without food forever!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1736 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_973 ;
    neo:id "ebb1b171fa7db9df4d11e5447bff854d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 5, sentence number 1 on page 72"^^xsd:string ;
    neo:text "At that Bankei opened the door."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1737 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "3fc91559a50bf9f874e0284a91d26af9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 5, sentence number 2 on page 72"^^xsd:string ;
    neo:text "He was smiling."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1738 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1444,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1715,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "12bbad9799f1c448782d7f435b3a943c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 5, sentence number 3 on page 72"^^xsd:string ;
    neo:text "He told Dairyo: ‘I insist on eating the same food as the least of my followers."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1739 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "414b0908e4346df511325fe3d4267e77"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 51. Sour Miso, paragraph number 5, sentence number 4 on page 72"^^xsd:string ;
    neo:text "When you become the teacher I do not want you to forget this.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1740 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1741,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_605,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "c49a01a39bdf402fdf6535af0da9db26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 52. Your Light may go out, paragraph number 1, sentence number 1 on page 73"^^xsd:string ;
    neo:text "A student of Tendai a philosophical school of Buddhism, came to the Zen abode of Gasan as a pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1742 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "3a84b82492337ebf2f106163804fc838"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 52. Your Light may go out, paragraph number 1, sentence number 2 on page 73"^^xsd:string ;
    neo:text "When he was departing a few years later, Gasan warned him: ‘Studying the truth speculatively is useful as a way of collecting preaching material."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1743 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1744,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484 ;
    neo:id "a27aef9e15e4e685f7901e398c9a9d99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 52. Your Light may go out, paragraph number 1, sentence number 3 on page 73"^^xsd:string ;
    neo:text "But remember that unless you meditate constantly your light of truth may go out.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1745 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1747,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1748 ;
    neo:id "f92d61932b4e25eabbcb01fe22245b9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 1, sentence number 1 on page 74"^^xsd:string ;
    neo:text "While Seisetsu was the master of Engaku in Kamakura he required larger quarters, since those in which he was teaching were overcrowded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1749 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1750,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1751,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_227 ;
    neo:id "559bb9e1c74f9a343baf668d4bab0d41"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 1, sentence number 2 on page 74"^^xsd:string ;
    neo:text "Umezu Seibei, a merchant of Edo, decided to donate five hundred pieces of gold called ryo toward the construction of a more commodious school."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1752 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "4c18fdf7cce0ab7aaf49f3e73bee8fe5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 1, sentence number 3 on page 74"^^xsd:string ;
    neo:text "This money he brought to the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1753 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746 ;
    neo:id "7423a467e6b59fd1ef4f287f812f3791"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 2, sentence number 1 on page 74"^^xsd:string ;
    neo:text "Seisetsu said: ‘All right."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1754 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "3c3c28c5680ef3b9601640a51b64b1b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 2, sentence number 2 on page 74"^^xsd:string ;
    neo:text "I will take it.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1755 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1756,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1757 ;
    neo:id "6e851a609d414f05ac553f4b1d09c6ea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 3, sentence number 1 on page 74"^^xsd:string ;
    neo:text "Umezu gave Seisetsu the sack of gold, but he was dissatisfied with the attitude of the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1758 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1760,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1761,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1762 ;
    neo:id "5b84d9d02c36f7af12a88b608bca5b3b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 3, sentence number 2 on page 74"^^xsd:string ;
    neo:text "One might live a whole year on three ryo, and the merchant had not even been thanked for five hundred."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1763 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1756,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1764,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_674 ;
    neo:id "889ed438f46a846772f991dcb0088cac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 4, sentence number 1 on page 74"^^xsd:string ;
    neo:text "‘In that sack are five hundred ryo,’ hinted Umezu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1765 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746 ;
    neo:id "2edef101077bfdd62fce79755a4d3c82"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 5, sentence number 1 on page 74"^^xsd:string ;
    neo:text "“You told me that before,’ replied Seisetsu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1766 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1756,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1767 ;
    neo:id "4f5f2298799f9aa369512668edb7f481"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 6, sentence number 1 on page 74"^^xsd:string ;
    neo:text "‘Even if I am a wealthy merchant, five hundred ryo is a lot of money,’ said Umezu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1769 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746 ;
    neo:id "03bb16d013ebad013c71db566b4bf417"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 7, sentence number 1 on page 74"^^xsd:string ;
    neo:text "‘Do you want me to thank you for it?’ asked Seisetsu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_177 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_178,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_179,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_181,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_182 ;
    neo:id "f777a8ade6c3cd3195c70eae42c60050"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 11, sentence number 3 on page 11"^^xsd:string ;
    neo:text "You serve humanity humbly, fulfilling your presence in this world with loving-kindness and observing your passing as a petal falling from a flower."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1770 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1756 ;
    neo:id "b98b171490f3752dc9d6c1fa6088d640"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 8, sentence number 1 on page 74"^^xsd:string ;
    neo:text "“You ought to,’ replied Umezu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1771 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1746 ;
    neo:id "b1e46c0fc2e0bc17ff6aff0720a6354b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 9, sentence number 1 on page 74"^^xsd:string ;
    neo:text "‘Why should I?’ inquired Seisetsu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1772 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1773 ;
    neo:id "d1ac88c49d47e0d96d0e96a50d9e92cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 53. The Giver Should be Thankful, paragraph number 9, sentence number 2 on page 74"^^xsd:string ;
    neo:text "‘The giver should be thankful.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1775 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1777,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "7d7494d1a82af0a2c61e6660eb5fd685"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 1, sentence number 1 on page 75"^^xsd:string ;
    neo:text "Ikkyu, a famous Zen teacher of the Ashikaga era, was the son of the emperor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1778 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1779,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1780,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_783 ;
    neo:id "aa488271d78328c139a415969b157de6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 1, sentence number 2 on page 75"^^xsd:string ;
    neo:text "When he was very young, his mother left the palace and went to study Zen in a temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1781 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1782 ;
    neo:id "5c390deafc19ae6edeef6e08c2465e12"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 1, sentence number 3 on page 75"^^xsd:string ;
    neo:text "In this way Prince Ikkyu also became a student."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1783 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1784,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_783 ;
    neo:id "b273ce65840c97aa78a38be5ede6c2c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 1, sentence number 4 on page 75"^^xsd:string ;
    neo:text "When his mother passed on, she left with him a letter."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1785 a neo:Document ;
    neo:id "90b7578b222f6ccf101c2b04ed0ae0e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 1, sentence number 5 on page 75"^^xsd:string ;
    neo:text "It read:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1786 a neo:Document ;
    neo:id "bc65131a952effe4234c0abe936b7114"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 2, sentence number 1 on page 75"^^xsd:string ;
    neo:text "To Ikkyu:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1787 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1788,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "f17650a4b9cfaa50716c7d7995bc54b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 3, sentence number 1 on page 75"^^xsd:string ;
    neo:text "I have finished my work in this life and am now returning Into Eternity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1789 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1790,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "d748e34ca8a714368c3e66f9804ae0e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 3, sentence number 2 on page 75"^^xsd:string ;
    neo:text "I wish you to become a good student and to realize your Buddha-nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1791 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1792,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "3105e02865de194870782d28704db856"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 3, sentence number 3 on page 75"^^xsd:string ;
    neo:text "You will know if I am in hell and whether I am always with you or not."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1793 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "5e5a9f2b287a562cfdc60647894851f1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 4, sentence number 1 on page 75"^^xsd:string ;
    neo:text "If you become a man who realizes that the Buddha and his follower Bodhidharma are your own servants, you may leave off studying and work for humanity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1794 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1795,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1796 ;
    neo:id "373e58c99ca9f32a10a26c5b7057787c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 4, sentence number 2 on page 75"^^xsd:string ;
    neo:text "The Buddha preached for forty-nine years and in all that time found it not necessary to speak one word."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1797 a neo:Document ;
    neo:id "646f27c6162bb5d8ff0f4b8bde7e717b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 4, sentence number 3 on page 75"^^xsd:string ;
    neo:text "You ought to know why."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1798 a neo:Document ;
    neo:id "ed7df18e705486bb2d5efe05c8c5b878"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 4, sentence number 4 on page 75"^^xsd:string ;
    neo:text "But if you don’t and yet wish to, avoid thinking fruitlessly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1799 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367 ;
    neo:id "6d1da427b4b0ce769441d4d813b42c5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 5, sentence number 1 on page 75"^^xsd:string ;
    neo:text "Your Mother,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1800 a neo:Document ;
    neo:id "e2e5b76ff1f568529f9e4c0416e627d4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 6, sentence number 1 on page 75"^^xsd:string ;
    neo:text "Not born, not dead."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1801 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1802,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1803 ;
    neo:id "bb103438cfabbb869877867832098bd5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 7, sentence number 1 on page 75"^^xsd:string ;
    neo:text "September first."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1804 a neo:Document ;
    neo:id "70e8d78668a0ca6ec1e1ddff46398f72"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 8, sentence number 1 on page 75"^^xsd:string ;
    neo:text "PS."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1805 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "08100d462aa2f6297693cab7fef8f1ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 8, sentence number 2 on page 75"^^xsd:string ;
    neo:text "The teaching of Buddha was mainly for the purpose of enlightening others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1807 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1808,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1809,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1810 ;
    neo:id "7c3c9ca9730eefa467b0fa42f5c814d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 8, sentence number 3 on page 75"^^xsd:string ;
    neo:text "If you are dependent a any of its methods, you are naught but an ignorant insect."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1811 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1341,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_605 ;
    neo:id "1f980a4ba78d49cbace7f9c0be4e3c87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 8, sentence number 4 on page 75"^^xsd:string ;
    neo:text "There are 80,000, books on Buddhism and if you should read all of them and still not see your own nature, you will not understand even this letter."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1812 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1813,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "17e17daff125b240fabd7e85a2962afb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 54. Last Will and Testament, paragraph number 8, sentence number 5 on page 75"^^xsd:string ;
    neo:text "This is my will and testament."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1814 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1815,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1816,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1817,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_940 ;
    neo:id "2e5e4c31ea4c23a6d6c64ec803e9a0ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 1, sentence number 1 on page 76"^^xsd:string ;
    neo:text "Taiko, a warrior who lived in Japan before the Tokugawa era, studied Cha- no-yu, tea etiquette, with Sen no Rikyu, a teacher of that aesthetical expression of calmness and contentment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1818 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1815,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1817,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1819 ;
    neo:id "0431bbf017019eb4d7f6dd547e7d641d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 2, sentence number 1 on page 76"^^xsd:string ;
    neo:text "Taiko’s attendant warrior Kato interpreted his superior’s enthusiasm for tea etiquette as negligence of state affairs, m he decided to kill Sen no Rikyu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1820 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1634,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "cc1ad5bed13607ca826e14b2efc108ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 2, sentence number 2 on page 76"^^xsd:string ;
    neo:text "He pretended to make a social call upon the tea-master and was invited to drink tea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1821 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1816,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1819,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1822,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1824,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_980 ;
    neo:id "433e3ee405834d536ad2ccd62574e101"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 3, sentence number 1 on page 76"^^xsd:string ;
    neo:text "The master, who was well skilled in his art, saw at a glance the warrior’s intention, so he invited Kato to leave his sword outside before entering the room for the ceremony, explaining that Cha-no-yu represents peacefulness itself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1825 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1819,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1826 ;
    neo:id "da700d3ad0f9e0563be9bd7452387556"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 4, sentence number 1 on page 76"^^xsd:string ;
    neo:text "Kato would wt Isten to this ‘I am a warrior,’ he said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1827 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "7db09dedd5062b06a38b1cb65468397d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 4, sentence number 2 on page 76"^^xsd:string ;
    neo:text "I always have my sword with me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1828 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1816 ;
    neo:id "a6e1f135734072a58985859c9568c48c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 4, sentence number 3 on page 76"^^xsd:string ;
    neo:text "Cha-no-yu or no Cha-no-yu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1829 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "29eb62ce1e3e424e3548db59a510b461"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 4, sentence number 4 on page 76"^^xsd:string ;
    neo:text "I have my sword.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_183 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_184,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_186 ;
    neo:id "80e8cb58d5541d49de04bfa00dd45eae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 11, sentence number 4 on page 11"^^xsd:string ;
    neo:text "Serene you enjoy life in blissful tranquility."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1830 a neo:Document ;
    neo:id "ad7bd81d2b3c12d64d99967acfda899f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 5, sentence number 1 on page 76"^^xsd:string ;
    neo:text "‘Very well."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1831 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1633,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_207 ;
    neo:id "004be6b53ae9e5ef4601ab37629af6dc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 5, sentence number 2 on page 76"^^xsd:string ;
    neo:text "Bring your sword in and have some tea,’ consented Sen no Rikyu."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1832 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1833,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1834 ;
    neo:id "2b8155be7833ae95de9e445d605acb50"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 6, sentence number 1 on page 76"^^xsd:string ;
    neo:text "The kettle was boiling on the charcoal fire."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1835 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1633 ;
    neo:id "24aa075e84c46d8369e48d0a41c2a5dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 6, sentence number 2 on page 76"^^xsd:string ;
    neo:text "Suddenly Sen no Rikyu tipped it over."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1836 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1658,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1837,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1838,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_980 ;
    neo:id "172e833134246400ae98533f6573cbdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 6, sentence number 3 on page 76"^^xsd:string ;
    neo:text "Hissing steam arose filling the room with smoke and ashes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1839 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1822 ;
    neo:id "ae5b4bcc2d278f332e16e24b341c3aba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 6, sentence number 4 on page 76"^^xsd:string ;
    neo:text "The startled warrior ran outside."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1840 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1634 ;
    neo:id "c163b25fd82d394b63c67b62cb1f3d80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 7, sentence number 1 on page 76"^^xsd:string ;
    neo:text "The tea-master apologized."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1841 a neo:Document ;
    neo:id "fb71719c33d1f54a1770895f9049e883"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 7, sentence number 2 on page 76"^^xsd:string ;
    neo:text "‘It is my mistake."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1842 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_207 ;
    neo:id "92ea658c629a12c18c4969aa887e266e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 7, sentence number 3 on page 76"^^xsd:string ;
    neo:text "Come back in and have some tea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1843 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1838,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "cecddc9a37d954a9020dbad4d893740a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 7, sentence number 4 on page 76"^^xsd:string ;
    neo:text "I have your sword here covered with ashes and will clean it and give it to you.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1844 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1634,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1822 ;
    neo:id "e11b310ac37d126b5c476daab0386bb5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 55. The Tea-Master and the Assassin, paragraph number 8, sentence number 1 on page 76"^^xsd:string ;
    neo:text "In this predicament the warrior realized he could not very well kill the tea-master, so he gave up the idea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1846 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1847 ;
    neo:id "aaa368f8548e308d71aaf0b1e25e2ee1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 1, sentence number 1 on page 77"^^xsd:string ;
    neo:text "Just before Ninakawa passed away the Zen master Ikkyu visited him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1848 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776 ;
    neo:id "a95014d138d26852bbe70bcf1ea44fec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 1, sentence number 2 on page 77"^^xsd:string ;
    neo:text "‘Shall I lead you on Ikkyu asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1849 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1847 ;
    neo:id "05da18bf0b1deae44df6765f144737b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 2, sentence number 1 on page 77"^^xsd:string ;
    neo:text "Ninakawa replied: ‘I came here alone and I go alone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1850 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "f5128891fed043bca4d9bb2bdb7343d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 2, sentence number 2 on page 77"^^xsd:string ;
    neo:text "What help could you be to me?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1851 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1852 ;
    neo:id "a54090f6f652f9803f213d7456e1b630"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 3, sentence number 1 on page 77"^^xsd:string ;
    neo:text "Ikkyu answered: ‘If you think you really come and go, that is your delusion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1853 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1854 ;
    neo:id "d514fd8c6ba5ed8540a0e36a653cb9a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 3, sentence number 2 on page 77"^^xsd:string ;
    neo:text "Let me show you the path on which there is no coming and no going.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1855 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1847 ;
    neo:id "a6d3f9f7f3bef4fbe24f8beb5d84716e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 56. The True Path, paragraph number 4, sentence number 1 on page 77"^^xsd:string ;
    neo:text "With his words Ikkyu had revealed the path so clearly that Ninakawa smiled and passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1856 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1792,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1857,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1858,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "5903c40d32172d5172f7efe0268fba3b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 1, sentence number 1 on page 78"^^xsd:string ;
    neo:text "A soldier named Nobushige came to Hakuin, and asked: ‘Is there really a paradise and a hell?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1859 a neo:Document ;
    neo:id "7445f1f134b7dc05cb3327b1077d814d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 2, sentence number 2 on page 78"^^xsd:string ;
    neo:text "‘ Inquired Hakuin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1860 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1822 ;
    neo:id "30a515b213efb8911233df86fe28896c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 3, sentence number 1 on page 78"^^xsd:string ;
    neo:text "‘I am a samurai,’ the warrior replied."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1861 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1862,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "c10fa97cc7aaede3ae2deaaad8754663"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 4, sentence number 1 on page 78"^^xsd:string ;
    neo:text "‘You, a soldier!’ exclaimed Hakuin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1863 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1864,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1865 ;
    neo:id "0d839090285e434bb16ab149c7cfdb06"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 4, sentence number 2 on page 78"^^xsd:string ;
    neo:text "‘What kind of ruler would have you as his guard?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1866 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1503,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1554 ;
    neo:id "b501eae9751da507dbeac55337955369"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 4, sentence number 3 on page 78"^^xsd:string ;
    neo:text "Your face looks like that of a beggar.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1867 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1857,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "42217f1ee3001a2574a2998ffc74b64a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 5, sentence number 1 on page 78"^^xsd:string ;
    neo:text "Nobushige became so angry that he began to draw his sword, but Hakuin continued: ‘So you have a sword!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1868 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1869,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "41d40fee9dbc16acd57e44d5439df815"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 5, sentence number 2 on page 78"^^xsd:string ;
    neo:text "Your weapon is probably much too dull to cut off my head.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_187 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_189,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "8b1327c1bbc740af33d9bf734241c02e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 12, sentence number 2 on page 12"^^xsd:string ;
    neo:text "Such is the spirit of Zen, whose venture is thousands of temples in China and Japan, priests and monks, wealth and prestige, and often the very formalism it would itself transcend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1871 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1872,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1873,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "87b94e69fcc5523370914d16d52bc13b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 6, sentence number 1 on page 78"^^xsd:string ;
    neo:text "As Nohushige drew his sword Hakuin remarked: ‘Here open the gates of hell!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1874 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1875,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "a41936170f6473d415a4cdea322017a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 7, sentence number 1 on page 78"^^xsd:string ;
    neo:text "At these words the samurai, perceiving the master’s discipline, sheathed his sword and bowed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1876 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1858,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "4375fb18154a099d844401ac9276ad55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 8, sentence number 1 on page 78"^^xsd:string ;
    neo:text "‘Here open the gates of paradise,’ said Hakuin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1877 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1508,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1760,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1878,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1879 ;
    neo:id "2c531ef2a9585b6ead9de5ca4c248f82"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 1, sentence number 1 on page 79"^^xsd:string ;
    neo:text "A merchant bearing fifty rolls of cotton goods on his shoulder stopped to rest from the heat of the day beneath a shelter when a large stone Buddha was standing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1880 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1881,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "6f96a51d456ff5d8205f7eff1db956b4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 1, sentence number 2 on page 79"^^xsd:string ;
    neo:text "Then he fell asleep, and when he awoke his goods had disappeared."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1882 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_624 ;
    neo:id "7d138fcb624bef0b93ec3d00e727eeb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 1, sentence number 3 on page 79"^^xsd:string ;
    neo:text "He immediately reported the matter to the police."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1883 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1884,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1885 ;
    neo:id "361b5dce6d4d1f3ff7a80b4163fe7c53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 2, sentence number 1 on page 79"^^xsd:string ;
    neo:text "A judge named O-oka opened court to investigate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1886 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1881,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1887,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1888 ;
    neo:id "8c6310b98444a9e227a3ec36314a0591"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 2, sentence number 2 on page 79"^^xsd:string ;
    neo:text "‘That stone Buddha must have stolen the goods,’ concluded the judge."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1889 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1890,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "089e117f15f05250f3d39fd16617778a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 3, sentence number 1 on page 79"^^xsd:string ;
    neo:text "‘He is supposed to care for the welfare of the people but he has failed to perform his holy duty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1892 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1893,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "9c18f2792e4350f212379c95c4bb4328"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 3, sentence number 2 on page 79"^^xsd:string ;
    neo:text "Arrest him’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1894 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1885,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1887,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_624 ;
    neo:id "e8569d80fa23a3b5578374ed4ce40aac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 4, sentence number 1 on page 79"^^xsd:string ;
    neo:text "The police arrested the stone Buddha and carried it into the court."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1895 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1647,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1888,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1896,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_397 ;
    neo:id "52e549d0b7fd6ccf6a68b08069894e96"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 4, sentence number 2 on page 79"^^xsd:string ;
    neo:text "A noisy crowd followed the statue; curious to learn what kind of a sentence the judge was about to impose."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1897 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1884,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1898,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1899 ;
    neo:id "b6dd8fe944e64a57d0cbaafd44bbde04"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 5, sentence number 1 on page 79"^^xsd:string ;
    neo:text "When O-oka appeared on the bench he rebuked the boisterous audience."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1900 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1885,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "27ecd29dca17a84ea3f611f5569dc133"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 5, sentence number 2 on page 79"^^xsd:string ;
    neo:text "“What right have you people to appear before the court laughing and joking in this manner?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1901 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1885,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1902,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1903 ;
    neo:id "198128e8907f60a601b936e27e61c786"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 5, sentence number 3 on page 79"^^xsd:string ;
    neo:text "You are in contempt of court and subject to a fine and imprisonment.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1904 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "81cf06d82c6e358d4d794bc865b311a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 6, sentence number 1 on page 79"^^xsd:string ;
    neo:text "The people hastened to apologize."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1906 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1878,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1885,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1888,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1902 ;
    neo:id "4682de54ca31cddb4085167024c148f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 6, sentence number 2 on page 79"^^xsd:string ;
    neo:text "“I shall have to impose a fine on you,’ said the judge,’ but I will remit it provided each one of you brings one roll, of cotton goods to the court within three days."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1907 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555 ;
    neo:id "ea603b914f0eb10cd4a96b98700cfac4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 6, sentence number 3 on page 79"^^xsd:string ;
    neo:text "Anyone failing to do this will be arrested.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1909 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1760,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1910,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_514,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "6dc6eecd50f2bd05b61680422010c6b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 7, sentence number 1 on page 79"^^xsd:string ;
    neo:text "One of the rolls of cloth, which the people brought, was quickly recognized by the merchant as his own, and thus the thief was easily discovered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_191 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_192,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_193,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "621b3bb57ee45bfe2d4db3de5916a170"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 12, sentence number 1 on page 12"^^xsd:string ;
    neo:text "To study Zen, the flowering of one’s nature, is no easy task in any age or civilization."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1911 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1760,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1881,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1912,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "f0b5e079f92e19231888a5a98a70de5d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 58. Arresting the Stone Buddha, paragraph number 7, sentence number 2 on page 79"^^xsd:string ;
    neo:text "The merchant recovered his goods, and the cotton rolls were returned to the people."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1913 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1914,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1915,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1916,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1917 ;
    neo:id "51027ebd61e9294c45a9720038133061"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 1, sentence number 1 on page 80"^^xsd:string ;
    neo:text "Once a division of the Japanese army was engaged in I sham battle, and some of the officers found it necessary to make their headquarters in Gasan’s temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1918 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1916,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "910af86b83e4da55e5382fc74c2cbfaf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 2, sentence number 1 on page 80"^^xsd:string ;
    neo:text "Gasan told his cook: ‘Let the officers have only the same simple fare we eat.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1919 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1920 ;
    neo:id "0e4d7a9b15cf4bb046022d88a4ea995a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 3, sentence number 1 on page 80"^^xsd:string ;
    neo:text "This made the army men angry, as they were used to very differential treatment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1923 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "19571eb4e9d397afdbbd79f0a68babd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 3, sentence number 2 on page 80"^^xsd:string ;
    neo:text "One came to Gasan and said: ‘Who do you think we are?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1924 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1925 ;
    neo:id "81d251ecdf22733d542acc0bf00b5a81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 3, sentence number 3 on page 80"^^xsd:string ;
    neo:text "We are soldiers, sacrificing our lives for our country."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1926 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1446,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "17d7f9c94b49a269dd2f3e0dc6789466"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 3, sentence number 4 on page 80"^^xsd:string ;
    neo:text "Why don’t you treat us accordingly?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1927 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "c7229fe533cdbcb34b7972e5437795b4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 4, sentence number 1 on page 80"^^xsd:string ;
    neo:text "Gasan answered sternly: ‘Who do you think we are?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1928 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1073,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_178,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1929 ;
    neo:id "5e8aecace5aa72f6274f37b90929b3b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 59. Soldiers of Humanity, paragraph number 4, sentence number 2 on page 80"^^xsd:string ;
    neo:text "We are soldiers of humanity aiming to save all sentient beings.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1930 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1875,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1932,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_227 ;
    neo:id "05c32bda92179a7d96999d0c9b3ed0ff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 1, sentence number 1 on page 81"^^xsd:string ;
    neo:text "Zenkai, the son of a samurai, journeyed to Edo and there became the retainer of a high official."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1933 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1934,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1935,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a17e75c9739c78f873e8690136f5d11f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 1, sentence number 2 on page 81"^^xsd:string ;
    neo:text "He fell in love with the official’s wife and was discovered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1936 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1935,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7f505141981f80c8314eea658c580c35"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 1, sentence number 3 on page 81"^^xsd:string ;
    neo:text "In self-defense, he slew the official."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1937 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "0f15d171ffb210b1048fc906720ba249"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 1, sentence number 4 on page 81"^^xsd:string ;
    neo:text "Then he ran away with the wife."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1938 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492 ;
    neo:id "47be5ba80e4cc8c040557532966543fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 2, sentence number 1 on page 81"^^xsd:string ;
    neo:text "Both of them later became thieves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1940 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242 ;
    neo:id "3961ff40c39fd22a66276df17586a4e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 2, sentence number 2 on page 81"^^xsd:string ;
    neo:text "But the woman was so greedy that Zenkai grew disgusted."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1941 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1942,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "009432c84f45d10d94d64e593650d246"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 2, sentence number 3 on page 81"^^xsd:string ;
    neo:text "Finally, leaving her, he journeyed far away to the province of Buzen, where he became a wandering mendicant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1943 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1944,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1945 ;
    neo:id "c1d9ec9898eeea8618c79a12f370e443"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 3, sentence number 1 on page 81"^^xsd:string ;
    neo:text "To atone for his past, Zenkai resolved to accomplish some good deed in his lifetime."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1946 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1947,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1948,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "6515a39377384ec1e82137d329d6f2fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 3, sentence number 2 on page 81"^^xsd:string ;
    neo:text "Knowing of a dangerous road over a cliff that had caused the death and injury of many persons he resolved to cut a tunnel through the mountains there."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1950 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1951,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489 ;
    neo:id "c40c8d6f41ccc9958530d0f8f6923a78"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 4, sentence number 1 on page 81"^^xsd:string ;
    neo:text "Begging food in the daytime, Zenkai worked at night digging his tunnel."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1952 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1949 ;
    neo:id "022c73546d0de442e33eb61c145054ef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 4, sentence number 2 on page 81"^^xsd:string ;
    neo:text "When thirty years had gone by, the tunnel was 2,280 feet long, 20, feet high, and 30 feet wide."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1956 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1935,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1957 ;
    neo:id "e7eeda9b655d8defe871464160572843"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 5, sentence number 1 on page 81"^^xsd:string ;
    neo:text "Two years before the work was completed, the son of the official he had slain, who was a skillful swordsman found Zenkai out and came to kill him in revenge."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1958 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931 ;
    neo:id "5477aaac7ce1f05c07a115bf1f6aba53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 6, sentence number 1 on page 81"^^xsd:string ;
    neo:text "‘I will give you my life willingly,’ said Zenkai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1959 a neo:Document ;
    neo:id "b58f83dce922cc56848def881262cacd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 6, sentence number 2 on page 81"^^xsd:string ;
    neo:text "‘Only let me finish this work."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_196 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_197 ;
    neo:id "db0d6de611b4dfe0e9a391f5680141ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 12, sentence number 2 on page 12"^^xsd:string ;
    neo:text "Many teachers, true and false, have purposed to assist others in this accomplishment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1960 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1354,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "0a725024f5fca49877e5dd5bd2ab6c3d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 6, sentence number 3 on page 81"^^xsd:string ;
    neo:text "On the day it is completed then you may kill me.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1961 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "1fae4f783e771f925472c44412396217"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 7, sentence number 1 on page 81"^^xsd:string ;
    neo:text "So the son awaited the day."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1962 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1963 ;
    neo:id "9a6c2cffc95bbca88fdae1bd7aba51d0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 7, sentence number 2 on page 81"^^xsd:string ;
    neo:text "Several months passed and Zenkai kept on digging."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1965 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "bb7035b39b4856f2e21cbcd2754d76fb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 7, sentence number 3 on page 81"^^xsd:string ;
    neo:text "The son grew tired of doing nothing and began to help with the digging."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1967 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "517a25572fe6833ed6f74879f56021e7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 7, sentence number 4 on page 81"^^xsd:string ;
    neo:text "After he had helped for more than a year, he came to admire Zenkai’s strong will and character."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1968 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "c9e1117d6dc66ef9870f9f3f2896e653"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 8, sentence number 1 on page 81"^^xsd:string ;
    neo:text "At last the tunnel was completed and the people could use it and travel in safety."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1969 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1931 ;
    neo:id "f83aa3ddbaf5730bb4357d3e356964c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 9, sentence number 1 on page 81"^^xsd:string ;
    neo:text "‘Now cut off my head,’ said Zenkai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1970 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "80893c100701076a83a3da839afecb2c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 9, sentence number 2 on page 81"^^xsd:string ;
    neo:text "‘My work is done.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1971 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1972,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "a1f5882ebfe9843aa1157bf6143ec67f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 60. The Tunnel, paragraph number 10, sentence number 1 on page 81"^^xsd:string ;
    neo:text "‘How can I cut off my own teacher’s head?’ asked the younger man with tears in his eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1973 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1974,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "4ce138f6cad8c58bea5ed723d6cfa29c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 1, sentence number 1 on page 82"^^xsd:string ;
    neo:text "The emperor Goyozei was studying Zen under Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1975 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "8cb2866e0477c823788a66bb883a95da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 1, sentence number 2 on page 82"^^xsd:string ;
    neo:text "He inquired: ‘In Zen this very mind is Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1976 a neo:Document ;
    neo:id "ec0fbd77f70d3895256b050c54045e51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 1, sentence number 3 on page 82"^^xsd:string ;
    neo:text "Is this correct?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1977 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "86e77b032df9b3822ed8e022c86a0303"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 2, sentence number 1 on page 82"^^xsd:string ;
    neo:text "Gudo answered: ‘If I say yes, you will think that you understand without understanding."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1978 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1979,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "4bc79472529713b23ab9974b2816e2d8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 2, sentence number 2 on page 82"^^xsd:string ;
    neo:text "If I say no, I would be contradicting a fact which many understand quite well.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1980 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_822 ;
    neo:id "43a54f62cdd14f149f277bbf398f8705"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 3, sentence number 1 on page 82"^^xsd:string ;
    neo:text "On another day the emperor asked Gudo: ‘Where does the enlightened man go when he dies?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1982 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "09657ee1fe81c57c48bd43a8b2aa7180"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 4, sentence number 1 on page 82"^^xsd:string ;
    neo:text "Gudo answered: ‘I know not.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1984 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "a5a7d6ceb5cd83ba7ae12a8257ad45b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 5, sentence number 1 on page 82"^^xsd:string ;
    neo:text "‘Why don’t you know?’ asked the emperor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1985 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "53bc8b511545bc34c6663beb8050d71f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 6, sentence number 1 on page 82"^^xsd:string ;
    neo:text "‘Because I have not died yet,’ replied Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1986 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_322 ;
    neo:id "b37ced3856c4efcd5717fbb944a6a538"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 7, sentence number 1 on page 82"^^xsd:string ;
    neo:text "The emperor hesitated to inquire further about these things his mind could not grasp."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1987 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "4dc34b8f85c721cbb9aad6d5b96baba5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 7, sentence number 2 on page 82"^^xsd:string ;
    neo:text "So Gudo beat the floor with his hand as if to awaken him, and the emperor was enlightened!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1988 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1989,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "04b2f9a21b77a69eecbc15ae620e59db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 8, sentence number 1 on page 82"^^xsd:string ;
    neo:text "The emperor respected Zen and old Gudo more than ever after his enlightenment, and he even permitted Gudo to wear his hat in the palace in winter."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_199 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_200,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_9 ;
    neo:id "092ef70d59b60b45d85fdf3458a701ed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 12, sentence number 3 on page 12"^^xsd:string ;
    neo:text "It is from innumerable and actual adventures in Zen that these stories have evolved."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1990 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "103458fdbe0c8e2a27b097de1d9d6e89"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 61. Gudo and the Emperor, paragraph number 8, sentence number 2 on page 82"^^xsd:string ;
    neo:text "When Gudo was over eighty he used to fall asleep in the midst of his lecture, and the emperor would quietly retire to another room so his beloved teacher might enjoy the rest his ageing body required."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1991 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1992,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1993 ;
    neo:id "6289d0d3362c15684668912389dcea9e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 1, sentence number 1 on page 83"^^xsd:string ;
    neo:text "A great Japanese warrior named Nobunaga decided to attack the enemy although he had only one tenth the number of men the opposition commanded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1994 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1925,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "d93881a9d235d9bafc7ecf1ae02238a7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 1, sentence number 2 on page 83"^^xsd:string ;
    neo:text "He knew that he would win, but his soldiers were in doubt."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1995 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1996,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1997,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1998,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "35985e3597eb54292ee776f521b0da06"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 2, sentence number 1 on page 83"^^xsd:string ;
    neo:text "On the way he stopped at a Shinto shrine and told his man, ‘After I visit the shrine I will toss a coin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1999 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2000,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2001,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_261 ;
    neo:id "88c60464bdc29e444321ae3b8fb39109"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 2, sentence number 2 on page 83"^^xsd:string ;
    neo:text "If head comes we will win; if tails we will loose."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2002 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2003 ;
    neo:id "a703d822195b101f4c1b9c44aaaaa5cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 2, sentence number 3 on page 83"^^xsd:string ;
    neo:text "Destiny holds us in her hand.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2004 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1992,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2005 ;
    neo:id "76c6fb3c8daa1dde761a461d60617de3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 3, sentence number 1 on page 83"^^xsd:string ;
    neo:text "Nobunaga entered the shrine and offered a silent prayer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2007 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1998,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4bad93cba6d65f58b47111f570671d56"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 3, sentence number 2 on page 83"^^xsd:string ;
    neo:text "He came forth and tossed a coin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2008 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2009 ;
    neo:id "475498ca00ec1c9016daeec8e0d02d60"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 3, sentence number 3 on page 83"^^xsd:string ;
    neo:text "Heads appeared."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_201 a neo:Document ;
    neo:id "6dd95f1b096601571eb92b08049ac385"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101 ZEN STORIES, paragraph number 12, sentence number 4 on page 12"^^xsd:string ;
    neo:text "May the reader in turn realize them in living experience today."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2010 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1925,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2011 ;
    neo:id "590b88c7bef2e9c3d125c29f061199a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 3, sentence number 4 on page 83"^^xsd:string ;
    neo:text "His soldiers were so eager to fight that they won their battle easily."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2012 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2011,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_451 ;
    neo:id "57fabefab43fa6b09c2ad869b2555dbd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 4, sentence number 1 on page 83"^^xsd:string ;
    neo:text "‘No one can change the hand of destiny,’ his attendant told him after the battle."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2013 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1992,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1998 ;
    neo:id "d1e9d66598702d32e76d9ae6f5d45c64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 62. In the Hands of Destiny, paragraph number 5, sentence number 1 on page 83"^^xsd:string ;
    neo:text "‘Indeed not,’ said Nobunaga, showing a coin, which had been doubled, with heads facing either way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2014 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2015,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "99a51ec154fb70106738a5cc3675d928"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 1 on page 84"^^xsd:string ;
    neo:text "Gasan instructed his adherents one day: ‘Those who speak against killing and who desire to spare the live of all conscious beings are right."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2016 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2017,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2018 ;
    neo:id "30f2bff4868ef3d97a0ecf9989937096"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 2 on page 84"^^xsd:string ;
    neo:text "It is good to protect even animals and insects."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_202 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_205,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "fad067020e78dd5fd31ae942ebb526bf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 1, sentence number 1 on page 13"^^xsd:string ;
    neo:text "Nan-in, a Japanese master during the Meiji era (1868-1912) received a university professor who came to inquire about Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2020 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1475,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2021,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2022,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "d0606cb20e2e075a20e9f04d9c7de32e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 3 on page 84"^^xsd:string ;
    neo:text "But what about those persons who kill time, what about those who are destroying wealth and those who destroy political economy?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2023 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492 ;
    neo:id "e998f585468b7bde6b9a37bfe879eec7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 4 on page 84"^^xsd:string ;
    neo:text "We should not overlook them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2024 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2025,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "0026765721051dc00147ca6e3180b5e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 5 on page 84"^^xsd:string ;
    neo:text "Furthermore, what of the one who preaches without enlightenment?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2026 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_605 ;
    neo:id "a8e4601933e056132029c84574d1fec4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 63. Killing, paragraph number 1, sentence number 6 on page 84"^^xsd:string ;
    neo:text "He is killing Buddhism.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2027 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2028,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2029 ;
    neo:id "a7d2ee865c6d7d10a1f9201cb0954867"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 1, sentence number 1 on page 85"^^xsd:string ;
    neo:text "Kasan was asked to officiate at the funeral of a provincial lord."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2030 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2031,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "8352d46ec7a648b60ece513bb218049b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 1, sentence number 2 on page 85"^^xsd:string ;
    neo:text "He had never met lords and nobler before so he was nervous."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2032 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1824,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2028 ;
    neo:id "1533aa67e24eaafc5f2775504f9d89ca"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 2, sentence number 1 on page 85"^^xsd:string ;
    neo:text "When the ceremony started, Kasan sweated."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2034 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a32b5da560859053df6370d3bc85f05e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 3, sentence number 1 on page 85"^^xsd:string ;
    neo:text "Afterwards, when he had returned, he gathered his pupils together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2035 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2028,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2036,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2037,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "007ffbe845d7c48fd3e6c4e40f84a761"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 3, sentence number 2 on page 85"^^xsd:string ;
    neo:text "Kasan confessed that he was not yet qualified to be a teacher for he lacked the sameness of bearing in the world of fame that he possessed in the secluded temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2038 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2028,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "da810b8c6f8648d5d5618ae2900f8c0d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 3, sentence number 3 on page 85"^^xsd:string ;
    neo:text "Then Kasan resigned and became the pupil of another master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2039 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2040,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "611dd4106c0c2c5cc418451b8015e88d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 64. Kasan Sweated, paragraph number 3, sentence number 4 on page 85"^^xsd:string ;
    neo:text "Eight years later he returned to his former pupils, enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2041 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2042 ;
    neo:id "c7442ba6e4f3248859f4771f6e76bd1f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 1, sentence number 1 on page 86"^^xsd:string ;
    neo:text "A young wife fell sick and was about to die."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2044 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2045,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "83ff2f433b8de743c1de2fe6ff6ced17"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 1, sentence number 2 on page 86"^^xsd:string ;
    neo:text "‘I love you so much,’ she told her husband, ‘I do not want to leave you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2046 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "7556b3e10671242a87bb1c5e4f348bbf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 1, sentence number 3 on page 86"^^xsd:string ;
    neo:text "Do not go from me to any other woman."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2047 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "cb082e637e3cfd18c2c6c3f12ba4c427"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 1, sentence number 4 on page 86"^^xsd:string ;
    neo:text "If you do, I will return as a ghost and cause you endless trouble.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2049 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "66b436f41c325b17e40d264aae870ab6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 2, sentence number 1 on page 86"^^xsd:string ;
    neo:text "Soon the wife passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2050 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2051,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279 ;
    neo:id "1ca733a6e449aa7e5059ed0d04bd5137"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 2, sentence number 2 on page 86"^^xsd:string ;
    neo:text "The husband respected her last wish for the first three months but then he met another woman and fell in love with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2052 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2053,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_584 ;
    neo:id "3afb9e4f8f73d6f639a6c06c0bea3560"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 2, sentence number 3 on page 86"^^xsd:string ;
    neo:text "They became engaged to be married."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2054 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048 ;
    neo:id "6f7f475f69b3afec63ca165967421166"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 3, sentence number 1 on page 86"^^xsd:string ;
    neo:text "Immediately after the engagement a ghost appeared every night to the man blaming him for not keeping his promise."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2055 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048 ;
    neo:id "f1e129db3497d5787a1df0343c861e26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 3, sentence number 2 on page 86"^^xsd:string ;
    neo:text "The ghost was clever too."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2056 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2057,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "81687b2f900b22e49cb807529267d7f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 3, sentence number 3 on page 86"^^xsd:string ;
    neo:text "She told him exactly what had transpired between himself and his new sweetheart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2058 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2059,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2060,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2061,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a4152416cc4f50a30bc4991f794f8278"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 3, sentence number 4 on page 86"^^xsd:string ;
    neo:text "Whenever he gave his fiancée a present the ghost would describe it in detail She would even repeat conversations, and it so annoyed the man that he could not sleep."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_206 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_207 ;
    neo:id "aefbe5bc4200f4905e3363c1eebe741a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 2, sentence number 1 on page 13"^^xsd:string ;
    neo:text "Nan-in saved tea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2062 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_552 ;
    neo:id "2c9ecd8616e6876bd434c0c6362fc2d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 3, sentence number 5 on page 86"^^xsd:string ;
    neo:text "Someone advised him to take his problem to a Zen master who lived close to the village."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2063 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2064,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "03c383b83a9306dad963a92de684eaa4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 1 on page 86"^^xsd:string ;
    neo:text "At length, in despair, the poor man went to him for help."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2065 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2066,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "b461a9ac52a07d4a742ed38c089fb781"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 2 on page 86"^^xsd:string ;
    neo:text "‘Your former wife became a ghost and knows everything you do,’ commented the master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2067 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2068 ;
    neo:id "38462ec003d68598518d7869f380c1b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 3 on page 86"^^xsd:string ;
    neo:text "‘Whatever you do or say, whatever you give your beloved she knows."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2069 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048 ;
    neo:id "ecefe30a60ed0780f43ad132d21285ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 4 on page 86"^^xsd:string ;
    neo:text "She must be a very wise ghost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2070 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048 ;
    neo:id "5fc82615380172c959feafca79a80f7f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 5 on page 86"^^xsd:string ;
    neo:text "Really you should admire such a ghost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2071 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "b60bad7847380befb2df9ee7b775ea39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 6 on page 86"^^xsd:string ;
    neo:text "The next time she appears, bargain with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2073 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "eb6baf9269d6da3f17a82a9117b98cce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 4, sentence number 7 on page 86"^^xsd:string ;
    neo:text "Tell her she knows so much you can hide nothing from her, and that if she will answer you one question, you promise to break your engagement and remain single.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2074 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "e3d3a20ede1ca1a8b3fdfd465b59f75a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 5, sentence number 1 on page 86"^^xsd:string ;
    neo:text "‘What is the question I must ask her?’ inquired the man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2075 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2076,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "76bad20dbe7009b5cc1d4980f8a1e2cd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 6, sentence number 1 on page 86"^^xsd:string ;
    neo:text "The master replied: Take a large handful of soybeans and ask her exactly how many beans you hold in your hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2077 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "8b7114cb39fd6f13c38ba38eab007a97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 6, sentence number 2 on page 86"^^xsd:string ;
    neo:text "If she cannot tell you, you will know she is only figment of your imagination and will trouble you no longer.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2078 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048 ;
    neo:id "fc1f5996032faea49c21a500bf443dd4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 7, sentence number 1 on page 86"^^xsd:string ;
    neo:text "The next night, when the ghost appeared the man flattered her and told her that she knew everything."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2079 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2048,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413 ;
    neo:id "4ea5c78eaef130e55b8b75e40332824c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 7, sentence number 2 on page 86"^^xsd:string ;
    neo:text "‘Indeed,’ replied the ghost, ‘and I know you went to see that Zen master today."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_208 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_210,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211 ;
    neo:id "7c67a4610b77271807a09f5c117b6e00"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 2, sentence number 2 on page 13"^^xsd:string ;
    neo:text "He poured his visitor’s cup full, and then kept on pouring."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2080 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "a95582ae14f9ce593ff49226ddfd2748"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 8, sentence number 1 on page 86"^^xsd:string ;
    neo:text "‘And since you know so much,’ demanded the man, ‘tell me how many beans I hold in this hand!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2081 a neo:Document ;
    neo:id "5526533788d091b43e7782af5a00302e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 65. The Subjugation of a Ghost, paragraph number 9, sentence number 1 on page 86"^^xsd:string ;
    neo:text "There was no longer any ghost to answer the question."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2082 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2083,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "7fdb6a51368e59e339800885d33c53c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 1, sentence number 1 on page 88"^^xsd:string ;
    neo:text "Yamaoka Tesshu was a tutor of the emperor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2084 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2085,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "45807a2eb73458a4b20c900520600167"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 1, sentence number 2 on page 88"^^xsd:string ;
    neo:text "He was also a master of fencing and a profound student of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2086 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2087,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244 ;
    neo:id "384070e6e1d502c833560b79c9a8b294"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 2, sentence number 1 on page 88"^^xsd:string ;
    neo:text "His home was the abode of vagabonds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2088 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2089,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "0c03538a25b0df3d8d4701d5d27a9035"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 2, sentence number 2 on page 88"^^xsd:string ;
    neo:text "He had but one suit of clothes, for they kept him always poor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2090 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2092,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265 ;
    neo:id "ab571c5372186ea612b9d84ae1842baa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 3, sentence number 1 on page 88"^^xsd:string ;
    neo:text "The emperor, observing how worn his garments were, gave Yamaoka some money to buy new ones."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2093 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2094 ;
    neo:id "6652a8b5f123d735c72757fbeba7a475"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 3, sentence number 2 on page 88"^^xsd:string ;
    neo:text "The next rime Yamaoka appeared he wore the same old outfit."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2095 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2096,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "798b6f2cd767704aa9c5e55d31f37deb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 4, sentence number 1 on page 88"^^xsd:string ;
    neo:text "‘What became of the new clothes, Yamaoka?’ asked the emperor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2097 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2098,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519 ;
    neo:id "d82fde4cad1b34b1f91495a0a44b83a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 66.Children of His Majesty, paragraph number 5, sentence number 1 on page 88"^^xsd:string ;
    neo:text "‘I provided clothes for the children of Your Majesty,’ explained Yamaoka."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2099 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2100,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2101,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "efa673b17f09db7cf025755de0101a37"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 1 on page 89"^^xsd:string ;
    neo:text "In modern times a great deal of nonsense is talked about masters and disciples, and about the inheritance of a master’s teaching by favorite pupils, entitling them to pass the truth on to their adherents."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2102 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "64471328cb45b25573b1020a82381a77"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 2 on page 89"^^xsd:string ;
    neo:text "Of course Zen should be imparted in this way, from heart to heart, and in the past it was really accomplished."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2104 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1131,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2105,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2106,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2107 ;
    neo:id "e3fb8ffbf701afdb3d18fabddad8f88b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 3 on page 89"^^xsd:string ;
    neo:text "Silence and humility reigned rather than profession and assertion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2108 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "f85561a7666f33f7b8d3aba2f8af37a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 4 on page 89"^^xsd:string ;
    neo:text "The one who received such a teaching kept the matter hidden even after twenty years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2110 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2111,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "d209cfef98ee2c9019d62d0703a7d16a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 5 on page 89"^^xsd:string ;
    neo:text "Not until another discovered through his own need that a real master was at hand was it learned that the teaching had been imparted, and even then the occasion arose quite naturally and the teaching made its way in its own right."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2112 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "cdd59b1f9630456b69ad4dae2b4aeee2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 1, sentence number 6 on page 89"^^xsd:string ;
    neo:text "Under no circumstance did the teacher ever claim ‘I am the successor of So-and-so.’ Such a claim would prove quite the contrary"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2115 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_338 ;
    neo:id "f9b61653b35a15a04d8d773ea37df52c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 1 on page 89"^^xsd:string ;
    neo:text "The Zen master Mu-nan had only one successor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2116 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117 ;
    neo:id "f271eadfb9043efb0966c404cbe93535"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 2 on page 89"^^xsd:string ;
    neo:text "His name was Shoju."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2118 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "6012ce5eee7e1cc39045a1e2a9352d47"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 3 on page 89"^^xsd:string ;
    neo:text "After Shoju had completed his study of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2119 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_338 ;
    neo:id "fd24c8e374a5bec9b1894a52e027e8b4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 4 on page 89"^^xsd:string ;
    neo:text "Mu- nan called him into his room."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_212 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_213 ;
    neo:id "a951beefcdf0db06d99b49c3a6e69bda"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 3, sentence number 1 on page 13"^^xsd:string ;
    neo:text "The professor watched the overflow until he no longer could restrain himself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2120 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117 ;
    neo:id "65656f5334bd501024267b961b74a924"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 5 on page 89"^^xsd:string ;
    neo:text "‘I am getting old,’ he said, ‘and as far as I know Shoju, you are the only one who will carry out this teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2121 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103 ;
    neo:id "2730896c1f97ac4f612b3c5b74a0c6a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 6 on page 89"^^xsd:string ;
    neo:text "Here is a book."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2122 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "3b5d4bfe4bb4fc48398f09ebbd1839aa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 7 on page 89"^^xsd:string ;
    neo:text "It has been passed down from master to master for seven generations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2124 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268 ;
    neo:id "936af9f1dc2645a2a77bdd2e06510c94"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 8 on page 89"^^xsd:string ;
    neo:text "I also have added many points according to my understanding."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2125 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "9676651e951fe0ed8fd29b0eb23ac0d5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 2, sentence number 9 on page 89"^^xsd:string ;
    neo:text "The book is very valuable and I am giving it to you to represent your successor ship.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2126 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "ca564a6f24ac956f250cebfa83002111"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 3, sentence number 1 on page 89"^^xsd:string ;
    neo:text "‘If the book is such an important thing, you had better keep it,’ Shoju replied.’ I received your Zen without writing and am satisfied with it as it is.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2127 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_338 ;
    neo:id "fc22b8927cedf78cae464cda78c91fa0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 4, sentence number 1 on page 89"^^xsd:string ;
    neo:text "‘I know that,’ said Mu-nan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2128 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "f64074ba861e22ac505232adcc296c77"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 4, sentence number 2 on page 89"^^xsd:string ;
    neo:text "‘Even so, this work has been carried from master to master for seven generations, so you may keep it as a symbol of having received the teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2129 a neo:Document ;
    neo:id "079519795f74420ebfde3ec8b33433b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 4, sentence number 3 on page 89"^^xsd:string ;
    neo:text "Here.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2130 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2131,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2132 ;
    neo:id "4a2bd4230124ac6d5d63978a9f62c209"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 5, sentence number 1 on page 89"^^xsd:string ;
    neo:text "The two happened to be talking before a brazier."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2133 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2134 ;
    neo:id "fed2d498f322d9d9a75a9a87cd6eb563"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 5, sentence number 2 on page 89"^^xsd:string ;
    neo:text "The instant Shoju felt the book in his hands he thrust it into the flaming coals."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2135 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2136 ;
    neo:id "bb184bb5a8bc41c8b70ccd3ac6d0c26c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 5, sentence number 3 on page 89"^^xsd:string ;
    neo:text "He had no lust for possessions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2137 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_338 ;
    neo:id "df69c6039bec4092ad715d387e1a1ced"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 6, sentence number 1 on page 89"^^xsd:string ;
    neo:text "Mu-nan who never had been angry before yelled: ‘What are you doing!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2139 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2117 ;
    neo:id "1547c715323e59b266bc63c202f88e4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 67. What Are You Doing! What Are You Saying!, paragraph number 7, sentence number 1 on page 89"^^xsd:string ;
    neo:text "Shoju shouted back: ‘What are you saying!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_214 a neo:Document ;
    neo:id "70695e49fbd05508e698d24f34ae02e3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 3, sentence number 2 on page 13"^^xsd:string ;
    neo:text "‘It is overfull."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2141 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "f005644dfbf45a9286bd2e571cec02a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 1, sentence number 1 on page 90"^^xsd:string ;
    neo:text "After Kakua visited the emperor he disappeared and no one knew what became of him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2143 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "0fd23e6bbceaa4159ce0b44c1f862607"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 1, sentence number 2 on page 90"^^xsd:string ;
    neo:text "He was the first Japanese to study Zen in China, but since he showed nothing of it, save one note, he is not remembered for having brought Zen into his country."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2144 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2145,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30 ;
    neo:id "bea9c345355f21ee81d21c49548c4a14"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 2, sentence number 1 on page 90"^^xsd:string ;
    neo:text "Kakua visited China and accepted the true teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2146 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2147 ;
    neo:id "46664e1ae2fb6d5288696cf0be043b73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 2, sentence number 2 on page 90"^^xsd:string ;
    neo:text "He did not travel while he was there."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2148 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "e0aea74ca06264237ecb6fe22a96b2f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 2, sentence number 3 on page 90"^^xsd:string ;
    neo:text "Meditating constantly, he lived on a remote part of a mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2149 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786 ;
    neo:id "176361f91b8c1d4290f38afef62a7a97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 2, sentence number 4 on page 90"^^xsd:string ;
    neo:text "Whenever people found him and asked him to preach he would say a few words and then move to another part of the mountain where he could be found less easily."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_215 a neo:Document ;
    neo:id "d1fb2acd55f1156bedd40dafa50c9c5f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 3, sentence number 3 on page 13"^^xsd:string ;
    neo:text "No more will go in!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2150 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "a359d4c5877007e0bae85361baa4febd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 3, sentence number 1 on page 90"^^xsd:string ;
    neo:text "The emperor heard about Kakua when he returned to Japan and asked him to preach Zen for his edification and that of his subjects."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2151 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "587b58d9f4821c79b8a90876f01edabc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 4, sentence number 1 on page 90"^^xsd:string ;
    neo:text "Kakua stood before the emperor in silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2152 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2153 ;
    neo:id "39444ee1e9cd3a21a47749fbdc98d927"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 4, sentence number 2 on page 90"^^xsd:string ;
    neo:text "He then produced a flute from the folds of his robe and blew one short note."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2154 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "c2454447843aabeb9f5ef774567b3b36"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 68. One Note of Zen, paragraph number 5, sentence number 1 on page 90"^^xsd:string ;
    neo:text "Bowing politely, he disappeared."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2155 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1444,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2156 ;
    neo:id "90c0085a88fccf1619a3ebee533c696e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 69. Eating the Blame, paragraph number 1, sentence number 1 on page 91"^^xsd:string ;
    neo:text "Circumstances arose one day which delayed preparation of the dinner of a Sate Zen master, Fugai, and his followers."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2157 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2162 ;
    neo:id "8a6e86b0448c944d6fbf7d512b26d01a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 69. Eating the Blame, paragraph number 1, sentence number 2 on page 91"^^xsd:string ;
    neo:text "In haste the cook went to the garden with his curved knife and cut off the tops of green vegetables, chopped them together, and made soup, unaware that in his haste he had included a part of a snake in the vegetables."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_216 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211 ;
    neo:id "362f1b81462b7d6d84ef76bd842b4835"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 4, sentence number 1 on page 13"^^xsd:string ;
    neo:text "‘Like this cup,’ Nan-in said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2163 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2156,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2162,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2164 ;
    neo:id "052b850e30e851b4a43eabe1d7d1803d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 69. Eating the Blame, paragraph number 2, sentence number 1 on page 91"^^xsd:string ;
    neo:text "The followers of Fugai thought they never had tasted such good soup."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2165 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "deb03dd10c567d6fc771fbd81ba519e9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 69. Eating the Blame, paragraph number 2, sentence number 2 on page 91"^^xsd:string ;
    neo:text "But when the master himself found the snake’s head in his bowl, he summoned the cook, ‘What is this?’ he demanded, holding up the head of the snake."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2166 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1722,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2167,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "46bc44f289551fa811607876ed98d46d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 69. Eating the Blame, paragraph number 3, sentence number 1 on page 91"^^xsd:string ;
    neo:text "‘Oh, thank you, master,’ replied the cook, taking the morsel and eating it quickly.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2168 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2170,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2171,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "aea4e4d2ce75988115281faa60b48808"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 70. The Most Valuable Thing in the World, paragraph number 1, sentence number 1 on page 92"^^xsd:string ;
    neo:text "Sozan, a Chinese Zen master, was asked by a student: ‘What is the most valuable thing in the world?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_217 a neo:Document ;
    neo:id "baed589c0b7f0e9995dfa298d98ec22e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 4, sentence number 2 on page 13"^^xsd:string ;
    neo:text "‘You are full of your own opinions and speculations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2172 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2173,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "79bc53d4cebae382cb87bff81ffe7563"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 70. The Most Valuable Thing in the World, paragraph number 2, sentence number 1 on page 92"^^xsd:string ;
    neo:text "The master replied: The head of a dead cat.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2174 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2173,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "3b2abe7432482cb3330312a4b9aea422"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 70. The Most Valuable Thing in the World, paragraph number 3, sentence number 1 on page 92"^^xsd:string ;
    neo:text "‘Why is the head of a dead cat the most valuable thing in the world?’ inquired the student."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2175 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169 ;
    neo:id "797db81c98d0a853d9097fdee58b7e4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 70. The Most Valuable Thing in the World, paragraph number 4, sentence number 1 on page 92"^^xsd:string ;
    neo:text "Sozan replied: ‘Because no one can name its price.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2176 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2177,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2178,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484 ;
    neo:id "81670f027a216961d12a25054f975ffd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 1, sentence number 1 on page 93"^^xsd:string ;
    neo:text "The pupils of the Tendai School used to study meditation before Zen entered Japan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2179 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1131,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2181 ;
    neo:id "c3a37b4cccf769f9f7b5f029124bb7c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 1, sentence number 2 on page 93"^^xsd:string ;
    neo:text "Four of them who were intimate friends promised one another to observe seven days of silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_218 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "dd5dc4a1f9375264a70c59f0c5adec14"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 4, sentence number 3 on page 13"^^xsd:string ;
    neo:text "How can I show you Zen unless you first empty your cup?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2182 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2183,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2184,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "c8e63b895287c161f53f983d5ad256e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 2, sentence number 1 on page 93"^^xsd:string ;
    neo:text "On the first day all were silent Their meditation had begun auspiciously, but when night came and the oil-lamps were growing dim one of the pupils could not help exclaiming to a servant: ‘Fix those lamps.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2185 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2187 ;
    neo:id "aa525426a0a8329c5fa3d6098282405e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 3, sentence number 1 on page 93"^^xsd:string ;
    neo:text "The second pupil was surprised to hear the first one talk."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2188 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dcc30969f2aee82c60d1523c141e3485"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 3, sentence number 2 on page 93"^^xsd:string ;
    neo:text "‘We are not supposed to say a word,’ he remarked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2189 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2191,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "03bfe4f9f894b53678913df69f5ab6e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 4, sentence number 1 on page 93"^^xsd:string ;
    neo:text "‘You two are stupid."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_219 a neo:Document ;
    neo:id "5fe37026e420cb862d7778701b344030"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. A Cup of Tea, paragraph number 4, sentence number 4 on page 13"^^xsd:string ;
    neo:text "‘"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2192 a neo:Document ;
    neo:id "ddde3f75b09d482cb4402014fc2eeb70"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 4, sentence number 2 on page 93"^^xsd:string ;
    neo:text "Why did you talk?’ asked the third."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2193 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2194 ;
    neo:id "d0a7f36d086e9cf253d143eab348f514"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 71. Learning to be Silent, paragraph number 5, sentence number 1 on page 93"^^xsd:string ;
    neo:text "‘I am the only one who has not talked,’ muttered the fourth pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2195 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1250,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2196,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "408204ecfd0430556cef6f78ddddce7a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 72. The Blockhead Lord, paragraph number 1, sentence number 1 on page 94"^^xsd:string ;
    neo:text "Two Zen teachers Daigu and Gudo, were invited to visit a lord."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2197 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "d6adc136be84cfc4f3c62c94d00e56f1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 72. The Blockhead Lord, paragraph number 1, sentence number 2 on page 94"^^xsd:string ;
    neo:text "Upon arriving, Gudo said to the lord: ‘You are wise by nature and have an inborn ability to learn Zen.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2199 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2196,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2200 ;
    neo:id "1e832bc1c598e724c78900a0c404ce0a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 72. The Blockhead Lord, paragraph number 2, sentence number 1 on page 94"^^xsd:string ;
    neo:text "‘Nonsense,’ said Daigu ‘Why do you flatter this blockheads?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_220 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222 ;
    neo:id "aa45ffb0d7a4ebbab3c06c369243ab9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 1, sentence number 1 on page 14"^^xsd:string ;
    neo:text "Gudo was the emperor’s teacher of his time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2201 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1250,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "86384581cc90c5d52fc7b516eb7dbce3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 72. The Blockhead Lord, paragraph number 2, sentence number 2 on page 94"^^xsd:string ;
    neo:text "He may be a lord, but he doesn’t know anything of Zen.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2202 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2196,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "41b46186e1cbc404f1d763d5f77c259c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 72. The Blockhead Lord, paragraph number 3, sentence number 1 on page 94"^^xsd:string ;
    neo:text "So, instead of building a temple for Gudo the lord built it for Daigu and studied Zen with him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2203 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "2050e3af81b2990859ddee1502ebf91d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 1 on page 95"^^xsd:string ;
    neo:text "Zen pupils take a vow that even if they are killed by their teacher, they intend to learn Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2205 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2206,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2207,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2208,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "c2d9aee38c7758091b52b0ce4a83bc22"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 2 on page 95"^^xsd:string ;
    neo:text "Usually they cut a finger and seal their resolution with blood."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2209 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2210,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2211,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "06357ceeef8551e5c101454377163d0c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 3 on page 95"^^xsd:string ;
    neo:text "In time the vow has become a men formality, and for this reason the pupil who died by the hand of Ekido was made to appear a martyr."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2212 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714 ;
    neo:id "54c505c8e8284b6e61cb0013a6145241"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 4 on page 95"^^xsd:string ;
    neo:text "Ekido had become a severe teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2213 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "e2911b455449e404b422ad39e08df0fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 5 on page 95"^^xsd:string ;
    neo:text "His pupils feared him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2214 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2215,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2216,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2217,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_972 ;
    neo:id "a42a88f0006b5938f5d560e1ffa4da94"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 1, sentence number 6 on page 95"^^xsd:string ;
    neo:text "One of them on duty, striking the gong to tell the time of day, missed his beats when his eye was attracted by a beautiful girl passing the temple gate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2218 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714 ;
    neo:id "37ce3beda68d1f88275f556ece3523e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 2, sentence number 1 on page 95"^^xsd:string ;
    neo:text "At that moment Ekido, who was directly behind him, hit him with a stick and the shock happened to kill him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2220 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714 ;
    neo:id "7c283903d6fdc98fb4bc9af9537f1013"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 3, sentence number 1 on page 95"^^xsd:string ;
    neo:text "The pupil’s guardian, hearing of the accident went directly to Ekido."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2223 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "d30e654300104eb6cd4b5723e0880442"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 3, sentence number 2 on page 95"^^xsd:string ;
    neo:text "Knowing that he was not to blame he praised the master for his severe teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2224 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "4caabfd2a798e19e661c49f4e83680a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 3, sentence number 3 on page 95"^^xsd:string ;
    neo:text "Ekido’s attitude was just the same as if the pupil were still alive."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2225 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2226 ;
    neo:id "63506df761d704f458beae0923d3b0ec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 73. Ten Successors, paragraph number 4, sentence number 1 on page 95"^^xsd:string ;
    neo:text "After this took place, he was able to produce under his guidance more than ten enlightened successors, a very unusual number."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2227 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "3ffa99753bd7fd856d1eaa1cec5089dc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 1, sentence number 1 on page 96"^^xsd:string ;
    neo:text "Ryokan devoted his life to the study of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2228 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2230,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_640 ;
    neo:id "ae07358db61fb0e0caa45d6180e46ce5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 1, sentence number 2 on page 96"^^xsd:string ;
    neo:text "One day he heard that his nephew, despite the admonitions of relatives, was spending his money on a courtesan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_223 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "92c3cb1f84dd4beae81922773bc45e21"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 1, sentence number 2 on page 14"^^xsd:string ;
    neo:text "Nevertheless, he used to travel done as a wandering mendicant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2231 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2232,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_640 ;
    neo:id "d692f76518a680fe0cad19c7be28c264"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 1, sentence number 3 on page 96"^^xsd:string ;
    neo:text "Inasmuch as the nephew had taken Ryokan’s place in managing the family estate and the property was in danger of being dissipated, the relatives asked Ryokan to do something about it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2233 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "2403d803aeb42ca9308f4fdc1161600c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 2, sentence number 1 on page 96"^^xsd:string ;
    neo:text "Ryokan had to travel a long way to visit his nephew, whom he had not seen for many years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2234 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2235 ;
    neo:id "52dc9b0ee9a4f754ea76f82a9b5cebab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 2, sentence number 2 on page 96"^^xsd:string ;
    neo:text "The nephew seemed pleased to meet his uncle again and invited him to remain overnight."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2236 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "7ed08805a610398a10d873e6842f85c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 3, sentence number 1 on page 96"^^xsd:string ;
    neo:text "All night Ryokan sat in meditation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2237 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_615 ;
    neo:id "b7bf02cd792701530f1fa2af5df82015"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 3, sentence number 2 on page 96"^^xsd:string ;
    neo:text "As he was departing in the morning he said to the young man: ‘I must be getting old, my hand shakes so."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2238 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "03a03393115431990ce6b24075451905"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 3, sentence number 3 on page 96"^^xsd:string ;
    neo:text "Will you help me tie the string of my straw sandal?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2241 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "475408f112d4371bedb6e93ffcb464a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 4, sentence number 1 on page 96"^^xsd:string ;
    neo:text "The nephew helped him willingly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2242 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "3c34d959bc976775136ba21629023dcc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 4, sentence number 2 on page 96"^^xsd:string ;
    neo:text "‘Thank you,’ finished Ryokan, ‘you see, a man becomes older and feebler day by day."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2243 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2245,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "2b2f1b41925e642dc8c28a1cee62923f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 5, sentence number 1 on page 96"^^xsd:string ;
    neo:text "Take good care of yourself.’ Then Ryokan left, never mentioning a word about the courtesan or the complaints of the relatives."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2246 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_298 ;
    neo:id "33ef52c602a448038fa78fdf8419c17d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 74. True Reformation, paragraph number 5, sentence number 2 on page 96"^^xsd:string ;
    neo:text "But, from that morning on, the dissipations of the nephew ended."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2247 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "1e91f1b587466af0e0eb8ff55471bc6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 1, sentence number 1 on page 97"^^xsd:string ;
    neo:text "A Zen student came to Bankei and complained: ‘Master, I have an ungovernable temper."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2249 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2250,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "519788d725c3a793cc84dc48f5218b07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 1, sentence number 2 on page 97"^^xsd:string ;
    neo:text "How can I cure it?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2251 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "07e3b3ffd597d62344bb830f415a033d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 2, sentence number 1 on page 97"^^xsd:string ;
    neo:text "‘You have something very strange,’ replied Bankei."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2252 a neo:Document ;
    neo:id "cdc5a9957703c758a28bca892c06d784"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 2, sentence number 2 on page 97"^^xsd:string ;
    neo:text "‘Let me see what you have.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2253 a neo:Document ;
    neo:id "fb216f6332a21add238a1bf61116a089"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 3, sentence number 1 on page 97"^^xsd:string ;
    neo:text "‘Just now I cannot show it to you,’ replied the other."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2254 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "ca7cf338866fb016e9b35f81f6d7b571"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 4, sentence number 1 on page 97"^^xsd:string ;
    neo:text "‘When can you show it to me?’ asked Bankei."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2255 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "78eb4c3dac5678036cf67db0cdef685e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 5, sentence number 1 on page 97"^^xsd:string ;
    neo:text "‘It arises unexpectedly,’ replied the student."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2256 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2257,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "7c7ef0ad471c052ecb207d8bd177aebe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 6, sentence number 1 on page 97"^^xsd:string ;
    neo:text "‘Then,’ concluded Bankei, ‘it must not be your own nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2258 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "9dec16071abd5e115a149d987e3f042c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 6, sentence number 2 on page 97"^^xsd:string ;
    neo:text "If it were, you could show it to me at any time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2259 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_344,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "5a0bf4a0b36908f21669adf053062947"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 6, sentence number 3 on page 97"^^xsd:string ;
    neo:text "When you were born you did not have if and your parents did not give it to you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_226 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_227,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_228,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_230 ;
    neo:id "9ea01443e6bc84949e6701b40a7829c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 1, sentence number 3 on page 14"^^xsd:string ;
    neo:text "Once when he was on his way to Edo, the cultural and political center of the shogunate, he approached a little village mad Takenaka."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2260 a neo:Document ;
    neo:id "841c1c6f52ddd452414c6bd562b1cc8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 75. Temper, paragraph number 6, sentence number 4 on page 97"^^xsd:string ;
    neo:text "Think that over.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2261 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2262,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2263,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2264 ;
    neo:id "11d66fb66963735d212f0dae5e16602e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 1, sentence number 1 on page 98"^^xsd:string ;
    neo:text "Hogen, a Chinese Zen teacher, lived alone in a small temple in the country."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2265 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1057,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190 ;
    neo:id "ae43ad5e30e9dda2e95406aa38338aa4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 1, sentence number 2 on page 98"^^xsd:string ;
    neo:text "One day four traveling monks appeared and asked if they might make a fire in his yard to warm themselves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2267 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1328,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2262 ;
    neo:id "94c7c4497a2bfb220fc6dc02361bc6e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 2, sentence number 1 on page 98"^^xsd:string ;
    neo:text "While they were building the fire, Hogen heard them arguing about subjectivity and objectivity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2268 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2269 ;
    neo:id "b4177841664a195103c132997195ca84"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 2, sentence number 2 on page 98"^^xsd:string ;
    neo:text "He joined them and said: There is a big stone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2270 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108 ;
    neo:id "671858dc4c8cbe8039777b98dc8d00c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 2, sentence number 3 on page 98"^^xsd:string ;
    neo:text "Do you consider it to be inside or outside your mind?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2271 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2269,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2272,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "9eda8e11f3de7c682a721f0a0bd9fae2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 3, sentence number 1 on page 98"^^xsd:string ;
    neo:text "One of the monks replied: ‘From the Buddhist viewpoint everything is an objectification of mind, so I would say that the stone is inside my mind.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2273 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2262 ;
    neo:id "b504f0b95059af65d07a094f81247360"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 4, sentence number 1 on page 98"^^xsd:string ;
    neo:text "‘Your head must feel very heavy’, observed Hogen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2274 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2269 ;
    neo:id "d65a7dfc83b6e1d9a67d985758a2129a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 76. The Stone Mind, paragraph number 4, sentence number 2 on page 98"^^xsd:string ;
    neo:text "‘if you are carrying around a stone like that in your mind.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2275 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2276,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_670 ;
    neo:id "c793ab4510799a48a9772d8217c759c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 1, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Zengetsu, a Chinese master of the T’ang dynasty, wrote the following advice for his pupils:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2277 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2248 ;
    neo:id "e9bd3696980939b440aa16f90bdf65e4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 2, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Living in the world yet not forming attachments to the dust of the world is the way of a true Zen student."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2278 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1575,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2111,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2279 ;
    neo:id "429756d82e71b4eac6cf9e87a31008fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 3, sentence number 1 on page 99"^^xsd:string ;
    neo:text "When witnessing the good action of another encourage yourself to follow his example."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2280 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1040,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555 ;
    neo:id "43923fd7b46d9018d0bd5ddbe00b866d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 3, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Hearing of the mistaken action of another, advise yourself not to emulate it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2281 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2283,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "b6318910267ba446cdeb48394bc036fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 4, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Even though alone in a dark room, be as if you were facing a noble guest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2284 a neo:Document ;
    neo:id "da62232e034cc160269604b04382f80c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 4, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Express your feelings, but become no more expressive than your true nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2285 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2286,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2287 ;
    neo:id "34cfd9d36dcfdef9c6637f00e603ac3c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 5, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Poverty is your treasure."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2288 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2289,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "eef7be3a389f19b2a4aab57484e31c9c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 5, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Never exchange it for an easy life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2290 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "9b0c47ca3b7fa34af6007c936bcd1bd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 6, sentence number 1 on page 99"^^xsd:string ;
    neo:text "A person may appear a fool and yet not be one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2292 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2293 ;
    neo:id "739e600f5a0e3b26213740a9f31b9787"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 6, sentence number 2 on page 99"^^xsd:string ;
    neo:text "He may only be guarding his wisdom carefully."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2294 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2296,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_543 ;
    neo:id "da882f3fa2d1910af39914ea82c9eb34"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 7, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Virtues are the fruit of self-discipline and do not drop from heaven of themselves as does rain or snow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2298 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2299 ;
    neo:id "b0ee054e9b6f8592423021f2ad1b8d64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 8, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Modesty is the foundation of all virtues."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_23 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_15,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_24,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_25,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_26,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_27 ;
    neo:id "7b86aa04ea78128fefcfa8773056d86b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 3, sentence number 1 on page 7"^^xsd:string ;
    neo:text "10 Bulls was first published in 1935 by DeVorss and Company, Los Angeles, and subsequently by Ralph R. Phillips, Portland, Oregon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2300 a neo:Document ;
    neo:id "c4ec56eff32a4623425e85f6e45c16b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 8, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Let your neighbors discover you before you make yourself known to them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2301 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2302 ;
    neo:id "6ca65c90e993cf9484539871bbc49fb1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 9, sentence number 1 on page 99"^^xsd:string ;
    neo:text "A noble heart never forces itself forward."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2303 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2304,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "f9d1b9f97a4ca2d0d0b7a21e4bf110dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 9, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Its words are a rare gems seldom displayed and of great value."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2305 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2306 ;
    neo:id "1e12d82a297fe8d2dd7bac1332de0d92"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 10, sentence number 1 on page 99"^^xsd:string ;
    neo:text "To a sincere student, every day is a fortunate day."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2307 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "5376cf997b7dcd11f62b2309fc2d4196"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 10, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Time passes but he never lags behind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2308 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2309,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_948 ;
    neo:id "dc961a388312043173e9cf92a71c3f2d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 10, sentence number 3 on page 99"^^xsd:string ;
    neo:text "Neither glory nor shame can move him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_231 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_232,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_233 ;
    neo:id "b7d649dc4c8350d19ca09d2259de1a51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 2, sentence number 1 on page 14"^^xsd:string ;
    neo:text "It was evening and a heavy rain was falling."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2310 a neo:Document ;
    neo:id "765562951cb75e9dfbc39ad8f8c7ab4b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 11, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Censure yourself, never another."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2311 a neo:Document ;
    neo:id "a5609a72c2b092a178d95c52e87a631f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 11, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Do not discuss right and wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2312 a neo:Document ;
    neo:id "a55556b5439506b8b90b7b17194d555a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 12, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Some things though right, were considered wrong for generations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2313 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2314,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2315,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2316 ;
    neo:id "51ad876e6675d1c171dd4f3e123f2696"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 12, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Since the value of righteousness may be recognized after centuries, there is no need to crave an immediate appreciation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2317 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2318,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2319,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2320 ;
    neo:id "addb8a50add91c037867db64e6ef54b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 13, sentence number 1 on page 99"^^xsd:string ;
    neo:text "Live with cause and leave results to the great law of the universe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2321 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2322 ;
    neo:id "6c435a7a8b2e682ed2c0020d9dfbf4db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 77. No Attachment to Dust, paragraph number 13, sentence number 2 on page 99"^^xsd:string ;
    neo:text "Pass each day in peaceful contemplation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2323 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2324,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316 ;
    neo:id "74091690cd29e88b554f34c7387d1142"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 1, sentence number 1 on page 100"^^xsd:string ;
    neo:text "A rich man asked Sengai to write something for the continued prosperity of his family so that it might be treasured from generation to generation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2326 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_368,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_923 ;
    neo:id "abddb38361bf26138ab99916178338bf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 2, sentence number 1 on page 100"^^xsd:string ;
    neo:text "Sengai obtained a large sheet of paper and wrote: ‘Father dies, son dies, grandson dies.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2328 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2324 ;
    neo:id "238a28fdcf38a210bd7de0bbdc22ff6e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 3, sentence number 1 on page 100"^^xsd:string ;
    neo:text "The rich man became angry."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2330 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316 ;
    neo:id "7bcc3d29f4ceb94a4375b98368c77f85"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 3, sentence number 2 on page 100"^^xsd:string ;
    neo:text "I asked you to write something for the happiness of my family!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2331 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2332,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "27da009c414de0c0a67a649de0aa8d6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 3, sentence number 3 on page 100"^^xsd:string ;
    neo:text "Why do you make such a joke as this?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2333 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325 ;
    neo:id "ade2c552ab6b825aa27c3ee0d9b1ab5c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 4, sentence number 1 on page 100"^^xsd:string ;
    neo:text "‘No joke is intended,’ explained Sengai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2334 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2335 ;
    neo:id "f706a2b546b1a0bf876639d2e0d3cd5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 4, sentence number 2 on page 100"^^xsd:string ;
    neo:text "‘If before you yourself die your son should die, this would grieve you greatly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2337 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "1c8daf05cfce19d94c99e13d57a666b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 4, sentence number 3 on page 100"^^xsd:string ;
    neo:text "If your grandson should pass away before your son, both of you would be broken hearted."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2338 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316 ;
    neo:id "1b7670199e73f637159240bea59b8841"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 4, sentence number 4 on page 100"^^xsd:string ;
    neo:text "If your family, generation after generation, passes away in the order I have named, it will be the natural course of life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2339 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "628708521dccaa86ff2e317601a38289"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 78. Real Prosperity, paragraph number 4, sentence number 5 on page 100"^^xsd:string ;
    neo:text "I call this real prosperity.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_234 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "f16643a307f943c7c0a8ac1c7404d914"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 2, sentence number 2 on page 14"^^xsd:string ;
    neo:text "Gudo was thoroughly wet."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2341 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2343,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2344,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33 ;
    neo:id "197279dad6b0e8e1b88763bfa8fc3312"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 1, sentence number 1 on page 101"^^xsd:string ;
    neo:text "A woman of Nagasaki named Kame was one of the few makers of incense burners in Japan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2345 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2346,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2347,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_249 ;
    neo:id "07b9eae049c373bd467f328698a33d2a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 1, sentence number 2 on page 101"^^xsd:string ;
    neo:text "Such a burner is a work of art to be used only in a tea room or before a family shrine."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2348 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2349 ;
    neo:id "ec585b6762dcb9bccb6928b1a7355408"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 2, sentence number 1 on page 101"^^xsd:string ;
    neo:text "Kame whose father before her had been such an artist, was fond of drinking."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_235 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_236,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_237 ;
    neo:id "8b6d0c846959026dc67c57e6885d7255"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 2, sentence number 3 on page 14"^^xsd:string ;
    neo:text "His straw sandals were in pieces."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2350 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "83d2f7224517af0d4eb2548b6114974f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 2, sentence number 2 on page 101"^^xsd:string ;
    neo:text "She also smoked and associated with men most of the time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2353 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2354,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2355,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2356,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2357,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "98aad843075d83b67c31f03d7fed7d57"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 2, sentence number 3 on page 101"^^xsd:string ;
    neo:text "Whatever she made a little money she gave a feast inviting artists, poets, carpenters, workers, men of many vocations and avocations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2358 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "e8901c742df50ae3b16933838c3be06d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 2, sentence number 4 on page 101"^^xsd:string ;
    neo:text "In their association she evolved her designs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2360 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342 ;
    neo:id "ea7f28aa7699ccfe51c8431279425402"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 3, sentence number 1 on page 101"^^xsd:string ;
    neo:text "Kame was exceedingly slow in creating, but when her work was finished it was always a masterpiece."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2361 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2351,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2362,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2364,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "a1eac6e8d08c8ede69f3c44286456df9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 3, sentence number 2 on page 101"^^xsd:string ;
    neo:text "Her burners were treasured in homes whose womenfolk never drank, smoked, or associated freely with men."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2365 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2366,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2367 ;
    neo:id "8f15db94e409f09236ebe92685da6567"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 4, sentence number 1 on page 101"^^xsd:string ;
    neo:text "The mayor of Nagasaki once requested Kame to design an incense burner for him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2368 a neo:Document ;
    neo:id "495f70bfa52e52a316868bfd986dcde0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 4, sentence number 2 on page 101"^^xsd:string ;
    neo:text "She delayed doing so until almost half a year had passed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2369 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1254,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2370,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2371,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "8ee06fb8cebee5882053cf814c73a4a7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 4, sentence number 3 on page 101"^^xsd:string ;
    neo:text "At that time the mayor, who had been promoted to office in a distant city, visited her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2372 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2346 ;
    neo:id "c51fa915f88c4844e619080ac11c584b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 4, sentence number 4 on page 101"^^xsd:string ;
    neo:text "He urged Kame to begin work on his burner."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2373 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2374 ;
    neo:id "51854ea5b9fb6f95a9470400757b6f89"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 5, sentence number 1 on page 101"^^xsd:string ;
    neo:text "At last receiving the inspiration, Kame made the incense burner."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2375 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2376,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "28b69d383c7c32d797b085237170dabe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 5, sentence number 2 on page 101"^^xsd:string ;
    neo:text "After it was completed she placed it upon a table."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2377 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "367dc44e9cc5af0dc83c137739914e9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 5, sentence number 3 on page 101"^^xsd:string ;
    neo:text "She looked at it long and carefully."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2378 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2379,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "32a0e8abd15e3e9a1c4c3783963c0505"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 5, sentence number 4 on page 101"^^xsd:string ;
    neo:text "She smoked and drank before it as if it were her own company."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_238 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_240 ;
    neo:id "14588b2663c245e378766384bb633499"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 2, sentence number 4 on page 14"^^xsd:string ;
    neo:text "At a farmhouse near the village he noticed four or five pairs of sandals in the window and decided to buy some dry ones."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2380 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "ef0e8d63fa8f936c375513be84e6a2f5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 5, sentence number 5 on page 101"^^xsd:string ;
    neo:text "All day she observed it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2381 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2342,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2382 ;
    neo:id "ccb7444b6c148cc3d221d388c8c05085"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 6, sentence number 1 on page 101"^^xsd:string ;
    neo:text "At last, picking up a hammer, Kame smashed it to bits."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2383 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2384,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "bbf3c8284d6cb8dbf68077838f574c9c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 79. Incense Burner, paragraph number 6, sentence number 2 on page 101"^^xsd:string ;
    neo:text "She saw it was not the perfect creation her mind demanded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2385 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_646,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_647 ;
    neo:id "8d53eb1505d7826fb6eaa67d441e87c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 1, sentence number 1 on page 102"^^xsd:string ;
    neo:text "When Bankei was preaching at Ryumon temple, a Shinshu priest, who believed in salvation through the repetition of the name of the Buddha of Love, was jealous of his large audience and wanted to debate with him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2387 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2388,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "2e590ec8a8d2bc59dcf05ac3ca1d193d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 2, sentence number 1 on page 102"^^xsd:string ;
    neo:text "Bankei was in the midst of a talk when the priest appeared but the fellow made such a disturbance that Bankei stopped his discourse and asked about the noise."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2391 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2392,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2393,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2394,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2395,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_451,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_923 ;
    neo:id "13676e75e109920d36b08b78385f876a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 3, sentence number 1 on page 102"^^xsd:string ;
    neo:text "‘The founder of our sect,’ boasted the priest, ‘had such miraculous powers that he held a brush in his hand on one bank of the river, his attendant held up a paper on the other bank, and the teacher wrote the holy name of Amida through the air."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2396 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "4d1014de0c6e7a0f77afe53fe64bbb1a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 4, sentence number 1 on page 102"^^xsd:string ;
    neo:text "Can you do such a wonderful thing?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2397 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c84477d23de171aab8ef337941371f80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 5, sentence number 1 on page 102"^^xsd:string ;
    neo:text "Bankei replied lightly: ‘Perhaps your fox can perform that trick, but that is not the manner of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2398 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2399,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2400,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_315,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_701 ;
    neo:id "5a104828d84b4a07201b74aaaff9f192"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 80.The Real Miracle, paragraph number 5, sentence number 2 on page 102"^^xsd:string ;
    neo:text "My miracle is that when I feel hungry I eat, and when I feel thirsty I drink.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2401 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "f5eda1cfa94621676777cee9d9254e3b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 1, sentence number 1 on page 103"^^xsd:string ;
    neo:text "Gasan was sitting at the bedside of Tekisui three days before his teacher’s passing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2403 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "33df652c95285f3fc52981b0c5b73e04"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 1, sentence number 2 on page 103"^^xsd:string ;
    neo:text "Tekisui had already chosen him as his successor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2404 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "9f8b004ee2554c40c78f02d8af1a7c25"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 2, sentence number 1 on page 103"^^xsd:string ;
    neo:text "A temple recently had burned and Gasan was busy rebuilding the structure."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2405 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "55935c56a4d85cd1074891945fc2adeb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 2, sentence number 2 on page 103"^^xsd:string ;
    neo:text "Tekisui asked him: ‘What are you going to do when you get the temple rebuilt?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2406 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2043,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "a3584dfb61306cfa08925ab7c564e903"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 3, sentence number 1 on page 103"^^xsd:string ;
    neo:text "‘When your sickness is over we want you to speak there,’ said Gasan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2407 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "de087c64a7f6bcd55b04dd23895d9b8b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 4, sentence number 1 on page 103"^^xsd:string ;
    neo:text "‘Suppose I do not live until then?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2408 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "b2f941de190f3e3ca342ec5484a68e4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 5, sentence number 1 on page 103"^^xsd:string ;
    neo:text "‘Then we will get someone else,’ replied Gasan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_241 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244 ;
    neo:id "4e78b0ce5f46833028086a36f7821bde"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 3, sentence number 1 on page 14"^^xsd:string ;
    neo:text "The woman who offered him the sandals seeing how wet he was invited him to remain for the night in her home."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2410 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402 ;
    neo:id "507aaa92705555df102ed2cb209b2f3e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 6, sentence number 1 on page 103"^^xsd:string ;
    neo:text "Suppose you cannot find anyone?’ continued Tekisui."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2411 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "aadbee2061fe610be00be5b5fdb09249"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 7, sentence number 1 on page 103"^^xsd:string ;
    neo:text "Gasan answered loudly: ‘Don’t ask such foolish questions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2412 a neo:Document ;
    neo:id "9d43cebc5e97118d76b25b92a571871c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 81. Just Go to Sleep, paragraph number 7, sentence number 2 on page 103"^^xsd:string ;
    neo:text "Just go to sleep.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2413 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2083,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "67294a70759ee6bde94ab5f10de1710f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 1, sentence number 1 on page 104"^^xsd:string ;
    neo:text "Yamaoka Tesshu, as a young student of Zen, visited one master after another."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2414 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2415,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2416 ;
    neo:id "5616962b9fd7943bae66e09df13ecf8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 1, sentence number 2 on page 104"^^xsd:string ;
    neo:text "He called upon Dokuon of Shokoku."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2417 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2418,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "ee19710f61e2d681b08e17f0d724e082"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 2, sentence number 1 on page 104"^^xsd:string ;
    neo:text "Desiring to show his attainment, he said: The mind, Buddha, and sentient beings, after all, do not exist."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2419 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1326,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2420 ;
    neo:id "6abc99c4481dc6808609e28ae5d3679f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 2, sentence number 2 on page 104"^^xsd:string ;
    neo:text "The true nature of phenomena is emptiness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2421 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1852,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2423,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2424 ;
    neo:id "1021830256958ba803f3b8bd2cb92b1d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 2, sentence number 3 on page 104"^^xsd:string ;
    neo:text "There is no realization, no delusion, no sage, no mediocrity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2425 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2426 ;
    neo:id "bc70b74e004e745a7062f42b3b19319e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 2, sentence number 4 on page 104"^^xsd:string ;
    neo:text "There is no giving and nothing to be received.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2427 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2415 ;
    neo:id "5b909a5175e3a73a13c58422ca5948b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 3, sentence number 1 on page 104"^^xsd:string ;
    neo:text "Dokuon, who was smoking quietly, said nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2428 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2429 ;
    neo:id "ae73e77f4f5bf9e0d2e3883c9a5e4b3a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 3, sentence number 2 on page 104"^^xsd:string ;
    neo:text "Suddenly he whacked Yamaoka with his bamboo pipe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2430 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2431 ;
    neo:id "98ff81816ee927a2883eda4b24c4a2cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 3, sentence number 3 on page 104"^^xsd:string ;
    neo:text "This made the youth quite angry."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2432 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1922,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2415 ;
    neo:id "df126d1e5307eceb13de8723df9f8a71"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 82. Nothing Exists, paragraph number 4, sentence number 1 on page 104"^^xsd:string ;
    neo:text "‘If nothing exists,’ inquired Dokuon, ‘where did this anger come from?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2433 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1571,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2435,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2436,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "c9906f981369d893a363d8b85aa161f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 1, sentence number 1 on page 105"^^xsd:string ;
    neo:text "Hyakujo, the Chinese Zen master, used to labor with his pupils even at the age of eighty, trimming the gardens, cleaning the grounds, and pruning the trees."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2437 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2438,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2439,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "28e981e0fb727bf72751acb727b5c875"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 2, sentence number 1 on page 105"^^xsd:string ;
    neo:text "The pupils felt sorry to see the old teacher working so hard, but they knew he would not listen to their advice to stop, so they hid away his tools."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2440 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "8a751a811f2f56008dcf6ecf9700c9ef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 3, sentence number 1 on page 105"^^xsd:string ;
    neo:text "That day the master did not eat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2441 a neo:Document ;
    neo:id "ace1b1e6c0cc9166fcda5fee74718784"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 3, sentence number 2 on page 105"^^xsd:string ;
    neo:text "The next day he did not eat, nor the next."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2442 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2439,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "cea9dbe3a0aa94e0dfb5180c1d6e4104"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 3, sentence number 3 on page 105"^^xsd:string ;
    neo:text "‘He may be angry because we have hidden his tools,’ the pupils surmised."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2443 a neo:Document ;
    neo:id "68e8bb4e74ee03726f4d5af2af43b547"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 3, sentence number 4 on page 105"^^xsd:string ;
    neo:text "‘We had better put than back.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2444 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "00c04dfddc62c2a6e20516498d0f4997"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 4, sentence number 1 on page 105"^^xsd:string ;
    neo:text "The day they did, the teacher worked and ate the same as before."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2445 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "051ce83f373e8c0b867f07167e5e0b23"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 83. No Work, No Food, paragraph number 4, sentence number 2 on page 105"^^xsd:string ;
    neo:text "In the evening he instructed them: ‘No work no food.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2446 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2447,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2448,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_760 ;
    neo:id "9ac6da9ee931e6010add0ec283574d64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 1, sentence number 1 on page 106"^^xsd:string ;
    neo:text "A long time ago in China there were two friends, one who played the harp skillfully and one who listened skillfully."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2449 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2450,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2451,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "207d037c268ed708a85f5a1f4f6a35cc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 2, sentence number 1 on page 106"^^xsd:string ;
    neo:text "When the one played or sang about a mountain, the other would say: ‘I can see the mountain before us.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_245 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "43d65a889ab5e58695da40c774990fe2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 3, sentence number 2 on page 14"^^xsd:string ;
    neo:text "Gudo accepted, thanking her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2452 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2453,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2454,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "032812a74b66ed2770e84601adab339a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 3, sentence number 1 on page 106"^^xsd:string ;
    neo:text "When the one played about water, the listener would exclaim: ‘Here is the running stream!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2455 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "a196afb841f07bf40461a45b039c73b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 4, sentence number 1 on page 106"^^xsd:string ;
    neo:text "But the listener fell sick and died."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2456 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_760,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "8bf774f43d7a517c0b718513efdeda1d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 4, sentence number 2 on page 106"^^xsd:string ;
    neo:text "The first friend cut the strings of his harp and never played again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2458 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2459,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2460 ;
    neo:id "2882437dd0247fc7fb769ef5b68cad5c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 84. True Friends, paragraph number 4, sentence number 3 on page 106"^^xsd:string ;
    neo:text "Since that time the cutting of harp strings has always been a sign of intimate friendship."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2461 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413 ;
    neo:id "eeb7406a59112b4b95dc8a1a47037171"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 1, sentence number 1 on page 107"^^xsd:string ;
    neo:text "Ikkyu, the Zen master, was very clever even as a boy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2462 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2463,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "02fb33504b7160e6ec215c4bd61515ae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 1, sentence number 2 on page 107"^^xsd:string ;
    neo:text "His teacher had a precious teacup, a rare antique."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2464 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211 ;
    neo:id "cc5325ea1b43407952e05219b6e70926"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 1, sentence number 3 on page 107"^^xsd:string ;
    neo:text "Ikkyu happened to break this cup and was greatly perplexed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2465 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2466,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "cb4aaeb63b4526288465df9562407e2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 1, sentence number 4 on page 107"^^xsd:string ;
    neo:text "Hearing the footsteps of his teacher, he held the pieces of the cup behind him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2467 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "44940bf3b2a71735b19efa3cddc44165"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 1, sentence number 5 on page 107"^^xsd:string ;
    neo:text "When the master appeared, Ikkyu asked: ‘Why do people have to die?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2468 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2469 ;
    neo:id "439b35f69a8fbd9daca1e85d42e2cbb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 2, sentence number 1 on page 107"^^xsd:string ;
    neo:text "‘This is natural,’ explained the older man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_247 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_249 ;
    neo:id "93d94ec1a0b8e878def0a9922f37030e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 3, sentence number 3 on page 14"^^xsd:string ;
    neo:text "He entered and recited a sutra before the family shrine."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2470 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_505 ;
    neo:id "ecf068d9cc819ca11f8aadfb0e0bd090"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 2, sentence number 2 on page 107"^^xsd:string ;
    neo:text "‘Everything has to die and has just so long to live.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2471 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_211 ;
    neo:id "09296a151a8dd910ba0e0d2da5780d13"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 85. Time to Die, paragraph number 3, sentence number 1 on page 107"^^xsd:string ;
    neo:text "Ikkyu, producing the shattered cup, added: ‘It was time for your cup to die.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2472 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2473 ;
    neo:id "d3b8f43e5ed84f0041ec782ae619746a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 1, sentence number 1 on page 107"^^xsd:string ;
    neo:text "Zen masters give personal guidance in a secluded room."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2474 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "564429131762c3259d15ccb111ccc5d8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 1, sentence number 2 on page 107"^^xsd:string ;
    neo:text "No one enters while teacher and pupil are together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2475 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2476,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2477,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_955 ;
    neo:id "721f17d1330be22c25041bac5e433581"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 2, sentence number 1 on page 107"^^xsd:string ;
    neo:text "Mokurai, the Zen master of Kennin temple in Kyoto, used to enjoy talking with merchants and newspapermen as well as with his pupils."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2478 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2479 ;
    neo:id "17b9de78ab4c36e60a179b2f4947d390"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 2, sentence number 2 on page 107"^^xsd:string ;
    neo:text "A certain tubmaker was almost illiterate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2480 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "2f9d53c409cc25ca1f424191e318aa93"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 2, sentence number 3 on page 107"^^xsd:string ;
    neo:text "He would ask foolish questions of Mokurai have tea, and then go away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2481 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2479,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "574561e23d6108195585139df5b5e5f4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 3, sentence number 1 on page 107"^^xsd:string ;
    neo:text "One day while the tubmaker was there Mokurai wished to give personal guidance to a disciple so he asked the tubmaker to wait in another room."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2482 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2483 ;
    neo:id "ba0c8ff40a2a5ab00e2f3e91dff081bc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 4, sentence number 1 on page 107"^^xsd:string ;
    neo:text "‘I understand you are a living Buddha,’ the man protested."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2484 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1887,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2021,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "a666aad5fff694cc0d5ff1574c0a1f77"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 4, sentence number 2 on page 107"^^xsd:string ;
    neo:text "‘Even the stone Buddha’s in the temple never refuse the numerous persons who come together before them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2485 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "333aef89c7d1cb74047038001b094674"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 4, sentence number 3 on page 107"^^xsd:string ;
    neo:text "Why then should I be excluded?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2486 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "a1c4d9cfbd0a8ad60b455e24e0156092"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 86. The Living Buddha and the Tubmaker, paragraph number 5, sentence number 1 on page 107"^^xsd:string ;
    neo:text "Mokurai had to go outside to see his disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2487 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2488,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_940 ;
    neo:id "04ff310fc0542a6dc5e9e7933476dba9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 1, sentence number 1 on page 108"^^xsd:string ;
    neo:text "A Zen master named Gettan lived in the latter part of the Tokugawa era."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2489 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1652,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2490,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2491,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "697262a5f592e92f5044306bb87b90ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 1, sentence number 2 on page 108"^^xsd:string ;
    neo:text "He used to say: ‘ There are three kinds of disciples: those who impart Zen to others, those who maintain the temples and shrines, and then there are the rice bags and the clothes-hangers.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2492 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "1a58beb22b07da03916cf5ca8f5293b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 1 on page 108"^^xsd:string ;
    neo:text "Gasan expressed the same idea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2493 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402 ;
    neo:id "06f7c9802d41cdf3524ffcafe18ab23d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 2 on page 108"^^xsd:string ;
    neo:text "When he was studying under Tekisui, his teacher was very severe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2494 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "730b3c8a2b8fa658b1a53b69ef87ba3d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 3 on page 108"^^xsd:string ;
    neo:text "Sometimes he even beat him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2495 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "0c878c55cc322faf8476c92ae1d6ba23"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 4 on page 108"^^xsd:string ;
    neo:text "Other pupils would not stand this kind of teaching and quit."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2496 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "2d318aaab0dd5343a31cfe1197291308"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 5 on page 108"^^xsd:string ;
    neo:text "Gasan remained saying: ‘A poor disciple utilizes a teacher’s influence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2497 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "a5a7046ab72b670f7b8771b6503a87bb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 6 on page 108"^^xsd:string ;
    neo:text "A fair disciple admires a teacher’s kindness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2499 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "577a440d29724e8fad1d6870ba387dd7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 87. Three Kinds of Disciples, paragraph number 2, sentence number 7 on page 108"^^xsd:string ;
    neo:text "A good disciple grows strong under a teacher’s discipline.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_250 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_252 ;
    neo:id "6301c2935e9ab4f7744efd8485d15377"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 3, sentence number 4 on page 14"^^xsd:string ;
    neo:text "He then was introduced to the woman’s mother, and to her children."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2500 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2501,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2502 ;
    neo:id "4a99521219936075d1c01a7538757ad3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 1, sentence number 1 on page 109"^^xsd:string ;
    neo:text "A well-known Japanese poet was asked how to compose a Chinese poem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2503 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2502 ;
    neo:id "3d74f998565d0dac4ef9a5e92cef21b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 1, sentence number 2 on page 109"^^xsd:string ;
    neo:text "The usual Chinese poem is four lines,’ he explained."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2505 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2506,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2507,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2508,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2509 ;
    neo:id "33ef85799a687cc9d01a56a06e77ddc0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 1, sentence number 3 on page 109"^^xsd:string ;
    neo:text "The first line contains the initial phrase; the second line, the continuation of that phase; the third line turns from this subject and begins a new one; and the fourth line brings the first three lines together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2510 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2511 ;
    neo:id "c4d01669b0a46a647dbbf4a6dfc9f776"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 1, sentence number 4 on page 109"^^xsd:string ;
    neo:text "A popular Japanese song illustrates this:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2512 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2513,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2514,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303 ;
    neo:id "68ce110fb3f996e77a148a554d4c8cc3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 2, sentence number 1 on page 109"^^xsd:string ;
    neo:text "‘Two daughters of a silk merchant live in Kyoto,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2515 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2516,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2517 ;
    neo:id "fe174e4cfa3bbc5116a02260be2d94f4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 3, sentence number 1 on page 109"^^xsd:string ;
    neo:text "The elder is twenty, the younger, eighteen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2518 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1862 ;
    neo:id "0aac9d6c2aa1d793461a2dcfa14ade51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 4, sentence number 1 on page 109"^^xsd:string ;
    neo:text "A soldier may kill with his sword,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2520 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2351,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2521 ;
    neo:id "802b60249fbcfe64aef45b4b7d62b272"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 88. How to Write a Chinese Poem, paragraph number 5, sentence number 1 on page 109"^^xsd:string ;
    neo:text "But these girls slay men with their eyes.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2522 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_18,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "44e2909686acf9e1fe2180a2a278995f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 1, sentence number 1 on page 110"^^xsd:string ;
    neo:text "Zen teachers train their young pupils to express themselves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2523 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2524,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2526,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2527 ;
    neo:id "39c809328a108114568e7c19423aac10"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 1, sentence number 2 on page 110"^^xsd:string ;
    neo:text "Two Zen temples; each had a child protégé."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2528 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2526,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2527,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2529 ;
    neo:id "61789dfcf2f0fb24d10dd2a66dd6ab80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 1, sentence number 3 on page 110"^^xsd:string ;
    neo:text "One child going to obtain vegetables each morning would meet the other on the way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_253 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_254 ;
    neo:id "4038e988afcb74480fb8a3c1ef8948dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 3, sentence number 5 on page 14"^^xsd:string ;
    neo:text "Observing that the entire family was depressed Gudo asked what was wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2530 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2453 ;
    neo:id "2977b6479eaa2793669dba3cf9230421"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 2, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘Where are you going?’ asked the one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2531 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2532,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2533,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "d4101253920550d3f7fd7b6b695c34f4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 3, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘I am going wherever my feet go.’ the other responded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2534 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "75c816c2bf868ab7a8bc2dcb6fa916b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 4, sentence number 1 on page 110"^^xsd:string ;
    neo:text "This reply puzzled the first child who went to his teacher for help."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2535 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2536,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "c018e71492583b2ad729874f44fabf25"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 5, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘Tomorrow morning,’ the teacher told him, ‘when you meet that little fellow, ask him the same question."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2537 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "943ed771852f4a545af0546999c8f80b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 5, sentence number 2 on page 110"^^xsd:string ;
    neo:text "He will give you the same answer, and then you ask him: “Suppose have no feet, then where are you going!” That will fix him.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2538 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_298 ;
    neo:id "da1bd1c7855847f7858a37a04efc7816"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 6, sentence number 1 on page 110"^^xsd:string ;
    neo:text "The children met again the following morning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2539 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2540 ;
    neo:id "44a1c591a3423d8002cd7705b6abb1f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 11, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘Where are you going?’ asked the first child."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2541 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "2e42d6fb117a82540ae216aa27b54ba1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 7, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘I am going wherever the wind blows,’ answered the other."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2542 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "44b4e9f5cd4dfeb1d9f64bab7d62b16b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 8, sentence number 1 on page 110"^^xsd:string ;
    neo:text "This again nonplussed the youngster, who took his defeat to his teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2544 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "4f48550cb95b8f50520cd4bd1bc6c791"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 9, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘Ask him where he is going if there is no wind,’ suggested the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2545 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_418 ;
    neo:id "93f3d5be9f39e798cb31c80639d67ae2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 10, sentence number 1 on page 110"^^xsd:string ;
    neo:text "The next day the children met a third time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2546 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2529,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "eb01f59bf2e9c95a6be9146839b53295"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 89. Zen Dialogue, paragraph number 12, sentence number 1 on page 110"^^xsd:string ;
    neo:text "‘I am going to market to buy vegetables,’ the other replied."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2547 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548 ;
    neo:id "c83d6e297b8844ec6f100d326ed11bfc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 1, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Tangen had studied with Sengai since childhood."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2549 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325 ;
    neo:id "b5c01e8cb901eaab56144a50c49cbfa1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 1, sentence number 2 on page 111"^^xsd:string ;
    neo:text "When he was twenty he wanted to have his teacher and visit others for comparative study, but Sengai would not permit this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_255 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_256,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257 ;
    neo:id "9a5816adad47c0a8adb3b272873d2508"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 4, sentence number 1 on page 14"^^xsd:string ;
    neo:text "‘My husband is a gambler and a drunkard,’ the housewife told him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2550 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548 ;
    neo:id "9d9884a0a832a24b31071fc93c14b1d8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 1, sentence number 3 on page 111"^^xsd:string ;
    neo:text "Every time Tangen suggested it, Sengai would give him a rap on the head."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2551 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1126,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548 ;
    neo:id "f1cec27520dde1d7a69f733ab0282af3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 2, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Finally Tangen asked an elder brother to coax permission from Sengai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2552 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "55556f778bcee27cf514c6da225c6865"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 2, sentence number 2 on page 111"^^xsd:string ;
    neo:text "This the brother did and then reported to Tangen:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2553 a neo:Document ;
    neo:id "0fde88018e15df0608ffc67f4bd661b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 3, sentence number 1 on page 111"^^xsd:string ;
    neo:text "‘It is arranged."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2554 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "626ea45ea148c0e76ec2dda9ad157015"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 3, sentence number 2 on page 111"^^xsd:string ;
    neo:text "I have fixed it for you to start on your pilgrimage at once.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2555 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548 ;
    neo:id "bc48a6a99475c7656a6a28449ced78d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 4, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Tangen went to Sengai to thank him for his permission."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2556 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "f8cf271fa9e5c70954388e2ed9286d7b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 4, sentence number 2 on page 111"^^xsd:string ;
    neo:text "The master answered by giving him another rap."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2557 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2548,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2558 ;
    neo:id "ac99c92b23a9a95c15b24897a9fc38bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 5, sentence number 1 on page 111"^^xsd:string ;
    neo:text "When Tangen related this to his elder brother the other said: ‘What is the matter?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2559 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325 ;
    neo:id "058bcae0522f4c09e4f9ec22934fa3fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 5, sentence number 2 on page 111"^^xsd:string ;
    neo:text "Sengai has no business giving permission and then changing his mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2560 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "cbde0184a72109fd0dfaebdb063273bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 5, sentence number 3 on page 111"^^xsd:string ;
    neo:text "I will tell him so.’ And off he went to see the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2561 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325 ;
    neo:id "0b756112a52daaf7a4612ea1f2713797"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 6, sentence number 1 on page 111"^^xsd:string ;
    neo:text "‘I did not cancel my permission,’ said Sengai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2562 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "a30fba530432d9cb49b42690262e833a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 90. The Last Rap, paragraph number 6, sentence number 2 on page 111"^^xsd:string ;
    neo:text "‘I just wished to give him one last smack over the head, for when he returns he will be enlightened and I will not be able to reprimand him again.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2563 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2564,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2565 ;
    neo:id "aa78a5672e85ccf0ae847b483f6c8902"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 1, sentence number 1 on page 112"^^xsd:string ;
    neo:text "Matajuro Yagyu was the son of a famous swordsman."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2567 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_368,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "0f0fbbb575fbe44201c846456d073bf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 1, sentence number 2 on page 112"^^xsd:string ;
    neo:text "His father, believing that his son’s work was too mediocre to anticipate mastership, disowned him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2568 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2570,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "bc55e3149c7432035057cdfc10026d5d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 2, sentence number 1 on page 112"^^xsd:string ;
    neo:text "So Matajuro went to Mount Fuhra and there found the famous swordsman Banzo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2572 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_368 ;
    neo:id "ddadfaa41cd6ffa2073f5ed95562208a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 2, sentence number 2 on page 112"^^xsd:string ;
    neo:text "But Banzo confirmed the father’s judgment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2573 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "60b4c549fdde09ef85372bba20637126"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 2, sentence number 3 on page 112"^^xsd:string ;
    neo:text "‘You wish to learn swordsmanship under my guidance?’ asked Banzo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2575 a neo:Document ;
    neo:id "40f8833b9a80b2c5851d53ee6367f4b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 2, sentence number 4 on page 112"^^xsd:string ;
    neo:text "‘You cannot fulfill the requirements.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2576 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2431 ;
    neo:id "56d8328afc9e921e07d5083240d71bc2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 3, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘But if I work hard, how many years will it take me to be come a master?’ persisted the youth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2577 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "cb917ee47898fcfb2b168e15b8361c42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 4, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘The rest of your life,’ replied Banzo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2579 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "fe16c2e045e4176a5de08f922d9aee39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 5, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘I cannot wait that long,’ explained Matajuro."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2580 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2581,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "09cd34bedd93b1d72617c4e7ba528cb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 5, sentence number 2 on page 112"^^xsd:string ;
    neo:text "‘I am willing to pass through any hardship if only you will teach me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2582 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2183,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "7531d212119a8a997f5fcc97b744a519"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 5, sentence number 3 on page 112"^^xsd:string ;
    neo:text "If I become your devoted servant, how long might it be?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2583 a neo:Document ;
    neo:id "1511ea6d1a9193817391dd4a149916a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 6, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘Oh, maybe ten years,’ Banzo relented."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2584 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2585 ;
    neo:id "7d746dbf065c207c4756a9619a7a33fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 7, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘My father is getting old, and soon I must take care of him,’ continued Matajuro."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2586 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "0c478edd5670465e8926624bb9511856"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 7, sentence number 2 on page 112"^^xsd:string ;
    neo:text "‘If I work far more intensively, how long would it take me!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2587 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "0887859154a85d61191e224cab114ee3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 8, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘Oh, maybe thirty years.’ said Banzo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2588 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "9fec201110f789c4900d680c1cfc0c72"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 9, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘Why is that?’ asked Matajuro."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2589 a neo:Document ;
    neo:id "e86e0052ba8ed67c4d308730315a5133"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 9, sentence number 2 on page 112"^^xsd:string ;
    neo:text "‘First you say ten and now thirty years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2590 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2591,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "22d040d6fc415dc2c4cda07938f0f7a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 9, sentence number 3 on page 112"^^xsd:string ;
    neo:text "I will undergo any hardship to master this art in the shortest time!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2592 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "ef6705238661556c65a93e0ecb6fdcca"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 10, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘Well,’ said Banzo, ‘in that case you will have to remain with me for seventy years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2594 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2320 ;
    neo:id "d162a4d709192691e974e1e70e7cc569"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 10, sentence number 2 on page 112"^^xsd:string ;
    neo:text "A man in such a hurry as you are to get results seldom learns quickly.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2595 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2431 ;
    neo:id "d7e4ed5b52f94bf6d01ff44706f0b530"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 11, sentence number 1 on page 112"^^xsd:string ;
    neo:text "‘Very well.’ declared the youth, understanding at last that he was being rebuked for impatience, ‘I agree.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2596 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2085,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "744a71f4f3bae4baca27f3a48af170a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 12, sentence number 1 on page 112"^^xsd:string ;
    neo:text "Matajuro was told never to speak of fencing and never to touch a sword."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2597 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1053,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1057,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2598,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "7e4c99af0e6ab6e41f430dffb10020ff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 12, sentence number 2 on page 112"^^xsd:string ;
    neo:text "He cooked for his master, washed the dishes, made his bed, and cleaned the yard, cared for the garden, all without a word of swordsmanship."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2599 a neo:Document ;
    neo:id "01404f70cb17c987a27bbed463ac029e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 13, sentence number 1 on page 112"^^xsd:string ;
    neo:text "Three years passed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_260 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "41dda9e5bf643392446cd5cb7fbf025e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 4, sentence number 2 on page 14"^^xsd:string ;
    neo:text "‘When he happens to win he drinks and becomes abusive."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2600 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "a9be935eef9c317d82761197f8a0bd01"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 13, sentence number 2 on page 112"^^xsd:string ;
    neo:text "Still Matajuro labored on."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2602 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2603 ;
    neo:id "9d6bf150a09ab1409d27af543a43e659"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 13, sentence number 3 on page 112"^^xsd:string ;
    neo:text "Thinking of his future he was sad."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2605 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2591 ;
    neo:id "f60ae60f1cac9d2260641b14a7aff65e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 13, sentence number 4 on page 112"^^xsd:string ;
    neo:text "He had not even begun to learn the art to which he had devoted his life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2606 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2607 ;
    neo:id "91c4df52fc530f24130cbe83ec8f879a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 14, sentence number 1 on page 112"^^xsd:string ;
    neo:text "But one day Banzo crept up behind him and gave him a terrific blow with a wooden sword."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2608 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "0e7fa226eec895b47115beff6584cc00"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 15, sentence number 1 on page 113"^^xsd:string ;
    neo:text "The following day, when Matajuro was cooking rice, Banzo, again sprang upon him unexpectedly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2610 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "f79a6efb65d3861613a4b9de2486b856"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 16, sentence number 1 on page 113"^^xsd:string ;
    neo:text "After that, day and night, Matajuro had to defend himself from unexpected thrusts."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2611 a neo:__Entity__ ;
    neo:ATTACKED ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569 ;
    neo:id "Unspecified"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2612 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2571 ;
    neo:id "0ae5cb42352521544c9e27532364c30d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 16, sentence number 2 on page 113"^^xsd:string ;
    neo:text "Not a moment passed in any day that he did not have to think of the taste of Banzo’s sword."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2613 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1429,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "6edf0208b43e9d71ee007665785ce250"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 17, sentence number 1 on page 113"^^xsd:string ;
    neo:text "He learned so rapidly he brought smiles to the face of his master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2614 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2569,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2615 ;
    neo:id "bf1098a4fe8ebe2fdfcff45f7072e90b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 91. The Taste of Banzo’s Sword, paragraph number 17, sentence number 2 on page 113"^^xsd:string ;
    neo:text "Matajuro became the greatest swordsman in the land."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2616 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2617,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "3df5a132071b2b8657607278e774f50a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 1, sentence number 1 on page 114"^^xsd:string ;
    neo:text "Hakuin used to tell his pupils about an old woman who had a teashop, praising her understanding of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2618 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2617,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "53bdcfef26cb1cee6a1ad119f8052eb6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 1, sentence number 2 on page 114"^^xsd:string ;
    neo:text "The pupils refused to believe what he told them and would go to the teashop to find out for themselves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2619 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_207,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "6031c60d51a5509c91ab7df9013e623c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 2, sentence number 1 on page 114"^^xsd:string ;
    neo:text "Whenever the woman saw them coming she could tell it once whether they had come for tea or to look into her grasp of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2620 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "4ffc030b091fbf7dfdb9fbfc29df5ee9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 2, sentence number 2 on page 114"^^xsd:string ;
    neo:text "In the former case, she would serve them graciously."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2621 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2622,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "b5ae1d49f0bfdec1272635b92c2419a3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 2, sentence number 3 on page 114"^^xsd:string ;
    neo:text "In the latter, she would beckon to the pupils to come behind her screen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2623 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2624,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "3dceb1f565e60f9fd2e7448292419a47"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 2, sentence number 4 on page 114"^^xsd:string ;
    neo:text "The instant they obeyed, she would strike than with a fire-poker."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2625 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "4fa44f5f8e87241b36be57abbb2d614e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 92. Fire-Poker Zen, paragraph number 3, sentence number 1 on page 114"^^xsd:string ;
    neo:text "Nine out of ten of them could not escape her beating."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2626 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295 ;
    neo:id "bf96c6baad6e860673cf07361fd0d9aa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 1, sentence number 1 on page 115"^^xsd:string ;
    neo:text "Encho was a famous storyteller."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2627 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2628,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2629,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_378,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_379 ;
    neo:id "2cf32d739d85758830bd8b691c507b63"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 1, sentence number 2 on page 115"^^xsd:string ;
    neo:text "His tales of love stirred the hearts of his listeners."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2630 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2632,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_379,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_531 ;
    neo:id "a550d949581fa130adbd816e7e8566c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 1, sentence number 3 on page 115"^^xsd:string ;
    neo:text "When he narrated a story of war, it was as if the listeners themselves were on the field of battle."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2633 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2083,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "313babae9874fcb1a05ca419524995f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 1 on page 115"^^xsd:string ;
    neo:text "One day Encho met Yamaoka Tesshu, a layman who had almost embraced master hood in Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2634 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2635 ;
    neo:id "d108674e03ea31c2bdfa224d53324ed6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 2 on page 115"^^xsd:string ;
    neo:text "‘I understand,’ said Yamaoka, ‘you are the best storyteller in our land and that you make people cry or laugh at will."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2636 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2637,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268 ;
    neo:id "87fd1b1df3df6799848b992bec6ca835"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 3 on page 115"^^xsd:string ;
    neo:text "Tell me my favorite story of the Peach Boy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2638 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367 ;
    neo:id "9f04284febeaf9ab35dea940c66a9508"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 4 on page 115"^^xsd:string ;
    neo:text "When I was a little tot I used to sleep beside my mother, and she often related this legend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2639 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_531,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "b4cf693981eeac83f4340fce4f039507"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 5 on page 115"^^xsd:string ;
    neo:text "In the middle of the story I would fall asleep."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_264 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a8bc198ca59a3f40fd95188aa98efd93"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 4, sentence number 3 on page 14"^^xsd:string ;
    neo:text "When he losses he borrows money from others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2640 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367 ;
    neo:id "b7188673e1092d44c59f2ca38d90095f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 2, sentence number 6 on page 115"^^xsd:string ;
    neo:text "Tell it to me just is my mother did.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2641 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295 ;
    neo:id "74be8c094bbfb01166198429adf0af9b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 3, sentence number 1 on page 115"^^xsd:string ;
    neo:text "Encho dared not attempt to do this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2642 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "8853c39e79590ed3bd8ffd15ad2942ed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 3, sentence number 2 on page 115"^^xsd:string ;
    neo:text "He requested time to study."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2643 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091 ;
    neo:id "886ddbff11b0c54164908e8b0c502f14"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 3, sentence number 3 on page 115"^^xsd:string ;
    neo:text "Several months later he went to Yamaoka and said,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2644 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_531 ;
    neo:id "12a4f5bed98287d79a7ffcecf9efa9b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 4, sentence number 1 on page 115"^^xsd:string ;
    neo:text "‘Please give me the opportunity to tell you the story."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2645 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091 ;
    neo:id "c2a5ec7a0d12b6f11b76c42f4f2cc555"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 5, sentence number 1 on page 115"^^xsd:string ;
    neo:text "‘Some other day,’ answered Yamaoka."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2646 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295 ;
    neo:id "4db882018b61969a25972b8b9e7f252a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 6, sentence number 1 on page 115"^^xsd:string ;
    neo:text "Encho was keenly disappointed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2648 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "953c72b27ad78d985dc1e991449b49fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 6, sentence number 2 on page 115"^^xsd:string ;
    neo:text "He studied further and tried again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2649 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "4c1548931d1648ab68eed10b7d9b5274"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 6, sentence number 3 on page 115"^^xsd:string ;
    neo:text "Yamaoka rejected him many times."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2650 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2651 ;
    neo:id "f1806554370488199dbecf65c171d9b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 6, sentence number 4 on page 115"^^xsd:string ;
    neo:text "When Encho would start to talk Yamaoka would stop him, saying: ‘You are not yet like my mother.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2652 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2653,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2654 ;
    neo:id "75916c74a2c4b8e74f8ea7cc9736a4b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 7, sentence number 1 on page 115"^^xsd:string ;
    neo:text "It took Encho five years to be able to tell Yamaoka the legend as his mother had told it to him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2655 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "8ec76f3570a1c824dd2531c75311135d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 93. Storyteller’s Zen, paragraph number 7, sentence number 2 on page 115"^^xsd:string ;
    neo:text "In this way, Yamaoka imparted Zen to Encho."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2656 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "b13910303015d32a30ef27aaff219570"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 1, sentence number 1 on page 116"^^xsd:string ;
    neo:text "Many pupils were studying meditation under the Zen master Sengai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2657 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2658,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "f3fe33687842176ba73ea60ed4b8c43b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 1, sentence number 2 on page 116"^^xsd:string ;
    neo:text "One of them used to arise at night, climb over the temple wall, and go to town on a pleasure jaunt."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2659 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2660,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2661,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2662,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "449170912d5930d2bfeed1a2237c1264"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 2, sentence number 1 on page 116"^^xsd:string ;
    neo:text "Sengai, inspecting the dormitory quarters, found this pupil missing one night and also discovered the high stool he had used to scale the wall."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_266 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "f058ca515159bf142e821294e88ef613"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 4, sentence number 4 on page 14"^^xsd:string ;
    neo:text "Sometimes when he becomes thoroughly drunk he does not come home at all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2663 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2664 ;
    neo:id "edbf882b02bb09ee06adede00ee10e22"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 2, sentence number 2 on page 116"^^xsd:string ;
    neo:text "Sengai removed the stool and stood there in its place."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2665 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2436,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2664,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2666 ;
    neo:id "d6932c92d2376c854d6818fb811c8806"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 3, sentence number 1 on page 116"^^xsd:string ;
    neo:text "When the wanderer returned, not knowing that Sengai was the stool he put his feet on the master’s head and jumped down into the grounds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2667 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "8dbd764ebbfa0da19b620bf78f9302ad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 3, sentence number 2 on page 116"^^xsd:string ;
    neo:text "Discovering what he had done, he was aghast."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2668 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2669 ;
    neo:id "959695474e7b81d8b5ed6ecc712f920b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 4, sentence number 1 on page 116"^^xsd:string ;
    neo:text "Sengai said: ‘It is very chilly in the early morning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_267 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268 ;
    neo:id "d4b7ef7c9106f725b1b6182c912a43ad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 4, sentence number 5 on page 14"^^xsd:string ;
    neo:text "What can I do?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2670 a neo:Document ;
    neo:id "2c41001901d641d39ca9dd5030768acd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 4, sentence number 2 on page 116"^^xsd:string ;
    neo:text "Do be careful not to catch cold yourself.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2671 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "288304423e20477d74bfe6df6f9e1ad3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 94. Midnight Excursion, paragraph number 5, sentence number 1 on page 116"^^xsd:string ;
    neo:text "The pupil never went out at night again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2672 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2673,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_943 ;
    neo:id "4f719e2360a6a2f8362e4295c4bc84e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 1, sentence number 1 on page 117"^^xsd:string ;
    neo:text "Bassui wrote the following letter to one of his disciples who was about to die:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2674 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2675 ;
    neo:id "286bdafbaceeff2bcdfcbaf85c0727ac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 2, sentence number 1 on page 117"^^xsd:string ;
    neo:text "The essence of your mind is not born so it will never die."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2676 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2677 ;
    neo:id "3f9aa975edbff1de8dd6c42aae60de75"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 2, sentence number 2 on page 117"^^xsd:string ;
    neo:text "It is not an existence, which is perishable."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2678 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1326,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2679 ;
    neo:id "40be2dc99fb3a979222eaa80c7c6cb5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 2, sentence number 3 on page 117"^^xsd:string ;
    neo:text "It is not an emptiness, which is a mere void."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2680 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2681,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "95d0e40c3cd601a926c8387e147ed2c7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 2, sentence number 4 on page 117"^^xsd:string ;
    neo:text "It has neither color nor form."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2683 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2684,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2685,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "3fba966a17c3bc214f5d9e56bb3ec60f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 2, sentence number 5 on page 117"^^xsd:string ;
    neo:text "It enjoys no pleasures and suffers no pain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2686 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2043,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "dff033bbe701d15e3881760777be7ce1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 1 on page 117"^^xsd:string ;
    neo:text "‘I know you are very ill. Like a good Zen student, you are facing that sickness squarely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2687 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2688 ;
    neo:id "ebff86a65ac68607261e9ed3df1f1487"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 2 on page 117"^^xsd:string ;
    neo:text "You may not know exactly who is suffering, but question yourself: What is the essence of this mind?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2689 a neo:Document ;
    neo:id "2bc06836e6f876b525ee27d05be55a18"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 3 on page 117"^^xsd:string ;
    neo:text "Think only of this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_269 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "0797af8a0dfd379fe77c40df2a40ebae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 5, sentence number 1 on page 14"^^xsd:string ;
    neo:text "‘I will help him,’ said Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2690 a neo:Document ;
    neo:id "8ac4ead380283e1eb8f3da5db8723d68"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 4 on page 117"^^xsd:string ;
    neo:text "You will need no more."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2691 a neo:Document ;
    neo:id "cc57826ddf43c0f8f61dc458908052cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 5 on page 117"^^xsd:string ;
    neo:text "Covet nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2692 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2694,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2695 ;
    neo:id "4bc17f51e7bcd05198b36d658a3a4d9c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 95. A Letter to a Dying Man, paragraph number 3, sentence number 6 on page 117"^^xsd:string ;
    neo:text "Your end which is endless is as a snowflake dissolving in the pure air.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2696 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2697,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2698,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2699,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2700 ;
    neo:id "96e433031b1692cbe3b727df9711b6b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 1, sentence number 1 on page 118"^^xsd:string ;
    neo:text "A Zen master named Gisan asked a young student to bring him a pail of water to cool his bath."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_270 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_265 ;
    neo:id "37e951c4879e9dcf79b8193df7a0494d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 5, sentence number 2 on page 14"^^xsd:string ;
    neo:text "‘Here is some money."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2701 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2700,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_685,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "f4e6e13fb0d69e079782155de0813525"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 2, sentence number 1 on page 118"^^xsd:string ;
    neo:text "The student brought the water and, after cooling the bath, threw on to the ground the little that was left over."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2702 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "c1ea1aa3f030af5dc2a89378ea95ed73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 3, sentence number 1 on page 118"^^xsd:string ;
    neo:text "‘You dunce!’ the master scolded him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2703 a neo:Document ;
    neo:id "886f6622831d52d4895cec95c986284a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 3, sentence number 2 on page 118"^^xsd:string ;
    neo:text "‘Why didn’t you give the rest of the water to the plants?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2704 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "54fe6ab9fed16cac124ef2edd292c4c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 3, sentence number 3 on page 118"^^xsd:string ;
    neo:text "What right have you to waste even a drop of water in this temple?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2705 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2698,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "ecf85821350d1f5b3f2ee3d348c79cb3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 4, sentence number 1 on page 118"^^xsd:string ;
    neo:text "The young student attained Zen in that instant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2706 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2402,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2707 ;
    neo:id "39d5481f8c253adb032b5e1a2cd67e4b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 96.A Drop of Water, paragraph number 4, sentence number 2 on page 118"^^xsd:string ;
    neo:text "He changed his name to Tekisui, which means a drop of water."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2708 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2709,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2710,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33 ;
    neo:id "899282d8f14183668a3c781f48b280df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 1, sentence number 1 on page 119"^^xsd:string ;
    neo:text "In early times in Japan, bamboo-and-paper lanterns wee used with candles inside."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_271 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_272,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_273 ;
    neo:id "0f9a02e2e0de5d084feaad3c82b11c47"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 5, sentence number 3 on page 14"^^xsd:string ;
    neo:text "Get me a gallon of fine wine and something good to eat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2711 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1168,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "10a575b489ad358f251cee75e18820d4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 1, sentence number 2 on page 119"^^xsd:string ;
    neo:text "A blind man, visiting a friend one night was offered a lantern to carry home with him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2713 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "52c57a18cecbe20e84ff1f05a08e74bb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 2, sentence number 1 on page 119"^^xsd:string ;
    neo:text "‘I do not need a lantern,’ he said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2714 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2715,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "fca0e964b4ed2ae69635a38a75938048"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 2, sentence number 2 on page 119"^^xsd:string ;
    neo:text "Darkness or light is all the same to me’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2716 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2409,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2717 ;
    neo:id "4237e04bb92e8ebbbe9f3c5f3bb986d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 3, sentence number 1 on page 119"^^xsd:string ;
    neo:text "‘I know you do not need a lantern to find your way,’ his friend replied, ‘but if you don’t have one someone else may run into you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2718 a neo:Document ;
    neo:id "11469352f926ec9f6e60f10a5a9a5e60"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 3, sentence number 2 on page 119"^^xsd:string ;
    neo:text "So you must take it.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2719 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1168,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_552 ;
    neo:id "71cdb10984daa8227d74e0254f2a3b0a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 4, sentence number 1 on page 119"^^xsd:string ;
    neo:text "The blind man started off with the lantern and before he had walked very far someone ran squarely into him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2720 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "c95f5b9ea9cbe99a3e82fef74318e6a5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 4, sentence number 2 on page 119"^^xsd:string ;
    neo:text "‘Look out where you are going!’ he exclaimed to the stranger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2721 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "79ee86af31edf7811738ac313966c46b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 4, sentence number 3 on page 119"^^xsd:string ;
    neo:text "‘Can’t you see this lantern?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2722 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2723,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "608772ac55093f26d1b57a622501a053"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 97. Teaching the Ultimate, paragraph number 5, sentence number 1 on page 119"^^xsd:string ;
    neo:text "‘Your candle has burned out brother,’ replied the stranger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2724 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2725,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2726 ;
    neo:id "e4c2d1ea011a3ea3e92bc4bc7c28af5b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 1, sentence number 1 on page 120"^^xsd:string ;
    neo:text "Kitano Gempo, abbot of Eihei temple was ninety-two years old when he passed away in the year 1933."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2728 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7cc76ded8a209a711923e5f6c61e19fb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 1, sentence number 2 on page 120"^^xsd:string ;
    neo:text "He endeavored his whole life not to be attached to anything."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2729 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2730,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2731 ;
    neo:id "bd1355cfc2729bab7c9c1e9c1d1fa3d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 1, sentence number 3 on page 120"^^xsd:string ;
    neo:text "As a wandering mendicant when he was twenty he happened to meet a traveler who smoked tobacco."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2732 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2733,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_436,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "665809cb234f52b0c957511d99cd75bf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 1, sentence number 4 on page 120"^^xsd:string ;
    neo:text "As they walked together down a mountain road they stopped under a tree to rest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2734 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2735 ;
    neo:id "cbcd1a7d76fd8d5f5caf850fb8480a73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 1, sentence number 5 on page 120"^^xsd:string ;
    neo:text "The traveler offered Kitano a smoke, which he accepted, as he was very hungry at the time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2736 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4e149684fab0bc2f3a00dbb9af381ae2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 2, sentence number 1 on page 120"^^xsd:string ;
    neo:text "‘How pleasant this smoking is,’ he commented."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2737 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2450,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2451,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2731,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2738 ;
    neo:id "6ef9807fb61031496a5d666f36ec9183"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 2, sentence number 2 on page 120"^^xsd:string ;
    neo:text "The other gave him an extra pipe and tobacco and they parted."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2739 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2735,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2740,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484 ;
    neo:id "5acd2972c49a525933dde47d2143a3d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 3, sentence number 1 on page 120"^^xsd:string ;
    neo:text "Kitano felt: ‘Such pleasant things may disturb meditation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_274 a neo:Document ;
    neo:id "72d9e02db049ce70d03d99ac4e43522e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 5, sentence number 4 on page 14"^^xsd:string ;
    neo:text "Then you may retire."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2741 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2742 ;
    neo:id "e820ae715c1b0bfaab596964465dddc3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 3, sentence number 2 on page 120"^^xsd:string ;
    neo:text "Before this goes too far, I will stop now.’ So he threw the smoking outfit away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2743 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2744 ;
    neo:id "d55cd0484206a87feeb30d8569c12e67"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 1 on page 120"^^xsd:string ;
    neo:text "When he was twenty-three years old he studied I-King, the profoundest doctrine of the universe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2745 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2746,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_438 ;
    neo:id "fd55a0574ee4f977e3d81626a040b2b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 2 on page 120"^^xsd:string ;
    neo:text "It was winter at the time and he needed some heavy clothes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2747 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1136,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_943 ;
    neo:id "bb6d56919c7f6ce6935d5db7d11e0e25"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 3 on page 120"^^xsd:string ;
    neo:text "He wrote to his teacher, who lived a hundred miles away, telling him of his need, and gave the letter to a traveler to deliver."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2748 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_438,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_69 ;
    neo:id "3bbb24533961a2ea2bffe812cb877732"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 4 on page 120"^^xsd:string ;
    neo:text "Almost the whole winter passed and neither answer nor clothes arrived."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2749 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2735,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2744 ;
    neo:id "36d91f1532516da57bf43fed99a6467d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 5 on page 120"^^xsd:string ;
    neo:text "So Kitano resorted to the prescience of I-King, which also teaches the art of divination, to determine whether or not his letter had miscarried."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_275 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_276,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "b1021766bcf747fba5c1f35a1a0a4e35"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 5, sentence number 5 on page 14"^^xsd:string ;
    neo:text "I will meditate before the shrine.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2750 a neo:Document ;
    neo:id "98240c4461f10a89a29826060a4f7931"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 6 on page 120"^^xsd:string ;
    neo:text "He found that this had been the case."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2751 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_943 ;
    neo:id "035baee2656f94997c50376cd4da3af4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 4, sentence number 7 on page 120"^^xsd:string ;
    neo:text "A letter afterwards from his teacher made no mention of clothes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2752 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2735,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2744 ;
    neo:id "066f8fb126a0b7f7a3d04f960abbecd0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 5, sentence number 1 on page 120"^^xsd:string ;
    neo:text "‘If I perform such accurate determinative work with I-King, I may neglect my meditation,’ felt Kitano."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2753 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "4475a4ef85b3a9740e2f8eb8bc3d91a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 5, sentence number 2 on page 120"^^xsd:string ;
    neo:text "So he gave up this marvelous teaching and never resorted to its powers again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2754 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2755,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2756 ;
    neo:id "97a2516d52a99765e11709b22615df13"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 6, sentence number 1 on page 120"^^xsd:string ;
    neo:text "When he was twenty-eight he studied Chinese calligraphy and poetry."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2757 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2758,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "25ddce20285055a0ff7e2ea5ad90fa16"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 6, sentence number 2 on page 120"^^xsd:string ;
    neo:text "He grew so skilful in these arts that his teacher praised him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2759 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2735,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_388,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_561 ;
    neo:id "efbfd0b4c1ad750d15064afd4718a22e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 98. Non-Attachment, paragraph number 6, sentence number 3 on page 120"^^xsd:string ;
    neo:text "Kitano mused: ‘If I don’t stop now, I’ll be a poet not a Zen teacher.’ So he never wrote another poem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2760 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2761 ;
    neo:id "f5f7c1195979a1d154f2538367c0f05c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 1, sentence number 1 on page 121"^^xsd:string ;
    neo:text "Tosui was the Zen master who left the formalism of temples to live under a bridge with beggars."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2762 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "3e2eb55d4ef5d58d6acebde189dd95f0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 1, sentence number 2 on page 121"^^xsd:string ;
    neo:text "When he was getting very old, a friend helped him to earn his living without begging."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2763 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2609,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2764 ;
    neo:id "f9e91fb432eb4e6f7b018496c592fd23"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 1, sentence number 3 on page 121"^^xsd:string ;
    neo:text "He showed Tosui how to collect rice and manufacture vinegar from it and Tosui did this until he passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2765 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2761,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2766 ;
    neo:id "1ee72f19ac370dfd69901b63f7a9802b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 2, sentence number 1 on page 121"^^xsd:string ;
    neo:text "While Tosui was making vinegar, one of the beggars gave him a picture of the Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2767 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2662,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2768,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_429 ;
    neo:id "03711c0b89898c2f7f44ee062879e2e8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 2, sentence number 2 on page 121"^^xsd:string ;
    neo:text "Tosui hung it on the wall of his hut and put a sign beside it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2769 a neo:Document ;
    neo:id "ac7aa9e4bb3369bd187c154b943deb03"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 2, sentence number 3 on page 121"^^xsd:string ;
    neo:text "The sign read:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2770 a neo:Document ;
    neo:id "f403fa6da894be07cdd0d03f0837ca66"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 3, sentence number 1 on page 121"^^xsd:string ;
    neo:text "‘Mr."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2771 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2772,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2773 ;
    neo:id "9c0cf7f65989f860b7d992ae2d0912bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 3, sentence number 2 on page 121"^^xsd:string ;
    neo:text "Amida Buddha: This little loom is quite narrow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2774 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "d6269c01e49b741fbfa87956fcb3d0fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 3, sentence number 3 on page 121"^^xsd:string ;
    neo:text "I can let you remain as a transient."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2776 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1858,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "fb147571e4cfcfbb3c5d1329e20ccc90"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 99. Tasui’s Vinegar, paragraph number 3, sentence number 4 on page 121"^^xsd:string ;
    neo:text "But don’t think I am asking you to help me to be reborn in your paradise.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2777 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2778,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "26b2d04ea598cdb0b49ffe51e288b7b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 1, sentence number 1 on page 122"^^xsd:string ;
    neo:text "Shochi was a one-eyed teacher of Zen, sparkling with enlightenment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2779 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2780,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "3d7b2e2ad9bf4f35e6ab448a5f26ff84"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 1, sentence number 2 on page 122"^^xsd:string ;
    neo:text "He taught his disciple in Tofuku temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_278 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_280 ;
    neo:id "b51665c3cb3c1e2fa0ba87b9683deff5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 6, sentence number 1 on page 14"^^xsd:string ;
    neo:text "When the man of the house returned about midnight, quite drunk; he bellowed: ‘Hey, wife I am home."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2781 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489 ;
    neo:id "f9c7a0f593cd5d6464f301598008d55e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 2, sentence number 1 on page 122"^^xsd:string ;
    neo:text "Day and night the whole temple stood in silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2782 a neo:Document ;
    neo:id "f05a09a2fc29aeb2f26969212c7aabdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 2, sentence number 2 on page 122"^^xsd:string ;
    neo:text "There was no sound at all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2783 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "99299d3c0631a8ee09db959479f9d14f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 3, sentence number 1 on page 122"^^xsd:string ;
    neo:text "Even the reciting of sutras was abolished by the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2784 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_466 ;
    neo:id "7015cbd54c76e7fcfcbad4d954bfac38"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 3, sentence number 2 on page 122"^^xsd:string ;
    neo:text "His pupils had nothing to do but meditate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2786 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2787,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2788,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "fd9393401dfaa7ebbcbc28ab4f8bb475"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 4, sentence number 1 on page 122"^^xsd:string ;
    neo:text "What the master passed away, an old neighbor heard the ringing of bells and the recitation of sutras."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2789 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2790,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "6782292451242548ff47ee55fb7be50d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 100. The Silent Temple, paragraph number 4, sentence number 2 on page 122"^^xsd:string ;
    neo:text "Then she knew Shoichi had gone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2791 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "493adab7b9564bc8177936a05ba552ec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 1, sentence number 1 on page 123"^^xsd:string ;
    neo:text "Buddha said:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2792 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2793,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2794,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2795,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "b2c65f18c7e3b36e04063cd623369291"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 1 on page 123"^^xsd:string ;
    neo:text "‘I consider the positions of kings and rulers as that of dust motes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2796 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1349,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2797,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2798,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2799 ;
    neo:id "1e9c140bb99c23d74cc2fd39d0a51d8d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 2 on page 123"^^xsd:string ;
    neo:text "I observe treasure of gold and gems as so many bricks and pebbles."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_28 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_29,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_31,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_34 ;
    neo:id "39e669bd136b80777f9f4e19400f6d24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 3, sentence number 2 on page 7"^^xsd:string ;
    neo:text "It is a translation from the Chinese of a famous twelfth century commentary upon the stages of awareness leading to enlightenment and is here illustrated by one of Japan’s best contemporary woodblock artists."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2800 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2801,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2802,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "99091f350d5b22f25f00da1875ca887b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 3 on page 123"^^xsd:string ;
    neo:text "I look upon the finest silken robes as tattered rags."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2803 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2804,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2805,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2806,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2807,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2808 ;
    neo:id "4868fb12fc101c9c5cafbbd463ef280f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 4 on page 123"^^xsd:string ;
    neo:text "I see myriad worlds of the universe as small seeds of fruit, and the greatest lake in India as a drop of oil on my foot."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2809 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2810,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2811,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2812 ;
    neo:id "c2c22c99007886497f8935c75c390b13"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 5 on page 123"^^xsd:string ;
    neo:text "I perceive the teachings of the world to be the illusion of, magicians."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_281 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284 ;
    neo:id "ab345b29a89633e7d3cd2502b56d534e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 6, sentence number 2 on page 14"^^xsd:string ;
    neo:text "Have you something for me eat?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2813 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2814,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2815,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2816,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2817,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2818,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492 ;
    neo:id "92716bcbead801b9772f6ff34e375f79"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 6 on page 123"^^xsd:string ;
    neo:text "I discern the highest conception of emancipation as golden brocade in a dream, and view the holy path of the illuminated one as flowers appearing in one’s eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2819 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1951,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2820,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2821,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "4a2991feca6cde226752baac46c432c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 7 on page 123"^^xsd:string ;
    neo:text "I see meditation as a pillar of a mountain, Nirvana as a nightmare of daytime."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2822 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2824,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2825,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2826,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2827,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_407 ;
    neo:id "efe5549a0b03e12b8ad2df6164ae077f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 101. Buddha’s Zen, paragraph number 2, sentence number 8 on page 123"^^xsd:string ;
    neo:text "I look upon the judgment of right and wrong as the serpentine dance of a dragon, and the rise and fall of beliefs as but traces left by the four seasons.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2828 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2829,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830 ;
    neo:id "3ff18530f6af5a302fe44f77d92ea05f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: THE GATELESS GATE, paragraph number 1, sentence number 1 on page 125"^^xsd:string ;
    neo:text "by Ekai, called Mumon"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2831 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1790,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2832,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "7a42223d14eb8ea0de1b8de0307d6c41"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 1, sentence number 1 on page 127"^^xsd:string ;
    neo:text "A monk asked Joshu, a Chinese Zen master: “Has a dog Buddha-nature or not?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2833 a neo:Document ;
    neo:id "7e8d007b80fabeec1206288e16a1f908"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 2, sentence number 1 on page 127"^^xsd:string ;
    neo:text "Joshu answered: “Mu.” *"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2834 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2835,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "e5ce62f066971e9616af84ed03cfa5a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 3, sentence number 1 on page 127"^^xsd:string ;
    neo:text "Mumon’s comment: To realize Zen one has to pass through the barrier of the patriarchs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2836 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2837,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "531ffbd3902e1ffa43716997becdedb0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 3, sentence number 2 on page 127"^^xsd:string ;
    neo:text "Enlightenment always comes after the road of thinking is blocked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2838 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2839,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2840,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2841 ;
    neo:id "80fb914b720466711f6e1c14529b4f55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 3, sentence number 3 on page 127"^^xsd:string ;
    neo:text "If you do not pass the barrier of the patriarchs or if your thinking road is not blocked, whatever you think, whatever you do, is like a tangling ghost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2842 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2843,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2844 ;
    neo:id "258902c65e81b67645343cb8c1aca16d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 3, sentence number 4 on page 127"^^xsd:string ;
    neo:text "You may ask: What is a barrier of a patriarch?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2845 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_880 ;
    neo:id "c45bec8e10e051a9fc95f905e82b67db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 3, sentence number 5 on page 127"^^xsd:string ;
    neo:text "This one word, Mu, is it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2846 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2844,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "f87dfcf0ac89c4915abf998ffbbf89e7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 4, sentence number 1 on page 127"^^xsd:string ;
    neo:text "This is the barrier of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2847 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "a9c1e1525ffed436f5db1e048d93f11d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 4, sentence number 2 on page 127"^^xsd:string ;
    neo:text "If you pass through it you will see Joshu face to face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2848 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2849 ;
    neo:id "313c3e6a35a28eecdbbd54321e0dc377"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 4, sentence number 3 on page 127"^^xsd:string ;
    neo:text "Then you can work hand in hand with the whole line of patriarchs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_285 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "45b2d603cce799a96adcaa2dd99100d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 7, sentence number 1 on page 14"^^xsd:string ;
    neo:text "I have something for you: said Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2850 a neo:Document ;
    neo:id "76bbf7ffa788dac757e5e63c8775c007"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 4, sentence number 4 on page 127"^^xsd:string ;
    neo:text "Is this not a pleasant thing to do?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2851 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2844,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2852,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_880,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_96 ;
    neo:id "bb6ea182c8e9e5890981320a565cafd6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 5, sentence number 1 on page 127"^^xsd:string ;
    neo:text "If you want to pass this barrier, you must work through every bone in your body, through every pore of your skin, filled with this question: What is Mu?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2853 a neo:Document ;
    neo:id "d42dd589daa5b9b4c2808082197ca333"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 5, sentence number 2 on page 127"^^xsd:string ;
    neo:text "and carry it day and night."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2854 a neo:Document ;
    neo:id "c3f1d893de53e1b9d81a8baeae57b9f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 5, sentence number 3 on page 127"^^xsd:string ;
    neo:text "Do not believe it is the common negative symbol meaning nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2855 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2677,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2856 ;
    neo:id "d8ff906f2ec601fefcdb708cf5086d34"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 5, sentence number 4 on page 127"^^xsd:string ;
    neo:text "It is not nothingness, the opposite of existence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2857 a neo:Document ;
    neo:id "9a7f7cbed5d46bf29ef35367742cb452"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 5, sentence number 5 on page 127"^^xsd:string ;
    neo:text "If you really want to pass this barrier, you should feel like drinking a hot iron ball that you can neither swallow nor spit out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2858 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2859 ;
    neo:id "cd388493213425558cc42ad8e961d971"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 6, sentence number 1 on page 127"^^xsd:string ;
    neo:text "Then your previous lesser knowledge disappears."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_286 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "ae149919b2606107e43b594762a02f34"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 7, sentence number 2 on page 14"^^xsd:string ;
    neo:text "‘I happened to be caught in the rain and your wife kindly asked me to remain here for the night."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2861 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1328,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2862,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_676 ;
    neo:id "af4627e85a0c3e7e69d012b6f6aeef3f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 6, sentence number 2 on page 127"^^xsd:string ;
    neo:text "As a fruit ripening in season, your subjectivity and objectivity naturally become one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2863 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2816 ;
    neo:id "9e49d3407bc01c3cd6808cfb7d2886c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 6, sentence number 3 on page 127"^^xsd:string ;
    neo:text "It is like a dumb man who has had a dream."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2864 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "aaa63e63a6fa70db6cd8ab7482b40e79"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 6, sentence number 4 on page 127"^^xsd:string ;
    neo:text "He knows about it but he cannot tell it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2865 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2866,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867 ;
    neo:id "08f4a7ee12a96ad9d9a09ffa98ba9ff0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 7, sentence number 1 on page 127"^^xsd:string ;
    neo:text "When he enters this condition his ego-shell is crushed and he can shake the heaven and move the earth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2868 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1822,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "aed51f2f77e3b58340c06bed9b6d6fe3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 7, sentence number 2 on page 127"^^xsd:string ;
    neo:text "He is like a great warrior with a sharp sword."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2869 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2843,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "d0480e975dbc1d1245f27b7714845b52"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 7, sentence number 3 on page 127"^^xsd:string ;
    neo:text "If a Buddha stands in his way, he will cut him down; if a patriarch offers him any obstacle, he will kill him; and he will be free in his way of birth and death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2870 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2871 ;
    neo:id "6a93fe31d40ed215ff4c2ef1c69be21a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 7, sentence number 4 on page 127"^^xsd:string ;
    neo:text "He can enter any world as if it were his own playground."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2872 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_17,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "d40f07210ac0881deefe68124e90382e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 7, sentence number 5 on page 127"^^xsd:string ;
    neo:text "I will tell you how to do this with this koan:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2873 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2874,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_880 ;
    neo:id "cd4e0ccd37a192f208b7fb976b154a45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 8, sentence number 1 on page 127"^^xsd:string ;
    neo:text "Just concentrate your whole energy into this Mu, and do not allow any discontinuation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2875 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2723,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2876,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_880 ;
    neo:id "c3c5fe1b5595bcacf1d40dca5be7e83f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 8, sentence number 2 on page 127"^^xsd:string ;
    neo:text "When you enter this Mu and there is no discontinuation, your attainment will be as a candle burning and illuminating the whole universe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2877 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1790,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2832 ;
    neo:id "1c01c7b7e5d7ef15b954cb57a7ef466b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 9, sentence number 1 on page 128"^^xsd:string ;
    neo:text "Has a dog Buddha-nature?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2878 a neo:Document ;
    neo:id "1fedd73143b2ad81fb133dd7a70c2ed2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 9, sentence number 2 on page 128"^^xsd:string ;
    neo:text "This is the most serious question of all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2879 a neo:Document ;
    neo:id "bf78ad2ad551fce29db29dc1e8785a16"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. Joshu’s Dog, paragraph number 9, sentence number 3 on page 128"^^xsd:string ;
    neo:text "If you say yes or no, You lose your own Buddha-nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2880 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1578,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2881 ;
    neo:id "fbab59c170a6e4f50eadb114d0582e99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 1, sentence number 1 on page 129"^^xsd:string ;
    neo:text "Once when Hyakujo delivered some Zen lectures an old man attended them, unseen by the monks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2882 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2883 ;
    neo:id "0cef3d9cfede2a5f74c93f8063b77f26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 1, sentence number 2 on page 129"^^xsd:string ;
    neo:text "At the end of each talk when the monks left so did he."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2884 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434 ;
    neo:id "e51754c9939b5b7f7a7012188d26e9e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 1, sentence number 3 on page 129"^^xsd:string ;
    neo:text "But one day he remained after they had gone, and Hyakujo asked him: “Who are you?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2885 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2886,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2887,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2888 ;
    neo:id "001522e05d71b36d78713cc33d2f3d99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 1 on page 129"^^xsd:string ;
    neo:text "The old man replied: “I am not a human being, but I was a human being when the Kashapa Buddha preached in this world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2889 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "ac869f99be7f2819b76fce408bfef68d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 2 on page 129"^^xsd:string ;
    neo:text "I was a Zen master and lived on this mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_289 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_290,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_291 ;
    neo:id "1b4755e9047a6db199803537d327ab4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 7, sentence number 3 on page 14"^^xsd:string ;
    neo:text "In return I have bought some wine and fish."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2890 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2892,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "fd4cdb333693e325e07cdcec19f19558"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 3 on page 129"^^xsd:string ;
    neo:text "At that time one of my students asked me whether or not the enlightened man is subject to the law of causation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2893 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2892,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2894,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2895 ;
    neo:id "1c1b803c92adbd143c1f42c437b2e3c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 4 on page 129"^^xsd:string ;
    neo:text "I answered him: ‘The enlightened man is not subject to the law of causation.’ For this answer evidencing a clinging to absoluteness I became a fox for five hundred rebirths, and I am still a fox."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2896 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2897,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2898,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2899 ;
    neo:id "9b555624695a281a2da3eaf6009d6af7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 5 on page 129"^^xsd:string ;
    neo:text "Will you save me from this condition with your Zen words and let me get out of a fox’s body?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2900 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2892 ;
    neo:id "56c24b1b1186b5cfa1aad286aced0d07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 2, sentence number 6 on page 129"^^xsd:string ;
    neo:text "Now may I ask you: Is the enlightened man subject to the law of causation?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2901 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2902,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_822 ;
    neo:id "89cd99349a339a26ca8d9ba07c9f9fbc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 3, sentence number 1 on page 129"^^xsd:string ;
    neo:text "Hyakujo said: “The enlightened man is one with the law of causation.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2903 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1578,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434 ;
    neo:id "927d3996cea4bd150aa89a7f8e301042"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 4, sentence number 1 on page 129"^^xsd:string ;
    neo:text "At the words of Hyakujo the old man was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2904 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "6b85e6eb1e72b32e25cf5ae21dda18d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 4, sentence number 2 on page 129"^^xsd:string ;
    neo:text "“I am emancipated,” he said, paying homage with a deep bow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2905 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2895,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2906,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "516090903e86e5860bcf3f81d4f84bcb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 4, sentence number 3 on page 129"^^xsd:string ;
    neo:text "“I am no more a fox, but I have to leave my body in my dwelling place behind this mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2907 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "f08f4d38d8083bb905dc52197689fa26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 4, sentence number 4 on page 129"^^xsd:string ;
    neo:text "Please perform my funeral as a monk.” Then he disappeared."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2908 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2909,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "75dfdc3cf19cd03afce984ad4cc5f288"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 5, sentence number 1 on page 129"^^xsd:string ;
    neo:text "The next day Hyakujo gave an order through the chief monk to prepare to attend the funeral of a monk."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2910 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2911 ;
    neo:id "84e917ab7640d9cb0b5ee286b18920c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 5, sentence number 2 on page 129"^^xsd:string ;
    neo:text "“No one was sick in the infirmary,” wondered the monks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2912 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "839bebfad3c2d9aea2dabd5bedd4f353"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 5, sentence number 3 on page 129"^^xsd:string ;
    neo:text "“What does our teacher mean?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2913 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "13d459ac0a0dbdccaae0028181aadee2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 6, sentence number 1 on page 129"^^xsd:string ;
    neo:text "After dinner Hyakujo led the monks out and around the mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2914 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2915,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2916,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2917,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "4e9d258c20995f4e24f9a67b0b3c9d50"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 6, sentence number 2 on page 129"^^xsd:string ;
    neo:text "In a cave, with his staff he poked out the corpse of an old fox and then performed the ceremony of cremation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2918 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2902,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_531 ;
    neo:id "ed0a8e463d350bd3ffdacbfbdd4e7104"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 7, sentence number 1 on page 129"^^xsd:string ;
    neo:text "That evening Hyakujo gave a talk to the monks and told them this story about the law of causation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2919 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2920,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2921 ;
    neo:id "6351bd4b1c803daff328527c88a890c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 8, sentence number 1 on page 129"^^xsd:string ;
    neo:text "Obaku, upon hearing the story, asked Hyakujo: “I understand that a long time ago because a certain person gave a wrong Zen answer he became a fox for five hundred rebirths."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_292 a neo:Document ;
    neo:id "da6cc1a27e78fa25102c0472116d46c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 7, sentence number 4 on page 14"^^xsd:string ;
    neo:text "You might as well have them.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2922 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2923 ;
    neo:id "b40f40e65658a7337642ea89eceb9158"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 8, sentence number 2 on page 129"^^xsd:string ;
    neo:text "Now I want to ask: If some modern master is asked many questions and he always gives the right answer, what will become of him?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2924 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2920,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2925 ;
    neo:id "3064cac84179b4048a0ae86ffc6c273d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 9, sentence number 1 on page 129"^^xsd:string ;
    neo:text "Hyakujo said: “You come here near me and I will tell you.” Obaku went near Hyakujo and slapped the teacher’s face with his hand, for he knew this was the answer his teacher intended to give him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2926 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434 ;
    neo:id "79399f0a366bdfdfd0267d57b5a06cdd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 10, sentence number 1 on page 130"^^xsd:string ;
    neo:text "Hyakujo clapped his hands and laughed at this discernment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2928 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2929 ;
    neo:id "16874c05d8c1e2b639ac72389fc99950"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 10, sentence number 2 on page 130"^^xsd:string ;
    neo:text "“I thought a Persian had a red beard,” he said, “and now I know a Persian who has a red beard.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_293 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "3beed59e609cc9db4d7a823ff39e404e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 8, sentence number 1 on page 14"^^xsd:string ;
    neo:text "The man was delighted."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2930 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2931,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2932,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2933 ;
    neo:id "a54e39ffe3bbb4ca39646162ddd964b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 11, sentence number 1 on page 130"^^xsd:string ;
    neo:text "Mumon’s comment: “The enlightened man is not subject.” How can this answer make the monk a fox?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2934 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2892,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2895 ;
    neo:id "cf49b5ea8f184793f8a4b04fd34f93bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 12, sentence number 1 on page 130"^^xsd:string ;
    neo:text "“The enlightened man is one with the law of causation.” How can this answer make the fox emancipated?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2935 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2936 ;
    neo:id "cc4fe3215e2303b859858dfa6aa6a4ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 13, sentence number 1 on page 130"^^xsd:string ;
    neo:text "To understand this clearly one has to have just one eye."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2937 a neo:Document ;
    neo:id "946dbe491d978cb2ecbe70f20f8f3c56"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 14, sentence number 1 on page 130"^^xsd:string ;
    neo:text "Controlled or not controlled?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2938 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2939,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2940 ;
    neo:id "1fa2b89db7d83b8aaf06d2e159c6f658"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 14, sentence number 2 on page 130"^^xsd:string ;
    neo:text "The same dice shows two faces."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_294 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_290,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_295 ;
    neo:id "a78a7aaecc9195a1af9b54aedca9ecec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 8, sentence number 2 on page 14"^^xsd:string ;
    neo:text "He drank the wine at once and laid himself down on the floor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2941 a neo:Document ;
    neo:id "982216a12ce6371baf02e8cdfc89f90c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Hyakujo’s Fox, paragraph number 14, sentence number 3 on page 130"^^xsd:string ;
    neo:text "Not controlled or controlled, Both are a grievous error."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2942 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "50923e98eff83b93da4f66b174e78725"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 1, sentence number 1 on page 131"^^xsd:string ;
    neo:text "Gutei raised his finger whenever he was asked a question about Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2944 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2945 ;
    neo:id "d8c130233a8e65a5f63daa85315c4eaa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 1, sentence number 2 on page 131"^^xsd:string ;
    neo:text "A boy attendant began to imitate him in this way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2946 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2947,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "e60523ddda1f01af64ce321f166c4edf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 1, sentence number 3 on page 131"^^xsd:string ;
    neo:text "When anyone asked the boy what his master had preached about, the boy would raise his finger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2948 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2949 ;
    neo:id "5421c4900cd07ad80203c53b1ec41e91"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 1 on page 131"^^xsd:string ;
    neo:text "Gutei heard about the boy’s mischief."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2950 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "15e477a5e27e2e6aa2bd694526af92e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 2 on page 131"^^xsd:string ;
    neo:text "He seized him and cut off his finger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2951 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2947 ;
    neo:id "cc3b0dfc08f3b2de0eda1d303be7f572"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 3 on page 131"^^xsd:string ;
    neo:text "The boy cried and ran away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2952 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943 ;
    neo:id "ac1518628654d5c411bf6f545ee2f13e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 4 on page 131"^^xsd:string ;
    neo:text "Gutei called and stopped him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2953 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2947 ;
    neo:id "3576f4c5758e9f556c9098ac6a98a534"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 5 on page 131"^^xsd:string ;
    neo:text "When the boy turned his head to Gutei, Gutei raised up his own finger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2954 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2947 ;
    neo:id "744f73a6d3d847a93fd2791e52c8bf8f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 2, sentence number 6 on page 131"^^xsd:string ;
    neo:text "In that instant the boy was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2955 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943 ;
    neo:id "f931a41a9d8232d86ef0b3a2c3e66167"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 3, sentence number 1 on page 131"^^xsd:string ;
    neo:text "When Gutei was about to pass from this world he gathered his monks around him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2956 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2958 ;
    neo:id "df52b4e6eb66cd0daa2c12f0e7a728fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 3, sentence number 2 on page 131"^^xsd:string ;
    neo:text "“I attained my finger-Zen,” he said, “from my teacher Tenryu, and in my whole life I could not exhaust it.” Then he passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2959 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32 ;
    neo:id "7af7c9eedf425c5897ca357cd4cc8c66"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 4, sentence number 1 on page 131"^^xsd:string ;
    neo:text "Mumon’s comment: Enlightenment, which Gutei and the boy attained, has nothing to do with a finger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_296 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "b3dbf7d467ac6be94150e23d6952bcf0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 8, sentence number 3 on page 14"^^xsd:string ;
    neo:text "Gudo sat in mediation beside him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2960 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2961 ;
    neo:id "820acd88a43ab52cdc180815322d6dae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 4, sentence number 2 on page 131"^^xsd:string ;
    neo:text "If anyone clings to a finger, Tenryu will be so disappointed that he will annihilate Gutei, the boy, and the clinger all together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2962 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2949,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2963,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2964 ;
    neo:id "72a35be5a39a6c813d62898fcb23fc1a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 5, sentence number 1 on page 131"^^xsd:string ;
    neo:text "Gutei cheapens the teaching of Tenryu, Emancipating the boy with a knife."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2965 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2966,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "37928221cb4b8d1d8929b4f5bae41120"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 5, sentence number 2 on page 131"^^xsd:string ;
    neo:text "Compared to the Chinese god who pushed aside a mountain with one"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2967 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2968 ;
    neo:id "380073d6aa160786cb87e365794cf3f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Gutei’s Finger, paragraph number 6, sentence number 1 on page 131"^^xsd:string ;
    neo:text "hand Old Gutei is a poor imitator."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2969 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2970,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_796 ;
    neo:id "3be25f457645bdf51129bfe4da046369"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 1, sentence number 1 on page 132"^^xsd:string ;
    neo:text "Wakuan complained when he saw a picture of bearded Bodhidharma: “Why hasn’t that fellow a beard?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_297 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_298,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_299 ;
    neo:id "5e516c60914f67229cbed142d6a10005"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 9, sentence number 1 on page 14"^^xsd:string ;
    neo:text "In the morning when the husband awoke he had forgotten about the previous night."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2971 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "3dd0fd4fab17b29b57a6913ad951b458"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 2, sentence number 1 on page 132"^^xsd:string ;
    neo:text "Mumon’s comment: If you want to study Zen, you must study it with your heart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2972 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422 ;
    neo:id "7ff2113910dcc9cbf18a30a0b9d7747b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 2, sentence number 2 on page 132"^^xsd:string ;
    neo:text "When you attain realization, it must be true realization."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2973 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "f4032d7da370fa2b235c9ece4071f691"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 2, sentence number 3 on page 132"^^xsd:string ;
    neo:text "You yourself must have the face of the great Bodhidharma to see him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2974 a neo:Document ;
    neo:id "9126ca47690ad570406d0e541c7c08fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 2, sentence number 4 on page 132"^^xsd:string ;
    neo:text "Just one such glimpse will be enough."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2975 a neo:Document ;
    neo:id "6a036960b1bf4c4d87eb882bdcf8bc39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 2, sentence number 5 on page 132"^^xsd:string ;
    neo:text "But if you say you met him, you never saw him at all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2976 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2816,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2977 ;
    neo:id "5d200cb8c02064a932f6d07e39e18dfd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 3, sentence number 1 on page 132"^^xsd:string ;
    neo:text "One should not discuss a dream In front of a simpleton."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2978 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "2bde1714a67e3bad457971a356b3a4d4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 3, sentence number 2 on page 132"^^xsd:string ;
    neo:text "Why has Bodhidharma no beard?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2979 a neo:Document ;
    neo:id "470fad9bca79bd2fa42581cd69f4553e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. A Beardless Foreigner, paragraph number 3, sentence number 3 on page 132"^^xsd:string ;
    neo:text "What an absurd question!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2980 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_436,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_895 ;
    neo:id "02903f590bf75a4efa79e3946f5f2450"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 1, sentence number 1 on page 133"^^xsd:string ;
    neo:text "Kyogen said: “Zen is like a man hanging in a tree by his teeth over a precipice."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2982 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2983,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "571d38849f812844dca74d8efad490b4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 1, sentence number 2 on page 133"^^xsd:string ;
    neo:text "His hands grasp no branch, his feet rest on no limb, and under the tree another person asks him: ‘Why did Bodhidharma come to China from India?’”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2984 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_436 ;
    neo:id "dce4e7cbe2c1de98a22863fbb068bb89"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 2, sentence number 1 on page 133"^^xsd:string ;
    neo:text "If the man in the tree does not answer, he fails; and if he does answer, he falls and loses his life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2985 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "f21e89965d1a739bd3239a02ef1a791d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 2, sentence number 2 on page 133"^^xsd:string ;
    neo:text "Now what shall he do?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2986 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2987,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2988 ;
    neo:id "abcdac54a735ecf1d166a937f8ebdae8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 3, sentence number 1 on page 133"^^xsd:string ;
    neo:text "Mumon’s comment: In such a predicament the most talented eloquence is of no use."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2989 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "8d796759d36ec3e6a61191fc07c5a64b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 3, sentence number 2 on page 133"^^xsd:string ;
    neo:text "If you have memorized all the sutras, you cannot use them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2990 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2991,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2992,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2993 ;
    neo:id "a15eff403578daaab430382de1b4b34a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 3, sentence number 3 on page 133"^^xsd:string ;
    neo:text "When you can give the right answer, even though your past road was one of death, you open up a new road of life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2994 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2995,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2996 ;
    neo:id "68db1f327693a9b2214aa58f0c85db2a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 3, sentence number 4 on page 133"^^xsd:string ;
    neo:text "But if you cannot answer, you should live ages hence and ask the future Buddha, Maitreya."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2997 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2998,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "482ceebdbc58112c670937c078fcd402"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Kyogen Mounts the Tree, paragraph number 4, sentence number 1 on page 133"^^xsd:string ;
    neo:text "Kyogen is truly a fool Spreading that ego-killing poison That closes his pupils’ mouths And lets their tears stream from their dead eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2999 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_182,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3000,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_379,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "e44cd7334446687818fee39f25c554c4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 1, sentence number 1 on page 134"^^xsd:string ;
    neo:text "When Buddha was in Grdhrakuta mountain he turned a flower in his fingers and held it before his listeners."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_300 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268 ;
    neo:id "cab92f0bdd8b65d3c6c06a8c5a45c39f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 57. The Gates of Paradise, paragraph number 2, sentence number 1 on page 78"^^xsd:string ;
    neo:text "‘Who are you?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3001 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "92077e262e130a4716fb3eeb431950bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 1, sentence number 2 on page 134"^^xsd:string ;
    neo:text "Every one was silent."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3002 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3004 ;
    neo:id "d756c76186b283db47aca559c1b44ef2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 1, sentence number 3 on page 134"^^xsd:string ;
    neo:text "Only Maha-Kashapa smiled at this revelation, although he tried to control the lines of his face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3005 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2145,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2820,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3006,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3007,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "a4acc2f9e60954d967661504f9c7cb99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 2, sentence number 1 on page 134"^^xsd:string ;
    neo:text "Buddha said: “I have the eye of the true teaching, the heart of Nirvana, the true aspect of non-form, and the ineffable stride of Dharma."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3008 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "e3334c233851bc4687676246cb2326ca"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 2, sentence number 2 on page 134"^^xsd:string ;
    neo:text "It is not expressed by words, but especially transmitted beyond teaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3009 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "162fb6fa92db827890680d3e73a67758"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 2, sentence number 3 on page 134"^^xsd:string ;
    neo:text "This teaching I have given to Maha-Kashapa.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_301 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "05f945bbe16238242f9d34adeb5e699c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 9, sentence number 3 on page 14"^^xsd:string ;
    neo:text "Where do yon come from?’ he asked Gudo, who still was meditating."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3010 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3011 ;
    neo:id "e1d5de042267f600aafc4c955e4d0f0b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 1 on page 134"^^xsd:string ;
    neo:text "Mumon’s comment: Golden-faced Gautama thought he could cheat anyone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3012 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3013,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3014,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_379 ;
    neo:id "80a1316f8e8566877842051aab76959f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 2 on page 134"^^xsd:string ;
    neo:text "He made the good listeners as bad, and sold dog meat under the sign of mutton."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3015 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "4b6dd8d8a13823053526d94555cfff3a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 3 on page 134"^^xsd:string ;
    neo:text "And he himself thought it was wonderful."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3016 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3017 ;
    neo:id "8cb38a61ef3ae1b8bb201c8ed93359db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 4 on page 134"^^xsd:string ;
    neo:text "What if all the audience had laughed together?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3018 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "f7da975e34f0283a2e7a2e9c7cb8fc44"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 5 on page 134"^^xsd:string ;
    neo:text "How could he have transmitted the teaching?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3019 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3020 ;
    neo:id "3e910795a7e8748237b4e281a309b97e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 6 on page 134"^^xsd:string ;
    neo:text "And again, if Maha-Kashapa had not smiled, how could he have transmitted the teaching?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_302 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_227,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_304,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_305 ;
    neo:id "318ea4d37fa43c3a230e17c01fdcc54d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 10, sentence number 1 on page 14"^^xsd:string ;
    neo:text "‘I am Gudo of Kyoto and I am going on to Edo,’ replied the Zen master. The man was utterly ashamed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3021 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3022,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3023 ;
    neo:id "f7fb0cb78115401533d3a5224b24a93e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 3, sentence number 7 on page 134"^^xsd:string ;
    neo:text "If he says that realization can be transmitted, he is like the city slicker that cheats the country dub, and if he says it cannot be transmitted, why does he approve of Maha-Kashapa?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3024 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_182,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3025 ;
    neo:id "46ac478129dcf180a8a1d9cf6781e363"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 4, sentence number 1 on page 134"^^xsd:string ;
    neo:text "At the turning of a flower His disguise was exposed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3026 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3003 ;
    neo:id "0b4b031375a4f43d1dcadb0add6ac046"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Buddha Twirls a Flower, paragraph number 4, sentence number 2 on page 134"^^xsd:string ;
    neo:text "No one in heaven or earth can surpass Maha-Kashapa’s wrinkled face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3027 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3028,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "6e04c9d0f6670008a037cb7c342ccce1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 1, sentence number 1 on page 135"^^xsd:string ;
    neo:text "A monk told Joshu: “I have just entered the monastery."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3029 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "001bde96a0cb747df567b6e70b23ae75"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 3, sentence number 4 on page 151"^^xsd:string ;
    neo:text "Please teach me.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3030 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3031,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "92329cad67f519e362a107f619352907"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 2, sentence number 1 on page 135"^^xsd:string ;
    neo:text "Joshu asked: “Have you eaten your rice porridge?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3032 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "5347e4e8c158409f9e653a265fd33494"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 3, sentence number 1 on page 135"^^xsd:string ;
    neo:text "The monk replied: “I have eaten.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3033 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "bcf9d592262f214bc7c56e2085d36843"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 4, sentence number 1 on page 135"^^xsd:string ;
    neo:text "Joshu said: “Then you had better wash your bowl.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3034 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "64f7b36a7e8cc27496178441edd12968"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 5, sentence number 1 on page 135"^^xsd:string ;
    neo:text "At that moment the monk was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3035 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "3c695cc1a86bf13953e1052036740f9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 6, sentence number 1 on page 135"^^xsd:string ;
    neo:text "Mumon’s comment: Joshu is the man who opens his mouth and shows his heart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3036 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "a20174edc3e6e255c9162c06c8589e7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 6, sentence number 2 on page 135"^^xsd:string ;
    neo:text "I doubt if this monk really saw Joshu’s heart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3037 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3038,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3039 ;
    neo:id "3fcf03eebc1d6d23482bf838ba0d0e24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 6, sentence number 3 on page 135"^^xsd:string ;
    neo:text "I hope he did not mistake the bell for a pitcher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3040 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3041 ;
    neo:id "125e4d3e667a7c8097fc919df736630c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 7, sentence number 1 on page 135"^^xsd:string ;
    neo:text "It is too clear and so it is hard to see."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3042 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2712,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3043 ;
    neo:id "06dc50968061e2bc0af0ddc80aad5fbf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 7, sentence number 2 on page 135"^^xsd:string ;
    neo:text "A dunce once searched for a fire with a lighted lantern."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3044 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2609 ;
    neo:id "1751fc0d40f777ab4351137a1cbcd30c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Joshu Washes the Bowl, paragraph number 7, sentence number 3 on page 135"^^xsd:string ;
    neo:text "Had he known what fire was, He could have cooked his rice much sooner."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3045 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3046,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3047 ;
    neo:id "6f75026e8811b91e3b16e63ce8fb33a3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 1, sentence number 1 on page 136"^^xsd:string ;
    neo:text "Getsuan said to his students: “Keichu, the first wheel-maker of China, made two wheels of fifty spokes each."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3048 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3049,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3050 ;
    neo:id "25ae2bca6ac97b78eb0a34f4fcca1a27"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 1, sentence number 2 on page 136"^^xsd:string ;
    neo:text "Now, suppose you removed the nave uniting the spokes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3051 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3052 ;
    neo:id "f7b0ea713be0a9ace44c3ad8250ddfb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 1, sentence number 3 on page 136"^^xsd:string ;
    neo:text "What would become of the wheel?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3053 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1219 ;
    neo:id "443f5e85bf3a40e250dd1ad62d9fdd61"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 1, sentence number 4 on page 136"^^xsd:string ;
    neo:text "And had Keichu done this, could he be called the master wheel-maker?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3054 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3055,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3056 ;
    neo:id "c7dcf178660bc4b9fb6ad14be787feed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 2, sentence number 1 on page 136"^^xsd:string ;
    neo:text "Mumon’s comment: If anyone can answer this question instantly, his eyes will be like a comet and his mind like a flash of lightning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3057 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3058,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "d74c8fd69ad250aa23f46f3faf9ab952"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 3, sentence number 1 on page 136"^^xsd:string ;
    neo:text "When the hubless wheel turns, Master or no master can stop it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3059 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1095,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3060,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3061,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3062 ;
    neo:id "9d2033249f3c860551e12bbcb28f6334"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Keichu’s Wheel, paragraph number 3, sentence number 2 on page 136"^^xsd:string ;
    neo:text "It turns above heaven and below earth, South, north, east, and west."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_306 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "32325d53ae2218d88b1cf372540ce23d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 11, sentence number 2 on page 15"^^xsd:string ;
    neo:text "He apologized profusely to the teacher of his emperor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3063 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2932,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3064,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3065 ;
    neo:id "8cd8cbcee91ac47830946fc6982a9eeb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 1, sentence number 1 on page 137"^^xsd:string ;
    neo:text "A monk asked Seijo: “I understand that a Buddha who lived before recorded history sat in meditation for ten cycles of existence and could not realize the highest truth, and so could not become fully emancipated."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3067 a neo:Document ;
    neo:id "4678b4e8ceb3058d60669a47e127eeca"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 1, sentence number 2 on page 137"^^xsd:string ;
    neo:text "Why was this so?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3068 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3064 ;
    neo:id "5623ef0d1457f40f777001906aecc3fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 2, sentence number 1 on page 137"^^xsd:string ;
    neo:text "Seijo replied: “Your question is self-explanatory.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3069 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "f96e049500d33f654ac7e8d3f4f20133"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 3, sentence number 1 on page 137"^^xsd:string ;
    neo:text "The monk asked: “Since the Buddha was meditating, why could he not fulfill Buddhahood?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3070 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3064,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "b5224d89ab7fc871e02e437f02c739da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 4, sentence number 1 on page 137"^^xsd:string ;
    neo:text "Seijo said: “He was not a Buddha.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3071 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830 ;
    neo:id "c6422ccc58c2d4a98a9787a754f79f1d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 5, sentence number 1 on page 137"^^xsd:string ;
    neo:text "Mumon’s comment: I will allow his realization, but I will not admit his understanding."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3072 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3073,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3074 ;
    neo:id "cea50b816221da8e9d870cf4515d6fdb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 5, sentence number 2 on page 137"^^xsd:string ;
    neo:text "When one ignorant attains realization he is a saint."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3075 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3074,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3076 ;
    neo:id "184445611e01bb6a052d9ac52ba221a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 5, sentence number 3 on page 137"^^xsd:string ;
    neo:text "When a saint begins to understand he is ignorant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3077 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "6e568930d68946b60f78a42c8f143d0c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 6, sentence number 1 on page 137"^^xsd:string ;
    neo:text "It is better to realize mind than body."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3078 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "069ef11325e9f51262ad89fcd799fff5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 6, sentence number 2 on page 137"^^xsd:string ;
    neo:text "When mind is realized one need not worry about body."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3079 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "8f32978a312fd171df35d82560226cc5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 6, sentence number 3 on page 137"^^xsd:string ;
    neo:text "When mind and body become one The man is free."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_308 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "c12448a84519e3d164ffb4cfa000f93d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 11, sentence number 1 on page 15"^^xsd:string ;
    neo:text "Gudo smiled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3081 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "fd3a2dc80646f52192a9d359a59ecf97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. A Buddha before History, paragraph number 6, sentence number 4 on page 137"^^xsd:string ;
    neo:text "Then he desires no praising."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3083 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3084 ;
    neo:id "194960f469950b0c317050b718f1e1ff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 1, sentence number 1 on page 138"^^xsd:string ;
    neo:text "A monk named Seizei asked of Sozan: “Seizei is alone and poor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3085 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3086 ;
    neo:id "f3de97e9b1b5a59dec145a576c8131f6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 1, sentence number 2 on page 138"^^xsd:string ;
    neo:text "Will you give him support?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3087 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3084 ;
    neo:id "529d51bfd65b67ffb3041e7639b36798"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 2, sentence number 1 on page 138"^^xsd:string ;
    neo:text "Sozan asked: “Seizei?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3088 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3084 ;
    neo:id "d7775359ad456c4478a258e43bc2157c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 3, sentence number 1 on page 138"^^xsd:string ;
    neo:text "Seizei responded: “Yes, sir.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3090 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c2139e5104f83971edc1564721826f0c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 4, sentence number 1 on page 138"^^xsd:string ;
    neo:text "Sozan said: “You have Zen, the best wine in China, and already have finished three cups, and still you are saying that they did not even wet your lips.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3091 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3084 ;
    neo:id "b6932e4dae2b85bcde2d5b3e0b73ba47"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 5, sentence number 1 on page 138"^^xsd:string ;
    neo:text "Mumon’s comment: Seizei overplayed his hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3092 a neo:Document ;
    neo:id "2bac0fe0ba84e9323c2a3e23df09a777"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 5, sentence number 2 on page 138"^^xsd:string ;
    neo:text "Why was it so?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3093 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2169 ;
    neo:id "da21257e5c41c699cd8c00e49dae7252"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 5, sentence number 3 on page 138"^^xsd:string ;
    neo:text "Because Sozan had eyes and knew with whom to deal."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3094 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_290,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3084 ;
    neo:id "0a5ef43fbe88c5bdd9078022966bc962"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 5, sentence number 4 on page 138"^^xsd:string ;
    neo:text "Even so, I want to ask: At what point did Seizei drink wine?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3095 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3096,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3097,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3098 ;
    neo:id "e81dbe1c37d848a9bfac609af8b61e3c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. Seizei Alone and Poor, paragraph number 6, sentence number 1 on page 138"^^xsd:string ;
    neo:text "The poorest man in China, The bravest man in China, He barely sustains himself, Yet wishes to rival the wealthiest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3099 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "6d48d94132390ae053229932e26bb7f6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 1, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Joshu went to a place where a monk had retired to meditate and asked him: “What is, is what?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_310 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a9020228edc7474d95b4ffe612ac7126"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 11, sentence number 2 on page 15"^^xsd:string ;
    neo:text "‘Everything in this life is impermanent’ he explained."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3100 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "04b7850c5736f022e632b726bc1e8848"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 2, sentence number 1 on page 139"^^xsd:string ;
    neo:text "The monk raised his fist."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3102 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "85b70529d70ca61b063f7c97fb45d500"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 3, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Joshu replied: “Ships cannot remain where the water is too shallow.” And he left."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3104 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "18047dac6ccf8b6f12719e45899b78b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 4, sentence number 1 on page 139"^^xsd:string ;
    neo:text "A few days later Joshu went again to visit the monk and asked the same question."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3105 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "122e33aee2979f5ae2a02c5dd3422ca4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 5, sentence number 1 on page 139"^^xsd:string ;
    neo:text "The monk answered the same way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3106 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2932,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "ac3554046d623df0a8bde327917acf37"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 6, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Joshu said: “Well given, well taken, well killed, well saved.” And he bowed to the monk."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3108 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3109,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3110 ;
    neo:id "59921f8057e840598d62eb91513cb797"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 7, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Mumon’s comment: The raised fist was the same both times."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3111 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3112,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "fc5b24a8f4811aedc471ff15983a9d31"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 7, sentence number 2 on page 139"^^xsd:string ;
    neo:text "Why is it Joshu did not admit the first and approved the second one?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3114 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3115 ;
    neo:id "36a93054f9cc35e0f4da3c592baa1600"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 7, sentence number 3 on page 139"^^xsd:string ;
    neo:text "Where is the fault?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3116 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3117,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "7290e7b4e49578d52f7f9607fbbe8f82"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 8, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Whoever answers this knows that Joshu’s tongue has no bone so he can use it freely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3119 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "8d7a2b0ee2b6c9bc925bc253c34ff83a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 8, sentence number 2 on page 139"^^xsd:string ;
    neo:text "Yet perhaps Joshu is wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_312 a neo:Document ;
    neo:id "e1bb800c90501333fea014a9baffb048"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 11, sentence number 3 on page 15"^^xsd:string ;
    neo:text "‘Life is very brief."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3120 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3121 ;
    neo:id "276992d00938cc7b6a251d6453d5ad86"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 8, sentence number 3 on page 139"^^xsd:string ;
    neo:text "Or, through that monk, he may have discovered his mistake."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3122 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_163,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "c1a284194000897bfdf674b738c8363f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 9, sentence number 1 on page 139"^^xsd:string ;
    neo:text "If anyone thinks that the one’s insight exceeds the other’s, he has no eyes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3123 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3055,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3056,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3124,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "31a176a5b9ed0cee9cc79a71d6c3bd94"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 10, sentence number 1 on page 139"^^xsd:string ;
    neo:text "The light of the eyes is as a comet, And Zen’s activity is as lightning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3125 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823 ;
    neo:id "2691c32de367268db7e255885452bcea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. Joshu Examines a Monk in Meditation, paragraph number 10, sentence number 2 on page 139"^^xsd:string ;
    neo:text "The sword that kills the man Is the sword that saves the man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3126 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3127 ;
    neo:id "e918a8c9366aed408ff0d43f1c76523c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 1, sentence number 1 on page 140"^^xsd:string ;
    neo:text "Zuigan called out to himself every day: “Master.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3128 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "c0e89624e9bb23ccd5aaefc4bdb5b1b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 2, sentence number 1 on page 140"^^xsd:string ;
    neo:text "Then he answered himself: “Yes, sir.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3129 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "00d85b43c4a0ebf4fb6938f211f0c5db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 3, sentence number 1 on page 140"^^xsd:string ;
    neo:text "And after that he added: “Become sober.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_313 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_314,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_315,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316 ;
    neo:id "0c53b1b7e156213a5490e980e98a1a0f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 11, sentence number 4 on page 15"^^xsd:string ;
    neo:text "If you keep on gambling and drinking yon will have no time left to accomplish anything else, and you will cause your family to suffer too.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3131 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "a160d053f5ae68bc0ed484a729d6f542"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 4, sentence number 1 on page 140"^^xsd:string ;
    neo:text "Again he answered: “Yes, sir.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3132 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "da5743380a01287c669732b35484ccfd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 5, sentence number 1 on page 140"^^xsd:string ;
    neo:text "“And after that,” he continued, “do not be deceived by others.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3133 a neo:Document ;
    neo:id "18e1d63975421b25f7d18402c0e0b76c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 6, sentence number 1 on page 140"^^xsd:string ;
    neo:text "“Yes, sir; yes, sir,” he answered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3134 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3127 ;
    neo:id "2412b2f86017100032802982b5b78cff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 7, sentence number 1 on page 140"^^xsd:string ;
    neo:text "Mumon’s comment: Old Zuigan sells out and buys himself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3135 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3136 ;
    neo:id "43d9b78b1c81e689479925a2b093fa41"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 7, sentence number 2 on page 140"^^xsd:string ;
    neo:text "He is opening a puppet show."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3137 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3138,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "e575d0b35be22b61e068274280fd74c9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 7, sentence number 3 on page 140"^^xsd:string ;
    neo:text "He uses one mask to call “Master” and another that answers the master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3140 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2895,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3141 ;
    neo:id "ddcbcc131e880eb7e1fe1c1a70a2e36d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 7, sentence number 4 on page 140"^^xsd:string ;
    neo:text "Another mask says “Sober up” and another, “Do not be cheated by others.” If anyone clings to any of his masks, he is mistaken, yet if he imitates Zuigan, he will make himself fox-like."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3142 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3141,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3143,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3144,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_374 ;
    neo:id "fb898743734bba6b90f9ff96279dfa63"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 8, sentence number 1 on page 140"^^xsd:string ;
    neo:text "Some Zen students do not realize the true man in a mask Because they recognize ego-soul."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3145 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3143,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3144,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3146,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3147 ;
    neo:id "50c9984e7bad0ec15628026705b1c7b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Zuigan Calls His Own Master, paragraph number 8, sentence number 2 on page 140"^^xsd:string ;
    neo:text "Ego-soul is the seed of birth and death, And foolish people call it the true man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3148 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3150,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_548 ;
    neo:id "7e6a897a30a6f3205545581dd14035c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 1, sentence number 1 on page 141"^^xsd:string ;
    neo:text "Tokusan went to the dining room from the meditation hall holding his bowl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3151 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3152 ;
    neo:id "8cf38c4182712dc9d60c120b39675c53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 1, sentence number 2 on page 141"^^xsd:string ;
    neo:text "Seppo was on duty cooking."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3154 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "e3bb985f11bd525b738dde32c92fd8b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 1, sentence number 3 on page 141"^^xsd:string ;
    neo:text "When he met Tokusan he said: “The dinner drum is not yet beaten."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3155 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176 ;
    neo:id "466bafbfde7c992b4f7873ce37b3853c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 1, sentence number 4 on page 141"^^xsd:string ;
    neo:text "Where are you going with your bowl?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3156 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3157 ;
    neo:id "e221f47e0f63deac57fe682518becd30"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 2, sentence number 1 on page 141"^^xsd:string ;
    neo:text "So Tokusan returned to his room."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3158 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3152,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159 ;
    neo:id "84bd439d0b60179c0effd8761af3ca39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 3, sentence number 1 on page 141"^^xsd:string ;
    neo:text "Seppo told Ganto about this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3160 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159 ;
    neo:id "3e02f04afe319e3b34afc625d61fbfd6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 3, sentence number 2 on page 141"^^xsd:string ;
    neo:text "Ganto said: “Old Tokusan did not understand ultimate truth.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3162 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159 ;
    neo:id "0a00cb4b21c8f4ea558b671475757ab0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 4, sentence number 1 on page 141"^^xsd:string ;
    neo:text "Tokusan heard of this remark and asked Ganto to come to him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3163 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "3e1497225ef00c71c336549e7e061861"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 4, sentence number 2 on page 141"^^xsd:string ;
    neo:text "“I have heard,” he said, “you are not approving my Zen.” Ganto admitted this indirectly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3164 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "da2bcec0458cf1c837554780613294f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 4, sentence number 3 on page 141"^^xsd:string ;
    neo:text "Tokusan said nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3165 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "565e55aae38271ca001b0ac320227a56"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 5, sentence number 1 on page 141"^^xsd:string ;
    neo:text "The next day Tokusan delivered an entirely different kind of lecture to the monks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3166 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1578,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159 ;
    neo:id "f3e6600df24b24013ef682e27b88c78e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 5, sentence number 2 on page 141"^^xsd:string ;
    neo:text "Ganto laughed and clapped his hands, saying: “I see our old man understands ultimate truth indeed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3167 a neo:Document ;
    neo:id "79c4ab9e3cb611164a04fea86b119f6a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 5, sentence number 3 on page 141"^^xsd:string ;
    neo:text "None in China can surpass him.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3168 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3161 ;
    neo:id "46aef1d17b1da988f6c5f15b10449684"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 6, sentence number 1 on page 141"^^xsd:string ;
    neo:text "Mumon’s comment: Speaking about ultimate truth, both Ganto and Tokusan did not even dream it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3169 a neo:Document ;
    neo:id "beaf4b9442f34c4d68f45645e379a660"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 6, sentence number 2 on page 141"^^xsd:string ;
    neo:text "After all, they are dummies."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_317 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_257 ;
    neo:id "644ea087e7545e3e434eff6401154d5c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 12, sentence number 1 on page 15"^^xsd:string ;
    neo:text "The perception of the husband awoke as if from a dream."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3170 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3171 ;
    neo:id "0f08c6bcc594b08314b851ac72169484"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 7, sentence number 1 on page 141"^^xsd:string ;
    neo:text "Whoever understands the first truth Should understand the ultimate truth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3172 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3173,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3174 ;
    neo:id "773c4bde99e51a3b1689b1100eb97d84"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. Tokusan Holds His Bowl, paragraph number 7, sentence number 2 on page 141"^^xsd:string ;
    neo:text "The last and first, Are they not the same?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3175 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3177,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3178,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3179 ;
    neo:id "50de27fb456877be5c2683b8e843bfd0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 1, sentence number 1 on page 142"^^xsd:string ;
    neo:text "Nansen saw the monks of the eastern and western halls fighting over a cat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_318 a neo:Document ;
    neo:id "326025e3f056752e873eb7d1812055e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 12, sentence number 2 on page 15"^^xsd:string ;
    neo:text "‘You are right,’ he declared."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3180 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3179 ;
    neo:id "099b94b4b6f72076e5a804757f2b8113"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 1, sentence number 2 on page 142"^^xsd:string ;
    neo:text "He seized the cat and told the monks: “If any of you say a good word, you can save the cat.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3181 a neo:Document ;
    neo:id "6702068711534540a21953210e824bb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 2, sentence number 1 on page 142"^^xsd:string ;
    neo:text "No one answered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3182 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3179 ;
    neo:id "9aaaaf1370a731eee83653d013c54a64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 2, sentence number 2 on page 142"^^xsd:string ;
    neo:text "So Nansen boldly cut the cat in two pieces."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3183 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "959a580c353557803e3d425c013f2a81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 3, sentence number 1 on page 142"^^xsd:string ;
    neo:text "That evening Joshu returned and Nansen told him about this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3184 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "ee8534a0516bb7a9dfe502a11ce12ea7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 3, sentence number 2 on page 142"^^xsd:string ;
    neo:text "Joshu removed his sandals and, placing them on his head, walked out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3185 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3179 ;
    neo:id "057b705bf5a5edb9354063a0c2369068"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 4, sentence number 1 on page 142"^^xsd:string ;
    neo:text "Nansen said: “If you had been there, you could have saved the cat.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3186 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "a7c70ade15d0a438486eee86fbe49285"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 5, sentence number 1 on page 142"^^xsd:string ;
    neo:text "Mumon’s comment: Why did Joshu put his sandals on his head?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3187 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3188 ;
    neo:id "97ed9d3f7c4ece0ab96ef502711bf50c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 5, sentence number 2 on page 142"^^xsd:string ;
    neo:text "If anyone answers this question, he will understand exactly how Nansen enforced the edict."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3189 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "749de17b6fdf5f3846c318f9c2b0a041"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 5, sentence number 3 on page 142"^^xsd:string ;
    neo:text "If not, he should watch his own head."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_319 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "28996919fa7c9325d0be3e0a903cdaf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 12, sentence number 3 on page 15"^^xsd:string ;
    neo:text "‘How can I ever repay you for this wonderful teaching!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3190 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3191,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "357fa4e529db70d4c85d147a4f20dd3c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 6, sentence number 1 on page 142"^^xsd:string ;
    neo:text "Had Joshu been there, He would have enforced the edict oppositely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3192 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "f48fdc61274650fbe6595688449657d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Nansen Cuts the Cat in Two, paragraph number 6, sentence number 2 on page 142"^^xsd:string ;
    neo:text "Joshu snatches the sword And Nansen begs for his life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3193 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "d51aa1645c042a2171e7105311ed70c9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 1, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Tozan went to Ummon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3196 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "d6747c69ad6dd7a0e271bb987a69dc9d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 1, sentence number 2 on page 143"^^xsd:string ;
    neo:text "Ummon asked him where he had come from."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3197 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3198 ;
    neo:id "fb797a9eac11ab156c0141a7f0363529"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 2, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Tozan said: “From Sato village.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3199 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "67aa035854b829ac3d67f5372e6c6c63"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 3, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Ummon asked: “In what temple did you remain for the summer?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3200 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3201,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3202 ;
    neo:id "29e04beb56abc2ce39bd663def5c1c9f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 4, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Tozan replied: “The temple of Hoji, south of the lake.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3203 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "13c79d7f06ac0fc6bf7e054aa7ea3e68"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 5, sentence number 1 on page 143"^^xsd:string ;
    neo:text "“When did you leave there?” asked Ummon, wondering how long Tozan would continue with such factual answers."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3204 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3205 ;
    neo:id "430ec2dd7742f713c97b31ff2d151ce0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 6, sentence number 1 on page 143"^^xsd:string ;
    neo:text "“The twenty-fifth of August,” answered Tozan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3206 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "9d777c0863b5c67d3adbd08422a7e318"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 7, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Ummon said: “I should give you three blows with a stick, but today I forgive you.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3207 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "3375e67fd17a4dc1c9d7fc0521e010b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 8, sentence number 1 on page 143"^^xsd:string ;
    neo:text "The next day Tozan bowed to Ummon and asked: “Yesterday you forgave me three blows."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3208 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "e8b80667fc327b10455d5ad212448fea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 8, sentence number 2 on page 143"^^xsd:string ;
    neo:text "I do not know why you thought me wrong.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3209 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "2cb66a2258230638e6878860b4609e81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 9, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Ummon, rebuking Tozan’s spiritless responses, said: “You are good for nothing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_321 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_322 ;
    neo:id "ad5e164235536ff4865d2ac922467f61"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 12, sentence number 4 on page 15"^^xsd:string ;
    neo:text "Let me see you off and carry your things a little way.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3210 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3028 ;
    neo:id "ae492d293d0c519e69e85f03f9ff679c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 9, sentence number 2 on page 143"^^xsd:string ;
    neo:text "You simply wander from one monastery to another.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3211 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "7f028d5ea1543da385ca4ef4ca59f508"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 10, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Before Ummon’s words were ended Tozan was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3212 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3213 ;
    neo:id "35a2036d64266d6748ccbe7a3b538141"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 11, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Mumon’s comment: Ummon fed Tozan good Zen food."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3214 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "f204ebec8874b8a4d249948efafb5e4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 11, sentence number 2 on page 143"^^xsd:string ;
    neo:text "If Tozan can digest it, Ummon may add another member to his family."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3215 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3216,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_496 ;
    neo:id "815543815f8c561d5e432a596a790c02"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 12, sentence number 1 on page 143"^^xsd:string ;
    neo:text "In the evening Tozan swam around in a sea of good and bad, but at dawn Ummon crushed his nut shell."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3217 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "938354424ae5b97ee8f9556f9be6f147"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 12, sentence number 2 on page 143"^^xsd:string ;
    neo:text "After all, he wasn’t so smart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3218 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194 ;
    neo:id "a149abf5914d71dc733bbb7acf5fa6ef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 13, sentence number 1 on page 143"^^xsd:string ;
    neo:text "Now, I want to ask: Did Tozan deserve the three blows?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3220 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194 ;
    neo:id "1ee133fbb63914d1a8c1eb0dee1a99f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 13, sentence number 2 on page 143"^^xsd:string ;
    neo:text "If you say yes, not only Tozan but every one of you deserves them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3221 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3222 ;
    neo:id "83a55525c11f01dcf26d1b30668ea44c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 13, sentence number 3 on page 143"^^xsd:string ;
    neo:text "If you say no, Ummon is speaking a lie."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3223 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194 ;
    neo:id "f1e9a1f2691c1a1bf63b4c1de54c1e1b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 13, sentence number 4 on page 143"^^xsd:string ;
    neo:text "If you answer this question clearly, you can eat the same food as Tozan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3224 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3225,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3226 ;
    neo:id "54ae90040b5b70025dad2b3c99995426"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 14, sentence number 1 on page 143"^^xsd:string ;
    neo:text "The lioness teaches her cubs roughly; The cubs jump and she knocks them down."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3227 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "70a286a835bc3c036a6fe43e61cd1c5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Tozan’s Three Blows, paragraph number 14, sentence number 2 on page 143"^^xsd:string ;
    neo:text "When Ummon saw Tozan his first arrow was light; His second arrow shot deep."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_323 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "2eb981b81a1d98e77f5b07a33f3f0e36"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 13, sentence number 1 on page 15"^^xsd:string ;
    neo:text "‘If you wish,’ assented Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3230 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3038,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3231,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3232 ;
    neo:id "7f32e6246d634103dba9d35df05b2a05"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 1, sentence number 1 on page 144"^^xsd:string ;
    neo:text "Ummon asked: “The world is such a wide world, why do you answer a bell and don ceremonial robes?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3233 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "f320ea62cac55f4262a0517ff2ff489c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 2, sentence number 1 on page 144"^^xsd:string ;
    neo:text "Mumon’s comment: When one studies Zen one need not follow sound or color or form."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3234 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1181,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_163,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2681,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3235 ;
    neo:id "9b1631bf411eda55db1b6b713d2e3aef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 2, sentence number 2 on page 144"^^xsd:string ;
    neo:text "Even though some have attained insight when hearing a voice or seeing a color or a form, this is a very common way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3236 a neo:Document ;
    neo:id "120a61090cbe81553569ff9c6b5e6be1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 2, sentence number 3 on page 144"^^xsd:string ;
    neo:text "It is not true Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3237 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2681,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "347a1ce4fd198b2d37a42e05683e2e36"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 2, sentence number 4 on page 144"^^xsd:string ;
    neo:text "The real Zen student controls sound, color, form, and actualizes the truth in his everyday life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3238 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "5941e1b156e1fa0cb718e736610ca420"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 3, sentence number 1 on page 144"^^xsd:string ;
    neo:text "Sound comes to the ear, the ear goes to sound."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_324 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_325,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_326 ;
    neo:id "9d3143a6c49536d00f9d1e6479481eeb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 13, sentence number 2 on page 15"^^xsd:string ;
    neo:text "The two started out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3240 a neo:Document ;
    neo:id "98f06ebb6fe09253a55f75b171e81913"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 3, sentence number 2 on page 144"^^xsd:string ;
    neo:text "When you blot out sound and sense, what do you understand?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3241 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3242 ;
    neo:id "5a4281667a12c0ae2dd409377dff3dd7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 3, sentence number 3 on page 144"^^xsd:string ;
    neo:text "While listening with ears one never can understand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3243 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "996f1f5d3191adb62546ed890c032a50"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 3, sentence number 4 on page 144"^^xsd:string ;
    neo:text "To understand intimately one should see sound."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3244 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316 ;
    neo:id "fd1f457423a92e5be37631094359bac2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 4, sentence number 1 on page 144"^^xsd:string ;
    neo:text "When you understand, you belong to the family; When you do not understand, you are a stranger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3245 a neo:__Entity__ ;
    neo:IS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160 ;
    neo:id "Lack_Of_Understanding"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3246 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_316,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3247,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3249 ;
    neo:id "4540abb46192796c188da4e8df9babd5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Bells and Robes, paragraph number 4, sentence number 2 on page 144"^^xsd:string ;
    neo:text "Those who do not understand belong to the family, And when they understand they are strangers."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3250 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_222,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3252,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253 ;
    neo:id "d7103e608c0e382bd16df8ca697f6a21"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 1, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Chu, called Kokushi, the teacher of the emperor, called to his attendant: “Oshin.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3254 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253 ;
    neo:id "e871322341df745c4850384b849e3e21"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 6, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Oshin answered: “Yes.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3256 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "038c16b3c94b237424b201e9ccd56ee6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 3, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Chu repeated, to test his pupil: “Oshin.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3257 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253 ;
    neo:id "83fc3c6167f616fc641d26ab327c71dc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 4, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Oshin repeated: “Yes.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3258 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253 ;
    neo:id "cf5f36f8a95bf6b317418c0e152db3dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 5, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Chu called: “Oshin.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3259 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251 ;
    neo:id "2522dce8703d0f0aec4d95ef7d8c71ea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 7, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Chu said: “I ought to apologize to you for all this calling, but really you ought to apologize to me.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3260 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253 ;
    neo:id "70b76ca0f0dbb2b66cf1984ae7ec2304"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 8, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Mumon’s comment: When old Chu called Oshin three times his tongue was rotting, but when Oshin answered three times his words were brilliant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3261 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3251,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3262,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3263 ;
    neo:id "4a48d64c0246b063aee9e4559c751316"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 8, sentence number 2 on page 145"^^xsd:string ;
    neo:text "Chu was getting decrepit and lonesome, and his method of teaching was like holding a cow’s head to feed it clover."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3264 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c0b6d6eca548b8b8dcc95cdda175c52a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 9, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Oshin did not trouble to show his Zen either."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3265 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1556,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3266 ;
    neo:id "a088561918a03747273b939417cabf16"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 9, sentence number 2 on page 145"^^xsd:string ;
    neo:text "His satisfied stomach had no desire to feast."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3267 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "346fcb15f887a9f6c1db9125439fab22"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 9, sentence number 3 on page 145"^^xsd:string ;
    neo:text "When the country is prosperous everyone is indolent; when the home is wealthy the children are spoiled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3268 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "b40b5901d24c65404f9b09b1a2bac632"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 10, sentence number 1 on page 145"^^xsd:string ;
    neo:text "Now I want to ask you: Which one should apologize?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3269 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3270,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3271 ;
    neo:id "5a93a7a42a5b5243366cb6fdf2215ee6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 11, sentence number 1 on page 145"^^xsd:string ;
    neo:text "When prison stocks are iron and have no place for the head, the"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_327 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "85b192bd4d97553be2a04f5cd433ec4e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 13, sentence number 3 on page 15"^^xsd:string ;
    neo:text "After they had gone three miles Gudo told him to return."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3272 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3273,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3274 ;
    neo:id "defd6bbf4c9685f1d6de6c7237a718f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 12, sentence number 1 on page 145"^^xsd:string ;
    neo:text "prisoner is doubly in trouble."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3275 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "5e21304c8ff709c16b6dc69b7a06eaf0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 12, sentence number 2 on page 145"^^xsd:string ;
    neo:text "When there is no place for Zen in the head of our generation, it is in"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3276 a neo:Document ;
    neo:id "8c6c654711dd8ee08e8f882fd7c75944"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 13, sentence number 1 on page 145"^^xsd:string ;
    neo:text "grievous trouble."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3277 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_280,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3278,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_973 ;
    neo:id "feed954a26e41e796de4d5c03617e3fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. The Three Calls of the Emperor’s Teacher, paragraph number 13, sentence number 2 on page 145"^^xsd:string ;
    neo:text "If you try to hold up the gate and door of a falling house, You also will be in trouble."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3279 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3280,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "dcf5df8387af279bb48c67ab176694b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 1, sentence number 1 on page 146"^^xsd:string ;
    neo:text "A monk asked Tozan when he was weighing some flax: “What is Buddha?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_328 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "c0c0c475f28bd9424bc8f297b43a3c17"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 13, sentence number 4 on page 15"^^xsd:string ;
    neo:text "‘Just another five miles,’ he begged Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3281 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3280 ;
    neo:id "f2485ac77f0384e89871610d342c8925"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 2, sentence number 1 on page 146"^^xsd:string ;
    neo:text "Tozan said: “This flax weighs three pounds.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3283 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "a120b1956701a4c7c6400ee2c29094fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 3, sentence number 1 on page 146"^^xsd:string ;
    neo:text "Mumon’s comment: Old Tozan’s Zen is like a clam."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3285 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3286,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3287 ;
    neo:id "12528b5e03bba41e43e4dbb8c429af43"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 3, sentence number 2 on page 146"^^xsd:string ;
    neo:text "The minute the shell opens you see the whole inside."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3288 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3194 ;
    neo:id "bdd6890e442252dd0b63570a8b109771"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 3, sentence number 3 on page 146"^^xsd:string ;
    neo:text "However, I want to ask you: Do you see the real Tozan?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3289 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1660,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3280 ;
    neo:id "99c07eaa4a83e3b1b092af5042ce78f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 4, sentence number 1 on page 146"^^xsd:string ;
    neo:text "Three pounds of flax in front of your nose, Close enough, and mind is still closer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_329 a neo:Document ;
    neo:id "0dd4e4767af44b598ec55e6e6bfea06a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 13, sentence number 5 on page 15"^^xsd:string ;
    neo:text "They continued on."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3290 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2824,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_407 ;
    neo:id "57e0eaec48aca03a20d9e49f6a880bf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. Tozan’s Three Pounds, paragraph number 4, sentence number 2 on page 146"^^xsd:string ;
    neo:text "Whoever talks about affirmation and negation Lives in the right and wrong region."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3294 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "2b4796ff8c243288786836554619129b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 1, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Joshu asked Nansen: “What is the path?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3295 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1854,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3296 ;
    neo:id "9d8cae31e14677e4416ea7fbba6384a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 2, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Nansen said: “Everyday life is the path.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3297 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "90f465bb63b21651b0e93b44ab45811d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 3, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Joshu asked: “Can it be studied?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3298 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176 ;
    neo:id "f48ef9bcc703bf2215a66b9d71ad3ec6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 4, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Nansen said: “If you try to study, you will be far away from it.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3299 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1128,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3300,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "7663b4f325d61f909fad1483b900e2e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 5, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Joshu asked: “If I do not study, how can I know it is the path?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_330 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221 ;
    neo:id "8f42ee6eb534511c1d72e42f0607283a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 14, sentence number 1 on page 15"^^xsd:string ;
    neo:text "You may return now,’ suggested Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3301 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1854,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3302,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3303 ;
    neo:id "64de2d59a25259999cffe48faa781e8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 6, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Nansen said: “The path does not belong to the perception world, neither does it belong to the nonperception world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3304 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1852,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3305,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3306,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3307 ;
    neo:id "3c284d72f9e76b0afa2ec331a40dc711"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 6, sentence number 2 on page 147"^^xsd:string ;
    neo:text "Cognition is a delusion and noncognition is senseless."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3308 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_170,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3080,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3309,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3310 ;
    neo:id "f3b03844a6876d85d1d83956cd5ddf1a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 6, sentence number 3 on page 147"^^xsd:string ;
    neo:text "If you want to reach the true path beyond doubt, place yourself in the same freedom as sky."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_331 a neo:Document ;
    neo:id "3e8dfa2aa9b845eed71a171d2f579891"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 15, sentence number 1 on page 15"^^xsd:string ;
    neo:text "‘After another ten miles,’ the man replied."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3311 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3312,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3313,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3314,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "94bd90a031117e965be4657f5cb14dbf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 6, sentence number 4 on page 147"^^xsd:string ;
    neo:text "You name it neither good nor not-good.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3315 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "22839fe8a6f577b11714ef09f1a13e43"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 7, sentence number 1 on page 147"^^xsd:string ;
    neo:text "At these words Joshu was enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3316 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "42f5cd2b6c5a7bbbc63c785725345fcb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 8, sentence number 1 on page 147"^^xsd:string ;
    neo:text "Mumon’s comment: Nansen could melt Joshu’s frozen doubts at once when Joshu asked his questions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3317 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "9b7a5bd0ad120742c2b3b0aaf327c830"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 8, sentence number 2 on page 147"^^xsd:string ;
    neo:text "I doubt though if Joshu reached the point that Nansen did."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3318 a neo:Document ;
    neo:id "dbe97b41cf2f5c8bac42eb8e23259aa9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 8, sentence number 3 on page 147"^^xsd:string ;
    neo:text "He needed thirty more years of study."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3319 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1707,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3321,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3322,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3323,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_438,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_543 ;
    neo:id "f243b8939a31fe72d629fccc8771c567"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 9, sentence number 1 on page 147"^^xsd:string ;
    neo:text "In spring, hundreds of flowers; in autumn, a harvest moon; In summer, a refreshing breeze; in winter, snow will accompany you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_332 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_333 ;
    neo:id "58223b8e4f0a2993ef14593b888b5a31"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 16, sentence number 1 on page 15"^^xsd:string ;
    neo:text "‘Return now,’ said Gudo, when the ten miles had been passed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3324 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2862,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_322 ;
    neo:id "d7b0c70c51e0530c73eaca8206d4a03f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. Everyday Life Is the Path, paragraph number 9, sentence number 2 on page 147"^^xsd:string ;
    neo:text "If useless things do not hang in your mind, Any season is a good season for you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3325 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3326,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_822 ;
    neo:id "01b68aa18b8807e064e4466ff66df71c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 1, sentence number 1 on page 148"^^xsd:string ;
    neo:text "Shogen asked: “Why does the enlightened man not stand on his feet and explain himself?” And he also said: “It is not necessary for speech to come from the tongue.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3327 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3326 ;
    neo:id "b47287dcdbb2aa1369513464654f43bc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 2, sentence number 1 on page 148"^^xsd:string ;
    neo:text "Mumon’s comment: Shogen spoke plainly enough, but how many will understand?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3328 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "e64d0746cc31977b73a683ee63214952"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 2, sentence number 2 on page 148"^^xsd:string ;
    neo:text "If anyone comprehends, he should come to my place and test out my big stick."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3329 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1092,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1349,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266 ;
    neo:id "0863b85ee358eeed1e980cd3195d38b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 2, sentence number 3 on page 148"^^xsd:string ;
    neo:text "Why, look here, to test real gold you must see it through fire."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3330 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3331,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3332,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3333 ;
    neo:id "da45025f5b0f668078a14476adbcb5c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 3, sentence number 1 on page 148"^^xsd:string ;
    neo:text "If the feet of enlightenment moved, the great ocean would overflow; If that head bowed, it would look down upon the heavens."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3334 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "a120e3429ec335441233a7b0707f1fe0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. The Enlightened Man, paragraph number 3, sentence number 2 on page 148"^^xsd:string ;
    neo:text "Such a body has no place to rest… Let another continue this poem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3335 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "a015fd3fc43b34aeb1bb4691582d696d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 1, sentence number 1 on page 149"^^xsd:string ;
    neo:text "A monk asked Ummon: “What is Buddha?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3336 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_69 ;
    neo:id "7bd9c8b8b1a5730c21e802659c119770"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 2, sentence number 1 on page 149"^^xsd:string ;
    neo:text "Ummon answered him: “Dried dung.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3338 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "ae56affb984aed8581e69ae4715dff41"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 3, sentence number 1 on page 149"^^xsd:string ;
    neo:text "Mumon’s comment: It seems to me Ummon is so poor he cannot distinguish the taste of one food from another, or else he is too busy to write readable letters."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3339 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1751,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3337 ;
    neo:id "fe4190b292f776bfca31cd7b4c5e8a97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 3, sentence number 2 on page 149"^^xsd:string ;
    neo:text "Well, he tried to hold his school with dried dung."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_334 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "1d9741e33c0477c253519b772e13a3a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 17, sentence number 1 on page 15"^^xsd:string ;
    neo:text "‘I am going to follow you all the rest of my life,’ declared the man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3340 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_378 ;
    neo:id "bacb17791645f21e2602220775ec9916"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 3, sentence number 3 on page 149"^^xsd:string ;
    neo:text "And his teaching was just as useless."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3341 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3056,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3342 ;
    neo:id "1772c3017da8b2cd4b3bdf727dad17f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 4, sentence number 1 on page 149"^^xsd:string ;
    neo:text "Lightning flashes, Sparks shower."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3343 a neo:Document ;
    neo:id "edfbc3c385297434293c19fff1b556c4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. Dried Dung, paragraph number 4, sentence number 2 on page 149"^^xsd:string ;
    neo:text "In one blink of your eyes You have missed seeing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3344 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3345,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3346,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "edcf7d8e53faee0ee06f27d8664c3df6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 1, sentence number 1 on page 150"^^xsd:string ;
    neo:text "Ananda asked Kashapa: “Buddha gave you the golden-woven robe of successorship."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3347 a neo:Document ;
    neo:id "f50a93c12ce1f649f69240c7a4420a8f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 1, sentence number 2 on page 150"^^xsd:string ;
    neo:text "What else did he give you?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3348 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3345,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66 ;
    neo:id "890ae8f5fa7396ccda74bf149b2cc779"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 2, sentence number 1 on page 150"^^xsd:string ;
    neo:text "Kashapa said: “Ananda.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3349 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66 ;
    neo:id "9d6fe4b5df85498f7cfa3fa92e3844cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 3, sentence number 1 on page 150"^^xsd:string ;
    neo:text "Ananda answered: “Yes, brother.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_335 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_336 ;
    neo:id "0f45dafa39d41306e0eb36500e85c460"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 18, sentence number 1 on page 15"^^xsd:string ;
    neo:text "Modern Zen teachers in Japan spring from the lineage of a famous master who was the successor of Gudo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3350 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3351,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3352 ;
    neo:id "4a81d41148c339be3b552ba31e6fe408"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 4, sentence number 1 on page 150"^^xsd:string ;
    neo:text "Said Kashapa: “Now you can take down my preaching sign and put up your own.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3353 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3354,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3355 ;
    neo:id "c8ae2b59a1877ec9cc5c3795e333d664"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 5, sentence number 1 on page 150"^^xsd:string ;
    neo:text "Mumon’s comment: If one understands this, he will see the old brotherhood still gathering, but if not, even though he has studied the truth from ages before the Buddhas, he will not attain enlightenment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3356 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3357,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_69 ;
    neo:id "b8c420f7bf2e2396d978d2f8d80d3748"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 6, sentence number 1 on page 150"^^xsd:string ;
    neo:text "The point of the question is dull but the answer is intimate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3358 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2021,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "aec51f00e63842458c0db349279e5ff5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 6, sentence number 2 on page 150"^^xsd:string ;
    neo:text "How many persons hearing it will open their eyes?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3360 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1126,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3320 ;
    neo:id "ae4d2c939f961888b867e6a67d4982d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 22. Kashapa’s Preaching Sign, paragraph number 6, sentence number 3 on page 150"^^xsd:string ;
    neo:text "Elder brother calls and younger brother answers, This spring does not belong to the ordinary season."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3362 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3364,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "a3347414bb174f06939daa52921870fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 1, sentence number 1 on page 151"^^xsd:string ;
    neo:text "When he became emancipated the sixth patriarch received from the fifth patriarch the bowl and robe given from the Buddha to his successors, generation after generation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3365 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2843,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3366,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3367 ;
    neo:id "2234f1c90552e65527e7570b0d84ddb2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 2, sentence number 1 on page 151"^^xsd:string ;
    neo:text "A monk named E-myo out of envy pursued the patriarch to take this great treasure away from him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3368 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2269,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3366,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3369 ;
    neo:id "a3470cac1b9252bf33a59ed272917a6c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 2, sentence number 2 on page 151"^^xsd:string ;
    neo:text "The sixth patriarch placed the bowl and robe on a stone in the road and told E-myo: “These objects just symbolize the faith."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_337 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_338 ;
    neo:id "cc3798b558c5b5a9282a6546296520b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Finding a Diamond on a Muddy Road, paragraph number 18, sentence number 2 on page 15"^^xsd:string ;
    neo:text "His name was Mu-nan, the man who never returned back."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3370 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492 ;
    neo:id "4acadc4320cb74cb5d11a0e32fc8740b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 2, sentence number 3 on page 151"^^xsd:string ;
    neo:text "There is no use fighting over them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3371 a neo:Document ;
    neo:id "0a1ac5be4bee1e0e52e23be9aaefec19"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 2, sentence number 4 on page 151"^^xsd:string ;
    neo:text "If you desire to take them, take them now.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3372 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3366 ;
    neo:id "b281ed7cdd80bf82f4068c3bcf2de691"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 3, sentence number 1 on page 151"^^xsd:string ;
    neo:text "When E-myo went to move the bowl and robe they were as heavy as mountains."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3373 a neo:Document ;
    neo:id "dacbd6cc6e560df95d1616749b3fd8c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 3, sentence number 2 on page 151"^^xsd:string ;
    neo:text "He could not budge them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3374 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3375 ;
    neo:id "e687451118e0627b40b1dde5981e5aea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 3, sentence number 3 on page 151"^^xsd:string ;
    neo:text "Trembling for shame he said: “I came wanting the teaching, not the material treasures."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3376 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3377 ;
    neo:id "c9f1d4f2c2e4eec177ede8743ae4ba02"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 4, sentence number 1 on page 151"^^xsd:string ;
    neo:text "The sixth patriarch said: “When you do not think good and when you do not think not-good, what is your true self?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3378 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3366 ;
    neo:id "c68a238a60bd2ce3c0d3f53160028fc1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 5, sentence number 1 on page 151"^^xsd:string ;
    neo:text "At these words E-myo was illumined."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3379 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3380,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "446caaefdb6a3743c1e455aa8898c31d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 5, sentence number 2 on page 151"^^xsd:string ;
    neo:text "Perspiration broke out all over his body."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3381 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3382 ;
    neo:id "1f4d1854a971c78045857ba5c9f5e975"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 5, sentence number 3 on page 151"^^xsd:string ;
    neo:text "He cried and bowed, saying: “You have given me the secret words and meanings."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3383 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320 ;
    neo:id "edb30274a2f69e67763eaa99c63dfa7b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 5, sentence number 4 on page 151"^^xsd:string ;
    neo:text "Is there yet a deeper part of the teaching?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3384 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363 ;
    neo:id "303b23644384670a3c672d75c4fabe3b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 6, sentence number 1 on page 151"^^xsd:string ;
    neo:text "The sixth patriarch replied: “What I have told you is no secret at all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3385 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3387 ;
    neo:id "e60e38d147af93c10e1e4fea023db434"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 6, sentence number 2 on page 151"^^xsd:string ;
    neo:text "When you realize your own true self the secret belongs to you.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3388 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3366,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3389 ;
    neo:id "87904ccfda0495f9d7bba3c8c80ba951"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 7, sentence number 1 on page 151"^^xsd:string ;
    neo:text "E-myo said: “I was under the fifth patriarch many years but could not realize my true self until now."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_339 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_341 ;
    neo:id "23880d51ad2a3066975b4c1fa63cf670"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 1, sentence number 1 on page 16"^^xsd:string ;
    neo:text "The Zen master Hakuin was praised by his neighbors as one living a pure life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3390 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "84a213272b7e5f35e515d055e538d996"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 7, sentence number 2 on page 151"^^xsd:string ;
    neo:text "Through your teaching I find the source."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3391 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "2a6c9ea8ac551dbd9ef977f4821d61b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 7, sentence number 3 on page 151"^^xsd:string ;
    neo:text "A person drinks water and knows himself whether it is cold or warm."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3392 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "2e2f0049c127e9a7adc502d50a1ceb51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 7, sentence number 4 on page 151"^^xsd:string ;
    neo:text "May I call you my teacher?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3393 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3364 ;
    neo:id "1b82804c28a2e1756932296e59812e65"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 8, sentence number 1 on page 151"^^xsd:string ;
    neo:text "The sixth patriarch replied: “We studied together under the fifth patriarch."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3394 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "ba5003ad657df97ebf439697698f9de8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 8, sentence number 2 on page 151"^^xsd:string ;
    neo:text "Call him your teacher, but just treasure what you have attained.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3395 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363 ;
    neo:id "61cf49b2c78bfe42479b2473e38d3fb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 9, sentence number 1 on page 151"^^xsd:string ;
    neo:text "Mumon’s comment: The sixth patriarch certainly was kind in such an emergency."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3396 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_676,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "9d4615d7e6a74878ad4c0e4013ab683b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 9, sentence number 2 on page 151"^^xsd:string ;
    neo:text "It was as if he removed the skin and seeds from the fruit and then, opening the pupil’s mouth, let him eat."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3397 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "347d04f7441d67cb078e8769c18de369"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 10, sentence number 1 on page 151"^^xsd:string ;
    neo:text "You cannot describe it, you cannot picture it, You cannot admire it, you cannot sense it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3401 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3377 ;
    neo:id "7cba5530bc5d67180f4e511b354bd3d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 10, sentence number 2 on page 151"^^xsd:string ;
    neo:text "It is your true self, it has nowhere to hide."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3402 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180 ;
    neo:id "d674c9c81798d5a13f82a3224128ce31"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 23. Do Not Think Good, Do Not Think Not-Good, paragraph number 11, sentence number 1 on page 152"^^xsd:string ;
    neo:text "When the world is destroyed, it will not be destroyed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3403 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3404,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "6b80a2dc94ef774af9a72cbc6374c405"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 1, sentence number 1 on page 153"^^xsd:string ;
    neo:text "A monk asked Fuketsu: “Without speaking, without silence, how can you express the truth?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3405 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3404,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3406,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3407 ;
    neo:id "d46090f977fbb02d8a008f86d5d08290"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 2, sentence number 1 on page 153"^^xsd:string ;
    neo:text "Fuketsu observed: “I always remember springtime in southern China."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3408 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3409,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492 ;
    neo:id "0fa06c624fa6debc4b77623ae99b39e9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 2, sentence number 2 on page 153"^^xsd:string ;
    neo:text "The birds sing among innumerable kinds of fragrant flowers.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3410 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3404 ;
    neo:id "eac45f73f0b13ca0f0e4468ea820adab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 3, sentence number 1 on page 153"^^xsd:string ;
    neo:text "Mumon’s comment: Fuketsu used to have lightning Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3412 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "b8bba1c46b5fddf502d04eb3e2c4666d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 3, sentence number 2 on page 153"^^xsd:string ;
    neo:text "Whenever he had the opportunity, he flashed it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3413 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3414 ;
    neo:id "49bffdc09445e1f63d18e6b2ba00ef2d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 3, sentence number 3 on page 153"^^xsd:string ;
    neo:text "But this time he failed to do so and only borrowed from an old Chinese poem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3415 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3404,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "14b64d08fd4c64e114731a1713130884"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 3, sentence number 4 on page 153"^^xsd:string ;
    neo:text "Never mind Fuketsu’s Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3416 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1131,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "ab5693fe4ad38b599788f216d7c6d516"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 3, sentence number 5 on page 153"^^xsd:string ;
    neo:text "If you want to express the truth, throw out your words, throw out your silence, and tell me about your own Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3417 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "2caa978ba6bf10f75425575f00758a52"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 4, sentence number 1 on page 153"^^xsd:string ;
    neo:text "Without revealing his own penetration, He offered another’s words, not his to give."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3418 a neo:Document ;
    neo:id "59206de8f2aea7be646be61cdf85c058"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 24. Without Words, Without Silence, paragraph number 4, sentence number 2 on page 153"^^xsd:string ;
    neo:text "Had he chattered on and on, Even his listeners would have been embarrassed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3419 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2995,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3420,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3421 ;
    neo:id "b1be9c9ae6c28ccba386ac0ee0bc8263"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 1, sentence number 1 on page 154"^^xsd:string ;
    neo:text "In a dream Kyozan went to Maitreya’s Pure Land."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_342 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_343,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_344,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_345 ;
    neo:id "8d04791bb6e46eb8db916a74c1c04d11"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 2, sentence number 1 on page 16"^^xsd:string ;
    neo:text "A beautiful Japanese girl whose parents owned a food store lived near him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3422 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2995,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3423,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3424 ;
    neo:id "5c00fcdac37e12d0639d0f98a0378670"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 1, sentence number 2 on page 154"^^xsd:string ;
    neo:text "He recognized himself seated in the third seat in the abode of Maitreya."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3425 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3423,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_552 ;
    neo:id "abdd1d4f20c2652661e37ed1e77e0199"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 1, sentence number 3 on page 154"^^xsd:string ;
    neo:text "Someone announced: “Today the one who sits in the third seat will preach.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3426 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3420,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3427 ;
    neo:id "143611c82684b933669f4169be1e03da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 2, sentence number 1 on page 154"^^xsd:string ;
    neo:text "Kyozan arose and, hitting the gavel, said: “The truth of Mahayana teaching is transcendent, above words and thought."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3428 a neo:Document ;
    neo:id "44cf352d4b6ce2a05b4d0081c1b823ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 2, sentence number 2 on page 154"^^xsd:string ;
    neo:text "Do you understand?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3429 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830 ;
    neo:id "5014245a93354af866e524cb3bd60277"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 3, sentence number 1 on page 154"^^xsd:string ;
    neo:text "Mumon’s comment: I want to ask you monks: Did he preach or did he not?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3430 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "2c39d30552c7d2a00c51d7cdaa6a6f16"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 4, sentence number 1 on page 154"^^xsd:string ;
    neo:text "When he opens his mouth he is lost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3431 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "0333384beba7ca9fe87ff87cb33092ad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 4, sentence number 2 on page 154"^^xsd:string ;
    neo:text "When he seals his mouth he is lost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3432 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "6122a159cb82ab72cd89b9d9a1a80876"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 4, sentence number 3 on page 154"^^xsd:string ;
    neo:text "If he does not open it, if he does not seal it, he is 108,000 miles from truth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3433 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1253,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2816 ;
    neo:id "5748b776683fcbe809b12e1b5f614f0e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 5, sentence number 1 on page 154"^^xsd:string ;
    neo:text "In the light of day, Yet in a dream he talks of a dream."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3434 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3435,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_397 ;
    neo:id "202a517549e79b6980173e8228a392b4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 25. Preaching from the Third Seat, paragraph number 5, sentence number 2 on page 154"^^xsd:string ;
    neo:text "A monster among monsters, He intended to deceive the whole crowd."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3436 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2262,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3438 ;
    neo:id "90771edd4d60aef0b4ad72f89cf924c4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 1, sentence number 1 on page 155"^^xsd:string ;
    neo:text "Hogen of Seiryo monastery was about to lecture before dinner when he noticed that the bamboo screen lowered for meditation had not been rolled up."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3439 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "af31a8c2801311c3fb647fc4afb75c1f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 1, sentence number 2 on page 155"^^xsd:string ;
    neo:text "He pointed to it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3440 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3017 ;
    neo:id "25381b2bd0d4b2a9453d4faccb9151f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 1, sentence number 3 on page 155"^^xsd:string ;
    neo:text "Two monks arose from the audience and rolled it up."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3441 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2262,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3442,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3443 ;
    neo:id "ddaed9f93b6d02b5a6d9a55166b562a3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 2, sentence number 1 on page 155"^^xsd:string ;
    neo:text "Hogen, observing the physical moment, said: “The state of the first monk is good, not that of the other.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3444 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3445 ;
    neo:id "7997288640bad28a35bb7826b1f58da0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 3, sentence number 1 on page 155"^^xsd:string ;
    neo:text "Mumon’s comment: I want to ask you: Which of those two monks gained and which lost?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3446 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3447 ;
    neo:id "f7839557ebbcff42a1869b79152daad5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 3, sentence number 2 on page 155"^^xsd:string ;
    neo:text "If any of you has one eye, he will see the failure on the teacher’s part."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3448 a neo:Document ;
    neo:id "84452c425dda73677319d760001af42d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 3, sentence number 3 on page 155"^^xsd:string ;
    neo:text "However, I am not discussing gain and loss."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3449 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2622,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "b2f0c025bb4f5d20c7d959e0ec4bb122"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 4, sentence number 1 on page 155"^^xsd:string ;
    neo:text "When the screen is rolled up the great sky opens, Yet the sky is not attuned to Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3450 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3451 ;
    neo:id "5e63d957091cbf7b9c3fe8e5ceea96a6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 26. Two Monks Roll Up the Screen, paragraph number 4, sentence number 2 on page 155"^^xsd:string ;
    neo:text "It is best to forget the great sky And to retire from every wind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3452 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "d6affe26c685ceff15725b74f617caa7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 1, sentence number 1 on page 156"^^xsd:string ;
    neo:text "A monk asked Nansen: “Is there a teaching no master ever preached before?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3453 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176 ;
    neo:id "9e08ea535716b5901d5ebb9ae7b1e4a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 2, sentence number 1 on page 156"^^xsd:string ;
    neo:text "Nansen said: “Yes, there is.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3455 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "ae665d5d5c76268440bff916c7538399"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 3, sentence number 1 on page 156"^^xsd:string ;
    neo:text "“What is it?” asked the monk."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3456 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_322,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "d54bdbcb662201e8e28ed86a093c5bde"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 4, sentence number 1 on page 156"^^xsd:string ;
    neo:text "Nansen replied: “It is not mind, it is not Buddha, it is not things.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3457 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176 ;
    neo:id "58d81f77ed69d909a5d2238acd2354de"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 5, sentence number 1 on page 156"^^xsd:string ;
    neo:text "Mumon’s comment: Old Nansen gave away his treasure-words."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3459 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "08d6783275f76a3378107e4878b70d24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 5, sentence number 2 on page 156"^^xsd:string ;
    neo:text "He must have been greatly upset."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_346 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_344,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "8d03c55b538381e30509c92f29ddb59a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 2, sentence number 2 on page 16"^^xsd:string ;
    neo:text "Suddenly, without any warning her parents discovered she was with child."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3460 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176 ;
    neo:id "40f7aa81531e3b76b538ab84024c2143"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 6, sentence number 1 on page 156"^^xsd:string ;
    neo:text "Nansen was too kind and lost his treasure."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3461 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3462,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "95d90888e8273192d73e1bdde6d350cf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 6, sentence number 2 on page 156"^^xsd:string ;
    neo:text "Truly, words have no power."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3463 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_496,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "782f7549c7402c244cc624b6013363bc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 27. It Is Not Mind, It Is Not Buddha, It Is Not Things, paragraph number 6, sentence number 3 on page 156"^^xsd:string ;
    neo:text "Even though the mountain becomes the sea, Words cannot open another’s mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3464 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "a55a6400df7fd784eac894194e27dbf0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 1, sentence number 1 on page 157"^^xsd:string ;
    neo:text "Tokusan was studying Zen under Ryutan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3466 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "bbbfae4a3f34470f2a1c935ef0e4df2d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 1, sentence number 2 on page 157"^^xsd:string ;
    neo:text "One night he came to Ryutan and asked many questions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3467 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489 ;
    neo:id "4181121bb1dab93ab97ef9e735e13738"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 1, sentence number 3 on page 157"^^xsd:string ;
    neo:text "The teacher said: “The night is getting old."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3468 a neo:Document ;
    neo:id "1abc753209811cfb10659af0e39467e4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 1, sentence number 4 on page 157"^^xsd:string ;
    neo:text "Why don’t you retire?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3469 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2622,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "c2f66782d7732f05c71094cd5d34c675"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 2, sentence number 1 on page 157"^^xsd:string ;
    neo:text "So Tokusan bowed and opened the screen to go out, observing: “It is very dark outside.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3470 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2723,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "01e3f4094cb1ccc8a644dbe72aaaf73f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 3, sentence number 1 on page 157"^^xsd:string ;
    neo:text "Ryutan offered Tokusan a lighted candle to find his way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3471 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "b77c2d28dcd8bb3ba389f492dd6c6672"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 3, sentence number 2 on page 157"^^xsd:string ;
    neo:text "Just as Tokusan received it, Ryutan blew it out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3472 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "4f3445c4b996f51bf98c6592270790bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 3, sentence number 3 on page 157"^^xsd:string ;
    neo:text "At that moment the mind of Tokusan was opened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3473 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "576542dc534a85523b8a3403c686378f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 4, sentence number 1 on page 157"^^xsd:string ;
    neo:text "“What have you attained?” asked Ryutan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3474 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "1c6696fce1aad7ffc0abfd7cbdd15cc4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 4, sentence number 2 on page 157"^^xsd:string ;
    neo:text "“From now on,” said Tokusan, “I will not doubt the teacher’s words.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3475 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "8609444046fe2cb19c5ccb909a7a0112"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 5, sentence number 1 on page 157"^^xsd:string ;
    neo:text "The next day Ryutan told the monks at his lecture: “I see one monk among you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3476 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3477,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3478,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3479,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3480 ;
    neo:id "fae651aa1393529bb9b1b36816a16028"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 5, sentence number 2 on page 157"^^xsd:string ;
    neo:text "His teeth are like the sword tree, his mouth is like the blood bowl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_348 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_344 ;
    neo:id "b565db5d9eaa4e4bec7e633e40b714a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 3, sentence number 1 on page 16"^^xsd:string ;
    neo:text "This made her parents angry."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3481 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277 ;
    neo:id "28d0a028eb3d89d2c4e286bc1e4df52e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 5, sentence number 3 on page 157"^^xsd:string ;
    neo:text "If you hit him hard with a big stick, he will not even so much as look back at you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3482 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3483,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3484 ;
    neo:id "f48708c88d75356856fc6a3fb8a8a72b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 5, sentence number 4 on page 157"^^xsd:string ;
    neo:text "Someday he will mount the highest peak and carry my teaching there.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3485 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3487 ;
    neo:id "d0611c060c18f4edb5e91d4d6f1602f0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 6, sentence number 1 on page 157"^^xsd:string ;
    neo:text "On that day, in front of the lecture hall, Tokusan burned to ashes his commentaries on the sutras."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3488 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3489,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3490 ;
    neo:id "c4de726131b5c4bdceedaa7b6f58bcbc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 6, sentence number 2 on page 157"^^xsd:string ;
    neo:text "He said: “However abstruse the teachings are, in comparison with this enlightenment they are like a single hair to the great sky."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_349 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_304,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "58018d812ef20484f37e430a30384900"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 3, sentence number 2 on page 16"^^xsd:string ;
    neo:text "She would not confess who the man was, but after much harassment at last named Hakuin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3491 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3231,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3493,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3494 ;
    neo:id "8dd426e3ec0549a058c313f5fa87d638"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 6, sentence number 3 on page 157"^^xsd:string ;
    neo:text "However profound the complicated knowledge of the world, compared to this enlightenment it is like one drop of water to the great ocean.” Then he left that monastery."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3495 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3496,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "a145e0a5ad81ca04e7556edea3b408dc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 1 on page 157"^^xsd:string ;
    neo:text "Mumon’s comment: When Tokusan was in his own country he was not satisfied with Zen although he had heard about it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3497 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3007,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3498,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747 ;
    neo:id "65f9349e3567ca0da1f400d246e1e0b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 2 on page 157"^^xsd:string ;
    neo:text "He thought: “Those Southern monks say they can teach Dharma outside of the sutras."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3499 a neo:Document ;
    neo:id "db4013b2f24fe3837175b1b6732b9fbd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 3 on page 157"^^xsd:string ;
    neo:text "They are all wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_35 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_36,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_37,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_38,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_39,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_40 ;
    neo:id "0e95065ac7f35c270d795a0a799188f1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 4, sentence number 1 on page 7"^^xsd:string ;
    neo:text "Centering, a transcription of ancient Sanskrit manuscripts, first appeared in the Spring 1955 issue of Gentry magazine, New York."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3500 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "f5640fc0d6f9db636082693a97686361"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 4 on page 157"^^xsd:string ;
    neo:text "I must teach them.” So he traveled south."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3501 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3502 ;
    neo:id "ea6129a9f0414aa650d1cb74d6892bb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 5 on page 157"^^xsd:string ;
    neo:text "He happened to stop near Ryutan’s monastery for refreshments."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3503 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_442 ;
    neo:id "3ca431bcb3e785a46b2d84d421cae2ef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 7, sentence number 6 on page 157"^^xsd:string ;
    neo:text "An old woman who was there asked him: “What are you carrying so heavily?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3504 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3505 ;
    neo:id "f57a0dacb28a93a3165a94e7277029d4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 8, sentence number 1 on page 157"^^xsd:string ;
    neo:text "Tokusan replied: “This is a commentary I have made on the Diamond Sutra after many years of work.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3506 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426 ;
    neo:id "c373e87472fe0a0895ec1e537373a96b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 9, sentence number 1 on page 157"^^xsd:string ;
    neo:text "The old woman said: “I read that sutra which says: ‘The past mind cannot be held, the present mind cannot be held, the future mind cannot be held.’ You wish some tea and refreshments."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3508 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492 ;
    neo:id "260911ab22da0fd972388f5b773fd2f5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 10, sentence number 2 on page 158"^^xsd:string ;
    neo:text "Which mind do you propose to use for them?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3509 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3149 ;
    neo:id "a0d47f0c7243854996e99d84cbba5aa0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 10, sentence number 1 on page 158"^^xsd:string ;
    neo:text "Tokusan was as though dumb."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_351 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_344,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "04c2b4c729c335dbc4dfc2be3b99d23c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 4, sentence number 1 on page 16"^^xsd:string ;
    neo:text "In great anger the parents went to the master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3510 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_242 ;
    neo:id "8dd60ab75cf1c295eead0b4ec6844bcb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 10, sentence number 2 on page 158"^^xsd:string ;
    neo:text "Finally he asked the woman: “Do you know of any good teacher around here?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3511 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_442 ;
    neo:id "67827801f1d759f0d3b69c98ade7df45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 11, sentence number 1 on page 158"^^xsd:string ;
    neo:text "The old woman referred him to Ryutan, not more than five miles away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3512 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "9dcbfbe059b9c7c955a62f7bf3079745"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 11, sentence number 2 on page 158"^^xsd:string ;
    neo:text "So he went to Ryutan in all humility, quite different from when he had started his journey."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3513 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3465 ;
    neo:id "da91b567e62dfa3ebad5d5349253da42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 11, sentence number 3 on page 158"^^xsd:string ;
    neo:text "Ryutan in turn was so kind he forgot his own dignity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3514 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3515,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3516 ;
    neo:id "4f49935f726aafe9015cfe36bd46d55f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 11, sentence number 4 on page 158"^^xsd:string ;
    neo:text "It was like pouring muddy water over a drunken man to sober him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3517 a neo:Document ;
    neo:id "f6c150a92c16238a653d20ae89aea03a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 11, sentence number 5 on page 158"^^xsd:string ;
    neo:text "After all, it was an unnecessary comedy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3518 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3519,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3520 ;
    neo:id "2a05487d49193529f722d1fa178e3e64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 12, sentence number 1 on page 158"^^xsd:string ;
    neo:text "A hundred hearings cannot surpass one seeing, But after you see the teacher, that one glance cannot surpass a"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_352 a neo:Document ;
    neo:id "14fcaad7fbdb45eb4581e146a9079043"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 4, sentence number 2 on page 16"^^xsd:string ;
    neo:text "‘Is that so?’ was all he would say."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3521 a neo:Document ;
    neo:id "561a7d015e615d2caae84043e26483ee"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 13, sentence number 1 on page 158"^^xsd:string ;
    neo:text "hundred hearings."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3522 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1660,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "cac03d912a7490bbd6be9183ebfd83a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 28. Blow Out the Candle, paragraph number 13, sentence number 2 on page 158"^^xsd:string ;
    neo:text "His nose was very high But he was blind after all."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3523 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3524,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3526 ;
    neo:id "20d95434ec99e876c51ba953ef80d78b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 1, sentence number 1 on page 159"^^xsd:string ;
    neo:text "Two monks were arguing about a flag."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3527 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3526 ;
    neo:id "56289fe00a56e2eb74fdb764b576bbdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 1, sentence number 2 on page 159"^^xsd:string ;
    neo:text "One said: “The flag is moving.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3529 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "e650e2c74020cef689fcbd5571cfbaff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 2, sentence number 1 on page 159"^^xsd:string ;
    neo:text "The other said: “The wind is moving.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_353 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "b74ca7582f02a71ab7a0bbd1496e5f2e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 5, sentence number 1 on page 16"^^xsd:string ;
    neo:text "After the child was born it was brought to Hakuin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3531 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363 ;
    neo:id "0ed4ea14571ed18355db818a3aa2ec32"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 3, sentence number 1 on page 159"^^xsd:string ;
    neo:text "The sixth patriarch happened to be passing by."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3532 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3526 ;
    neo:id "ad42c9055482a1fd46429a8efd50430a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 3, sentence number 2 on page 159"^^xsd:string ;
    neo:text "He told them: “Not the wind, not the flag; mind is moving.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3533 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3526 ;
    neo:id "51344e236a1fa2b36d6573f8f5c0a0b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 4, sentence number 1 on page 159"^^xsd:string ;
    neo:text "Mumon’s comment: The sixth patriarch said: “The wind is not moving, the flag is not moving."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3534 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "71462a5aeae1c9d4ce09efccc09405fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 4, sentence number 2 on page 159"^^xsd:string ;
    neo:text "Mind is moving.” What did he mean?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3535 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1349,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3271 ;
    neo:id "503a6a49e833702de6dc8b05bbc71407"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 4, sentence number 3 on page 159"^^xsd:string ;
    neo:text "If you understand this intimately, you will see the two monks there trying to buy iron and gaining gold."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3536 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2072,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3537 ;
    neo:id "1f312c7d3316e1573cba24120b09daab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 4, sentence number 4 on page 159"^^xsd:string ;
    neo:text "The sixth patriarch could not bear to see those two dull heads, so he made such a bargain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3538 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3526,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3539,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3540 ;
    neo:id "acd574a34e90d511539286c7da1b517b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 5, sentence number 1 on page 159"^^xsd:string ;
    neo:text "Wind, flag, mind moves, The same understanding."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_354 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_355 ;
    neo:id "e837f313e8d0f1616fb149fac44af966"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 5, sentence number 2 on page 16"^^xsd:string ;
    neo:text "By this time he had lost his reputation, which did not trouble him, but he took very good care of the child."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3541 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3479,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3528 ;
    neo:id "00e54781af232b19175d7f704cd85619"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 29. Not the Wind, Not the Flag, paragraph number 5, sentence number 2 on page 159"^^xsd:string ;
    neo:text "When the mouth opens All are wrong."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3542 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "0c251556f76f95378327a8fb1293e156"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 1, sentence number 1 on page 160"^^xsd:string ;
    neo:text "Daibai asked Baso: “What is Buddha?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3544 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "03f23ecd9024adcf06e00ccbed4c859c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 2, sentence number 1 on page 160"^^xsd:string ;
    neo:text "Baso said: “This mind is Buddha.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3545 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "01f2474489653329e3bf6effe31af462"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 3, sentence number 1 on page 160"^^xsd:string ;
    neo:text "Mumon’s comment: If anyone wholly understands this, he is wearing Buddha’s clothing, he is eating Buddha’s food, he is speaking Buddha’s words, he is behaving as Buddha, he is Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3546 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3547,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3548,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "e1212d2b2439adfa0fc3f6b75bf6c922"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 3, sentence number 2 on page 160"^^xsd:string ;
    neo:text "This anecdote, however, has given many a pupil the sickness of formality."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3549 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3242,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3479,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "6bc6608b7369d250b8333cc96127cf58"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 3, sentence number 3 on page 160"^^xsd:string ;
    neo:text "If one truly understands, he will wash out his mouth for three days after saying the word Buddha, and he will close his ears and flee after hearing “This mind is Buddha.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3550 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3551,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_801 ;
    neo:id "dd29fabf1796296a88dee56b7862ac45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 4, sentence number 1 on page 160"^^xsd:string ;
    neo:text "Under blue sky, in bright sunlight, One need not search around."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3552 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3553,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3554,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "7fa297c7bdc652bdf4521bbf7af2e100"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 30. This Mind Is Buddha, paragraph number 4, sentence number 2 on page 160"^^xsd:string ;
    neo:text "Asking what Buddha is Is like hiding loot in one’s pocket and declaring oneself innocent."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3555 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3556,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3557,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_442 ;
    neo:id "6aafa401531d62f5e0c794ed701aa293"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 1, sentence number 1 on page 161"^^xsd:string ;
    neo:text "A traveling monk asked an old woman the road to Taizan, a popular temple supposed to give wisdom to the one who worships there."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3558 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "a903d5a239af5df943c654cf45e68d87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 1, sentence number 2 on page 161"^^xsd:string ;
    neo:text "The old woman said: “Go straight ahead.” When the monk proceeded a few steps, she said to herself: “He also is a common church-goer.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_356 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_341,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_357,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_358 ;
    neo:id "033f2cd5f3c3ce16dc4984985e54626d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 5, sentence number 3 on page 16"^^xsd:string ;
    neo:text "He obtained milk from his neighbors and everything else the little one needed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3560 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_442,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "db7d005648fd1d223cbcf0888c0698d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 2, sentence number 1 on page 161"^^xsd:string ;
    neo:text "Someone told this incident to Joshu, who said: “Wait until I investigate.” The next day he went and asked the same question, and the old woman gave the same answer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3562 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "f711b058aaa58e9297a286ef1fd52f9c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 3, sentence number 1 on page 161"^^xsd:string ;
    neo:text "Joshu remarked: “I have investigated that old woman.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3563 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3564,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3565,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426 ;
    neo:id "2fb62712572803afe67ea46d15c8cc0e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 4, sentence number 1 on page 161"^^xsd:string ;
    neo:text "Mumon’s comment: The old woman understood how war is planned, but she did not know how spies sneak in behind her tent."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3566 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3567,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3568 ;
    neo:id "d3e81209e06165c3646682eaada2d667"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 4, sentence number 2 on page 161"^^xsd:string ;
    neo:text "Old Joshu played the spy’s work and turned the tables on her, but he was not an able general."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3569 a neo:Document ;
    neo:id "2964d904ffd43f1fce294ac2fe906d42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 4, sentence number 3 on page 161"^^xsd:string ;
    neo:text "Both had their faults."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3570 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "5270a996378f6e879463945beace42d5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 4, sentence number 4 on page 161"^^xsd:string ;
    neo:text "Now I want to ask you: What was the point of Joshu’s investigating the old woman?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3571 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_69 ;
    neo:id "d2c02be2b369acc2386242ffb8af52ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 5, sentence number 1 on page 161"^^xsd:string ;
    neo:text "When the question is common The answer is also common."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3572 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2219,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3574,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3575,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_69 ;
    neo:id "61164cbcb7d9edc5d10e397337e693d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 31. Joshu Investigates, paragraph number 5, sentence number 2 on page 161"^^xsd:string ;
    neo:text "When the question is sand in a bowl of boiled rice The answer is a stick in the soft mud."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3576 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "f95fa83436615607e35b2e699066e917"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 1, sentence number 1 on page 162"^^xsd:string ;
    neo:text "A philosopher asked Buddha: “Without words, without the wordless, will you tell me truth?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3578 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1795 ;
    neo:id "f98a3db7ec85749d70daff9cbae153da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 2, sentence number 1 on page 162"^^xsd:string ;
    neo:text "The Buddha kept silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3579 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "c63e78b23deeda465a33a4f7a19ffb3d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 3, sentence number 1 on page 162"^^xsd:string ;
    neo:text "The philosopher bowed and thanked the Buddha, saying: “With your loving kindness I have cleared away my delusions and entered the true path.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3580 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "05e46181e98f1d41a4dcd846a9154758"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 4, sentence number 1 on page 162"^^xsd:string ;
    neo:text "After the philosopher had gone, Ananda asked the Buddha what he had attained."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3581 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1795,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3583 ;
    neo:id "f94f23bdabffca1852b2bf0336ca1fdc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 5, sentence number 1 on page 162"^^xsd:string ;
    neo:text "The Buddha replied: “A good horse runs even at the shadow of the whip.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3584 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "c5b4e59bfdbf4bc547d6fc71d65031b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 6, sentence number 1 on page 162"^^xsd:string ;
    neo:text "Mumon’s comment: Ananda was the disciple of the Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3585 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3586,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3587 ;
    neo:id "6d63a4af9ee5fb64dfa15d080430d806"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 6, sentence number 2 on page 162"^^xsd:string ;
    neo:text "Even so, his opinion did not surpass that of outsiders."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3588 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3587,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "06195709cee52acfecd96142b2415ce6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 6, sentence number 3 on page 162"^^xsd:string ;
    neo:text "I want to ask you monks: How much difference is there between disciples and outsiders?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3589 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1823,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3590 ;
    neo:id "ab7ab1f5e4bc5b9d0739a9ae202520b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 7, sentence number 1 on page 162"^^xsd:string ;
    neo:text "To tread the sharp edge of a sword, To run on smooth-frozen ice, One needs no footsteps to follow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_359 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_360 ;
    neo:id "ee79aabf08ef24e68fcd41ef8308ccdf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 6, sentence number 1 on page 16"^^xsd:string ;
    neo:text "A year later the girl-mother could stand it no longer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3591 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3592,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_976 ;
    neo:id "75a85b0c8968e24b668a4d2b3bf02d79"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 32. A Philosopher Asks Buddha, paragraph number 7, sentence number 2 on page 162"^^xsd:string ;
    neo:text "Walk over the cliffs with hands free."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3593 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "b35442b4c7048bb7573797ae3c8e595b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 1, sentence number 1 on page 163"^^xsd:string ;
    neo:text "A monk asked Baso: “What is Buddha?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3594 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "9963c589d115c0d0688790f5fb192077"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 2, sentence number 1 on page 163"^^xsd:string ;
    neo:text "Baso said: “This mind is not Buddha.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3595 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "cc87ce6abf6289927d8431e27fa955b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 3, sentence number 1 on page 163"^^xsd:string ;
    neo:text "Mumon’s comment: If anyone understands this, he is a graduate of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3596 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1624,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3597 ;
    neo:id "0679b43e70fc3a8ec5b6cb2689176263"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 4, sentence number 1 on page 163"^^xsd:string ;
    neo:text "If you meet a fencing-master on the road, you may give him your"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3598 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576 ;
    neo:id "5134bf89a3ab76e0249ecc2281b4f82b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 5, sentence number 1 on page 163"^^xsd:string ;
    neo:text "sword, If you meet a poet, you may offer him your poem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3599 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3600 ;
    neo:id "183c3264da1df11020f77b49b616951c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 5, sentence number 2 on page 163"^^xsd:string ;
    neo:text "When you meet others, say only a part of what you intend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3601 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1040 ;
    neo:id "8f78c0365f8b35059547e4204df0b875"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 33. This Mind Is Not Buddha, paragraph number 5, sentence number 3 on page 163"^^xsd:string ;
    neo:text "Never give the whole thing at once."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3603 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "6fb278bcddc1d871a32c94d0656973cc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 1, sentence number 1 on page 164"^^xsd:string ;
    neo:text "Nansen said: “Mind is not Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3604 a neo:Document ;
    neo:id "99e680211c20332cd5ff0763b3f8139a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 1, sentence number 2 on page 164"^^xsd:string ;
    neo:text "Learning is not the path.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3605 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3176 ;
    neo:id "888e85985d78119f245b2af2b90922eb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 2, sentence number 1 on page 164"^^xsd:string ;
    neo:text "Mumon’s comment: Nansen was getting old and forgot to be ashamed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3607 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3608 ;
    neo:id "33dd1df5d9ee85e9146ab9ffd781fca8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 2, sentence number 2 on page 164"^^xsd:string ;
    neo:text "He spoke out with bad breath and exposed the scandal of his own home."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3609 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3610 ;
    neo:id "f7a12d42d40571584822cb7c56229869"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 2, sentence number 3 on page 164"^^xsd:string ;
    neo:text "However, there are few who appreciate his kindness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_361 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_362,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_364,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_365 ;
    neo:id "f2be4d46ceb064c667f54a23a49cbe63"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 6, sentence number 2 on page 16"^^xsd:string ;
    neo:text "She told her parents the truth—that the real father of the child was a young man who worked in the fish market."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3611 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3612 ;
    neo:id "d62e4e69c04b3609a91166512db8f4e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 3, sentence number 1 on page 164"^^xsd:string ;
    neo:text "When the sky is clear the sun appears, When the earth is parched rain will fall."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3613 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3614 ;
    neo:id "c08565212ea34a13e2556ed0298da473"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 34. Learning Is Not the Path, paragraph number 3, sentence number 2 on page 164"^^xsd:string ;
    neo:text "He opened his heart fully and spoke out, But it was useless to talk to pigs and fish."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3615 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3064,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3616 ;
    neo:id "5fb9a154ed9ff7dbd81c2693980c4fe9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 1, sentence number 1 on page 165"^^xsd:string ;
    neo:text "“Seijo, the Chinese girl,” observed Goso, “had two souls, one always sick at home and the other in the city, a married woman with two children."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3620 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3621 ;
    neo:id "279ed4f0d3e1a379cc8ac6159b2dc31e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 1, sentence number 2 on page 165"^^xsd:string ;
    neo:text "Which was the true soul?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3622 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_159,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3286,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3623 ;
    neo:id "c53d38cc8c953f17bb4a2e340b5c4ad8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 2, sentence number 1 on page 165"^^xsd:string ;
    neo:text "Mumon’s comment: When one understands this, he will know it is possible to come out from one shell and enter another, as if one were stopping at a transient lodging house."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3624 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3625,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3626,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_72 ;
    neo:id "e816f0574f51a06cb70da36edcce9369"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 2, sentence number 2 on page 165"^^xsd:string ;
    neo:text "But if he cannot understand, when his time comes and his four elements separate, he will be just like a crab dipped in boiling water, struggling with many hands and legs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3627 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830 ;
    neo:id "05c8846ea5b5abf3382a696151ee276b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 2, sentence number 3 on page 165"^^xsd:string ;
    neo:text "In such a predicament he may say: “Mumon did not tell me where to go!” but it will be too late then."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3628 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3629,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_523,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_799 ;
    neo:id "c35c33ae7135e094ca240a62e8ec260d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 3, sentence number 1 on page 165"^^xsd:string ;
    neo:text "The moon above the clouds is the same moon, The mountains and rivers below are all different."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3630 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1171,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3632 ;
    neo:id "f75002bee6fc7cf45b3499b1842ae5af"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 3, sentence number 2 on page 165"^^xsd:string ;
    neo:text "Each is happy in its unity and variety."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3633 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3634,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3635 ;
    neo:id "6105659a0070d63f0d26f25d593283fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 35. Two Souls, paragraph number 3, sentence number 3 on page 165"^^xsd:string ;
    neo:text "This is one, this is two."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3636 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3616,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413 ;
    neo:id "678f94ff4bb64ee81bc8a76c5855b004"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Meeting a Zen Master on the Road, paragraph number 1, sentence number 1 on page 166"^^xsd:string ;
    neo:text "Goso said: “When you meet a Zen master on the road you cannot talk to him, you cannot face him with silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3637 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "886b33c0c903c345f4f37af2c419eb87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Meeting a Zen Master on the Road, paragraph number 1, sentence number 2 on page 166"^^xsd:string ;
    neo:text "What are you going to do?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3638 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830 ;
    neo:id "ce54562155b3a6bcfea058cd6ff6a7d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Meeting a Zen Master on the Road, paragraph number 2, sentence number 1 on page 166"^^xsd:string ;
    neo:text "Mumon’s comment: In such a case, if you can answer him intimately, your realization will be beautiful, but if you cannot, you should look about without seeing anything."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3639 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1624,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413 ;
    neo:id "94d6579413be49811336b99a00c0fa55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Meeting a Zen Master on the Road, paragraph number 3, sentence number 1 on page 166"^^xsd:string ;
    neo:text "Meeting a Zen master on the road, Face him neither with words nor silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3640 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3641,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "fad68e0074c2f7ed5aced0c7f88965a5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 36. Meeting a Zen Master on the Road, paragraph number 3, sentence number 2 on page 166"^^xsd:string ;
    neo:text "Give him an uppercut And you will be called one who understands Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3642 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3616,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3643,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3644,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3645,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3646,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3647,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3648 ;
    neo:id "e33e81bcbf0f570873dcf1d02427126a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. A Buffalo Passes Through the Enclosure, paragraph number 1, sentence number 1 on page 167"^^xsd:string ;
    neo:text "Goso said: “When a buffalo goes out of his enclosure to the edge of the abyss, his horns and his head and his hoofs all pass through, but why can’t the tail also pass?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3649 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2418,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3650,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "309676c3dd2a26580863d0e6cc494d4a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. A Buffalo Passes Through the Enclosure, paragraph number 2, sentence number 1 on page 167"^^xsd:string ;
    neo:text "Mumon’s comment: If anyone can open one eye at this point and say a word of Zen, he is qualified to repay the four gratifications, and, not only that, he can save all sentient beings under him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3651 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3648,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3652,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3653 ;
    neo:id "41b82475b3544846d9633ed3f0d022fd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. A Buffalo Passes Through the Enclosure, paragraph number 2, sentence number 2 on page 167"^^xsd:string ;
    neo:text "But if he cannot say such a word of true Zen, he should turn back to his tail."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3654 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3643,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3655 ;
    neo:id "58c3f28d01a37a8b0ad27d2c6704485e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. A Buffalo Passes Through the Enclosure, paragraph number 3, sentence number 1 on page 167"^^xsd:string ;
    neo:text "If the buffalo runs, he will fall into the trench; If he returns, he will be butchered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3656 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3648 ;
    neo:id "e539020f0fba7c6b4661f742572624fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 37. A Buffalo Passes Through the Enclosure, paragraph number 3, sentence number 2 on page 167"^^xsd:string ;
    neo:text "That little tail Is a very strange thing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3657 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "37a504a8ae68e3744b01e761f46687ff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 1, sentence number 1 on page 168"^^xsd:string ;
    neo:text "A monk asked Joshu why Bodhidharma came to China."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3658 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3659,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "03b513fc404499994d322824af5b1ce7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 2, sentence number 1 on page 168"^^xsd:string ;
    neo:text "Joshu said: “An oak tree in the garden.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_366 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_368,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "feff2a84719d59413f765aee17a4f04a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 7, sentence number 1 on page 16"^^xsd:string ;
    neo:text "The mother and father of the girl at once went to Hakuin to ask his forgiveness, to apologize at length, and to get the child back again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3660 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3661,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879 ;
    neo:id "b98e380556916a1afce4cd6d160bb217"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 3, sentence number 1 on page 168"^^xsd:string ;
    neo:text "Mumon’s comment: If one sees Joshu’s answer clearly, there is no Shakyamuni Buddha before him and no future Buddha after him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3662 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_505,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "c072537ac4318b4de54d7e7146236e67"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 4, sentence number 1 on page 168"^^xsd:string ;
    neo:text "Words cannot describe everything."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3663 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1455,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103 ;
    neo:id "ecafa283e19fcdb316a0a58cb0a79452"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 4, sentence number 2 on page 168"^^xsd:string ;
    neo:text "The heart’s message cannot be delivered in words."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3664 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "dc9dced9c25bbe9449001b5ac35afd2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 4, sentence number 3 on page 168"^^xsd:string ;
    neo:text "If one receives words literally, he will be lost, If he tries to explain with words, he will not attain enlightenment in"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3665 a neo:Document ;
    neo:id "7cf07e412a1942db9dfa7826723c5c35"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 38. An Oak Tree in the Garden, paragraph number 5, sentence number 1 on page 168"^^xsd:string ;
    neo:text "this life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3666 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "f8147740be8a82845824a77bf3b7c360"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 1, sentence number 1 on page 169"^^xsd:string ;
    neo:text "A Zen student told Ummon: “Brilliancy of Buddha illuminates the whole universe.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3667 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576 ;
    neo:id "76defacdbb5d85ceb9e76f625c39a333"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 2, sentence number 1 on page 169"^^xsd:string ;
    neo:text "Before he finished the phrase Ummon asked: “You are reciting another’s poem, are you not?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3668 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "0e6a510657b9796233450e766c8f5572"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 3, sentence number 1 on page 169"^^xsd:string ;
    neo:text "“Yes,” answered the student."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3669 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195 ;
    neo:id "2890ade94e176211e0cc33c5f3396688"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 4, sentence number 1 on page 169"^^xsd:string ;
    neo:text "“You are sidetracked,” said Ummon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3671 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3672,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "20edb91dc69a7c1d2ab72c02fdf5be01"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 5, sentence number 1 on page 169"^^xsd:string ;
    neo:text "Afterwards another teacher, Shishin, asked his pupils: “At what point did that student go off the track?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3673 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3674,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "4a64918e1f0330605449e722206ae0d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 6, sentence number 1 on page 169"^^xsd:string ;
    neo:text "Mumon’s comment: If anyone perceives Ummon’s particular skillfulness, he will know at what point the student was off the track, and he will be a teacher of man and Devas."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3675 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "70d6a59db4e9731f843721a29286130f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 6, sentence number 2 on page 169"^^xsd:string ;
    neo:text "If not, he cannot even perceive himself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3676 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3677 ;
    neo:id "bbd8825833fbd37bd15bb59e9cf611b9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 7, sentence number 1 on page 169"^^xsd:string ;
    neo:text "When a fish meets the fishhook If he is too greedy, he will be caught."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3678 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3479,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_378 ;
    neo:id "2579e4735ca8f25873858cbf172a300e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 39. Ummon’s Sidetrack, paragraph number 7, sentence number 2 on page 169"^^xsd:string ;
    neo:text "When his mouth opens His life already is lost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3679 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3680,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "d61f7ced105666621cd9cc4a4ace6fad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 1, sentence number 1 on page 170"^^xsd:string ;
    neo:text "Hyakujo wished to send a monk to open a new monastery."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3681 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536 ;
    neo:id "dec929781685c11680e792171cc19350"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 1, sentence number 2 on page 170"^^xsd:string ;
    neo:text "He told his pupils that whoever answered a question most ably would be appointed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3682 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3683 ;
    neo:id "eafa90938ebfbd1cb012940cf1c179f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 1, sentence number 3 on page 170"^^xsd:string ;
    neo:text "Placing a water vase on the ground, he asked: “Who can say what this is without calling its name?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3684 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3685,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3686 ;
    neo:id "351fb0a16ed61405d7fad256687fe388"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 2, sentence number 1 on page 170"^^xsd:string ;
    neo:text "The chief monk said: “No one can call it a wooden shoe.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3687 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3688,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3689 ;
    neo:id "1e441fbfe84c698fb75a29a93e20ff92"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 3, sentence number 1 on page 170"^^xsd:string ;
    neo:text "Isan, the cooking monk, tipped over the vase with his foot and went out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3690 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2909,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3680,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3688 ;
    neo:id "1f5b0c6ff95e79ce3d349874eafaf4f3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 4, sentence number 1 on page 170"^^xsd:string ;
    neo:text "Hyakujo smiled and said: “The chief monk loses.” And Isan became the master of the new monastery."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3691 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2434,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3688 ;
    neo:id "12e39c68263431d1bdb8d53be07fbdc6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 5, sentence number 1 on page 170"^^xsd:string ;
    neo:text "Mumon’s comment: Isan was brave enough, but he could not escape Hyakujo’s trick."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3692 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3694 ;
    neo:id "0e022f31bf58138078742068c3c12b58"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 5, sentence number 2 on page 170"^^xsd:string ;
    neo:text "After all, he gave up a light job and took a heavy one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3695 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3696,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3697 ;
    neo:id "59afd1f6cfb82e82e3478b9798f729dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 5, sentence number 3 on page 170"^^xsd:string ;
    neo:text "Why, can’t you see, he took off his comfortable hat and placed himself in iron stocks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3698 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2844,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3699,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3700,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "c92d1aad0df480237f78f7c204991f22"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 40. Tipping Over a Water Vase, paragraph number 6, sentence number 1 on page 170"^^xsd:string ;
    neo:text "Giving up cooking utensils, Defeating the chatterbox, Though his teacher sets a barrier for him His feet will tip over everything, even the Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_370 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_340 ;
    neo:id "9eb97141f9fc6738aee599c2437efe0d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 8, sentence number 1 on page 16"^^xsd:string ;
    neo:text "Hakuin was willing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3701 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2662,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "fe21841e8d58c304b9782e69883d7a50"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 1, sentence number 1 on page 171"^^xsd:string ;
    neo:text "Bodhidharma sits facing the wall."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3702 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3703,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "f20cd5549633ff2bd069f9c0d186ddb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 1, sentence number 2 on page 171"^^xsd:string ;
    neo:text "His future successor stands in the snow and presents his severed arm to Bodhidharma."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3704 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "0b8e17ef304b73f6688a5a446309c7aa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 1, sentence number 3 on page 171"^^xsd:string ;
    neo:text "He cries: “My mind is not pacified."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3705 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "fd5e9139495412d918d9fea029a5d8b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 1, sentence number 4 on page 171"^^xsd:string ;
    neo:text "Master, pacify my mind.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3706 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "8d257a5368a13784b45ee787f34723a3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 2, sentence number 1 on page 171"^^xsd:string ;
    neo:text "Bodhidharma says: “If you bring me that mind, I will pacify it for you.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3707 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1290 ;
    neo:id "b3940ee59447dbee586712d5f4894244"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 3, sentence number 1 on page 171"^^xsd:string ;
    neo:text "The successor says: “When I search my mind I cannot hold it.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3708 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "d9c68b48da18bfa807b3253e4ae95ccb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 4, sentence number 1 on page 171"^^xsd:string ;
    neo:text "Bodhidharma says: “Then your mind is pacified already.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3709 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "13fab096e388923b53867ea7b59bdee7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 5, sentence number 1 on page 171"^^xsd:string ;
    neo:text "Mumon’s comment: That broken-toothed old Hindu, Bodhidharma, came thousands of miles over the sea from India to China as if he had something wonderful."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_371 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "115b166dfd50830cb625e065a0762fd7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Is That So?, paragraph number 8, sentence number 2 on page 16"^^xsd:string ;
    neo:text "In yielding the child, all he said was, ‘Is that so?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3710 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_478 ;
    neo:id "ab6ffe353596378acec99eba9e762d96"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 5, sentence number 2 on page 171"^^xsd:string ;
    neo:text "He is like raising waves without wind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3711 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "15fdd9d4be353d3849b5061721c76d33"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 5, sentence number 3 on page 171"^^xsd:string ;
    neo:text "After he remained years in China he had only one disciple and that one lost his arm and was deformed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3712 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "d114aa3d92d99e2b2b84ce269f1eea8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 5, sentence number 4 on page 171"^^xsd:string ;
    neo:text "Alas, ever since he has had brainless disciples."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3713 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "19d583512ac5be8963d2de57ce170f26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 6, sentence number 1 on page 171"^^xsd:string ;
    neo:text "Why did Bodhidharma come to China?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3714 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3715 ;
    neo:id "641ac71644b403e111956e84116be4eb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 6, sentence number 2 on page 171"^^xsd:string ;
    neo:text "For years monks have discussed this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3716 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3717,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577 ;
    neo:id "881f5ba3a5553b6d98e1da9b40044f9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 41. Bodhidharma Pacifies the Mind, paragraph number 6, sentence number 3 on page 171"^^xsd:string ;
    neo:text "All the troubles that have followed since Came from that teacher and disciple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3718 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3719,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3720,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3721 ;
    neo:id "e3e58ba5ee676600bbba2e5abc69f3ee"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 1, sentence number 1 on page 172"^^xsd:string ;
    neo:text "In the time of Buddha Shakyamuni, Manjusri went to the assemblage of the Buddhas."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_372 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_374,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_375 ;
    neo:id "ed1554cb23e88fe5f1600fe20307ba27"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 1, sentence number 1 on page 17"^^xsd:string ;
    neo:text "The master Bankei’s talks were attended not only by Zen students but by persons of all ranks and sects."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3722 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3723,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_67,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "6d44f44727a37b7de5a0c5ac96476bf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 1, sentence number 2 on page 172"^^xsd:string ;
    neo:text "When he arrived there, the conference was over and each Buddha had returned to his own Buddha-land."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3724 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "2aca8515659315d9dbe3e016f26f6615"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 1, sentence number 3 on page 172"^^xsd:string ;
    neo:text "Only one girl was yet unmoved in deep meditation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3725 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3720,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3726,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_733 ;
    neo:id "d8109136f6cc0633ca8c1d201495851c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 2, sentence number 1 on page 172"^^xsd:string ;
    neo:text "Manjusri asked Buddha Shakyamuni how it was possible for this girl to reach this state, one which even he could not attain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3727 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3728,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "36bb8ed19dfda29b46c008c6241d0660"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 2, sentence number 2 on page 172"^^xsd:string ;
    neo:text "“Bring her out from Samadhi and ask her yourself,” said the Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3729 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3720 ;
    neo:id "67ac5546c2ee11ab6c591f15c715f697"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 3, sentence number 1 on page 172"^^xsd:string ;
    neo:text "Manjusri walked around the girl three times and snapped his fingers."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3730 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "269399c45a9e4b6f28b850ed72d2dd3e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 3, sentence number 2 on page 172"^^xsd:string ;
    neo:text "She still remained in meditation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3731 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3732 ;
    neo:id "3704dd3eab42a14109d5665f9a9dbd42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 3, sentence number 3 on page 172"^^xsd:string ;
    neo:text "So by his miracle power he transported her to a high heaven and tried his best to call her, but in vain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3733 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3720,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3726,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3734 ;
    neo:id "f4b29acb3400b9bf2d74e6b5069e6e45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 4, sentence number 1 on page 172"^^xsd:string ;
    neo:text "Buddha Shakyamuni said: “Even a hundred thousand Manjusris could not disturb her, but below this place, past twelve hundred million countries, is a Bodhisattva, Mo-myo, seed of delusion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3735 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "0fd26bc026c7060c144c3383c48314c9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 4, sentence number 2 on page 172"^^xsd:string ;
    neo:text "If he comes here, she will awaken.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3736 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3737,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "48f7dc0a9e62859b0a39d932c219440d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 5, sentence number 1 on page 172"^^xsd:string ;
    neo:text "No sooner had the Buddha spoken than that Bodhisattva sprang up from the earth and bowed and paid homage to the Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3738 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "dff9d4056af71e49e3f964b84c19b6e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 5, sentence number 2 on page 172"^^xsd:string ;
    neo:text "Buddha directed him to arouse the girl."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3739 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3737 ;
    neo:id "3a3fbdb8aeafe5cab0bc32ef4ec740dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 5, sentence number 3 on page 172"^^xsd:string ;
    neo:text "The Bodhisattva went in front of the girl and snapped his fingers, and in that instant the girl came out from her deep meditation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3740 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3741 ;
    neo:id "7eea4bdf466047b12929a1e18f6faf86"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 6, sentence number 1 on page 172"^^xsd:string ;
    neo:text "Mumon’s comment: Old Shakyamuni set a very poor stage."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3742 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3720,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3743,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3744,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_733 ;
    neo:id "e25a97f92607901afa66f5ad670ef24c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 6, sentence number 2 on page 172"^^xsd:string ;
    neo:text "I want to ask you monks: If Manjusri, who is supposed to have been the teacher of seven Buddhas, could not bring this girl out of meditation, how then could a Bodhisattva who was a mere beginner?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3745 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3746,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484 ;
    neo:id "ca4a0fe3564b0b720f2c4cb83d82160c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 7, sentence number 1 on page 172"^^xsd:string ;
    neo:text "If you understand this intimately, you yourself can enter the great meditation while you are living in the world of delusion."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3747 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3748,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3749 ;
    neo:id "0c6eb57c23fd74efede4809d068ee306"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 8, sentence number 1 on page 172"^^xsd:string ;
    neo:text "One could not awaken her, the other could."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3750 a neo:Document ;
    neo:id "e93dad53debd05b7005b758f9f5f16bf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 8, sentence number 2 on page 172"^^xsd:string ;
    neo:text "Neither are good actors."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3751 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3752,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3753 ;
    neo:id "4894ea128d2720362f415bd4d00394e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 8, sentence number 3 on page 172"^^xsd:string ;
    neo:text "One wears the mask of god, one a devil’s mask."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3754 a neo:Document ;
    neo:id "e2b1cb664c65fc6291153c6a85d3844e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 42. The Girl Comes Out from Meditation, paragraph number 8, sentence number 4 on page 172"^^xsd:string ;
    neo:text "Had both failed, the drama still would be a comedy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3755 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3756,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3757 ;
    neo:id "ee4ac4717c98b18f6d6f627c6104b15b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 1, sentence number 1 on page 173"^^xsd:string ;
    neo:text "Shuzan held out his short staff and said: “If you call this a short staff, you oppose its reality."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3758 a neo:Document ;
    neo:id "329e444fe33d310687864ea414a629f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 2, sentence number 2 on page 173"^^xsd:string ;
    neo:text "If you do not call it a short staff, you ignore the fact."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3759 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "c92ecdeb291c49b24625a31b5f35cdad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 1, sentence number 3 on page 173"^^xsd:string ;
    neo:text "Now what do you wish to call this?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_376 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "51ac3874223aaf8041dc5dadf2f8c3c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 1, sentence number 2 on page 17"^^xsd:string ;
    neo:text "He never quoted sutras nor indulged in scholastic dissertations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3760 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3757,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_84 ;
    neo:id "06c670d343b609e6a411d2b68bab4fdc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 2, sentence number 1 on page 173"^^xsd:string ;
    neo:text "Mumon’s comment: If you call this a short staff, you oppose its reality."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3761 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2426 ;
    neo:id "fcf25c9069f9610e76bb23c3a8937e76"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 2, sentence number 3 on page 173"^^xsd:string ;
    neo:text "It cannot be expressed with words and it cannot be expressed without words."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3762 a neo:Document ;
    neo:id "0868f94d911fc0b06860550a70f1c157"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 2, sentence number 4 on page 173"^^xsd:string ;
    neo:text "Now say quickly what it is."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3763 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3757 ;
    neo:id "4488c0f288fffe8d8ca4ad4542bf242d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 3, sentence number 1 on page 173"^^xsd:string ;
    neo:text "Holding out the short staff, He gave an order of life or death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3765 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2849,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3355,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3766 ;
    neo:id "dcddfdc077685526b7c727582ba34507"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 43. Shuzan’s Short Staff, paragraph number 3, sentence number 2 on page 173"^^xsd:string ;
    neo:text "Positive and negative interwoven, Even Buddhas and patriarchs cannot escape this attack."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3767 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3768,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "5620f15ab447316be11fc223e3c1353a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 1, sentence number 1 on page 174"^^xsd:string ;
    neo:text "Basho said to his disciple: “When you have a staff, I will give it to you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3769 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "66b3a4b90eb54d908bea43f69d92b50d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 1, sentence number 2 on page 174"^^xsd:string ;
    neo:text "If you have no staff, I will take it away from you.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_377 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_378,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_379 ;
    neo:id "3a13f332550c24ab43271bf85fd1ef81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 1, sentence number 3 on page 17"^^xsd:string ;
    neo:text "Instead his words were spoken directly from his heart to the harts of his listeners."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3770 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3771,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "2cb9d22d1526c4978c27e602e01985a1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 2, sentence number 1 on page 174"^^xsd:string ;
    neo:text "Mumon’s comment: When there is no bridge over the creek the staff will help me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3772 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "15914621cc25d82bd5f8a622c132c93d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 2, sentence number 2 on page 174"^^xsd:string ;
    neo:text "When I return home on a moonless night the staff will accompany me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3773 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1792,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3774,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "4b5fd3da358319d98bad360850a0e161"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 2, sentence number 3 on page 174"^^xsd:string ;
    neo:text "But if you call this a staff, you will enter hell like an arrow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3775 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "b7f75fded799e768944c499f3ad581db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 3, sentence number 1 on page 174"^^xsd:string ;
    neo:text "With this staff in my hand I can measure the depths and shallows of the world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3776 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3333,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "99f2fdfeb628c915dc37191132bf6446"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 3, sentence number 2 on page 174"^^xsd:string ;
    neo:text "The staff supports the heavens and makes firm the earth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3777 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2145 ;
    neo:id "45f74dabe76690feacc81266a65235af"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 44. Basho’s Staff, paragraph number 3, sentence number 3 on page 174"^^xsd:string ;
    neo:text "Everywhere it goes the true teaching will be spread."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3778 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3779,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3780,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3781 ;
    neo:id "263b4e787c38333469fd6fbc4a69439d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 1, sentence number 1 on page 175"^^xsd:string ;
    neo:text "Hoen said: “The past and future Buddhas, both are his servants."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3783 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7a5b04f02cf36bcddb42a077b973c716"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 1, sentence number 2 on page 175"^^xsd:string ;
    neo:text "Who is he?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3784 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_368 ;
    neo:id "d61d9f360c5b4029a13c1669daeb4041"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 2, sentence number 1 on page 175"^^xsd:string ;
    neo:text "Mumon’s comment: If you realize clearly who he is, it is as if you met your own father on a busy street."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3785 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3786 ;
    neo:id "f77433d5814a3b0c947e2da217cefb4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 2, sentence number 2 on page 175"^^xsd:string ;
    neo:text "There is no need to ask anyone whether or not your recognition is true."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3787 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3788,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3789 ;
    neo:id "d9c0931989c75c7894718b7e3d2687c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 3, sentence number 1 on page 175"^^xsd:string ;
    neo:text "Do not fight with another’s bow and arrow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3790 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3791,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3792 ;
    neo:id "073f8017e7e08dd35aafd8cde14a3caf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 3, sentence number 2 on page 175"^^xsd:string ;
    neo:text "Do not ride another’s horse."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3793 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2111,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3794 ;
    neo:id "6b1f634e668c4960063339b5e2bc5aa8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 3, sentence number 3 on page 175"^^xsd:string ;
    neo:text "Do not discuss another’s faults."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3795 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2111 ;
    neo:id "beda148e8ade18c4363a6d6964f3d196"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 45. Who Is He?, paragraph number 3, sentence number 4 on page 175"^^xsd:string ;
    neo:text "Do not interfere with another’s work."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3796 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3797,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3798,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_388,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "cef7c7ab6649c0f2ff5be16226e4dc72"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 1, sentence number 1 on page 176"^^xsd:string ;
    neo:text "Sekiso asked: “How can you proceed on from the top of a hundred-foot pole?” Another Zen teacher said: “One who sits on the top of a hundred- foot pole has attained a certain height but still is not handling Zen freely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3799 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3800 ;
    neo:id "8886442097b1e4b8c95bfe27214129c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 1, sentence number 2 on page 176"^^xsd:string ;
    neo:text "He should proceed on from there and appear with his whole body in the ten parts of the world.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_380 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_382,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_383,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "6e2dc6ebdf343b2d53000e1364a667b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 2, sentence number 1 on page 17"^^xsd:string ;
    neo:text "His large audiences angered a priest of the Nichiren sect because the adherents had left to hear about Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3801 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3802 ;
    neo:id "98bb63c9136f34f33596f0ea7aa82e3f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 2, sentence number 1 on page 176"^^xsd:string ;
    neo:text "Mumon’s comment: One can continue his steps or turn his body freely about on the top of the pole."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3803 a neo:Document ;
    neo:id "e41b65dc7e42618c7d9b49f1b37cd4dc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 2, sentence number 2 on page 176"^^xsd:string ;
    neo:text "In either case he should be respected."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3804 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3805 ;
    neo:id "78d93d09a8c38548842db961bd26c2be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 2, sentence number 3 on page 176"^^xsd:string ;
    neo:text "I want to ask you monks, however: How will you proceed from the top of that pole?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3806 a neo:Document ;
    neo:id "c78a8d632b6e324f8d3ca872935e47ec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 2, sentence number 4 on page 176"^^xsd:string ;
    neo:text "Look out!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3807 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_163,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3808,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3809 ;
    neo:id "3a37e0f29ad6f0599f0e3a7078624431"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 3, sentence number 1 on page 176"^^xsd:string ;
    neo:text "The man who lacks the third eye of insight Will cling to the measure of the hundred feet."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3810 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "f8ebcf6a317290f583bd58173fefb352"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 46. Proceed from the Top of the Pole, paragraph number 3, sentence number 2 on page 176"^^xsd:string ;
    neo:text "Such a man will jump from there and kill himself, Like a blind man misleading other blind men."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3811 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3812,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3813 ;
    neo:id "99788f671e9abae12f90c571be693f51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 1, sentence number 1 on page 177"^^xsd:string ;
    neo:text "Tosotsu built three barriers and made the monks pass through them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3814 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2844,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c56d0e7c681f10f6cadf3e2b1fd59147"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 1, sentence number 2 on page 177"^^xsd:string ;
    neo:text "The first barrier is studying Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3815 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3816,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "428024e389ce60310633737626e6b9e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 1, sentence number 3 on page 177"^^xsd:string ;
    neo:text "In studying Zen the aim is to see one’s own true nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3817 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3818 ;
    neo:id "6895926ff525e814d277778f1a27e3c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 1, sentence number 4 on page 177"^^xsd:string ;
    neo:text "Now where is your true nature?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3819 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3146,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3816 ;
    neo:id "ab8bcde69402d9c139ee07a3dc0a8f45"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 2, sentence number 1 on page 177"^^xsd:string ;
    neo:text "Secondly, when one realizes his own true nature he will be free from birth and death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3820 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2916,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "9a8ef6b48e81b285a6e904f293370a2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 2, sentence number 2 on page 177"^^xsd:string ;
    neo:text "Now when you shut the light from your eyes and become a corpse, how can you free yourself?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3821 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3822,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3823 ;
    neo:id "766e6d9a0997d87202ca945ee4149357"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 3, sentence number 1 on page 177"^^xsd:string ;
    neo:text "Thirdly, if you free yourself from birth and death, you should know where you are."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3824 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3825,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "c7b7ca5706f0240a029e8a4ebf60ad2e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 3, sentence number 2 on page 177"^^xsd:string ;
    neo:text "Now your body separates into the four elements."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3826 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_268,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_405 ;
    neo:id "eccd993f47dec88b14a0c982b6948358"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 3, sentence number 3 on page 177"^^xsd:string ;
    neo:text "Where are you?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3827 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3828,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "d65931703f5d8ce121dd516249e29347"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 4, sentence number 1 on page 177"^^xsd:string ;
    neo:text "Mumon’s comment: Whoever can pass these three barriers will be a master wherever he stands."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3829 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "cc5c515653c05fcb4189985dcac6ccc0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 4, sentence number 2 on page 177"^^xsd:string ;
    neo:text "Whatever happens about him he will turn into Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3830 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3831 ;
    neo:id "7b6c51e09e59c1b0915792761b695f91"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 5, sentence number 1 on page 177"^^xsd:string ;
    neo:text "Otherwise he will be living on poor food and not even enough of that to satisfy himself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3832 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "0208ee2935cc9a52d757e4723258339b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 6, sentence number 1 on page 177"^^xsd:string ;
    neo:text "An instant realization sees endless time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3833 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3834,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "d8250c5f86de7fd4588825173bfc0158"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 6, sentence number 2 on page 177"^^xsd:string ;
    neo:text "Endless time is as one moment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3835 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3834 ;
    neo:id "503523a82cef3777ef53c928e2d92d05"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 47. Three Gates of Tosotsu, paragraph number 6, sentence number 3 on page 177"^^xsd:string ;
    neo:text "When one comprehends the endless moment He realizes the person who is seeing it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3836 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2820,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3355,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3837,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3838 ;
    neo:id "210a97ad1abc5f9ff06f7d4681e89d76"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 1, sentence number 1 on page 178"^^xsd:string ;
    neo:text "A Zen pupil asked Kembo: “All Buddhas of the ten parts of the universe enter the one road of Nirvana."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3839 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1624 ;
    neo:id "1801b67691b1647f1e665506b2ccfa64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 1, sentence number 2 on page 178"^^xsd:string ;
    neo:text "Where does that road begin?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_384 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_385,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386 ;
    neo:id "42e5e598cac6e3aac3eada2e24b1c843"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 2, sentence number 2 on page 17"^^xsd:string ;
    neo:text "The self-centered Nichiren priest came to the temple determined to debate with Bankei."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3840 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3838,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3841 ;
    neo:id "f2b6f591ce508950c1abb72bc0f6678f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 2, sentence number 1 on page 178"^^xsd:string ;
    neo:text "Kembo, raising his walking stick and drawing the figure one in the air, said: “Here it is.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3842 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "29b0fe55dde94187bb741859adc4016f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 3, sentence number 1 on page 178"^^xsd:string ;
    neo:text "This pupil went to Ummon and asked the same question."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3843 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3844,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3845,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3846 ;
    neo:id "ca1e50a0936086ef9431f3db7d26c388"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 3, sentence number 2 on page 178"^^xsd:string ;
    neo:text "Ummon, who happened to have a fan in his hand, said: “This fan will reach to the thirty- third heaven and hit the nose of the presiding deity there."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3847 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3848,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3849,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3850 ;
    neo:id "98b2597f0c3d8e1e9454ce2d659027b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 3, sentence number 3 on page 178"^^xsd:string ;
    neo:text "It is like the Dragon Carp of the Eastern Sea tipping over the rain-cloud with his tail.”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3851 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2867,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3852 ;
    neo:id "78f00c54b0a8782ee8a6be635a3be1db"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 1 on page 178"^^xsd:string ;
    neo:text "Mumon’s comment: One teacher enters the deep sea and scratches the earth and raises dust."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3853 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "2e0c1d804a6d8634ce14c9ffa0361717"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 2 on page 178"^^xsd:string ;
    neo:text "The other goes to the mountain top and raises waves that almost touch heaven."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3854 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1773,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3855 ;
    neo:id "5212223dc256df73603bad9bae07a78f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 3 on page 178"^^xsd:string ;
    neo:text "One holds, the other gives out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3856 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3857,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_990 ;
    neo:id "a391ea735308d410f38fd11cdbc89760"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 4 on page 178"^^xsd:string ;
    neo:text "Each supports the profound teaching with a single hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3858 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3838 ;
    neo:id "cbcd7e0fed1cd3b6c5a0b4703413c592"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 5 on page 178"^^xsd:string ;
    neo:text "Kembo and Ummon are like two riders neither of whom can surpass the other."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3859 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132 ;
    neo:id "8e68c51a73af9f7d4b073029920e9a73"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 6 on page 178"^^xsd:string ;
    neo:text "It is very difficult to find the perfect man."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3860 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1624 ;
    neo:id "307cc6f0084fe70f2faf4811ff165859"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 4, sentence number 7 on page 178"^^xsd:string ;
    neo:text "Frankly, neither of them know where the road starts."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3861 a neo:Document ;
    neo:id "bed97f98162f021c6cd4bd1da7e1cd09"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 5, sentence number 1 on page 178"^^xsd:string ;
    neo:text "Before the first step is taken the goal is reached."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3862 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1041,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3117 ;
    neo:id "d2704d0dc1dcf5345367426fc85a970a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 5, sentence number 2 on page 178"^^xsd:string ;
    neo:text "Before the tongue is moved the speech is finished."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3863 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3864,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3865,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3866 ;
    neo:id "704d97285c6b44b768ccafb0119f1e2a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 48. One Road of Kembo, paragraph number 5, sentence number 3 on page 178"^^xsd:string ;
    neo:text "More than brilliant intuition is needed To find the origin of the right road."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3867 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3868,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3869 ;
    neo:id "de78023616b24dd93a5d1bcda25ae9df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 1 on page 178"^^xsd:string ;
    neo:text "Amban, a layman Zen student, said: “Mumon has just published forty-eight koans and called the book Gateless Gate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_387 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_388 ;
    neo:id "3961abe30c9a17e4e34b787b438e68d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 3, sentence number 1 on page 17"^^xsd:string ;
    neo:text "‘Hey, Zen teacher,’ he called out."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3870 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3871 ;
    neo:id "ad9d973bc82a46af7179be86097874c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 2 on page 178"^^xsd:string ;
    neo:text "He criticizes the old patriarchs’ words and actions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3872 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "08ec087bd2a8e4080c85a26f0b8caff7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 3 on page 178"^^xsd:string ;
    neo:text "I think he is very mischievous."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3873 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3874,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3875,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_677 ;
    neo:id "ce6f7c103efd0970331e1bbc8d29da5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 4 on page 178"^^xsd:string ;
    neo:text "He is like an old doughnut seller trying to catch a passerby to force his doughnuts down his mouth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3876 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1239,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2688,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_677 ;
    neo:id "6af11337952284b0f706a0862599bdd2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 5 on page 178"^^xsd:string ;
    neo:text "The customer can neither swallow nor spit out the doughnuts, and this causes suffering."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3877 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "caed89a59322a117f45baa56471e5fb6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 6 on page 178"^^xsd:string ;
    neo:text "Mumon has annoyed everyone enough, so I think I shall add one more as a bargain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3878 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2072,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "5abf8d8b9d5ffad99c3001c5f9659766"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 1, sentence number 7 on page 178"^^xsd:string ;
    neo:text "I wonder if he himself can eat this bargain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3879 a neo:Document ;
    neo:id "29b5777e3b22964ce432e44d9f152b07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 2, sentence number 1 on page 179"^^xsd:string ;
    neo:text "If he can, and digest it well, it will be fine, but if not, we will have to put it back into the frying pan with his forty-eight also and cook them again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3880 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2409,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284 ;
    neo:id "7a2d02409fcb786dc1d683b670438d29"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 2, sentence number 2 on page 179"^^xsd:string ;
    neo:text "Mumon, you eat first, before someone else does:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3881 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "d531a4c10d3e32ad26463a49a8e4b414"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 3, sentence number 1 on page 179"^^xsd:string ;
    neo:text "“Buddha, according to a sutra, once said: ‘Stop, stop."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3882 a neo:Document ;
    neo:id "fbeb7d1724d5f9a8ffbadd6fc4a450fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 5, sentence number 2 on page 179"^^xsd:string ;
    neo:text "Do not speak."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3883 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "2a318b9fdc2441f5707159f9dbc54e1b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 3, sentence number 3 on page 179"^^xsd:string ;
    neo:text "The ultimate truth is not even to think.’”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3884 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3868 ;
    neo:id "45e0144de65bb85cb5fca00cdb898eb9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 1 on page 179"^^xsd:string ;
    neo:text "Amban’s comment: Where did that so-called teaching come from?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3885 a neo:Document ;
    neo:id "e2b1077cbe625c8f29afef289c7b3712"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 2 on page 179"^^xsd:string ;
    neo:text "How is it that one could not even think it?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3886 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_552,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "a91d596b9e154ee156dd742c1cb1a482"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 3 on page 179"^^xsd:string ;
    neo:text "Suppose someone spoke about it then what became of it?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3887 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "5b3efb6683ee787a87c5204346845612"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 4 on page 179"^^xsd:string ;
    neo:text "Buddha himself was a great chatterbox and in this sutra spoke contrarily."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3888 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2830,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_677 ;
    neo:id "41a1382e321c417c5bf49e3f8225a8c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 5 on page 179"^^xsd:string ;
    neo:text "Because of this, persons like Mumon appear afterwards in China and make useless doughnuts, annoying people."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3889 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1452 ;
    neo:id "1742c9d7edbc8c3e8f3a24d7bd9e9704"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 6 on page 179"^^xsd:string ;
    neo:text "What shall we do after all?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_389 a neo:Document ;
    neo:id "5510dcba694cfdbf62fe51ff5ea0e7d0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 3, sentence number 2 on page 17"^^xsd:string ;
    neo:text "‘Wait a minute."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3890 a neo:Document ;
    neo:id "5ede724b48b5e9e2f0624ced6fa625a5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 4, sentence number 7 on page 179"^^xsd:string ;
    neo:text "I will show you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3891 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3868 ;
    neo:id "1af02b8cd7c6cf10294666a2e1fddf6a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 5, sentence number 1 on page 179"^^xsd:string ;
    neo:text "Then Amban put his palms together, folded his hands, and said: “Stop, stop."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3892 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3161,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3893 ;
    neo:id "6eef2f83165aaa35d3ca0318633d5160"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 5, sentence number 3 on page 179"^^xsd:string ;
    neo:text "The ultimate truth is not even to think."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3894 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3869,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3895 ;
    neo:id "08b5f2f86784891c972f4f0d1fe5737a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 5, sentence number 4 on page 179"^^xsd:string ;
    neo:text "And now I will make a little circle on the sutra with my finger and add that five thousand other sutras and Vimalakirti’s gateless gate all are here!”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3896 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "c3a5aac375310097f50818cdaf26c2d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 6, sentence number 1 on page 179"^^xsd:string ;
    neo:text "If anyone tells you fire is light, Pay no attention."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3897 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1939,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3786,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3898 ;
    neo:id "da9ca1f6d0b0d415ef864cffe0a06d18"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 49. Amban’s Addition, paragraph number 6, sentence number 2 on page 179"^^xsd:string ;
    neo:text "When two thieves meet they need no introduction: They recognize each other without question."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3899 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3900 ;
    neo:id "a94cd4a2744367fcd613666d62b82877"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10 BULLS, paragraph number 1, sentence number 1 on page 181"^^xsd:string ;
    neo:text "by Kakuan"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_390 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_391,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_392 ;
    neo:id "dc38498de0dddbb1c14e0f76fad22b19"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 3, sentence number 3 on page 17"^^xsd:string ;
    neo:text "Whoever respects you will obey what you say, but a man like myself does not respect you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3901 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3902 ;
    neo:id "1e70cdb0447acd9a2c79b7b245a86ab3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10 BULLS, paragraph number 3, sentence number 1 on page 183"^^xsd:string ;
    neo:text "Illustrated by Tomikichiro Tokuriki"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3903 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3904,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3905 ;
    neo:id "f3994e4e0c0c94886c0a125f164865d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 1, sentence number 1 on page 184"^^xsd:string ;
    neo:text "In the pasture of this world, I endlessly push aside the tall grasses in"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3906 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3907,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908 ;
    neo:id "6532b4906c8e8e0e7e14d2b7ed2369fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 2, sentence number 1 on page 184"^^xsd:string ;
    neo:text "search of the bull."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3909 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3910,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3911 ;
    neo:id "85f4d0044a56384a7444674916b0b24a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 2, sentence number 2 on page 184"^^xsd:string ;
    neo:text "Following unnamed rivers, lost upon the interpenetrating paths of"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3912 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3913 ;
    neo:id "d4e72389477b84ea7f54768b85c85a7a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 3, sentence number 1 on page 184"^^xsd:string ;
    neo:text "distant mountains, My strength failing and my vitality exhausted, I cannot find the bull."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3914 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1015,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3915 ;
    neo:id "3ef5929fb7bcde7142fc40cac07a0dd5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 3, sentence number 2 on page 184"^^xsd:string ;
    neo:text "I only hear the locusts chirring through the forest at night."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3916 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908 ;
    neo:id "0c8b0aac6e5b3cde65d499d5dcc1bdb3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 1 on page 184"^^xsd:string ;
    neo:text "Comment: The bull never has been lost."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3917 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3907,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3918 ;
    neo:id "f33cfc69b725fec576bb66f6b19bf6c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 2 on page 184"^^xsd:string ;
    neo:text "What need is there to search?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3919 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3818 ;
    neo:id "cb470f24e407ff471e80f721ed37d625"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 3 on page 184"^^xsd:string ;
    neo:text "Only because of separation from my true nature, I fail to find him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3920 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3921 ;
    neo:id "d73633c6bd9c8efc65f7cddc03987f30"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 4 on page 184"^^xsd:string ;
    neo:text "In the confusion of the senses I lose even his tracks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3922 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3923 ;
    neo:id "77e9d1a7f97d2ba4c89305a9592c37e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 5 on page 184"^^xsd:string ;
    neo:text "Far from home, I see many crossroads, but which way is the right one I know not."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3924 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3313,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3925,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3926 ;
    neo:id "6a34f631b81b4a193664cec1c4e6328f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 1. The Search for the Bull, paragraph number 4, sentence number 6 on page 184"^^xsd:string ;
    neo:text "Greed and fear, good and bad, entangle me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3927 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1571,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3928,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3929 ;
    neo:id "d9fd82c3b7e346c08c00696f417ece49"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 1, sentence number 1 on page 185"^^xsd:string ;
    neo:text "Along the riverbank under the trees, I discover footprints!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_393 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "a01c53d76efa413f4cd45a11c318f21f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 3, sentence number 4 on page 17"^^xsd:string ;
    neo:text "Can you make me obey yon?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3930 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1570,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3931 ;
    neo:id "ca5542f7913d2069896b638a4b16f56b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 1, sentence number 2 on page 185"^^xsd:string ;
    neo:text "Even under the fragrant grass I see his prints."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3932 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1631 ;
    neo:id "9aae71ab3f883e23f4e49f1be20e1ceb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 1, sentence number 3 on page 185"^^xsd:string ;
    neo:text "Deep in remote mountains they are found."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3933 a neo:Document ;
    neo:id "a3286845bda57d749a0f96b075dbba1b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 1, sentence number 4 on page 185"^^xsd:string ;
    neo:text "These traces no more can be hidden than one’s nose, looking"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3934 a neo:Document ;
    neo:id "480c030d7de1000d5aececc8709a3100"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 2, sentence number 1 on page 185"^^xsd:string ;
    neo:text "heavenward."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3935 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908 ;
    neo:id "dcef3f29d8a5abcb55bd0b9ddd14450a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 3, sentence number 1 on page 185"^^xsd:string ;
    neo:text "Comment: Understanding the teaching, I see the footprints of the bull."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3936 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3937,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3938,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3939,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3940 ;
    neo:id "f67d9a866cfcd06c7213b5a6a93f09d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 3, sentence number 2 on page 185"^^xsd:string ;
    neo:text "Then I learn that, just as many utensils are made from one metal, so too are myriad entities made of the fabric of self."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3941 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3942,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3944,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62 ;
    neo:id "a52d5b23808e5889dbb099646146a569"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 3, sentence number 3 on page 185"^^xsd:string ;
    neo:text "Unless I discriminate, how will I perceive the true from the untrue?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3945 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1854,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3278 ;
    neo:id "3f67fc7e6daff629200b74a2ea693702"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 2. Discovering the Footprints, paragraph number 3, sentence number 4 on page 185"^^xsd:string ;
    neo:text "Not yet having entered the gate, nevertheless I have discerned the path."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3946 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3947,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3948 ;
    neo:id "6827288d4d9e60042836baf205a596e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 1, sentence number 1 on page 186"^^xsd:string ;
    neo:text "I hear the song of the nightingale."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3949 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1009,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3612,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3950,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3951 ;
    neo:id "d23502622c90d82aef723592b4a73e44"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 1, sentence number 2 on page 186"^^xsd:string ;
    neo:text "The sun is warm, the wind is mild, willows are green along the shore, Here no bull can hide!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_395 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "211885ab796fb0e7072620a31afe9b95"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 4, sentence number 1 on page 17"^^xsd:string ;
    neo:text "‘Come up beside me and I will show you,’ said Bankei."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3952 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3646 ;
    neo:id "4a62037ef33f02a1bbaddf0ab0a9182e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 1, sentence number 3 on page 186"^^xsd:string ;
    neo:text "What artist can draw that massive head, those majestic horns?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3953 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1181 ;
    neo:id "0cbcff04bcf85ba01c2359d0461405b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 2, sentence number 1 on page 186"^^xsd:string ;
    neo:text "Comment: When one hears the voice, one can sense its source."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3954 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3278,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3955 ;
    neo:id "dce69b9f8eeee949ed1cfed8fa6ade87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 2, sentence number 2 on page 186"^^xsd:string ;
    neo:text "As soon as the six senses merge, the gate is entered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3956 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908 ;
    neo:id "da1e3769a06ee0d7b17bc1872a68ddf9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 2, sentence number 3 on page 186"^^xsd:string ;
    neo:text "Wherever one enters one sees the head of the bull!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3957 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2681,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3631,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3958,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3959,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "e35eeaa173a65f073d1d54df2db0aa2b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 2, sentence number 4 on page 186"^^xsd:string ;
    neo:text "This unity is like salt in water, like color in dyestuff."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_396 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_397 ;
    neo:id "367405cf9ddbc2152f6b54fe47a5ce83"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 5, sentence number 1 on page 17"^^xsd:string ;
    neo:text "Proudly the priest pushed his way through the crowd to the teacher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3960 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3041,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3961 ;
    neo:id "63babeb4051d98acf22521f5010c5423"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 3. Perceiving the Bull, paragraph number 2, sentence number 5 on page 186"^^xsd:string ;
    neo:text "The slightest thing is not apart from self."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3962 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "3d32bf38108e639a96e438c84c3a536d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 1, sentence number 1 on page 187"^^xsd:string ;
    neo:text "I seize him with a terrific struggle."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3963 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3462,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3964 ;
    neo:id "a1234f32ed4e1507ae371c11ac3c50a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 1, sentence number 2 on page 187"^^xsd:string ;
    neo:text "His great will and power are inexhaustible."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3965 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3966,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3967,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3968 ;
    neo:id "14a2734f336a4e32777cf4d6e22b4aed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 1, sentence number 3 on page 187"^^xsd:string ;
    neo:text "He charges to the high plateau far above the cloud-mists, Or in an impenetrable ravine he stands."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3969 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3915,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "65bc057c4c7335bd4207dc33baa45632"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 2, sentence number 1 on page 187"^^xsd:string ;
    neo:text "Comment: He dwelt in the forest a long time, but I caught him today!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3970 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3971,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3972,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3973 ;
    neo:id "3b437b650ebd27823ab0856f0764c9cc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 2, sentence number 2 on page 187"^^xsd:string ;
    neo:text "Infatuation for scenery interferes with his direction."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3974 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3975 ;
    neo:id "ff4b2ce3bc3b7757ba94605877c72822"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 2, sentence number 3 on page 187"^^xsd:string ;
    neo:text "Longing for sweeter grass, he wanders away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3977 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3978 ;
    neo:id "3d6b8609cf319532607eee2206f5b8f0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 2, sentence number 4 on page 187"^^xsd:string ;
    neo:text "His mind still is stubborn and unbridled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_398 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "1248a6966468a679a9a18869833215c9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 6, sentence number 1 on page 17"^^xsd:string ;
    neo:text "Bankei smiled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3981 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3583,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "64106937d0106deeb70672c8b063fa7f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Catching the Bull, paragraph number 2, sentence number 5 on page 187"^^xsd:string ;
    neo:text "If I wish him to submit, I must raise my whip."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3982 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3583,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3983,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3984 ;
    neo:id "342dbd99b3708501df2f6c2b6ad56641"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 1, sentence number 1 on page 188"^^xsd:string ;
    neo:text "The whip and rope are necessary, Else he might stray off down some dusty road."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3985 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "b58f1a8c2180605481617ce9a5da53b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 1, sentence number 2 on page 188"^^xsd:string ;
    neo:text "Being well trained, he becomes naturally gentle."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3988 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "b086733446325b4282984883dea3a07a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 1, sentence number 3 on page 188"^^xsd:string ;
    neo:text "Then, unfettered, he obeys his master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3989 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "ea6a0668b65380531d97ee318de58057"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 2, sentence number 1 on page 188"^^xsd:string ;
    neo:text "Comment: When one thought arises, another thought follows."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_399 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_400 ;
    neo:id "220e670f5a5c0ed87099e628daf89aaa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 6, sentence number 2 on page 17"^^xsd:string ;
    neo:text "‘Come over to my left side.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3990 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3991,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3992 ;
    neo:id "02762f2222a50728084695b653c8bdd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 2, sentence number 2 on page 188"^^xsd:string ;
    neo:text "When the first thought springs from enlightenment, all subsequent thoughts are true."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3993 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1852,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3994,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_505 ;
    neo:id "8555facf1d719a9eb660107faebf9de3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 2, sentence number 3 on page 188"^^xsd:string ;
    neo:text "Through delusion, one makes everything untrue."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3995 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1327,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1328,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1852 ;
    neo:id "d4e111c7ba61a56f00fc56ac2a7a0d87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 2, sentence number 4 on page 188"^^xsd:string ;
    neo:text "Delusion is not caused by objectivity; it is the result of subjectivity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3996 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_170,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3997 ;
    neo:id "02473f941dbb0f322d2826133058cd6f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. Taming the Bull, paragraph number 2, sentence number 5 on page 188"^^xsd:string ;
    neo:text "Hold the nose-ring tight and do not allow even a doubt."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3998 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3999 ;
    neo:id "5374f2d8baa09e2f9e41a26ac34519a0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 1, sentence number 1 on page 189"^^xsd:string ;
    neo:text "Mounting the bull, slowly I return homeward."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4000 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1181,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2153,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_232 ;
    neo:id "6a1e340b00a174330cc19c0257bf93ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 1, sentence number 2 on page 189"^^xsd:string ;
    neo:text "The voice of my flute intones through the evening."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4001 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4002,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4003,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4004,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "8fafd554db18cebdc0efca8e0859918d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 1, sentence number 3 on page 189"^^xsd:string ;
    neo:text "Measuring with hand-beats the pulsating harmony, I direct the endless"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4005 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4006 ;
    neo:id "d7cfd1d50e4daf6298649c4445087464"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 2, sentence number 1 on page 189"^^xsd:string ;
    neo:text "rhythm."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4007 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4008 ;
    neo:id "9d699425c2ef5d4bd29bc00ff19c17b9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 2, sentence number 2 on page 189"^^xsd:string ;
    neo:text "Whoever hears this melody will join me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4009 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4010,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4011,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4012 ;
    neo:id "3653b9d1088548aedde618651b3a5759"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 3, sentence number 1 on page 189"^^xsd:string ;
    neo:text "Comment: This struggle is over; gain and loss are assimilated."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_401 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381 ;
    neo:id "ac99b70a5a7b2cf4f7824f1c9bc6798a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 7, sentence number 1 on page 17"^^xsd:string ;
    neo:text "The priest obeyed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4013 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3948,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4014,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4015 ;
    neo:id "34281146ab31fbdacb2cbd8f97ab69fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 3, sentence number 2 on page 189"^^xsd:string ;
    neo:text "I sing the song of the village woodsman, and play the tunes of the children."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4016 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_799 ;
    neo:id "5dee517c66d0d10835bc39901cbf8c19"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 3, sentence number 3 on page 189"^^xsd:string ;
    neo:text "Astride the bull, I observe the clouds above."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4017 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "872276260b21f8741b926683367f672e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. Riding the Bull Home, paragraph number 3, sentence number 4 on page 189"^^xsd:string ;
    neo:text "Onward I go, no matter who may wish to call me back."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4018 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "092399bc41f61e6b978d6bc06e7edc03"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 1, sentence number 1 on page 190"^^xsd:string ;
    neo:text "Astride the bull, I reach home."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4019 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "ccd63b4338980c78fb9731673e950f44"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 1, sentence number 2 on page 190"^^xsd:string ;
    neo:text "I am serene."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4020 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908 ;
    neo:id "ca13a2d4127e8197d6be3478b3dc837e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 1, sentence number 3 on page 190"^^xsd:string ;
    neo:text "The bull too can rest."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4021 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4022 ;
    neo:id "3f0078dff2bfe811915fb19dc8e1a582"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 1, sentence number 4 on page 190"^^xsd:string ;
    neo:text "The dawn has come."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4023 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3583,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3983,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4024 ;
    neo:id "244be5fe4d8d0285301affc878ca4c28"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 1, sentence number 5 on page 190"^^xsd:string ;
    neo:text "In blissful repose, Within my thatched dwelling I have abandoned the whip and rope."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4025 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2319 ;
    neo:id "f12df8c5e84727e9d082eac7ee227281"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 2, sentence number 1 on page 190"^^xsd:string ;
    neo:text "Comment: All is one law, not two."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4026 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_504 ;
    neo:id "513fac413908ff423d6960460ff424c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 2, sentence number 2 on page 190"^^xsd:string ;
    neo:text "We only make the bull a temporary subject."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4027 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4028,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4029,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4030 ;
    neo:id "aec4459739f7cf3583fa1cd84939020d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 2, sentence number 3 on page 190"^^xsd:string ;
    neo:text "It is as the relation of rabbit and trap, of fish and net."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_403 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "c9c2cfa9451b55658a9a1e141d7eda76"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 8, sentence number 1 on page 17"^^xsd:string ;
    neo:text "‘No,’ said Bankei, ‘we may talk better if you are on the right side."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4031 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1349,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4032,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4033,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_523 ;
    neo:id "db7447f754affb686d2e53330a77d066"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 2, sentence number 4 on page 190"^^xsd:string ;
    neo:text "It is as gold and dross, or the moon emerging from a cloud."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4034 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4035,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4036 ;
    neo:id "ac2dcb2df4f15fb555a9cdb186925bce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. The Bull Transcended, paragraph number 2, sentence number 5 on page 190"^^xsd:string ;
    neo:text "One path of clear light travels on throughout endless time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4037 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3583,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3908,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3983,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4038 ;
    neo:id "10d07e5afb9906195b9e99ce9c7805b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 1, sentence number 1 on page 191"^^xsd:string ;
    neo:text "Whip, rope, person, and bull — all merge in No-Thing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4039 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1455,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2297 ;
    neo:id "f9764da301cc3b1e4797e0a2efce8082"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 1, sentence number 2 on page 191"^^xsd:string ;
    neo:text "This heaven is so vast no message can stain it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_404 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_405 ;
    neo:id "b74f00f12ad277e28713d06212722ea0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 8, sentence number 2 on page 17"^^xsd:string ;
    neo:text "Step over here.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4040 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2694,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4041 ;
    neo:id "3006df82e0a88a3150387df11bfa4a2d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 1, sentence number 3 on page 191"^^xsd:string ;
    neo:text "How may a snowflake exist in a raging fire?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4042 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2849 ;
    neo:id "fc38fdee9ea76568bf28f534e68af790"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 1, sentence number 4 on page 191"^^xsd:string ;
    neo:text "Here are the footprints of the patriarchs."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4043 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2424 ;
    neo:id "99a0f24cf274259a5ff7b6767bbfe9a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 1 on page 191"^^xsd:string ;
    neo:text "Comment: Mediocrity is gone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4044 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4045 ;
    neo:id "2655f1718034d706198c413261752a5e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 2 on page 191"^^xsd:string ;
    neo:text "Mind is clear of limitation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4046 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "30d94a129b7dca300b8d8f2db1e1d127"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 3 on page 191"^^xsd:string ;
    neo:text "I seek no state of enlightenment."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4047 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "816896d707a40be9844cbb69f47d53fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 4 on page 191"^^xsd:string ;
    neo:text "Neither do I remain where no enlightenment exists."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4048 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2897 ;
    neo:id "d1a048fbe49cc1a4581e0c5f5941a2fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 5 on page 191"^^xsd:string ;
    neo:text "Since I linger in neither condition, eyes cannot see me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4049 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1854,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3409,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492 ;
    neo:id "a18e49b130020bc1395bebfb00e677bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Both Bull and Self Transcended, paragraph number 2, sentence number 6 on page 191"^^xsd:string ;
    neo:text "If hundreds of birds strew my path with flowers, such praise would be meaningless."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4050 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_113,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4051,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_896 ;
    neo:id "fc041df9ece793037792a31edf16ee3b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 1, sentence number 1 on page 192"^^xsd:string ;
    neo:text "Too many steps have been taken returning to the root and the source."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4052 a neo:Document ;
    neo:id "f4cfb97d8b4f167db3a886514d2bf9fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 1, sentence number 2 on page 192"^^xsd:string ;
    neo:text "Better to have been blind and deaf from the beginning!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4053 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2393,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_993 ;
    neo:id "3e6408adefdc26cd4b2e3ea684f13cc9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 1, sentence number 3 on page 192"^^xsd:string ;
    neo:text "Dwelling in one’s true abode, unconcerned with that without — The river flows tranquilly on and the flowers are red."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4054 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4055,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62 ;
    neo:id "3fb139da1d8802e04d4b763df3afb034"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 2, sentence number 1 on page 192"^^xsd:string ;
    neo:text "Comment: From the beginning, truth is clear."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4056 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4057,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4058,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4059 ;
    neo:id "89075f8e236b0c83fe00b12549914a3a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 2, sentence number 2 on page 192"^^xsd:string ;
    neo:text "Poised in silence, I observe the forms of integration and disintegration."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_406 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_381,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_407 ;
    neo:id "58e731a4c052488f4e0fec87b165fc5d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 9, sentence number 1 on page 17"^^xsd:string ;
    neo:text "The priest proudly stepped over to the right."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4060 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4061,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4062,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "7e29070729203dab865eff295c93145a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. Reaching the Source, paragraph number 2, sentence number 3 on page 192"^^xsd:string ;
    neo:text "One who is not attached to “form” need not be “reformed.” The water is emerald, the mountain is indigo, and I see that which is creating and that which is destroying."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4063 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4064 ;
    neo:id "0e2c075532886f82bfa1514e86ecac7d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 1, sentence number 1 on page 193"^^xsd:string ;
    neo:text "Barefooted and naked of breast, I mingle with the people of the world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4065 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "dd0088a865e9f2d973010a2363174dd4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 1, sentence number 2 on page 193"^^xsd:string ;
    neo:text "My clothes are ragged and dust-laden, and I am ever blissful."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4067 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4068 ;
    neo:id "90d6cce82ac1e7b0222b9ba1e54a1fd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 1, sentence number 3 on page 193"^^xsd:string ;
    neo:text "I use no magic to extend my life; Now, before me, the dead trees become alive."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4069 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1454,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3278 ;
    neo:id "1c17192850fdd2dafb76fa24d9470a10"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 2, sentence number 1 on page 193"^^xsd:string ;
    neo:text "Comment: Inside my gate, a thousand sages do not know me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4070 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2158 ;
    neo:id "d59cde58904e6d5b8554824c111df02a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 2, sentence number 2 on page 193"^^xsd:string ;
    neo:text "The beauty of my garden is invisible."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4071 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2849,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3907,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3929 ;
    neo:id "2a43e5cc668afc72d263331dd6d11d15"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 2, sentence number 3 on page 193"^^xsd:string ;
    neo:text "Why should one search for the footprints of the patriarchs?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4072 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4073,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4074,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "36048ce06bc5ca04f6924a5ffe2a67f4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 2, sentence number 4 on page 193"^^xsd:string ;
    neo:text "I go to the market place with my wine bottle and return home with my staff."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4075 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4076,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "ad4bac1e680b2813ed9c0ebcc81649dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. In the World, paragraph number 2, sentence number 5 on page 193"^^xsd:string ;
    neo:text "I visit the wineshop and the market, and everyone I look upon becomes enlightened."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4077 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_118 ;
    neo:id "45d703864883835058379f645f4e4225"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 1, sentence number 1 on page 195"^^xsd:string ;
    neo:text "Transcribed by Paul Reps"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4078 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "c62715a2dd9cbaa574efb1a32bf76e71"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 2, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Zen is nothing new, neither is it anything old."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4079 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "3c77eb9629580de867c5671c100a436f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 2, sentence number 2 on page 196"^^xsd:string ;
    neo:text "Long before Buddha was born the search was on in India, as the present work shows."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_408 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_373 ;
    neo:id "e135cc776854d3c05e9a93460ddce8d1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 10, sentence number 1 on page 17"^^xsd:string ;
    neo:text "‘You see,’ observed Bankei, ‘you are obeying me and I think you are a very gentle person."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4080 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_17,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_182,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3612,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4081,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4082,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_660,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "95a3e9142e300f63d63eb7ec1164c831"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 3, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Long after man has forgotten such words as Zen and Buddha, satori and koan, China and Japan and America—still the search will go on, still Zen will be seen even in flower, and grass-blade, before the sun."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4083 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4084,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4085 ;
    neo:id "d2c166fb455096a3c7a6d6dfb3a21555"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 4, sentence number 1 on page 196"^^xsd:string ;
    neo:text "The following is adapted from the preface to the first version in English of this ancient work."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4086 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4087,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_43,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "8884b911bf6bc8544ab766e7493d5d14"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 5, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Wandering in the ineffable beauty of Kashmir, above Srinagar I come upon the hermitage of Lakshmanjoo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4088 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4089,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4090,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4091,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4092,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4093 ;
    neo:id "c471e457130e9b9be8f16c1c0b789147"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 6, sentence number 1 on page 196"^^xsd:string ;
    neo:text "It overlooks green rice fields, the garden, of Shalimar and Nishat Bagh, lakes fringed with lotus."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_409 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "c577ab077e863e07bac5045ede1d7623"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 4. Obedience, paragraph number 10, sentence number 2 on page 17"^^xsd:string ;
    neo:text "Now sit down and listen.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4094 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4095,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "1603a150f5c43042324c14ddd1f0ccc2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 6, sentence number 2 on page 196"^^xsd:string ;
    neo:text "Water streams down from a mountaintop."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4096 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "2030e2c635d96aab8643a3d6e2536cc9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 7, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Here Lakshmanjoo—tall, full bodied, shining—welcomes me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4097 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4098,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4099,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4100 ;
    neo:id "2cf43fa1b4fd60626e6229114bc5cbdb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 7, sentence number 2 on page 196"^^xsd:string ;
    neo:text "He shares with me this ancient teaching from the Vigyan Bhairava and Sochanda Tantra, both written about four thousand years ago, and from Malini Vijaya Tantra, probably another thousand years older yet."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_41 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_42,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_43,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "1899f16203403eaa01891407498633c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 4, sentence number 2 on page 7"^^xsd:string ;
    neo:text "It presents in ancient teaching, still alive in Kashmir and parts of India after more than four thousand years that may well be the roots of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_410 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_412,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413 ;
    neo:id "9b1eba1f92be6ff5d1f2e36308c7f170"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 1, sentence number 1 on page 18"^^xsd:string ;
    neo:text "Twenty monks and one nun, who was named Eshun, were practicing meditation with a certain Zen master."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4101 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4102,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_42,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "05139a89b4e67273dd61d2b62fffa0d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 7, sentence number 3 on page 196"^^xsd:string ;
    neo:text "It is an ancient teaching, copied and recopied countless times, and from it Lakshmanjoo has made the beginning of an English version."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4103 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653 ;
    neo:id "a4426623e73f18b1a1fec532a825dac4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 7, sentence number 4 on page 196"^^xsd:string ;
    neo:text "I transcribe it eleven more times to get it into the form given here."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4104 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4105,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4106 ;
    neo:id "fe0793ef0f72a8dbcccde2293dc8aeb8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 8, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Shiva first chanted it to his consort Devi in a language of love we have yet to learn."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4107 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4108 ;
    neo:id "3c60164a11189ae3d474936038118a7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 8, sentence number 2 on page 196"^^xsd:string ;
    neo:text "It is about the Immanent experience."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4109 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4111,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4112 ;
    neo:id "f5a5445efe2a69509184d9b109b2755a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 8, sentence number 3 on page 196"^^xsd:string ;
    neo:text "It presents 112 ways to open the invisible door of consciousness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4113 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "d36c6dbfc9a7aef8cbb1b1320c9c690c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 8, sentence number 4 on page 196"^^xsd:string ;
    neo:text "I see Lakshmanjoo gives his life to its practicing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4115 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4116 ;
    neo:id "a9f505fb3d15d47f33be927bc52a5586"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 9, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Some of the ways may appear redundant, yet each differs from any other."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4117 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1092,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4118,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4119 ;
    neo:id "01818b4ceef109ea62b31da39904c5e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 9, sentence number 2 on page 196"^^xsd:string ;
    neo:text "Some may seem simple, yet any one requires constant dedication even to test it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4120 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4121,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4122,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4123,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4124,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4125 ;
    neo:id "6cefbd9c382ae868c1a5d5a7a76cad75"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 10, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Machines, ledgers, dancers, athletes balance."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4126 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_36,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4125,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4128 ;
    neo:id "05f3aad32bc6ef895eaf3052b75cd935"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 10, sentence number 2 on page 196"^^xsd:string ;
    neo:text "Just as centering or balance augments various skills, so it may awareness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4129 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2532,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4125,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4130 ;
    neo:id "697938027c45bf9312bbd9177005788f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 10, sentence number 3 on page 196"^^xsd:string ;
    neo:text "As an experiment, try standing equally on both feet; then imagine you are shifting your balance slightly from foot to foot: just as balance centers, do you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4131 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4132 ;
    neo:id "35eb484ff8178f1d3f1fa7d4096bda5a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 11, sentence number 1 on page 196"^^xsd:string ;
    neo:text "If we are conscious in part, this implies more inclusive consciousness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4133 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_990 ;
    neo:id "b7e86cd617020153c33b0d82750ffb81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 11, sentence number 2 on page 196"^^xsd:string ;
    neo:text "Have you a hand?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4134 a neo:Document ;
    neo:id "b127099c71415d532da3a26ed73eb041"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 11, sentence number 3 on page 196"^^xsd:string ;
    neo:text "Yes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4135 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2859 ;
    neo:id "2cd6b88de61a1271c0303e3010053a23"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 11, sentence number 4 on page 196"^^xsd:string ;
    neo:text "That you know without doubt."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4136 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_990 ;
    neo:id "866eb7f37529834b211053b946a151f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 11, sentence number 5 on page 196"^^xsd:string ;
    neo:text "But until asked the question were you cognizant of the hand apart?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4137 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2351,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4138 ;
    neo:id "d0352a4340739abd582c7a526162659e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 12, sentence number 1 on page 196"^^xsd:string ;
    neo:text "Surely men as inspiritors, known and unknown to the world, have shared a common uncommon discovery."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4139 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_147,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2820,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4140,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4141,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4142,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4143,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4144,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4145,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4146,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_83,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "1bf7554c17cced5d3c7bf8f6c99a994e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 12, sentence number 2 on page 196"^^xsd:string ;
    neo:text "The Tao of Lao-tse, Nirvana of Buddha, Jehovah of Moses, the Father of Jesus, the Allah of Mohammed — all point to the experience. No-thing-ness, spirit—once touched, the whole life clears."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_414 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411 ;
    neo:id "b8cc720c03704bd2df1afd177bc3e3c4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 2, sentence number 1 on page 18"^^xsd:string ;
    neo:text "Eshun was very pretty even though her head was shaved and her dress plain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4147 a neo:Document ;
    neo:id "37c68163a9b9fe25cab8d5c5208256da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 13, sentence number 1 on page 198"^^xsd:string ;
    neo:text "DEVI SAYS:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4148 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4105 ;
    neo:id "4b08fd713d656731c60091f445c55b10"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 14, sentence number 1 on page 198"^^xsd:string ;
    neo:text "O Shiva, what is your reality?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4149 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148 ;
    neo:id "ee15c315cb5c0b04b9d2547543349ce7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 15, sentence number 1 on page 198"^^xsd:string ;
    neo:text "What is this wonder-filled universe?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_415 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "da127ac12e19314673fdb61a90e499e9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 2, sentence number 2 on page 18"^^xsd:string ;
    neo:text "Several monks secretly fell in love with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4150 a neo:Document ;
    neo:id "3854775abb01458c071aa8ba084a1b24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 16, sentence number 1 on page 198"^^xsd:string ;
    neo:text "What constitutes seed?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4151 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4152 ;
    neo:id "efee262b21b06b3facc3f4bb1d8192c9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 17, sentence number 1 on page 198"^^xsd:string ;
    neo:text "Who centers the universal wheel?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4153 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682 ;
    neo:id "ff44f4f151faf350ca770e7118e16df0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 18, sentence number 1 on page 198"^^xsd:string ;
    neo:text "What is this life beyond form pervading forms?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4154 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4155,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4156,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4157,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4158,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "eb8d08b641599b95173686909a092c87"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 19, sentence number 1 on page 198"^^xsd:string ;
    neo:text "How may we enter it fully, above space and time, names and descriptions?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4159 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4160 ;
    neo:id "20b09009cc7c3787662b77ccb9134ab5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 20, sentence number 1 on page 198"^^xsd:string ;
    neo:text "Let my doubts be cleared!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_416 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_417,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_418 ;
    neo:id "e39a09ded1a35523b7f42685b073c2c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 3, sentence number 1 on page 18"^^xsd:string ;
    neo:text "One of them wrote her a love letter, insisting upon a private meeting."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4161 a neo:Document ;
    neo:id "f492292dfd5d61527510808530684567"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 21, sentence number 1 on page 198"^^xsd:string ;
    neo:text "SHIVA REPLIES:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4162 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4105,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4106,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4163 ;
    neo:id "a48db12ff12087f63615b3199adba3ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 22, sentence number 1 on page 198"^^xsd:string ;
    neo:text "[Devi, though already enlightened, has asked the foregoing questions so others through the universe might receive Shiva’s instructions."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4164 a neo:Document ;
    neo:id "136294134eb47aca0cc7beff52944bc2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 22, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Now follow Shiva’s reply, giving the 112 ways.]"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4165 a neo:Document ;
    neo:id "1d41e6f55521cdba4fc73febd09d2eb4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 23, sentence number 1 on page 198"^^xsd:string ;
    neo:text "1."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4166 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4167 ;
    neo:id "95bb569d8ebf6bbe30961ad98b895532"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 23, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Radiant one, this experience may dawn between two breaths."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4168 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4170 ;
    neo:id "746326cf25f73ffea05517f208c04780"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 23, sentence number 3 on page 198"^^xsd:string ;
    neo:text "After breath comes in (down) and just before turning up (out) — the beneficence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4171 a neo:Document ;
    neo:id "3e35563210f995ee79a073fa882e1fd6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 24, sentence number 1 on page 198"^^xsd:string ;
    neo:text "2."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4172 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4173 ;
    neo:id "efd894388f5f160e665fac4a08045cb2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 24, sentence number 2 on page 198"^^xsd:string ;
    neo:text "As breath turns from down to up, and again as breath curves from up to down—through both these turns, realize."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4174 a neo:Document ;
    neo:id "d9cb741476305f454667e117d9e4f7ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 25, sentence number 1 on page 198"^^xsd:string ;
    neo:text "3."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4175 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4177,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4178 ;
    neo:id "6faa5fbd99df7efb3c46dfbf1dcab085"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 25, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Or, whenever inbreath and outbreath fuse, at this instant touch the energyless energy-filled center."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4179 a neo:Document ;
    neo:id "ee2468a702bdc29871e84d63e851dd26"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 26, sentence number 1 on page 198"^^xsd:string ;
    neo:text "4."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4180 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3961,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169 ;
    neo:id "79526ed095ba56e4219acef0f7bbc08d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 26, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Or, when breath is all out (up) and stopped of itself, or all in (down) and stopped—in such universal pause, one’s small self vanishes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4181 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4182 ;
    neo:id "11273cb940acab93105788a98b5457c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 26, sentence number 3 on page 198"^^xsd:string ;
    neo:text "This is difficult only for the impure."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4183 a neo:Document ;
    neo:id "a85803f14639bef7f4539bad631d088c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 27, sentence number 1 on page 198"^^xsd:string ;
    neo:text "5."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4184 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2675,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4185,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4186,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4187 ;
    neo:id "935adbb23f08174e0abd1bf80a159b9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 27, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Consider your essence as light rays rising from center to center up the vertebrae, and so rises livingness in you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4188 a neo:Document ;
    neo:id "4363b12ae39947f045a4fb5fad740dc8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 28, sentence number 1 on page 198"^^xsd:string ;
    neo:text "6."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4189 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3056,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4190 ;
    neo:id "b621e6b89d38143fb8a59e5f618dad52"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 28, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Or in the spaces between, feel this as lightning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_419 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411 ;
    neo:id "e6984b4a202f45f76760e3b8e2ab6149"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 4, sentence number 1 on page 18"^^xsd:string ;
    neo:text "Eshun did not reply."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4191 a neo:Document ;
    neo:id "947ec8a6bed18b9c1a6fc73274ad4ac5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 29, sentence number 1 on page 198"^^xsd:string ;
    neo:text "7."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4192 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1020,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4106,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4193,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4194,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_915 ;
    neo:id "5ab0a4497566ce8045bf9b1ad863e1c4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 29, sentence number 2 on page 198"^^xsd:string ;
    neo:text "Devi, imagine the Sanskrit letters in these honey-filled foci of awareness, first as letters, then more subtly as sounds, then as most subtle feeling."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4196 a neo:Document ;
    neo:id "4a9891074ce0434f8c5a35bb781b438c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 29, sentence number 3 on page 198"^^xsd:string ;
    neo:text "Then, leaving them aside, be free."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4197 a neo:Document ;
    neo:id "25419da0c8dabdf8e3437f3cbbd94fd6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 30, sentence number 1 on page 199"^^xsd:string ;
    neo:text "8."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4198 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4199,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4200,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "00c650c4342115082257d4c9876425e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 30, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Attention between eyebrows, let mind be before thought."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_420 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_411,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_421,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "298449cb286f9f62fce8965186e41523"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 4, sentence number 2 on page 18"^^xsd:string ;
    neo:text "The following day the master gave a lecture to the group, and when it was over, Eshun arose."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4201 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4202,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "85dc0c899d92b17a5ca3f4479ee358b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 30, sentence number 3 on page 199"^^xsd:string ;
    neo:text "Let form fill with breath-essence to the top of the head, and there shower as light."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4203 a neo:Document ;
    neo:id "d39aeb060e81b0fc04267ae08255938a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 31, sentence number 1 on page 199"^^xsd:string ;
    neo:text "9."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4204 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4205,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4206,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4207,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4208 ;
    neo:id "0c1473d669bb0237a405c16541969b9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 31, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Or, imagine the five-colored circles of the peacock tail to be your five senses in illimitable space."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4209 a neo:Document ;
    neo:id "929e1467c86aabd655846c64464d1ade"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 31, sentence number 3 on page 199"^^xsd:string ;
    neo:text "Now let their beauty melt within."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4210 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2662,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3357,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4156 ;
    neo:id "5c24f18773a7b28823ec9bbc1eed5a96"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 31, sentence number 4 on page 199"^^xsd:string ;
    neo:text "Similarly, at any point in space or on a wall — until the point dissolves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4211 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4212,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4213 ;
    neo:id "4a9d7f2f709492c701682ad095bfbbfc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 31, sentence number 5 on page 199"^^xsd:string ;
    neo:text "Then your wish for another comes true."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4214 a neo:Document ;
    neo:id "ecb555b7c7fa7a949794449bbd3357f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 32, sentence number 1 on page 199"^^xsd:string ;
    neo:text "10."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4215 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4216 ;
    neo:id "cf2df6b3f7c29a35501409ae694de1d2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 32, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Eyes closed, see your inner being in detail."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4217 a neo:Document ;
    neo:id "788a1deebe05a6cfbb4acf7b5a31aa7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 32, sentence number 3 on page 199"^^xsd:string ;
    neo:text "Thus see your true nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4218 a neo:Document ;
    neo:id "5c6c9bea5cebc6bb3780d84a6c51be6a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 33, sentence number 1 on page 199"^^xsd:string ;
    neo:text "11."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4219 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4220,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4221,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4222 ;
    neo:id "3b1601a69c1756db7e97a4b46f41f7be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 33, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Place your whole attention in the nerve, delicate as the lotus thread, in the center of your spinal column."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4223 a neo:Document ;
    neo:id "a16bc0155f48c9ebd16d26fd13fd990f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 33, sentence number 3 on page 199"^^xsd:string ;
    neo:text "In such be transformed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4224 a neo:Document ;
    neo:id "76fde070b319d3b1f25909d6ed937b89"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 34, sentence number 1 on page 199"^^xsd:string ;
    neo:text "12."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4225 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4156,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_976 ;
    neo:id "019bd85c4ce38566f1a9a0d26d575441"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 34, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Closing the seven openings of the head with your hands, a space between your eyes becomes all-inclusive."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4226 a neo:Document ;
    neo:id "68125b7a06283c69036d98fe17fc4dbd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 35, sentence number 1 on page 199"^^xsd:string ;
    neo:text "13."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4227 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4228,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4229,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4230 ;
    neo:id "a7a0b6387dac9ef7ebfe528e98bf953c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 35, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Touching eyeballs as a feather, lightness between them opens into heart and there permeates the cosmos."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_423 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_424 ;
    neo:id "26176d3b03202e24ca78d814995cb9bf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 5. If You Love, Love Openly, paragraph number 5, sentence number 1 on page 18"^^xsd:string ;
    neo:text "Addressing the one who had written her, she said: ‘If you really love me so much, come and embrace me now.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4231 a neo:Document ;
    neo:id "5f516e9a831b1c7b7b97110c923e14b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 36, sentence number 1 on page 199"^^xsd:string ;
    neo:text "14."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4232 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4233,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "c962548e78a772a79d9adf5c35645354"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 36, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Bathe in the center of sound, as in the continuous sound of a waterfall."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4234 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3242,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4235,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "173b406b46a83af37b995731e1797755"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 36, sentence number 3 on page 199"^^xsd:string ;
    neo:text "Or, by putting fingers in ears, hear the sound of sounds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4236 a neo:Document ;
    neo:id "567df8ed23cd6f7da62b22589f8af589"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 37, sentence number 1 on page 199"^^xsd:string ;
    neo:text "15."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4237 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4238,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "67855edb9104d46dde18dcd1cdb4e3e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 37, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Intone a sound, as a-u-m, slowly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4239 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4240,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "10bb20586c80116a12a6dff8fb344b8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 37, sentence number 3 on page 199"^^xsd:string ;
    neo:text "As sound enters soundfulness, so do you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4241 a neo:Document ;
    neo:id "b157d04f2dce59999a41076690eb56e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 38, sentence number 1 on page 199"^^xsd:string ;
    neo:text "16."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4242 a neo:Document ;
    neo:id "4195158c6149846af1642a92d9b38d59"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 38, sentence number 2 on page 199"^^xsd:string ;
    neo:text "In the beginning and gradual refinement of the sound of any letter, awake."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4243 a neo:Document ;
    neo:id "26da66e7f52458058e6a8552ceea234f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 39, sentence number 1 on page 199"^^xsd:string ;
    neo:text "17."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4244 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4245,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4247 ;
    neo:id "46b7072181605460f37c42811a7fcc2d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 39, sentence number 2 on page 199"^^xsd:string ;
    neo:text "While listening to stringed instruments, hear their composite central sound; thus omnipresence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4248 a neo:Document ;
    neo:id "ecd15ee3a7985b2440f3c41cdd5445ae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 40, sentence number 1 on page 199"^^xsd:string ;
    neo:text "18."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4249 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4250,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "6942ea3b72faf607386b18b32775dbde"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 40, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Intone a sound audibly, then less and less audibly as feeling deepens into this silent harmony."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_425 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_426,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "74982eb5bbdfd29b00172def7a180a53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 1, sentence number 1 on page 19"^^xsd:string ;
    neo:text "There was an old woman in China who had supported a monk for over twenty years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4251 a neo:Document ;
    neo:id "3fbe59736dea478652b263f43af75f0f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 41, sentence number 1 on page 199"^^xsd:string ;
    neo:text "19."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4252 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_83 ;
    neo:id "e209cd5cb42426963bc958e4d3d61f19"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 41, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Imagine spirit simultaneously within and around you until the entire universe spiritualizes."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4253 a neo:Document ;
    neo:id "81eb1aafe187d1d6102537b21e3b3b4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 42, sentence number 1 on page 199"^^xsd:string ;
    neo:text "20."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4254 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4255,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4256 ;
    neo:id "7e9852d717d1bca9c921332a1b338850"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 42, sentence number 2 on page 199"^^xsd:string ;
    neo:text "Kind Devi, enter etheric presence pervading far above and below your form."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4257 a neo:Document ;
    neo:id "f52ba4cf5a98ba14dde152f5e8bc6551"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 43, sentence number 1 on page 200"^^xsd:string ;
    neo:text "21."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4258 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4259 ;
    neo:id "79b9bc0adb297335ec42954b37cee242"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 43, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Put mindstuff in such inexpressible fineness above, below, and in your heart."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4262 a neo:Document ;
    neo:id "8b36712362f306d073628f0fe78b5fac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 44, sentence number 1 on page 200"^^xsd:string ;
    neo:text "22."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4263 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4264,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4265 ;
    neo:id "aa8a3f5c413f538ab703901efd4758da"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 44, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Consider any area of your present form as limitlessly spacious."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4266 a neo:Document ;
    neo:id "d4fbca7834560377a100c91364ec53ec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 45, sentence number 1 on page 200"^^xsd:string ;
    neo:text "23."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4267 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2208,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4268,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4269,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_70,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_86 ;
    neo:id "62a0cbf5c4fbc1bf5011d7c3fc8f1b05"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 45, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Feel your substance, bones, flesh, blood, saturated with cosmic essence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4270 a neo:Document ;
    neo:id "21250cdbabe0f7964564376f3d523f38"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 46, sentence number 1 on page 200"^^xsd:string ;
    neo:text "24."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4271 a neo:Document ;
    neo:id "bf680d7e34a07f0b9070ef151743db78"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 46, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Suppose your passive form to be an empty room with walls of skin— empty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4272 a neo:Document ;
    neo:id "13f3022d707d2db79b2bbc152c21c483"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 47, sentence number 1 on page 200"^^xsd:string ;
    neo:text "25."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4273 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4093,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4274,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4275 ;
    neo:id "7bf0cb0e974338b0cdc23ddc8778cde0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 47, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Blessed one, as senses are absorbed in heart, reach the center of the lotus."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4276 a neo:Document ;
    neo:id "dd3391b01e6d23199e9d35f0a4f5d427"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 48, sentence number 1 on page 200"^^xsd:string ;
    neo:text "26."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4277 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108 ;
    neo:id "07bad3f319e591bc3b3494cefd867af6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 48, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Unminding mind, keep in the middle—until."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4278 a neo:Document ;
    neo:id "2cdebd29aacaf69cf85ee986bf491f6c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 49, sentence number 1 on page 200"^^xsd:string ;
    neo:text "27."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4279 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4114,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4167,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4280,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4281 ;
    neo:id "0f7c1b9ce1b3fc9df152455bd783ec04"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 49, sentence number 2 on page 200"^^xsd:string ;
    neo:text "When in worldly activity, keep attentive between the two breaths, and so practicing, in a few days be born anew."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_428 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_429 ;
    neo:id "3ebc6ceb8ce8e9f915a510f5ecbe9593"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 1, sentence number 2 on page 19"^^xsd:string ;
    neo:text "She had built a little hut for him and fed him while he was meditating."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4282 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "df4614f1fd14d3add688aae8a5a4ea30"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 49, sentence number 3 on page 200"^^xsd:string ;
    neo:text "[Lakshmanjoo says this is his favorite.]"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4283 a neo:Document ;
    neo:id "97f35d6fd654c8e23c1c8085806d2012"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 50, sentence number 1 on page 200"^^xsd:string ;
    neo:text "28."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4284 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1838,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "67c5da9729ffe9774d7f6d7fd00f82fd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 50, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Focus on fire rising through your form from the toes up until the body burns to ashes but not you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4285 a neo:Document ;
    neo:id "fa429db80d7f2e42225c65eca3a5e0fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 51, sentence number 1 on page 200"^^xsd:string ;
    neo:text "29."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4286 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1838,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4287,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4288 ;
    neo:id "519b128b28ce8fc0356d2fde93a76ed3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 51, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Meditate on the make-believe world as burning to ashes, and become being above human."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4289 a neo:Document ;
    neo:id "1cdc6cd68bb51aa7c2781179919aed54"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 52, sentence number 1 on page 200"^^xsd:string ;
    neo:text "30."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4290 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4292 ;
    neo:id "8c848dd9431dab84ee37ffb1b292eb5e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 52, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Feel the fine qualities of creativity permeating your breasts and assuming delicate configurations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4293 a neo:Document ;
    neo:id "e5f8f6f53656f649355828a033631cbb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 53, sentence number 1 on page 200"^^xsd:string ;
    neo:text "31."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4294 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1981,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2103,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4295,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4296,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4298 ;
    neo:id "5cadbf5efc014297693dc18c6d195d12"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 53, sentence number 2 on page 200"^^xsd:string ;
    neo:text "With intangible breath in center of forehead, as this reaches heart at the moment of sleep, have direction over dreams and over death itself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4299 a neo:Document ;
    neo:id "3ee68dd8c816db4fe61d42a07ed12794"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 54, sentence number 1 on page 200"^^xsd:string ;
    neo:text "32."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_430 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "8f158e48a00d71790f268c9f18362e47"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 1, sentence number 3 on page 19"^^xsd:string ;
    neo:text "Finally she wondered just what progress he had made in all this time."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4300 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2804,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4301,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4302,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4303,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_915,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "5b17951c4f73336c3816e1cc59a28081"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 54, sentence number 2 on page 200"^^xsd:string ;
    neo:text "As, subjectively, letters flow into words and words into sentences, and as, objectively, circles flow into worlds and worlds into principles, find at last these converging in our being."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4304 a neo:Document ;
    neo:id "4eb77bbfbb7dfadb2889cd985640f8b6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 55, sentence number 1 on page 200"^^xsd:string ;
    neo:text "33."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4305 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148 ;
    neo:id "4d6e3a35127a1b1aaae3a1d21f5d06f2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 55, sentence number 2 on page 200"^^xsd:string ;
    neo:text "Gracious one, play the universe is an empty shell wherein your mind frolics infinitely."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4306 a neo:Document ;
    neo:id "23c976d1a8379c448948eb31107041e7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 56, sentence number 1 on page 201"^^xsd:string ;
    neo:text "34."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4307 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1292 ;
    neo:id "671bacbc85ce9ac9cad5a4515067d7a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 56, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Look upon a bowl without seeing the sides or the material."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4308 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4309 ;
    neo:id "a8b293f5a019231f51508184a7dd9daf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 56, sentence number 3 on page 201"^^xsd:string ;
    neo:text "In a few moments become aware."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_431 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "2a1414904b1e583b1250352ef1df8ed4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 2, sentence number 1 on page 19"^^xsd:string ;
    neo:text "To find out, she obtained the help of a girl rich in desire."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4310 a neo:Document ;
    neo:id "42b4705084cd59468ee2365f27c86610"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 57, sentence number 1 on page 201"^^xsd:string ;
    neo:text "35."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4311 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640 ;
    neo:id "60b58fcd609aef98cc430c6e61e035fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 57, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Abide in some place endlessly spacious, clear of trees, hills, habitations."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4312 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4313 ;
    neo:id "2850ee42c0fa05569eadf5e4ba9a1158"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 57, sentence number 3 on page 201"^^xsd:string ;
    neo:text "Thence comes the end of mind pressures."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4314 a neo:Document ;
    neo:id "0b9018a21ebcf3a3aa7caccb0d9c969d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 58, sentence number 1 on page 201"^^xsd:string ;
    neo:text "36."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4315 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4316,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4317,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4318,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4319,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484 ;
    neo:id "0caa11762f983b0eb9a4879315e23559"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 58, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Sweet-hearted one, meditate on knowing and not knowing, existing and not existing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_432 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "b8e71d480c72adaad38b1f6eba656483"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 2, sentence number 2 on page 19"^^xsd:string ;
    neo:text "‘Go and embrace him,’ she told her;’ and then ask him suddenly:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4320 a neo:Document ;
    neo:id "497e78239c76aa33c41fc665437b1488"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 58, sentence number 3 on page 201"^^xsd:string ;
    neo:text "Then leave both aside that you may be."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4321 a neo:Document ;
    neo:id "f809e160bed476ba44ede4006561629b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 59, sentence number 1 on page 201"^^xsd:string ;
    neo:text "37."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4322 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323 ;
    neo:id "00018fa1c84009534dc7687034df1d70"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 59, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Look lovingly on some object Do not go on to another object."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4324 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4325 ;
    neo:id "3fa73f1cfb81208a2f9239fc3257386e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 59, sentence number 3 on page 201"^^xsd:string ;
    neo:text "Here, in the middle of this object — the blessing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4326 a neo:Document ;
    neo:id "98543d17b5eeae58358857d31fd1691b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 60, sentence number 1 on page 201"^^xsd:string ;
    neo:text "38."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4327 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_179,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4230 ;
    neo:id "a0bacf9aa6cb938c54455245f890da6b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 60, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Feel cosmos as translucent ever-living presence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4328 a neo:Document ;
    neo:id "29ca27f6318ad1b44e574d1003c07275"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 61, sentence number 1 on page 201"^^xsd:string ;
    neo:text "39."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4329 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4330,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4331 ;
    neo:id "47ad772274e6e68ab4b473fee44ab64b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 61, sentence number 2 on page 201"^^xsd:string ;
    neo:text "With utmost devotion, center on the two junctions of breath and know the knower."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_433 a neo:Document ;
    neo:id "6b67be734a754cb3ad5c8141dc8471e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 3, sentence number 1 on page 19"^^xsd:string ;
    neo:text "“What now?”"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4332 a neo:Document ;
    neo:id "9f50b5c6ab862e164a04953217e256f3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 62, sentence number 1 on page 201"^^xsd:string ;
    neo:text "40."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4333 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4334,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4335,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "01482175ee0202a9bc3efce51e4c7d17"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 62, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Consider the plenum to be your own body of bliss."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4336 a neo:Document ;
    neo:id "6a8dfcb504793b934c295085956eafb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 63, sentence number 1 on page 201"^^xsd:string ;
    neo:text "41."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4337 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4338,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4339,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4340 ;
    neo:id "7775696c17cce26698fa6e701aec30e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 63, sentence number 2 on page 201"^^xsd:string ;
    neo:text "While being caressed, sweet princess, enter the caressing as everlasting life."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_434 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427 ;
    neo:id "022fe5a7c66e1931ad80f01f23487186"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 4, sentence number 1 on page 19"^^xsd:string ;
    neo:text "The girl called upon the monk and without much ado caressed him, asking him what he was going to do about it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4341 a neo:Document ;
    neo:id "b63634580786cc376873425c404b1082"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 64, sentence number 1 on page 201"^^xsd:string ;
    neo:text "42."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4342 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4195,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4343,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4344 ;
    neo:id "c920249e33b927a2f23cf8990aa5e525"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 64, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Stop the doors of senses when feeling the creeping of an ant."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4345 a neo:Document ;
    neo:id "90bbb2d4db9fbd8985ada798e8a988fb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 117, sentence number 3 on page 205"^^xsd:string ;
    neo:text "Then."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4346 a neo:Document ;
    neo:id "32b10f3eef51539c485a24cd9b144839"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 65, sentence number 1 on page 201"^^xsd:string ;
    neo:text "43."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4347 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2693,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4055,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4199,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4348,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4349 ;
    neo:id "c9f4ab8c6dff43ec700e6ea3fb226dd1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 65, sentence number 2 on page 201"^^xsd:string ;
    neo:text "At the start of sexual union, keep attention on the fire in the beginning, and, so continuing, avoid the embers in the end."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_435 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_436,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_437,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_438 ;
    neo:id "fa4db5f0cd3f3fed143f02bdb707f9af"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 5, sentence number 1 on page 19"^^xsd:string ;
    neo:text "‘An old tree grows on a cold rock in winter,’ replied the monk somewhat poetically."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4350 a neo:Document ;
    neo:id "75a909bca1f32027d70ee7ac09b9f8c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 66, sentence number 1 on page 201"^^xsd:string ;
    neo:text "44."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4351 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4275,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4352,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4353 ;
    neo:id "6a1c657c71406ccbfab37270ceaeb328"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 66, sentence number 2 on page 201"^^xsd:string ;
    neo:text "When in such embrace your senses are shaken as leaves, enter this shaking."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4354 a neo:Document ;
    neo:id "202db5ecd6fe4efbe16bcad95139e398"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 67, sentence number 1 on page 201"^^xsd:string ;
    neo:text "45."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4355 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4352,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4356,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4357 ;
    neo:id "e725300ddbbabda47a5c657c8fa16671"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 67, sentence number 2 on page 201"^^xsd:string ;
    neo:text "Even remembering union, without the embrace, the transformation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4358 a neo:Document ;
    neo:id "f113baf6bfea0b3de3bdb49ad2d3937f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 68, sentence number 1 on page 201"^^xsd:string ;
    neo:text "46."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4359 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4360,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "3efcb91ec69b5b3bd4aa05741ab11cd2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 68, sentence number 2 on page 201"^^xsd:string ;
    neo:text "On joyously seeing a long-absent friend, permeate this joy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4361 a neo:Document ;
    neo:id "02c1e6fca4259eb111113663a861af6d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 69, sentence number 1 on page 201"^^xsd:string ;
    neo:text "47."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4362 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4363,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4364 ;
    neo:id "b4faf9a7ff575e51b951e6419d05d606"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 69, sentence number 2 on page 201"^^xsd:string ;
    neo:text "When eating or drinking, become the taste of the food or drink, and be filled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4365 a neo:Document ;
    neo:id "b11a8a099a50b0474f573bb1f34f46f4"^^xsd:string ;
