    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 2, sentence number 2 on page 207"^^xsd:string ;
    neo:text "But Zen comes of itself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4631 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_111,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3653,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110 ;
    neo:id "a8f0dc92aaa0add261616a1d2cd1ecab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 2, sentence number 3 on page 207"^^xsd:string ;
    neo:text "True Zen shows in everyday living, CONSCIOUSNESS in action."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4632 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4127,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4633 ;
    neo:id "407ed30331cc5056eed2d1c20611214f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 2, sentence number 4 on page 207"^^xsd:string ;
    neo:text "More than any limited awareness, it opens every inner door to our infinite nature."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4634 a neo:Document ;
    neo:id "77f50f574e6364cc1f7ace7b6bf07ed1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 3, sentence number 1 on page 207"^^xsd:string ;
    neo:text "Instantly mind frees."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4635 a neo:Document ;
    neo:id "1585e33c96fb848be42c2a98068a7426"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 3, sentence number 2 on page 207"^^xsd:string ;
    neo:text "How it frees!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4636 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_189,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4637,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4638 ;
    neo:id "7724daf5dbb38ddbb5629cbc4a485e9a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 3, sentence number 3 on page 207"^^xsd:string ;
    neo:text "False Zen wracks brains as a fiction concocted by priests and salesmen to peddle their own wares."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4639 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110 ;
    neo:id "fe8657683c8868d71f5357eeee7267be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 4, sentence number 1 on page 207"^^xsd:string ;
    neo:text "Look at it this way, inside out and outside in: CONSCIOUSNESS everywhere, inclusive, through you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_464 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
