        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4625 ;
    neo:id "4df085aaee56237f1624e3787aa15515"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 132, sentence number 4 on page 206"^^xsd:string ;
    neo:text "Perceive one being as knower and known."^^xsd:string .

