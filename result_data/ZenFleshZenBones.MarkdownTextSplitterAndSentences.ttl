    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 125, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Enter space, supportless, eternal, still."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4592 a neo:Document ;
    neo:id "511e7efa0e36b8aa89dda1960c84cb76"^^xsd:string ;
