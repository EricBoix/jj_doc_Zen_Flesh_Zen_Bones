ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4627 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4316 ;
    neo:id "e2d21a7e56d1efb316b34137748ae5df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 133, sentence number 2 on page 206"^^xsd:string ;
    neo:text "Beloved, at this moment let mind, knowing, breath, form, be included."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4628 a neo:Document ;
