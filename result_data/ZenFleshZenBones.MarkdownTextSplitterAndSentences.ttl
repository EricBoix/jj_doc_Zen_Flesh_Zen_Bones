    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 129, sentence number 2 on page 206"^^xsd:string ;
    neo:text "This consciousness is the spirit of guidance of each one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4603 a neo:Document ;
    neo:id "1711b92d64d35b2793b0e105c11dcab5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 129, sentence number 3 on page 206"^^xsd:string ;
    neo:text "Be this one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4604 a neo:Document ;
    neo:id "a50c49d3867e0b98c49d5fbc333399df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 129, sentence number 1 on page 206"^^xsd:string ;
    neo:text "108."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4605 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4606,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4607 ;
    neo:id "f981844fa0e30c70fc2597403844cd58"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 129, sentence number 2 on page 206"^^xsd:string ;
    neo:text "Here is a sphere of change, change, change."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4608 a neo:Document ;
    neo:id "7243bf061ba38fe22d2695f246aa3d0b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 129, sentence number 3 on page 206"^^xsd:string ;
    neo:text "Through change consume change."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4609 a neo:Document ;
    neo:id "433f559803962e3e27fc6226863924d9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 130, sentence number 1 on page 206"^^xsd:string ;
    neo:text "109."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4610 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4611,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4612 ;
    neo:id "5eef6e9b32e55a091c4f067246fb1f1a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 130, sentence number 2 on page 206"^^xsd:string ;
    neo:text "As a hen mothers her chicks, mother particular knowings, particular doings, in reality."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4613 a neo:Document ;
    neo:id "11e0fd75b80dfa4e1ab9b44ed28b5b65"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 131, sentence number 1 on page 206"^^xsd:string ;
    neo:text "110."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4614 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3080,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4615 ;
    neo:id "9e641a7e35f882cbcd76800d2c144d4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 131, sentence number 2 on page 206"^^xsd:string ;
    neo:text "Since, in truth, bondage and freedom are relative, these words are only for those terrified with the universe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4616 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4617 ;
    neo:id "8eb2ec46884688ba4fa7b2d9fb56b8c7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 131, sentence number 3 on page 206"^^xsd:string ;
    neo:text "This universe is a reflection of minds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4618 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4615,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4619,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4620,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "903bdf482a8bb09c4e577a255bfc7360"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 131, sentence number 4 on page 206"^^xsd:string ;
    neo:text "As you see many suns in water from one sun, so see bondage and liberation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_462 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_461,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_463 ;
    neo:id "30be9257c079fd32eeeeae4844c7fd42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 2, sentence number 1 on page 21"^^xsd:string ;
    neo:text "O-nami was immensely strong and knew the art of wrestling."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4621 a neo:Document ;
    neo:id "865c6da85f4b1e1460582e35ba2f33e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 132, sentence number 1 on page 206"^^xsd:string ;
    neo:text "111."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4622 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3041,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4316 ;
    neo:id "b4b38b5531a975f17e8cc261b3beb84d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 132, sentence number 2 on page 206"^^xsd:string ;
    neo:text "Each thing is perceived through knowing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4623 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3961,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4156,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4316 ;
    neo:id "8ea4d7f6c27553dd3866c109ef45c5e8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 132, sentence number 3 on page 206"^^xsd:string ;
    neo:text "The self shines in space through knowing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4624 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
