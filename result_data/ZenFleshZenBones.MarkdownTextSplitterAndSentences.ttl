    neo:id "c99a7d99080ff5ace4b8c22e5f099931"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 6, sentence number 1 on page 20"^^xsd:string ;
    neo:text "27 July 1892."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4580 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4581 ;
    neo:id "e8afee79dc9d0dde00e4b15eec96b1d2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 123, sentence number 2 on page 205"^^xsd:string ;
    neo:text "When a mood against someone or for someone arises, do not place it on the person in question, but remain centered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4583 a neo:Document ;
    neo:id "b8c2fc797526c5ff84a3e7f228608cf6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 124, sentence number 1 on page 205"^^xsd:string ;
    neo:text "102."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4584 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4388,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4585,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4586 ;
    neo:id "c62b1ea6f8ad6d8b6dd22580716ab132"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 124, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Suppose you contemplate something beyond perception, beyond grasping, beyond not being, you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4587 a neo:Document ;
    neo:id "4c7eb7b8967e626a8909804279753e33"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 125, sentence number 1 on page 205"^^xsd:string ;
    neo:text "103."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4588 a neo:Document ;
