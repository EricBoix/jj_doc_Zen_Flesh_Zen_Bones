    neo:id "84e22e44ebbd69e5175db126e1bc149b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 128, sentence number 2 on page 205"^^xsd:string ;
    neo:text "I am existing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4599 a neo:Document ;
    neo:id "62de9f1349ab481d6d37e33e9f3bfe10"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 128, sentence number 3 on page 205"^^xsd:string ;
    neo:text "This is mine."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_46 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_47 ;
    neo:id "8c907cb6294796d85bb62578bdeeb0e1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 5, sentence number 1 on page 7"^^xsd:string ;
    neo:text "Thanks are due the publishers named above for permission to gather the material together here."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_460 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_461 ;
    neo:id "70a77ea7731f18e96f4ad4060f2f0199"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 1, sentence number 1 on page 21"^^xsd:string ;
    neo:text "In the early days of the Meiji era there lived a well-known wrestler called O-nami, Great Waves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4600 a neo:Document ;
    neo:id "53eec8c7a6bdd1a50c1e698094139cd4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 128, sentence number 4 on page 205"^^xsd:string ;
    neo:text "This is this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4601 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2068 ;
    neo:id "f93b0413fb3d417b426f315a47031dbb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 128, sentence number 5 on page 205"^^xsd:string ;
    neo:text "0 Beloved, even in such know illimitably. 107."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4602 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1403,
