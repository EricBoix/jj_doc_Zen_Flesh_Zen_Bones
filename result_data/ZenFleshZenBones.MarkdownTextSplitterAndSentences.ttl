    neo:id "56c6e42a5507010b0fd5b94785862db8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 2, sentence number 2 on page 21"^^xsd:string ;
    neo:text "In his private bouts he defeated even his teacher, but in public he was so bashful that his own pupils threw him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4640 a neo:Document ;
    neo:id "2c3f0fc83bcc1f31316838c7d4a0457b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 4, sentence number 2 on page 207"^^xsd:string ;
    neo:text "Then you can’t help living humbly, in wonder."^^xsd:string .

