    neo:id "12d514bb2dbe6f62b9595b43c3ae1660"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 86, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Just as you have the impulse to do something, stop."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4433 a neo:Document ;
    neo:id "1cbb94da88330caad0d1b6a3a5dd16fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 87, sentence number 1 on page 203"^^xsd:string ;
    neo:text "65."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4434 a neo:Document ;
    neo:id "1c64737f0a00a81ca271e8b4b36dc9c0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 87, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Center on the sound a-u-m without any a or m."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4435 a neo:Document ;
    neo:id "02d965404b41f1fc72f5bd704e9e1f81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 88, sentence number 1 on page 203"^^xsd:string ;
    neo:text "66."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4436 a neo:Document ;
    neo:id "41e5d0c0bd9f632d4514eab34e999b59"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 88, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Silently intone a word ending in AH."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4437 a neo:Document ;
    neo:id "b2c6020e18ccb0139df8a7b7dab26e4e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 88, sentence number 3 on page 203"^^xsd:string ;
    neo:text "Then in the HH effortlessly, the spontaneity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4438 a neo:Document ;
    neo:id "13aefe8f4f3d8fbdb316c39ee5537152"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 89, sentence number 1 on page 203"^^xsd:string ;
    neo:text "67."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4439 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3961,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4440 ;
    neo:id "91c05c94730ca51e54d5c661050d525b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 89, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Feel yourself as pervading all directions, far, near."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_444 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_445,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_446 ;
    neo:id "bb856d2dde5ed44725325ee433059c22"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 7, sentence number 2 on page 19"^^xsd:string ;
    neo:text "He need not have responded to passion, but at last he should have evidenced some compassion.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4441 a neo:Document ;
    neo:id "1694a4b48fec87cdf1f32a48a55534a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 90, sentence number 1 on page 203"^^xsd:string ;
    neo:text "68."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4442 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4443,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4444 ;
    neo:id "80d0f9ff7ba3e3d4b748d013b8e55196"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 90, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Pierce some part of your nectar-filled form with a pin, and gently enter the piercing."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4445 a neo:Document ;
    neo:id "4023ced117adc1cf9b457b7da48d6eea"^^xsd:string ;
