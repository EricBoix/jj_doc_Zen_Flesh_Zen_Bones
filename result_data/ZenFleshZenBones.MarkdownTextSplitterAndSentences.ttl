        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "d3aa3094d0b81677b171945f4252de62"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 91, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Feel: My thought, I-ness, internal organs—me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4450 a neo:Document ;
    neo:id "9eb8f94e6849d3da687b8bc5393f5b00"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 92, sentence number 1 on page 203"^^xsd:string ;
    neo:text "70."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4451 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4452 ;
    neo:id "b3abe6d4d15c2a2dff02b986f3d09079"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 92, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Illusions deceive."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4454 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4455 ;
    neo:id "6147a2c44c295cf6dd0180c3ee73ac3d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 92, sentence number 3 on page 203"^^xsd:string ;
    neo:text "Colors circumscribe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4457 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4458,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4459 ;
    neo:id "f458d84eca894e73d6b2a9b3fc24fc0a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 92, sentence number 4 on page 203"^^xsd:string ;
    neo:text "Even divisibles are indivisible."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4460 a neo:Document ;
    neo:id "6a7d9c565534665e5337490ddc9fe118"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 93, sentence number 1 on page 203"^^xsd:string ;
    neo:text "71."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4461 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1556 ;
    neo:id "d5264c87fe726a507a992a8a1eeaecea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 93, sentence number 2 on page 203"^^xsd:string ;
    neo:text "When some desire comes, consider it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4463 a neo:Document ;
    neo:id "6034b57b3f86308be7ac9f44dbe34ff3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 93, sentence number 3 on page 203"^^xsd:string ;
    neo:text "Then, suddenly, quit it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4464 a neo:Document ;
    neo:id "32bfc5cbf6084c67d9e569ef04ca8349"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 94, sentence number 1 on page 203"^^xsd:string ;
    neo:text "72."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4465 a neo:Document ;
    neo:id "ff3677e4df695b64c965ce7d3af72c55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 94, sentence number 2 on page 203"^^xsd:string ;
    neo:text "Before desire and before knowing, how can I say I am?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4466 a neo:Document ;
    neo:id "294c27c687c5f05371603fb308544bf4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 94, sentence number 3 on page 203"^^xsd:string ;
    neo:text "Consider."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4467 a neo:Document ;
    neo:id "20c38809b7691a53089822d5103713ee"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 94, sentence number 4 on page 203"^^xsd:string ;
    neo:text "Dissolve in the beauty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4468 a neo:Document ;
    neo:id "2edc4c4500d4e1912015649a3ec7493c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 95, sentence number 1 on page 203"^^xsd:string ;
    neo:text "73."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4469 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1556,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4316 ;
    neo:id "80266493a43b702ae4a233ba4b3e20fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 95, sentence number 2 on page 203"^^xsd:string ;
    neo:text "With your entire consciousness in the very start of desire, of knowing, know."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_447 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_429 ;
    neo:id "9eae46fa094d563f88e1f1c1e88129b9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 8, sentence number 1 on page 19"^^xsd:string ;
    neo:text "She at once went to the hut of the monk and burned it down."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4470 a neo:Document ;
    neo:id "3d50451ba2e5a3a733e419271138fc33"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 96, sentence number 1 on page 203"^^xsd:string ;
    neo:text "74."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4471 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3943,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4414,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4472 ;
    neo:id "eb0f700b2d658fc5da3d8a98b3bbb4df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 96, sentence number 2 on page 203"^^xsd:string ;
    neo:text "0 Shakti, each particular perception is limited, disappearing in omnipotence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4473 a neo:Document ;
    neo:id "e89b8a1a866ef6f482dd46cdfee3b0ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 97, sentence number 1 on page 203"^^xsd:string ;
    neo:text "75."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4474 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4475,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62 ;
    neo:id "acfa793058845a8c52e46c5da9033e64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 97, sentence number 2 on page 203"^^xsd:string ;
    neo:text "In truth forms are inseparate."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4476 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4477 ;
    neo:id "17e7204867142230725c8c517b2a3eb4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 97, sentence number 3 on page 203"^^xsd:string ;
    neo:text "Inseparate are omnipresent being and your own form."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4478 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110 ;
    neo:id "321523f00ffac4020c9ae98a9761736f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 97, sentence number 4 on page 203"^^xsd:string ;
    neo:text "Realize each as made of this consciousness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4479 a neo:Document ;
    neo:id "e52681e4724e1bc966131349cb1ac1fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 98, sentence number 1 on page 203"^^xsd:string ;
    neo:text "76."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_448 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_450,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_451 ;
    neo:id "25cb6fc803a540bc908ce8e8dee2422e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 1, sentence number 1 on page 20"^^xsd:string ;
    neo:text "Tanzan wrote sixty postal cards on the last day of his life, and asked an attendant to mail them."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4480 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4481,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4482,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4483 ;
    neo:id "5895bcb636a9a8f2c3e3fe516975ddad"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 98, sentence number 2 on page 203"^^xsd:string ;
    neo:text "In moods of extreme desire, be undisturbed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4484 a neo:Document ;
    neo:id "22bdaddaed2589093dfe97b596c0fcf5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 99, sentence number 1 on page 203"^^xsd:string ;
    neo:text "77."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4485 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_148,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4486,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4487 ;
    neo:id "791254f43aaac554bbabb2f2bcee68a7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 99, sentence number 2 on page 203"^^xsd:string ;
    neo:text "This so-called universe appears as a juggling, a picture show."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4488 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1171 ;
    neo:id "5ca86562a999fbd0b309f89d54e31bed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 99, sentence number 3 on page 203"^^xsd:string ;
    neo:text "To be happy look upon it so."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4489 a neo:Document ;
    neo:id "58124ebbc81c130cc549fd11dafd0121"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 100, sentence number 1 on page 203"^^xsd:string ;
    neo:text "78."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4490 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2068,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2685,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4491 ;
    neo:id "20b45d83892a1928d3aa4227a0acd005"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 100, sentence number 2 on page 203"^^xsd:string ;
    neo:text "0 Beloved, put attention neither on pleasure or pain but between these."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4492 a neo:Document ;
    neo:id "92d491ae6c8ab4ae837c1e114b701203"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 101, sentence number 1 on page 204"^^xsd:string ;
    neo:text "79."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4493 a neo:Document ;
    neo:id "01c98ccfb7ae4692caa63ae2e1109c04"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 101, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Toss attachment for body aside, realizing I am everywhere."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4494 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4360 ;
    neo:id "0aa15711b64e445dcadfd98084ea0796"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 101, sentence number 3 on page 204"^^xsd:string ;
    neo:text "One who is everywhere is joyous."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4495 a neo:Document ;
    neo:id "debf7920708cdde5509a5160b1727c98"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 102, sentence number 1 on page 204"^^xsd:string ;
    neo:text "80."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4496 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1139,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4498 ;
    neo:id "ce567801466fd37899c9366470f745be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 102, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Objects and desires exist in me as in others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4499 a neo:Document ;
    neo:id "2005e982f9aacb12370432634f48b9f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 102, sentence number 3 on page 204"^^xsd:string ;
    neo:text "So accepting, let them be translated."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4500 a neo:Document ;
    neo:id "0da1c81ad298319cdbc2dc0fb5586415"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 103, sentence number 1 on page 204"^^xsd:string ;
    neo:text "81."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4501 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4497,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4502,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4503,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4504 ;
    neo:id "4471f2a0f77934e8ab2b703c2c9398ae"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 103, sentence number 2 on page 204"^^xsd:string ;
    neo:text "The appreciation of objects and subjects is the same for an enlightened as for an unenlightened person."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4505 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4506,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4507 ;
    neo:id "ed8f9639ec7482674bcd40402dfdc595"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 103, sentence number 3 on page 204"^^xsd:string ;
    neo:text "The former has one greatness: he remains in the subjective mood, not lost in things."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4509 a neo:Document ;
    neo:id "e59276609a3808718047377b900ad8c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 104, sentence number 1 on page 204"^^xsd:string ;
    neo:text "82."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4510 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110 ;
    neo:id "fe40b0fed6bf0fa69e8b8a2b8f51a933"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 104, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Feel the consciousness of each person as your own consciousness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4511 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4512 ;
    neo:id "d496ebcf34ecf37069f2ff2922141faa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 104, sentence number 3 on page 204"^^xsd:string ;
    neo:text "So, leaving aside concern for self, become each being."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4513 a neo:Document ;
    neo:id "d3902d07f5032ed6125b965cc2140f79"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 105, sentence number 1 on page 204"^^xsd:string ;
    neo:text "83."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4514 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3893,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4515,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4516,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4517 ;
    neo:id "d641896da9db4ed0b80547ba3641da74"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 105, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Thinking no thing, will limited-self unlimit."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4518 a neo:Document ;
    neo:id "2efd80dca809735d3ee9a1cf9db27745"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 106, sentence number 1 on page 204"^^xsd:string ;
    neo:text "84."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4519 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4520,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4521,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4522 ;
    neo:id "e57782ef4120e98644e0c9d466536e54"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 106, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Believe omniscient, omnipotent, pervading."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_452 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "ddb7ab84cfe18af82cebb78ace8a401e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 1, sentence number 2 on page 20"^^xsd:string ;
    neo:text "Then he passed away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4523 a neo:Document ;
    neo:id "676fb83db1cdf0a58bd8ebafe49002e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 107, sentence number 1 on page 204"^^xsd:string ;
    neo:text "85."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4524 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1065,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2266,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4525,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_478,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "f25d4bdc0136d7611cee3c5babdaea7a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 107, sentence number 2 on page 204"^^xsd:string ;
    neo:text "As waves come with water and flames with fire, so the universal waves with us."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4526 a neo:Document ;
    neo:id "14a0a994cc362305be39965ed576576a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 108, sentence number 1 on page 204"^^xsd:string ;
    neo:text "86."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4527 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4528,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_685 ;
    neo:id "8cfdf404051200de0316a4a9ab0165a6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 108, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Roam about until exhausted and then, dropping to the ground, in this dropping be whole."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4529 a neo:Document ;
    neo:id "9cb4cea28db7f625aa89f1e7d0030554"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 109, sentence number 1 on page 204"^^xsd:string ;
    neo:text "87."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_453 a neo:Document ;
    neo:id "a0b5244582ef3f1b0fd190b1c27facde"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 2, sentence number 1 on page 20"^^xsd:string ;
    neo:text "The cards read:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4530 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2859,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4531 ;
    neo:id "fc8161b589f54c5c9ec61c51dc8406c2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 109, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Suppose you are gradually being deprived of strength or of knowledge."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4532 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4533,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4534 ;
    neo:id "bcfe8a67569da8026a0cf76fbb525cdb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 109, sentence number 3 on page 204"^^xsd:string ;
    neo:text "At the instant of deprivation, transcend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4535 a neo:Document ;
    neo:id "c254e4da094ea5561f4f8d3e7be75033"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 110, sentence number 1 on page 204"^^xsd:string ;
    neo:text "88."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4536 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4537 ;
    neo:id "e853cbc7bd9b0de431549c3d5407c987"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 110, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Listen while the ultimate mystical teaching is imparted: Eyes still, without winking, at once become absolutely free."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4538 a neo:Document ;
    neo:id "979830c793e29f12f7a814539de00e30"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 111, sentence number 1 on page 204"^^xsd:string ;
    neo:text "89."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4539 a neo:Document ;
    neo:id "0593fe89219c74d114a5a2b92af29c64"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 111, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Stopping ears by pressing and rectum by contracting, enter the sound of sound."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_454 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "b00506bd632465c4322f3b3130e06d6e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 3, sentence number 1 on page 20"^^xsd:string ;
    neo:text "I am departing from this world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4540 a neo:Document ;
    neo:id "30bc847051d43856685b1b09834e711e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 112, sentence number 1 on page 204"^^xsd:string ;
    neo:text "90."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4541 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4542,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4544 ;
    neo:id "a51d9404c4f4e56b6a3c16fb031910a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 112, sentence number 2 on page 204"^^xsd:string ;
    neo:text "At the edge of a deep well look steadily into its depths until — the wondrousness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4545 a neo:Document ;
    neo:id "c1e4b459944fb9713d8237cb854f3aa3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 113, sentence number 1 on page 204"^^xsd:string ;
    neo:text "91."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4546 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640 ;
    neo:id "771822dbc295b93746ebb6f81007e859"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 113, sentence number 2 on page 204"^^xsd:string ;
    neo:text "Wherever your mind is wandering, internally or externally at this very place, this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4547 a neo:Document ;
    neo:id "3187bb9d4583d3269ce37e41e8170190"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 114, sentence number 1 on page 205"^^xsd:string ;
    neo:text "92."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4548 a neo:Document ;
    neo:id "924e2ff565d1776d4c98bde8df6baad8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 114, sentence number 2 on page 205"^^xsd:string ;
    neo:text "When vividly aware through some particular sense, keep in the awareness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4549 a neo:Document ;
    neo:id "a067d67597166f48fcabc609fc4ecd2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 115, sentence number 1 on page 205"^^xsd:string ;
    neo:text "93."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_455 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_456 ;
    neo:id "c5feaea1ea3e80f2b6c9794859d3b64e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 4, sentence number 1 on page 20"^^xsd:string ;
    neo:text "This is my last announcement."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4550 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2011,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2399,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4551,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4552,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4553,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4554,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4555 ;
    neo:id "d5f0765486b43a6e3dfbe0b510f22ac8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 115, sentence number 2 on page 205"^^xsd:string ;
    neo:text "At the start of sneezing, during fright, in anxiety, above a chasm, flying in battle, in extreme curiosity, at the beginning of hunger, at the end of hunger, be uninterruptedly aware."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4556 a neo:Document ;
    neo:id "33c5a7ae342dfbe473e46c581c9982ec"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 116, sentence number 1 on page 205"^^xsd:string ;
    neo:text "94."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4557 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1640,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2682,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4199,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4558 ;
    neo:id "7123e61bf0042f536edf1ec586481300"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 116, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Let attention be at a place where you are seeing some past happening, and even your form, having lost its present characteristics, is transformed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4559 a neo:Document ;
    neo:id "5e1cda82dc6d3974832d5beb355593b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 117, sentence number 1 on page 205"^^xsd:string ;
    neo:text "95."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4560 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "db34a56271311512588f114879f40dbe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 117, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Look upon some object, then slowly withdraw your sight from it, then slowly withdraw your thought from it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4562 a neo:Document ;
    neo:id "cb30d8304d369a2939b0fdedda6f8e09"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 118, sentence number 1 on page 205"^^xsd:string ;
    neo:text "96."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4563 a neo:Document ;
    neo:id "fbe22ecf1c42139b679a909cc3f97a40"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 118, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Devotion frees."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4564 a neo:Document ;
    neo:id "d4aea837437a5922201be0e28deffffb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 119, sentence number 1 on page 205"^^xsd:string ;
    neo:text "97."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4565 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323 ;
    neo:id "2ea5ad6cb9f3c42908fb17f1ec4e11b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 119, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Feel an object before you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4566 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323 ;
    neo:id "e405926a27dde57d8ad05778c36e0dba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 119, sentence number 3 on page 205"^^xsd:string ;
    neo:text "Feel the absence of all other objects but this one."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4567 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4568,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4569 ;
    neo:id "38c5946059afa1a7994f9d9a5c5e5030"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 119, sentence number 4 on page 205"^^xsd:string ;
    neo:text "Then, leaving aside the object-feeling and the absence-feeling, realize."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_457 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449 ;
    neo:id "3c65d2dd3824fd36210e623405f3a963"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 7. Announcement, paragraph number 5, sentence number 1 on page 20"^^xsd:string ;
    neo:text "Tanzan"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4570 a neo:Document ;
    neo:id "46e797119f58df68d498fa0b2840b45e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 120, sentence number 1 on page 205"^^xsd:string ;
    neo:text "98."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4571 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3489,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4572,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4573 ;
    neo:id "f4e8738396abce822c47760e7c25b6e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 120, sentence number 2 on page 205"^^xsd:string ;
    neo:text "The purity of other teachings is as impurity to us."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4574 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4572,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_84 ;
    neo:id "3c0db221e37e0dc0046a2f4afb02de70"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 120, sentence number 3 on page 205"^^xsd:string ;
    neo:text "In reality know nothing as pure or impure."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4575 a neo:Document ;
    neo:id "b78a1a83eaeab44de16109d9bd29c644"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 121, sentence number 1 on page 205"^^xsd:string ;
    neo:text "99."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4576 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4110 ;
    neo:id "57f5b56b7a23fade3a78622d2b2be1ba"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 121, sentence number 2 on page 205"^^xsd:string ;
    neo:text "This consciousness exists as each being, and nothing else exists."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4577 a neo:Document ;
    neo:id "8f885610bb42e76530f8902d55629b72"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 122, sentence number 1 on page 205"^^xsd:string ;
    neo:text "100."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4578 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1160,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "fe3448eb082629d8596b0ffcd4c6e052"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 122, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Be the unsame same to friend as to stranger, in honor and dishonor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4579 a neo:Document ;
    neo:id "fc377baf1ca0705e2a27d50ea9040358"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 123, sentence number 1 on page 205"^^xsd:string ;
    neo:text "101."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_458 a neo:Document ;
