    neo:text "What Is Zen?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4629 a neo:Document ;
    neo:id "59028dd9791c94d51b685f92703cb696"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: What Is Zen?, paragraph number 2, sentence number 1 on page 207"^^xsd:string ;
    neo:text "Try if you wish."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4630 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
