        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489 ;
    neo:id "85eb1450c729e493ac5c3b5f81efb04c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 6, sentence number 2 on page 21"^^xsd:string ;
    neo:text "As the night advanced the waves became larger and larger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_490 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_492,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_493 ;
    neo:id "837ba6063f0d588b6e8e55f03165284e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 6, sentence number 3 on page 21"^^xsd:string ;
    neo:text "They swept away the flowers in their vases."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_494 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_276,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "51f690764f756e3ed43f452608901d72"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 6, sentence number 4 on page 21"^^xsd:string ;
    neo:text "Even the Buddha in the shrine was inundated."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_495 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_496 ;
    neo:id "c79516951b99c8448bf67c6d0105f0c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 6, sentence number 5 on page 21"^^xsd:string ;
    neo:text "Before dawn the temple was nothing but the ebb and flow of an immense sea."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_497 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_461 ;
    neo:id "7a24caf6e66c26db389c6d1a21d2279a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 7, sentence number 1 on page 21"^^xsd:string ;
    neo:text "In the morning the teacher found O-nami meditating, a faint smile on his face."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_499 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_476,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_500 ;
    neo:id "7be705603fdc324ed1fbb6bbbea58eff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 7, sentence number 2 on page 21"^^xsd:string ;
    neo:text "He patted the wrestlers shoulder."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_50 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_43,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_51,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "a96673ed67afe7a69f5945b0db42d518"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 5, sentence number 2 on page 7"^^xsd:string ;
    neo:text "And most of all am I grateful to Nyogen Senzaki, ‘homeless monk’ exemplar-friend collaborator, who so delighted with me in transcribing the first three books, even as that prescient man of Kashmir, Lakshmanjoo, did on the fourth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_501 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7e3ef58c277bb57fc9e58a73cc1f72ca"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 7, sentence number 3 on page 21"^^xsd:string ;
    neo:text "‘Now nothing can disturb you.’ he said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_502 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_478 ;
    neo:id "2813cf8151596827be12bc69f8bf006b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 7, sentence number 4 on page 21"^^xsd:string ;
    neo:text "‘You are the waves."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_503 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_504 ;
    neo:id "18dea27320ef8648c1ebf4fb35caffd8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 7, sentence number 5 on page 21"^^xsd:string ;
    neo:text "You will sweep everything before you.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_506 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_461,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_507 ;
    neo:id "c08a059f2d385d9a522c0c7abfa5f2fd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 8, sentence number 1 on page 21"^^xsd:string ;
    neo:text "The same day O-nami entered the wrestling contests and won."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_508 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33 ;
    neo:id "b73dd3f4bef5aae837b6afb8678b5c28"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 8. Great Waves, paragraph number 8, sentence number 2 on page 21"^^xsd:string ;
    neo:text "After that, no one in Japan was able to defeat him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_509 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_511,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "da4717b232e1e10822b9533b76f89699"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 1, sentence number 1 on page 22"^^xsd:string ;
    neo:text "Ryokan, a Zen master, lived the simplest kind of life in a little hut at the foot of a mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_513 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_429,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_514 ;
    neo:id "eac9ed66f87c68d25c9f69751b8d7c01"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 1, sentence number 2 on page 22"^^xsd:string ;
    neo:text "One evening a thief visited the hut only to discover there was nothing in it to stea1."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_515 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510 ;
    neo:id "136efcf373e255c4e7fb42c7695b275a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 2, sentence number 1 on page 22"^^xsd:string ;
    neo:text "Ryokan returned and caught him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_516 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_517 ;
    neo:id "0d9193a3642a41a9c506221838417c4a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 2, sentence number 2 on page 22"^^xsd:string ;
    neo:text "‘You may have come a long way to visit me,’ he told the prowler, ‘and you should not return empty-handed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_518 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519 ;
    neo:id "6079f9fcb763f7dddfe9b23761464921"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 2, sentence number 3 on page 22"^^xsd:string ;
    neo:text "Please take my clothes as a gift.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_520 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_514 ;
    neo:id "4f03016835988fae05663903f047d440"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 3, sentence number 1 on page 22"^^xsd:string ;
    neo:text "The thief was bewildered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_521 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_519 ;
    neo:id "a7f13c8cf15297f6a18d459779480e07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 3, sentence number 2 on page 22"^^xsd:string ;
    neo:text "He took the clothes and slunk away."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_522 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_510,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_523 ;
    neo:id "6fc4dc2edbee1e185a1a379d295f1c81"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 4, sentence number 1 on page 22"^^xsd:string ;
    neo:text "Ryokan sat naked, watching the moon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_524 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_523 ;
    neo:id "bb3544af6211773fc6303ef87c912351"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 9. The Moon cannot be Stolen, paragraph number 4, sentence number 2 on page 22"^^xsd:string ;
    neo:text "‘Poor fellow,’ he mused, ‘I wish I could give him this beautiful moon.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_526 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527 ;
    neo:id "c9ca566bd6f7c5f2f61c28b978399580"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 1, sentence number 1 on page 23"^^xsd:string ;
    neo:text "The Zen master Hoshin lived in China many years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_528 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_529,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "d80809049d6cdcf6538f1bc4df31dfb4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 1, sentence number 2 on page 23"^^xsd:string ;
    neo:text "Then he returned to the northeastern part of Japan, where he taught his disciples."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_530 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_531 ;
    neo:id "8987ca88a1d283ad9073b817f6db88b0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 1, sentence number 3 on page 23"^^xsd:string ;
    neo:text "When he was getting very old, he told them a story he had heard in China."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_532 a neo:Document ;
    neo:id "6969577b18bcfe02f51bc8aa92366f49"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 2, sentence number 1 on page 23"^^xsd:string ;
    neo:text "This is the story:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_533 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_534,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "8965460434b21669024e116aa3b5de85"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 3, sentence number 1 on page 23"^^xsd:string ;
    neo:text "One year on the twenty-fifth of December, Tokufu, who was very old, said to his disciples: I am not going to-be alive next year so you fellows should treat me well this year.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_535 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_536,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_537,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_538 ;
    neo:id "dc8a56fc25336387bd68cb0f425e5211"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 4, sentence number 1 on page 23"^^xsd:string ;
    neo:text "The pupils thought he was joking, but since he was a great-hearted teacher each of them in turn treated him to a feast on succeeding days of the departing year."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_539 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_534,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_540 ;
    neo:id "79f0c57d69ea62cba2153deb1f2e86a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 5, sentence number 1 on page 23"^^xsd:string ;
    neo:text "On the eve of the New Year, Tokufu concluded: ‘You have been good to me."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_541 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_542,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_543 ;
    neo:id "07fd76c5f738c74ccf5a2e76c0bcd976"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 5, sentence number 2 on page 23"^^xsd:string ;
    neo:text "I shall leave you tomorrow afternoon when the snow has stopped.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_544 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_543,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "7d54061d2c43465ed24f52b782e3a6cf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 6, sentence number 1 on page 23"^^xsd:string ;
    neo:text "The disciples laughed, thinking he was aging and talking nonsense since the night was clear and without snow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_545 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_20,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_543 ;
    neo:id "6adee2563ce689926e5c3e5d15604ec5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 6, sentence number 2 on page 23"^^xsd:string ;
    neo:text "But at midnight snow began to fall, and the next day they did not find their teacher about."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_547 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_548 ;
    neo:id "de6b6edf799d120a1c42706582ce30e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 6, sentence number 3 on page 23"^^xsd:string ;
    neo:text "They went to the meditation hall."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_549 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "d1b3acfef8439456c713bac06cc680f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 7, sentence number 1 on page 23"^^xsd:string ;
    neo:text "There he had passed on."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_55 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_44,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "edcd2720e46da2e1bd9724c501b5ffa7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 6, sentence number 1 on page 7"^^xsd:string ;
    neo:text "The first Zen patriarch Bodhidharma brought Zen to China from India in the sixth century."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_550 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "3bf4a1d907499099e5bd70977fa7fd9c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 8, sentence number 1 on page 23"^^xsd:string ;
    neo:text "Hoshin, who related this story, told his disciples: ‘It is not necessary for a Zen master to predict his passing, but if he really wishes to do so, he can.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_551 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_552 ;
    neo:id "8db4a163a49603f8c1f08fc4a3ad789e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 9, sentence number 1 on page 23"^^xsd:string ;
    neo:text "‘Can you?’ someone asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_553 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527 ;
    neo:id "de497c8a9751ae11460d5f17643e33a7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 10, sentence number 1 on page 23"^^xsd:string ;
    neo:text "‘Yes,’ answered Hoshin."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_554 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_556 ;
    neo:id "bdee2ddb6aa59aafa732aa50e051192d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 10, sentence number 2 on page 23"^^xsd:string ;
    neo:text "‘I will show you what I can do seven days from now."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_557 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "36f129b4fe2a9fb524476904bc82c265"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 11, sentence number 1 on page 23"^^xsd:string ;
    neo:text "None of the disciple’s believed him, and most of them had even forgotten the conversation when Hoshin next called them together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_558 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "afd80b0684d01754a1df0b1b0afc14b8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 12, sentence number 1 on page 23"^^xsd:string ;
    neo:text "‘Seven days ago,’ he remarked, ‘I said I was going to leave you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_559 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_560,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_561,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_562 ;
    neo:id "cea57783a8fcaf5b7b5f3d159fbf1ca6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 12, sentence number 2 on page 23"^^xsd:string ;
    neo:text "It is customary to write a farewell poem, but I am neither poet nor calligrapher."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_563 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "f939907f38fae0f483d5e7cbf27571b3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 12, sentence number 3 on page 23"^^xsd:string ;
    neo:text "Let one of you inscribe my last words.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_564 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_565,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_566 ;
    neo:id "e6e0f924da9dd40b67c94b3f785657a9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 13, sentence number 1 on page 23"^^xsd:string ;
    neo:text "His followers thought he was joking, but one of them started to write."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_567 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527 ;
    neo:id "c42bcffaf1b229224440adbbd2d35509"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 14, sentence number 1 on page 23"^^xsd:string ;
    neo:text "‘Are you ready?’ Hoshin asked."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_568 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_569 ;
    neo:id "fe8a77e6ad1c72dfd2a4bf772e7b0858"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 15, sentence number 1 on page 23"^^xsd:string ;
    neo:text "‘Yes, sir,’ replied the writer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_57 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_30,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_58,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "e34aa38ccab430bf0d3179c670895e7d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 6, sentence number 2 on page 7"^^xsd:string ;
    neo:text "According to his biography recorded in the year 1004 by the Chinese teacher Dogen after nine years in China Bodhidharma wished to go home and gathered his disciples about him to test their apperception."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_570 a neo:Document ;
    neo:id "57cd636bc6d5e76df82c8020ac511387"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 16, sentence number 1 on page 23"^^xsd:string ;
    neo:text "Then Hoshin dictated:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_571 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_572,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573 ;
    neo:id "f140ff9e4aab6b4d47c9557283fb157e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 17, sentence number 1 on page 23"^^xsd:string ;
    neo:text "I came from brilliancy And return to brilliancy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_574 a neo:Document ;
    neo:id "efc45797ddd32ddad81371c29f3d549b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 18, sentence number 1 on page 24"^^xsd:string ;
    neo:text "What is this?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_575 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_577,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "e92b8f459cec434584d9d5e7770639f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 19, sentence number 1 on page 24"^^xsd:string ;
    neo:text "The poem was one line short of the customary four, so, the disciple said: ‘Master, we are one line short.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_578 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_527,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_579 ;
    neo:id "72feecae94ccfd09711bd4c936ff9545"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 10. The Last Poem of Hoshin, paragraph number 20, sentence number 1 on page 24"^^xsd:string ;
    neo:text "Hoshin, with the roar of a conquering lion, shouted ‘Kaa!’ and was gone."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_581 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_583 ;
    neo:id "f9f72a471cbec74c35525d6f724c9de0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 1, sentence number 1 on page 25"^^xsd:string ;
    neo:text "The exquisite Shunkai whose other name was Suzu was compelled to marry against her wishes when she was quite young."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_585 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_584,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_586,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_587 ;
    neo:id "268cea39f947d793dd4ff6e602b26e9f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 1, sentence number 2 on page 25"^^xsd:string ;
    neo:text "Later, after this marriage had ended, she attended the university, where she studied philosophy."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_588 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582 ;
    neo:id "5407d8372ac32e8c78599d0b5bfe92e2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 2, sentence number 1 on page 25"^^xsd:string ;
    neo:text "To see Shunkai was to fall in love with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_590 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "91acad44c17d99ef259b2f61fab66667"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 2, sentence number 2 on page 25"^^xsd:string ;
    neo:text "Moreover, wherever she went, she herself fell in love with others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_591 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_374,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_586,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_587,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_589 ;
    neo:id "1390138433a8f730f032ed589ad90ce3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 2, sentence number 3 on page 25"^^xsd:string ;
    neo:text "Love was with her at the university, and afterwards, when philosophy did not satisfy her and she visited a temple to learn about Zen, the Zen students fell in love with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_592 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_589 ;
    neo:id "9a0568cd7be8700b634c8ca45bd7be32"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 2, sentence number 4 on page 25"^^xsd:string ;
    neo:text "Shunkai’s whole life was saturated with love."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_593 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "6fb1d2548234a84bdd22f7f5f9e745fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 3, sentence number 1 on page 25"^^xsd:string ;
    neo:text "At last in Kyoto she became a real student of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_594 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_595,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_596 ;
    neo:id "c0c6a7248e09be40de9ba5dda540e191"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 3, sentence number 2 on page 25"^^xsd:string ;
    neo:text "Her brothers in the sub-temple of Kennin praised her sincerity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_597 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_598 ;
    neo:id "f98a04b7c79960f4c773bcb4f4abba66"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 3, sentence number 3 on page 25"^^xsd:string ;
    neo:text "One of them proved to be a congenial spirit and assisted her in the mastery of Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_599 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_601 ;
    neo:id "e72183a677606e7f48362f947336975d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 4, sentence number 1 on page 25"^^xsd:string ;
    neo:text "The abbot of Kennin, Mokurai, Silent Thunder, was severe."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_6 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_10,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_11,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_7,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_8,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_9 ;
    neo:id "dcc6ef415ba48736ef6ab7d738c7c749"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 1, sentence number 2 on page 7"^^xsd:string ;
    neo:text "These stories recount actual experiences of Chinese and Japanese Zen teachers over a period of more than five centuries."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_60 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_61,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_62 ;
    neo:id "294dff2c9de43be175489b051c6bfb66"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 7, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Dofuku said: ‘In my opinion truth is beyond affirmation or negation, for this is the way it moves.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_602 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_189,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_603 ;
    neo:id "0cffa967690562a08380ebb99c0f49d5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 4, sentence number 2 on page 25"^^xsd:string ;
    neo:text "He kept the precepts himself and expected his priests to do so."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_604 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_189,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_33,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_605,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_606 ;
    neo:id "939d98f379178e5947aada949676843e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 4, sentence number 3 on page 25"^^xsd:string ;
    neo:text "In modern Japan whatever zeal these priests have lost for Buddhism they seem to have gained for having wives."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_607 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_188,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_608 ;
    neo:id "b47e8eb20ab3c8ea7242342b29c680f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 5, sentence number 1 on page 25"^^xsd:string ;
    neo:text "Mokurai used to take a broom and chase the women away when he found them in any of his temples, but the more wives he swept out, the more seemed to come back."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_609 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_610,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_611 ;
    neo:id "977f476ae708f9c0472bc521b62727dd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 6, sentence number 1 on page 25"^^xsd:string ;
    neo:text "In this particular temple the wife of the head priest became jealous of Shunkai’s earnestness and beauty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_612 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_20,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_279,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_613 ;
    neo:id "63491c575a86f8eac16209db714583c0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 6, sentence number 2 on page 25"^^xsd:string ;
    neo:text "Hearing the students praise her serious Zen made this wife squirm and itch."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_614 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_615 ;
    neo:id "2adc7c7f332efda1c77c5abdbc3c9105"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 6, sentence number 3 on page 25"^^xsd:string ;
    neo:text "Finally she spread a rumor about Shunkai and the young man who was now her friend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_616 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582 ;
    neo:id "593785d63ff049a8341b21b067939436"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 6, sentence number 4 on page 25"^^xsd:string ;
    neo:text "As a consequence he was expelled and Shunkai was removed from the temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_617 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_618,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_619,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_620 ;
    neo:id "23ccad324a3ab752bbaddc2bd733296a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 7, sentence number 1 on page 25"^^xsd:string ;
    neo:text "‘I may have made the mistake of love,’ thought Shunkai, ‘but the priest’s wife shall not remain in the temple either if my friend is to be treated so unjustly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_621 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_622 ;
    neo:id "8c8e89fefc83c29d3f302bc838980026"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 8, sentence number 1 on page 25"^^xsd:string ;
    neo:text "Shunkai the same night with a can of kerosene set fire to the five hundred year old temple and burned it to the ground."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_623 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_624 ;
    neo:id "f6cc7bf8fc5f49b3b9166e4951a1176b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 8, sentence number 2 on page 25"^^xsd:string ;
    neo:text "In the morning she found herself in the hands of the police."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_625 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_626 ;
    neo:id "c1ef670fbe9f04a02f44f9702c748b68"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 9, sentence number 1 on page 25"^^xsd:string ;
    neo:text "A young lawyer became interested in her and endeavored to make her sentence lighter."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_627 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "fd371d06bbb0088bf88a87701a279bb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 9, sentence number 2 on page 25"^^xsd:string ;
    neo:text "‘Do not help me,’ she told him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_628 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_629,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_630 ;
    neo:id "56c4397de8df9b6b16626fbf18e2cfcd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 9, sentence number 3 on page 25"^^xsd:string ;
    neo:text "I might decide to do something else which would only imprison me again.’ At last a sentence of seven years was completed, and Shunkai was released from the prison, where the sixty-three-year-old warden also had become enamored of her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_63 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "29fd55bd922f957c5f5c8b64f43c9a0c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 8, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Bodhidharma replied: ‘You have my skin.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_631 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_633 ;
    neo:id "6ad9f1b25b093e3bf20f7adf265e132a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 1 on page 26"^^xsd:string ;
    neo:text "But now everyone looked upon her as a ‘jailbird’."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_634 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246 ;
    neo:id "c27c3067feeffd23d5abaac2fe322d7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 2 on page 26"^^xsd:string ;
    neo:text "No one would associate with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_635 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_32,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_636 ;
    neo:id "7b9f836ffcec22b6e23a878628f83cd9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 3 on page 26"^^xsd:string ;
    neo:text "Even the Zen people, who are supposed to believe in enlightenment in this life and with this body, shunned her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_637 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_638 ;
    neo:id "4bdc6694c1090836f681d88b6d72ee48"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 4 on page 26"^^xsd:string ;
    neo:text "Zen, Shunkai found, was one thing and the followers of Zen quite another."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_639 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_640 ;
    neo:id "ee049655fb038fa261da39bb716519cf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 5 on page 26"^^xsd:string ;
    neo:text "Her relatives would have nothing to do with her."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_64 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_65,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_66,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_67 ;
    neo:id "cf3e9e930d1168ee8f3cda6a86127a4c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 9, sentence number 1 on page 8"^^xsd:string ;
    neo:text "The nun Soji said: ‘In my view, it is like Ananda’s sight of the Buddha- land—seen once and for ever.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_641 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "92666f9f1cedfd3ea20d2fe04822f401"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 10, sentence number 6 on page 26"^^xsd:string ;
    neo:text "She grew sick, poor, and weak."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_645 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_646,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_647 ;
    neo:id "8da956c561252b75c68e0c4bfbcb3083"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 11, sentence number 1 on page 26"^^xsd:string ;
    neo:text "She met a Shinshu priest who taught her the name of the Buddha of Love, and in this Shunkai found some solace and peace of mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_648 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350 ;
    neo:id "c59037ea4d61537987ef5a757a17ea2b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 11, sentence number 2 on page 26"^^xsd:string ;
    neo:text "She passed away when she was still exquisitely beautiful and hardly thirty years old."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_649 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_650,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_651 ;
    neo:id "d50449fb4c8b9937fa7e03dfe9fa4665"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 12, sentence number 1 on page 26"^^xsd:string ;
    neo:text "She wrote her own story in a futile endeavor to support herself and some of it she told to a woman writer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_652 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_653,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_654 ;
    neo:id "3024dc4f17988048d4cdf8cb2d8abb92"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 12, sentence number 2 on page 26"^^xsd:string ;
    neo:text "So it reached the Japanese people."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_655 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_582,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_656,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_657 ;
    neo:id "e39990f1bd72af2394d2ba63fc259172"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 11. The Story of Shunkai, paragraph number 12, sentence number 3 on page 26"^^xsd:string ;
    neo:text "Those who rejected Shunkai, those who slandered and hated her, now read of her life with tears of remorse."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_658 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_659,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_660,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_661,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_662,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_663 ;
    neo:id "a6b2d38b8223e0730d27683eb359e48c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 1, sentence number 1 on page 27"^^xsd:string ;
    neo:text "Anyone walking about Chinatowns in America will observe statues of a stout fellow carrying a linen sack."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_664 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_665,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_666,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_667 ;
    neo:id "d1bd6921f4da5975a31f9b3418fad916"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 1, sentence number 2 on page 27"^^xsd:string ;
    neo:text "Chinese merchants call him Happy Chinaman or Laughing Buddha."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_668 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_669,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_670 ;
    neo:id "1e4d329359312208440be5f855b68a9f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 2, sentence number 1 on page 27"^^xsd:string ;
    neo:text "This Hotei lived in the T’ang dynasty."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_671 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "24e749c0dd6db05d80374ae9d0b0a26c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 2, sentence number 2 on page 27"^^xsd:string ;
    neo:text "He had no desire to call himself a Zen master or to gather many disciples about him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_672 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_673,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_674,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_675,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_676,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_677 ;
    neo:id "a517594d50b18f64e5b7487462142d4f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 2, sentence number 3 on page 27"^^xsd:string ;
    neo:text "Instead he walked the streets with a big sack into which he would put gifts of candy, fruit, or doughnuts."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_678 a neo:Document ;
    neo:id "6074b1433b22a3bf5fb9ba9a2d3fd7b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 2, sentence number 4 on page 27"^^xsd:string ;
    neo:text "These he would give to children who gathered around him in play."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_679 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_680 ;
    neo:id "602ab3f630f9814218b750580e97b455"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 2, sentence number 5 on page 27"^^xsd:string ;
    neo:text "He established a kindergarten of the streets."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_68 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "66642a78bae2018e1c3abe0a6c99cf06"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 10, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Bodhidharma answered: ‘You have my flesh.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_681 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_682 ;
    neo:id "31f3ec5e7ae17446f4eff5ce507fef49"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 3, sentence number 1 on page 27"^^xsd:string ;
    neo:text "Whenever he met a Zen devotee he would extend his hand and say: ‘Give me one penny.’ And if anyone asked him to return to a temple to teach others, again he would reply: ‘Give me one penny.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_683 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_413,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "6402bd39aafcbd3f4b098ab3be396d75"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 4, sentence number 1 on page 27"^^xsd:string ;
    neo:text "Once as he was about his play work another Zen master happened along and inquired: ‘What is the significance of Zen?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_684 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_669,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_674,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_685 ;
    neo:id "4f5f9846df78fc88ccdb768497b459e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 5, sentence number 1 on page 27"^^xsd:string ;
    neo:text "Hotei immediately plopped his sack down on the ground in silent answer."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_686 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_687 ;
    neo:id "39ca17c0f2494956f263abf931e47118"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 6, sentence number 1 on page 27"^^xsd:string ;
    neo:text "‘Then,’ asked the other, ‘what is the actualization of Zen?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_688 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_665,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_674 ;
    neo:id "400870dabfb89d910496b1272603ac2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 12. Happy Chinaman, paragraph number 7, sentence number 1 on page 27"^^xsd:string ;
    neo:text "At once the Happy Chinaman swung the sack over his shoulder and continued on his way."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_689 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_204,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_690,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_691,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_692 ;
    neo:id "4397132c54242bb47f51a359cc19aeea"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 1, sentence number 1 on page 28"^^xsd:string ;
    neo:text "In Tokyo in the Meiji era there lived two prominent teachers of opposite characteristics."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_693 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_694,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_695,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "2d2b85344a68b38c28119fa992f8c8ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 1, sentence number 2 on page 28"^^xsd:string ;
    neo:text "One, Unsho, an instructor in Shingon, kept Buddha’s precepts scrupulously."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_696 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "2b22084aa14ff1e4251046047f5f86f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 1, sentence number 3 on page 28"^^xsd:string ;
    neo:text "He never drank intoxicants, nor did he eat after eleven o’clock in the morning."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_698 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_699 ;
    neo:id "f1528c982a72f17c551c0e5631af3db7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 2, sentence number 1 on page 28"^^xsd:string ;
    neo:text "The other teacher, Tanzan, a professor of philosophy at the Imperial University, never observed the precepts."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_700 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "b287096f26aa5a49fd648fda08b21d37"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 2, sentence number 2 on page 28"^^xsd:string ;
    neo:text "When he felt like eating he ate, and when he felt like sleeping in the daytime he slept."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_703 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_290,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_694,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_704 ;
    neo:id "0404e95aee5a752447ef68d39c2371d3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 3, sentence number 1 on page 28"^^xsd:string ;
    neo:text "One day Unsho visited Tanzan, who was drinking wine at the time, not even a drop of which is supposed to touch the tongue of a Buddhist."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_705 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "7d95c66138b5593963e2dda3e2879931"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 4, sentence number 1 on page 28"^^xsd:string ;
    neo:text "‘Hello, brother,’ Tanzan greeted him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_707 a neo:Document ;
    neo:id "eb6b4c1f98cfd755ffe858a07ad95263"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 4, sentence number 2 on page 28"^^xsd:string ;
    neo:text "‘Won’t you have a drink?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_708 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_694 ;
    neo:id "3f5eed42812b104ec29d48be3e8baa97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 5, sentence number 1 on page 28"^^xsd:string ;
    neo:text "‘I never drink!’ exclaimed Unsho solemnly."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_709 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449 ;
    neo:id "676a526bb0c3c50ec971f12f6746ed97"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 6, sentence number 1 on page 28"^^xsd:string ;
    neo:text "‘One who does not drink is not even human,’ said Tanzan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_71 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_61,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_72,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_74,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_75,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_76 ;
    neo:id "66a299af946418ee1ca71cbe6274f229"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 11, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Dofuku said: ‘The four elements of light, airiness, fluidity, and solidity are empty (i.e."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_710 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_694 ;
    neo:id "25f30197e341e696509c8bbf2d1fbaf7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 7, sentence number 1 on page 28"^^xsd:string ;
    neo:text "‘Do you mean to call me inhuman just because I do not indulge in intoxicating liquids!’ exclaimed Unsho in anger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_711 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "539cc2938c3df92bad3e27f95daef2e5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 7, sentence number 2 on page 28"^^xsd:string ;
    neo:text "Then if I am not human, what am I?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_712 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "06b1815b7fd1dba596aaa6a7ceedf78c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 13. A Buddha, paragraph number 8, sentence number 1 on page 28"^^xsd:string ;
    neo:text "‘A Buddha.’ answered Tanzan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_713 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_715 ;
    neo:id "080cab8de045dfdbc8b0ec590048608c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 1, sentence number 1 on page 29"^^xsd:string ;
    neo:text "Tanzan and Ekido were once traveling together down a muddy road."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_716 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_233,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288 ;
    neo:id "c5ef58a529fa514b228ed6ba8f40221b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 1, sentence number 2 on page 29"^^xsd:string ;
    neo:text "A heavy rain was still falling."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_717 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_718,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_719,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_720 ;
    neo:id "2814cd1afcdae806daf1fbbce0af68e7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 2, sentence number 1 on page 29"^^xsd:string ;
    neo:text "Coming around a bend, they met a lovely girl in a silk kimono and sash, unable to cross the intersection."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_721 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449 ;
    neo:id "58d96d355fcd1efc7cdc0af1ba99f3f7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 3, sentence number 1 on page 29"^^xsd:string ;
    neo:text "‘Come on, girl,’ said Tanzan at once."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_722 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_723 ;
    neo:id "c0a12dc3b3701b1bd161391a13fec85c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 3, sentence number 2 on page 29"^^xsd:string ;
    neo:text "Lifting her in his arms, he carried her over the mud."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_724 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_714,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_725 ;
    neo:id "33780375274da0a7656e0a13f5358064"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 4, sentence number 1 on page 29"^^xsd:string ;
    neo:text "Ekido did not speak again until that night when they reached a lodging temple."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_726 a neo:Document ;
    neo:id "7d0aacbf60fb7a2e36d106e550504d53"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 4, sentence number 2 on page 29"^^xsd:string ;
    neo:text "Then he no longer could restrain himself."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_727 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_728 ;
    neo:id "434c067e41f11c9e0daf1e7f6166ab39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 5, sentence number 1 on page 29"^^xsd:string ;
    neo:text "‘We monks don’t go near females.’ He told Tanzan, especially not young and lovely ones."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_729 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_730 ;
    neo:id "7f5d435f8717f1fbf1684d6e827c3d65"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 5, sentence number 2 on page 29"^^xsd:string ;
    neo:text "It is dangerous."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_731 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555 ;
    neo:id "30f51263a89daf313e25a52b74c1eca4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 5, sentence number 3 on page 29"^^xsd:string ;
    neo:text "Why did you do that?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_732 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_449,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_733 ;
    neo:id "b2a0e55fc4f27b5848c78bff51d7176a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 6, sentence number 1 on page 29"^^xsd:string ;
    neo:text "‘I left the girl there,’ said Tanzan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_734 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "7d3744690df2f98a810c5c8b33f0a01e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 14. Muddy Road, paragraph number 6, sentence number 2 on page 29"^^xsd:string ;
    neo:text "‘Are you still carrying her?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_735 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_737 ;
    neo:id "d3126fd45ddf5d48399821259fc6c11e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 1, sentence number 1 on page 30"^^xsd:string ;
    neo:text "Shoun became a teacher of Soto Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_738 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_739,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_740 ;
    neo:id "62237c109dde465577416210871952b2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 1, sentence number 2 on page 30"^^xsd:string ;
    neo:text "When he was still a student his father passed away, leaving him to care for his old mother."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_741 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_548,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_742 ;
    neo:id "35713981ed45d1ca9f235e9973598c24"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 2, sentence number 1 on page 30"^^xsd:string ;
    neo:text "Whenever Shoun went to a meditation hall he always took his mother with him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_743 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_190,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_744 ;
    neo:id "9bcdbb800d37155c885be4e5b96d9f07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 2, sentence number 2 on page 30"^^xsd:string ;
    neo:text "Since she accompanied him, when he visited monasteries he could not live with the monks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_745 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_246,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_280 ;
    neo:id "9475197cf24d65abae8195268969384f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 2, sentence number 3 on page 30"^^xsd:string ;
    neo:text "So he would build a little house and care for her there."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_746 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_284,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_747,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_748,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_749 ;
    neo:id "802d5e380c3c3a599a84b1bcda4a22f8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 2, sentence number 4 on page 30"^^xsd:string ;
    neo:text "He would copy sutras, Buddhist verses and in this manner receive a few coins for food."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_750 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_291,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_427,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_742 ;
    neo:id "17c08ec749871c4053315e76472a7433"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 3, sentence number 1 on page 30"^^xsd:string ;
    neo:text "When Shoun bought fish for his mother, the people would scoff at him, for a monk is not supposed to eat fish."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_751 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "f0fa032798710f933e6dd47ed3d3f29d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 3, sentence number 2 on page 30"^^xsd:string ;
    neo:text "But Shoun did not mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_752 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "289b862b939f19cd41570390c33a027a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 3, sentence number 3 on page 30"^^xsd:string ;
    neo:text "His mother, however, was hurt to see others laugh at her son."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_754 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "afe0a26072456ecfac28de0ada6ab12c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 3, sentence number 4 on page 30"^^xsd:string ;
    neo:text "Finally she told Shoun: ‘I think I will become a nun."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_755 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "91cd05834bd16bc48bf2ba6b6a9905fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 3, sentence number 5 on page 30"^^xsd:string ;
    neo:text "I can be a vegetarian too.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_757 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491 ;
    neo:id "57be8d5eea9ede294e05c589b80b0d46"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 4, sentence number 1 on page 30"^^xsd:string ;
    neo:text "She did and they studied together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_758 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_742,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_760 ;
    neo:id "cf51e30c12f2fd53939451f4624f98ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 4, sentence number 2 on page 30"^^xsd:string ;
    neo:text "Shoun was fond of music and was a master of the harp, which his mother also played."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_761 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_762 ;
    neo:id "2598a22cb4e2a8cbd59fc98d1f74db1f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 5, sentence number 1 on page 30"^^xsd:string ;
    neo:text "On full-moon nights they used to play together."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_763 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_280,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_764 ;
    neo:id "99e8885a0d48abef13a20d70ad15fee7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 1 on page 30"^^xsd:string ;
    neo:text "One night a young lady passed by their house and heard music."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_765 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_350,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "d4154b564b8e5ffb0b29bdc2feb21698"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 2 on page 30"^^xsd:string ;
    neo:text "Deeply touched, she invited Shoun to visit her the next evening and play."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_766 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_767 ;
    neo:id "4a33ecac91a9e19abfa7024f402c3aac"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 3 on page 30"^^xsd:string ;
    neo:text "He accepted the invitation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_768 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_764 ;
    neo:id "8e46b61eec41cbc3d1507550f43e2f11"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 4 on page 30"^^xsd:string ;
    neo:text "A few days later he met the young lady on the street and thanked her for her hospitality."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_769 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_198,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243 ;
    neo:id "0c5094e86a10f556a47d263828d165e9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 5 on page 30"^^xsd:string ;
    neo:text "Others laughed at him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_77 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_78,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_79 ;
    neo:id "744998cad4b2f65dec74feedffb5f166"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 11, sentence number 2 on page 8"^^xsd:string ;
    neo:text "inclusive) and the five skandas are No-things."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_770 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_771 ;
    neo:id "e39a00fc2a447139103acdc1acca35fc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 6, sentence number 6 on page 30"^^xsd:string ;
    neo:text "He had visited the home of a woman of the streets."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_772 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_773 ;
    neo:id "d73ca5b504f69b862c82c9ac4225368b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 7, sentence number 1 on page 30"^^xsd:string ;
    neo:text "One day Shoun left a distant temple to deliver a lecture."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_774 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367 ;
    neo:id "e7e87c19a491676ef287ebf5c3f4f111"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 7, sentence number 2 on page 30"^^xsd:string ;
    neo:text "A few months afterwards he returned home to find his mother dead."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_775 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_776,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_777 ;
    neo:id "244bbcb8027f868e7e2a11162905d1e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 7, sentence number 3 on page 30"^^xsd:string ;
    neo:text "Friends had not known where to reach him, so the funeral was then in progress."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_778 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_779,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_780 ;
    neo:id "96933754a261194042efa435aec76c40"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 8, sentence number 1 on page 30"^^xsd:string ;
    neo:text "Shoun walked up and hit the coffin with his staff."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_781 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753 ;
    neo:id "7bc1ffce7fc23ec72a49a13186d268d6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 8, sentence number 2 on page 30"^^xsd:string ;
    neo:text "‘Mother, your son has returned,’ he said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_782 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_783 ;
    neo:id "2b322f9cf7add3fd533f49af1a580bce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 9, sentence number 1 on page 30"^^xsd:string ;
    neo:text "‘I am glad to see you have returned son,’ he answered for his mother."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_784 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "956dbbef0db561658be578ec34040a2f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 10, sentence number 1 on page 30"^^xsd:string ;
    neo:text "‘I’m glad too,’ Shoun responded."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_785 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_786,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_787 ;
    neo:id "271923e0a43798e97bec9044380d17a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 10, sentence number 2 on page 30"^^xsd:string ;
    neo:text "Then he announced to the people about him: The funeral ceremony is over."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_788 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_555,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_789 ;
    neo:id "41aae5f55696c4ab284efb5114613d83"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 10, sentence number 3 on page 30"^^xsd:string ;
    neo:text "You may bury the body.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_790 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "9fa4ddde757e943ce77fd40cf3366345"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 11, sentence number 1 on page 30"^^xsd:string ;
    neo:text "When Shoun was old he knew his end was approaching."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_791 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59 ;
    neo:id "7f61b371c39ffa2c6469b920433194c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 11, sentence number 2 on page 30"^^xsd:string ;
    neo:text "He asked his disciples to gather around him in the morning telling them he was going to pass on at noon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_793 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_576,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_783,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_794,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_795,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_796 ;
    neo:id "d58448627bfc1f7ff9a6a9e11c570d8e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 11, sentence number 3 on page 30"^^xsd:string ;
    neo:text "Burning incense before the picture of his mother and his old teacher, he wrote a poem:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_797 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_180,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_287 ;
    neo:id "a2fbfc4c9b2d2e849eae3b2880ed62ed"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 12, sentence number 1 on page 30"^^xsd:string ;
    neo:text "For fifty-six years I lived as best I could, Making my way in this world."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_798 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_799 ;
    neo:id "c83eab40473b87b57ffb4e9aceec2e4d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 13, sentence number 1 on page 31"^^xsd:string ;
    neo:text "Now the rain has ended, the clouds are clearing,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_80 a neo:Document ;
    neo:id "67b8a617804471048771fe9e3312bd8a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 11, sentence number 3 on page 8"^^xsd:string ;
    neo:text "In my opinion,"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_800 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_801,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_802 ;
    neo:id "2ab908f4ebd76b15eb627b2f4bc51a68"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 14, sentence number 1 on page 31"^^xsd:string ;
    neo:text "The blue sky has a full moon."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_803 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_736 ;
    neo:id "35e5216f792910698e059ac20fe96485"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 15. Shoun and His Mother, paragraph number 15, sentence number 1 on page 31"^^xsd:string ;
    neo:text "His disciples gathered about him, reciting a sutra, and Shoun passed on during the invocation."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_804 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_805,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_807 ;
    neo:id "8ff14ebd27b0dd4aeb97259cda9734e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 1, sentence number 1 on page 32"^^xsd:string ;
    neo:text "A university student while visiting Gasan asked him: ‘Have you ever read the Christian Bible?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_808 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "cefe4028d5186b2ad8e1fcfe6cd71158"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 2, sentence number 1 on page 32"^^xsd:string ;
    neo:text "‘No, read it to me,’ said Gasan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_809 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_811,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_812 ;
    neo:id "5ac1118c3183c410edda6f37ce5a1c84"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 2, sentence number 2 on page 32"^^xsd:string ;
    neo:text "The student opened the Bible and read from St Mattew: ‘And why take ye thought for raiment?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_81 a neo:Document ;
    neo:id "986ad6cbc8403b6aa63005917d624046"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 12, sentence number 1 on page 8"^^xsd:string ;
    neo:text "No-thing (i.e."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_813 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_814,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_815 ;
    neo:id "a37052f524f569a158d7c557148fa0df"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 2, sentence number 3 on page 32"^^xsd:string ;
    neo:text "Consider the lilies of the field, how they grow."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_816 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_491,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_817 ;
    neo:id "a26d0046b6e899725b5b9096197f2e60"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 2, sentence number 4 on page 32"^^xsd:string ;
    neo:text "They toil not, neither do they spin, and yet I say unto you that even Solomon in all his glory was not arrayed like one of these."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_818 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_819,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_820 ;
    neo:id "fa37de33c4df454083a10f693ee416cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 2, sentence number 5 on page 32"^^xsd:string ;
    neo:text "…Take therefore no thought for the morrow, for the morrow shall take thought for the things of itself.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_82 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_83,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_84 ;
    neo:id "7b56c5d7081307881fbef66a3a68c22f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 12, sentence number 2 on page 8"^^xsd:string ;
    neo:text "spirit) is reality.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_821 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_822 ;
    neo:id "a4a12590463f7aff9a6427185eadd504"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 3, sentence number 1 on page 32"^^xsd:string ;
    neo:text "Gasan said: ‘Whoever uttered those words I consider an enlightened man.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_823 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_92 ;
    neo:id "db2c5145386a3ba25742c0a29ddc24a8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 4, sentence number 1 on page 32"^^xsd:string ;
    neo:text "The student continued reading: ‘Ask and it shall be given you, seek and ye shall find, knock and it shall be opened unto you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_824 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_632 ;
    neo:id "062a15eeeebb7c4e8db98f6ddb0bb970"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 4, sentence number 2 on page 32"^^xsd:string ;
    neo:text "For everyone that asketh receiveth, and he that seeketh findeth, and to him that knocketh, it shall be opened.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_827 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_806 ;
    neo:id "6bc2fa3c97f8a20745f4da163482b0e0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 5, sentence number 1 on page 32"^^xsd:string ;
    neo:text "Gasan remarked: ‘That is excellent."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_828 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_829 ;
    neo:id "ad3fb5ad05a821bb31dc95eb2e8a6cef"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 16. Not Far from Buddahood, paragraph number 5, sentence number 2 on page 32"^^xsd:string ;
    neo:text "Whoever said that is not far from Buddhahood.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_830 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_690,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_832 ;
    neo:id "b1ea73b3f7930db30384a63c2eaf78a4"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 1, sentence number 1 on page 33"^^xsd:string ;
    neo:text "A young physician in Tokyo named Kusuda met a college friend who had been studying Zen."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_833 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_834 ;
    neo:id "0348bbdd7e97407c0b4c8bf406a94681"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 1, sentence number 2 on page 33"^^xsd:string ;
    neo:text "The young doctor asked him what Zen was."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_835 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836 ;
    neo:id "725ed01154377a3a1174dcfc0792f07c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 2, sentence number 1 on page 33"^^xsd:string ;
    neo:text "‘I cannot tell you what it is,’ the friend replied, ‘but one thing is certain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_837 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_838 ;
    neo:id "84f3401456449d0b6018b6d2d7a223cc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 2, sentence number 2 on page 33"^^xsd:string ;
    neo:text "If you understand Zen, you will not be afraid to die.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_839 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "ca10ff62ad10f56f426b4dc67aaebfc7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 3, sentence number 1 on page 33"^^xsd:string ;
    neo:text "That’s fine: said Kusuda."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_840 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "3a70d4b5584f69525ddc1693462c2a93"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 3, sentence number 2 on page 33"^^xsd:string ;
    neo:text "“I will try it."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_841 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307 ;
    neo:id "ec462cb0aee247688b1d2d9b08cade8f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 3, sentence number 3 on page 33"^^xsd:string ;
    neo:text "Where can I find a teacher?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_842 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_843,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_844 ;
    neo:id "c6f70901c2b020b34ccdbdd2e2f5ad05"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 4, sentence number 1 on page 33"^^xsd:string ;
    neo:text "‘Go to the master Nan-in,’ the friend told him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_845 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "8d0abb65bde2c50c0953e33aa449099e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 5, sentence number 1 on page 33"^^xsd:string ;
    neo:text "So Kusuda went to call on Nan-in."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_846 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_847 ;
    neo:id "5c923af5a4cd8bdcd3c0887ddad63a7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 5, sentence number 2 on page 33"^^xsd:string ;
    neo:text "He carried a dagger nine and a half inches long to determine whether or not the teacher himself was afraid to die."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_848 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "30709b5e3b48d794e5962809226f4aaf"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 6, sentence number 1 on page 33"^^xsd:string ;
    neo:text "When Nan-in saw Kusuda he exclaimed: ‘Hello, friend."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_849 a neo:Document ;
    neo:id "04e35eb3e4fcb8b395191053c359ca0e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 6, sentence number 2 on page 33"^^xsd:string ;
    neo:text "How are you?"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_85 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_86 ;
    neo:id "3b1eb600255b66a6c37430655e113177"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 13, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Bodhidharma commented: ‘You have my bones’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_850 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_851 ;
    neo:id "c448007de8f243a9c767d9d7a5701cab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 6, sentence number 3 on page 33"^^xsd:string ;
    neo:text "We haven’t seen each other for a long time!’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_852 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "d638b57b417a22d611d6890b1ee29ffa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 7, sentence number 1 on page 33"^^xsd:string ;
    neo:text "This perplexed Kusuda, who replied: ‘We have never met before.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_853 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203 ;
    neo:id "f325f749b8511460645b544ea7c90013"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 8, sentence number 1 on page 33"^^xsd:string ;
    neo:text "‘That’s right,’ answered Nan-in."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_854 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_176,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_573,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_855 ;
    neo:id "c5f98b12b4bf8f2aa02d439ad1bbf08f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 8, sentence number 2 on page 33"^^xsd:string ;
    neo:text "I mistook you for another physician who is receiving instruction here.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_857 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "899147bd99e58c30bab8e2bdae11323c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 9, sentence number 1 on page 33"^^xsd:string ;
    neo:text "With such a beginning, Kusuda lost his chance to test the master, so reluctantly be asked if he might receive Zen instruction."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_859 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45 ;
    neo:id "12cfede0330b3cc5d0fdd151587eef83"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 10, sentence number 1 on page 33"^^xsd:string ;
    neo:text "Nan-in said: ‘Zen is not a difficult task."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_860 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_861,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_862 ;
    neo:id "68d4cb63edcf7139b2205da3ecb06e83"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 10, sentence number 2 on page 33"^^xsd:string ;
    neo:text "If you are a physician, treat your patients with kindness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_863 a neo:Document ;
    neo:id "5b4ea8847dd6e0939bf2222fa9a9d950"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 10, sentence number 3 on page 33"^^xsd:string ;
    neo:text "That is Zen.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_864 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "cab4dd2070409eb10a6c95e1c292904e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 11, sentence number 1 on page 33"^^xsd:string ;
    neo:text "Kusuda visited Nan-in three times."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_865 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_861 ;
    neo:id "ea02250fca1a196951661e4b148eca20"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 11, sentence number 2 on page 33"^^xsd:string ;
    neo:text "Each time Nan-in told him the same thing.’ A physician should not waste time around here."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_866 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_244,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_862 ;
    neo:id "79ac3b2967740439bbbedcc08bf57ffd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 11, sentence number 3 on page 33"^^xsd:string ;
    neo:text "Go home and take care of your patients.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_867 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_320,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_838 ;
    neo:id "fcbdf428baa500cf1bdefd5968c7f2e6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 12, sentence number 1 on page 33"^^xsd:string ;
    neo:text "It was not yet clear to Kusuda how such teaching could remove the fear of death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_868 a neo:Document ;
    neo:id "5a9195fab7e533df9ce9b5ff789be577"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 12, sentence number 2 on page 33"^^xsd:string ;
    neo:text "So on his fourth visit he complained:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_869 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_836,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_838 ;
    neo:id "2ec5573f39d7ce1d3839bae478ad70ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 13, sentence number 1 on page 33"^^xsd:string ;
    neo:text "‘My friend told me when one learns Zen one loses his fear of death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_87 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_88,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89 ;
    neo:id "12121c04efb86bc2a5e0483bdd827352"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 14, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Finally Eka bowed before the master—and remained silent."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_870 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_862 ;
    neo:id "ea26cbc84e11350942f8602d4c0cb716"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 13, sentence number 2 on page 33"^^xsd:string ;
    neo:text "Each time I come here all you tell me is to take care of my patients."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_871 a neo:Document ;
    neo:id "c918cf3dca9efb6a1d1b0a0e738772a2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 13, sentence number 3 on page 33"^^xsd:string ;
    neo:text "I know that much."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_872 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_873 ;
    neo:id "7ddcd3c787e486181fa4ec6bd9907c0b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 13, sentence number 4 on page 33"^^xsd:string ;
    neo:text "If that is your so-called Zen, I am not going to visit you any more.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_874 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_875 ;
    neo:id "6c86ecae59a4a9cf5ad66c2179377343"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 14, sentence number 1 on page 33"^^xsd:string ;
    neo:text "Nan-in smiled and patted the doctor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_876 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "99334d0304612f66bad481124bed0523"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 14, sentence number 2 on page 33"^^xsd:string ;
    neo:text "‘I have been too strict with you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_877 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_17,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282 ;
    neo:id "e5921ac17d5edb41002a71b646ff0b2c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 14, sentence number 3 on page 33"^^xsd:string ;
    neo:text "Let me give you a koan."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_878 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_13,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_879,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_880 ;
    neo:id "b7b5cfdf1b467f5f1a7836e377798929"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 14, sentence number 4 on page 33"^^xsd:string ;
    neo:text "‘ He presented Kusuda with Joshu’s Mu to work over, which is the first mind-enlightening problem in the book called The Gateless Gate. Kusuda pondered this problem of Mu (No-thing) for two years."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_881 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "dc26356052210ffd9422d57c374d2978"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 15, sentence number 2 on page 34"^^xsd:string ;
    neo:text "At length he thought he had reached certainty of mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_882 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_810 ;
    neo:id "b202d734a16ef4ba2295429bc4f1a0ff"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 15, sentence number 1 on page 34"^^xsd:string ;
    neo:text "But his teacher commented: “You are not in yet.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_883 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_831 ;
    neo:id "ecb8a52d6fd5be1d4bfeec00721fd067"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 16, sentence number 1 on page 34"^^xsd:string ;
    neo:text "Kusuda continued in concentration for another year and a half."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_884 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108 ;
    neo:id "9ea7cec8919659a3a87e4278228770f1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 16, sentence number 2 on page 34"^^xsd:string ;
    neo:text "His mind became placid."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_886 a neo:Document ;
    neo:id "20c4dc384f04a8b6e7428c8ad3cc3394"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 16, sentence number 3 on page 34"^^xsd:string ;
    neo:text "Problems dissolved."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_887 a neo:Document ;
    neo:id "64932ca274b3ea9e7a247b2ebbb2c39d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 16, sentence number 4 on page 34"^^xsd:string ;
    neo:text "No-thing became the truth."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_888 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_862 ;
    neo:id "7516e6acc7cb3aa767cc42e8c0d2c2c7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 16, sentence number 5 on page 34"^^xsd:string ;
    neo:text "He served his patients well and, without even knowing it, be was free from concern over life and death."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_889 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_203,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "8840d5eb3a2387120a9f76eb0be2696d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 17. Stingy in Teaching, paragraph number 17, sentence number 1 on page 34"^^xsd:string ;
    neo:text "Then when he visited Nan-in his old teacher just smiled."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_890 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_248,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_815,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_891,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_892,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "33ae590598f15d396da4019af8453c07"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 1 on page 35"^^xsd:string ;
    neo:text "Buddha told a parable in a sutra: A man traveling across a field encountered a tiger."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_893 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_892 ;
    neo:id "72cd17df2c81ef18bf83fe649d5c8f32"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 2 on page 35"^^xsd:string ;
    neo:text "He fled, the tiger after him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_894 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_895,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_896,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_897,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_898 ;
    neo:id "69b559377e2f4c53e006d6fb3f95eb60"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 3 on page 35"^^xsd:string ;
    neo:text "Coming to a precipice, he caught hold of the root of a wild vine and swung himself down over the edge."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_899 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_892 ;
    neo:id "6854a672a5ee36b30321df9ff485db15"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 4 on page 35"^^xsd:string ;
    neo:text "The tiger sniffed at him from above."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_90 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_56 ;
    neo:id "d6b025133f9ad62e57279d786e422234"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 15, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Bodhidharma said: ‘You have my marrow.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_900 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_901 ;
    neo:id "b0c68eaf62ea57ddeaa8fe77f82a2a51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 5 on page 35"^^xsd:string ;
    neo:text "Trembling, the man looked down to where, far below, mother tiger was waiting to eat him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_902 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_903 ;
    neo:id "f9135bc85aa703ce1c4c3d097167382f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 1, sentence number 6 on page 35"^^xsd:string ;
    neo:text "Only the vine sustained him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_904 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_903,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_905,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_906 ;
    neo:id "4cdb7d631aa0c84f784617c5542580cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 2, sentence number 1 on page 35"^^xsd:string ;
    neo:text "Two mice one white and one black, little by little started to gnaw away the vine."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_907 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_132,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_908 ;
    neo:id "bf3af9d68c0b9f1146bed28a53aa4766"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 2, sentence number 2 on page 35"^^xsd:string ;
    neo:text "The man saw a luscious strawberry near him."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_909 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_903,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_908 ;
    neo:id "2e05f108083e069c4e2e985102ec42c8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 2, sentence number 3 on page 35"^^xsd:string ;
    neo:text "Grasping the vine with one hand, he plucked the strawberry with the other."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_910 a neo:Document ;
    neo:id "f228d3338ae446f7f8435f70e0eb1655"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 18. A Parable, paragraph number 2, sentence number 4 on page 35"^^xsd:string ;
    neo:text "How sweet it tasted!"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_911 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_303,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_912,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_913 ;
    neo:id "c33a6da67341b157980c17be3382d714"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 1, sentence number 1 on page 36"^^xsd:string ;
    neo:text "When one goes to Obaku temple in Kyoto one sees carved over the gate the words ‘ The First principle ‘."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_914 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_915,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_916,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_917,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_918 ;
    neo:id "46042d0875b21035a1272ad89856979d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 1, sentence number 2 on page 36"^^xsd:string ;
    neo:text "The letters are unusually large, and those who appreciate calligraphy always admire them as being a masterpiece."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_919 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_920,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_921 ;
    neo:id "6452088b5ae9f3d3074a71f20fc0cf99"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 1, sentence number 3 on page 36"^^xsd:string ;
    neo:text "They were drawn by Kosen two hundred years ago."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_922 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_923,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_924,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_925 ;
    neo:id "cf1d534658baceb9f566c107e26085ce"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 2, sentence number 1 on page 36"^^xsd:string ;
    neo:text "When the master drew them he did so on paper, from which workmen made the larger carving in wood."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_926 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_920,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_927 ;
    neo:id "8a03b08bd3982d865a7a97f503e62203"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 2, sentence number 2 on page 36"^^xsd:string ;
    neo:text "As Kosen sketched the letters a bold pupil was with him who had made several gallons of ink for the calligraphy and who never failed to criticize his master’s work."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_928 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_920 ;
    neo:id "bb540682d24b5eaaea4b737129893025"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 3, sentence number 1 on page 36"^^xsd:string ;
    neo:text "That is not good,’ he told Kosen after the first effort."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_929 a neo:Document ;
    neo:id "1dd8231b449cf92e9d446f70dbf115f9"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 4, sentence number 1 on page 36"^^xsd:string ;
    neo:text "‘How is that one?’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_93 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_94 ;
    neo:id "9aa2ad8b9afdc160e5935dc090ee499a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 16, sentence number 1 on page 8"^^xsd:string ;
    neo:text "Old Zen was so fresh it became treasured and remembered."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_930 a neo:Document ;
    neo:id "c259d87a8e76374e8dcaf44e9e9e5480"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 5, sentence number 1 on page 36"^^xsd:string ;
    neo:text "‘Poor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_931 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "b9959b935a41113ea08d7552677705be"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 5, sentence number 2 on page 36"^^xsd:string ;
    neo:text "Worse than before,’ pronounced the pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_933 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_920,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_934 ;
    neo:id "803bd08c536feee02d72ddcd1d464ea2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 6, sentence number 1 on page 36"^^xsd:string ;
    neo:text "Kosen patiently wrote one sheet after another until eighty-four First Principles had accumulated, still without the approval of the pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_935 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_364,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_920 ;
    neo:id "3f0aed1b2693fef8835f63cc517729b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 7, sentence number 1 on page 36"^^xsd:string ;
    neo:text "Then, when the young man stepped outside for a few moments, Kosen thought: ‘Now is my chance to escape his keen eye,’ and he wrote hurriedly, with a mind free from distraction: ‘The First principle.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_936 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_917,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_932 ;
    neo:id "17c171807d41fbdab200061d5800c6c1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 19. The First Principle, paragraph number 8, sentence number 1 on page 36"^^xsd:string ;
    neo:text "‘A masterpiece,’ pronounced the pupil."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_937 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_695,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_938,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_939,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_940 ;
    neo:id "1a7733ae74ec7e7e1b395ca9803b3ce0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 1, sentence number 1 on page 37"^^xsd:string ;
    neo:text "Jiun, a Shingon master, war a well-known Sanskrit scholar of the Tokugawa era."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_941 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_20,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_706 ;
    neo:id "6c26e0dbd4958b37f36ff452553e3e39"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 1, sentence number 2 on page 37"^^xsd:string ;
    neo:text "When he was young he used to deliver lectures to his brother students."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_942 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_243,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_367 ;
    neo:id "c54abe7e35607a3c2af13b7c22a00b10"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 2, sentence number 1 on page 37"^^xsd:string ;
    neo:text "His mother heard about this and wrote him a letter:"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_944 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_753,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "b9ecad48ee2e80023708ef6c3e005c70"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 3, sentence number 1 on page 37"^^xsd:string ;
    neo:text "‘Son, I do not think you become a devotee of the Buddha because you desire to turn into a walking dictionary for others."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_945 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_946,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_947,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_948,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_949 ;
    neo:id "c89f370362b468aa2c0778f489d42be6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 4, sentence number 1 on page 37"^^xsd:string ;
    neo:text "There is no end to information and commentation, glory and honor."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_95 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_70,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_86,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_91,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_96,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_97 ;
    neo:id "ba557cb1f46d0b8305b72aeb048d30de"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 16, sentence number 2 on page 8"^^xsd:string ;
    neo:text "Here are fragments of its skin flesh bones but not its marrow—never found in words."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_950 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_422 ;
    neo:id "66caddd35eae2b1b69392a5992257ed3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 4, sentence number 2 on page 37"^^xsd:string ;
    neo:text "I wish you would stop this lecture business."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_951 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_386,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_512 ;
    neo:id "d508c5be57463a91589af46b86a6a9b1"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 4, sentence number 3 on page 37"^^xsd:string ;
    neo:text "Shut yourself up in a little temple in a remote part of the mountain."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_952 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_484,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_953 ;
    neo:id "657b8b13766571d6ba243aad6708eb7d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 20. A Mother’s Advice, paragraph number 4, sentence number 4 on page 37"^^xsd:string ;
    neo:text "Devote your time to meditation and in this way attain hue realization.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_954 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_955 ;
    neo:id "1461513fabede44216462ffdee6662bd"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 1, sentence number 1 on page 38"^^xsd:string ;
    neo:text "The masts of Kennin temple was Mokurai, Silent Thunder."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_956 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "76a14eb6e89c793bfa07f0d813ee45b7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 1, sentence number 2 on page 38"^^xsd:string ;
    neo:text "He had a little protégé named Toyo who was only twelve years old."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_959 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_59,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_960,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_961 ;
    neo:id "a295fc373bf68662bb69911456e4eaab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 1, sentence number 3 on page 38"^^xsd:string ;
    neo:text "Toyo saw the olds disciples visit the master’s room each morning and evening to receive instruction in sanzen or personal guidance in which they were given koans to stop mind- wandering."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_962 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_960,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_963 ;
    neo:id "6902c2e1e34a92751d9a26a240a235b5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 2, sentence number 1 on page 38"^^xsd:string ;
    neo:text "Toro wished to do sanzen also."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_964 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "e7f0be9e1a3816bc5779b7aa88cbbc16"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 3, sentence number 1 on page 38"^^xsd:string ;
    neo:text "‘Wait a while,’ said Mokurai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_965 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_282,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_283 ;
    neo:id "bdfd08dd624a25e6d256ec9d244c922e"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 3, sentence number 2 on page 38"^^xsd:string ;
    neo:text "‘You are too young.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_967 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_347 ;
    neo:id "7bd6482a3e468593166a48c6117e1ed8"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 4, sentence number 1 on page 38"^^xsd:string ;
    neo:text "But the child insisted, so the teacher finally consented."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_968 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_969 ;
    neo:id "a2c9e572bcc7d864769f8ef83598ce08"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 5, sentence number 1 on page 38"^^xsd:string ;
    neo:text "In the evening little Toyo went at the props time to the threshold of Mokurai’s sanzen room."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_971 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_89,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_972,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_973 ;
    neo:id "88b5a671ef1ed211980a8f6e9c186fbe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 5, sentence number 2 on page 38"^^xsd:string ;
    neo:text "He struck the gong to announce his presence, bowed respectfully three times outside the door, and went to sit before the master in respectful silence."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_974 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_976 ;
    neo:id "d758f611084ae5e2b7a78ea2c14159d7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 6, sentence number 1 on page 38"^^xsd:string ;
    neo:text "‘You can hear the sound of two hands when they clap together,’ said Mokurai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_977 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_978 ;
    neo:id "bb3f425eb1a454ed9dcc98e510128353"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 6, sentence number 2 on page 38"^^xsd:string ;
    neo:text "‘Now show me the sound of one hand.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_979 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_980,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_981 ;
    neo:id "e184a85572500c57d510cf4d2072a2fa"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 7, sentence number 1 on page 38"^^xsd:string ;
    neo:text "Toyo bowed and went to his room to consider this problem."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_98 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_45,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_99 ;
    neo:id "64f33a8a2cb198106308a2dcb9407a2c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: Foreword, paragraph number 17, sentence number 1 on page 8"^^xsd:string ;
    neo:text "The directness of Zen has led many to believe it stemmed from sources before the time of Buddha, 500 BC."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_982 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_983,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_984 ;
    neo:id "0b20247751ece21f775cb05eadad8348"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 7, sentence number 2 on page 38"^^xsd:string ;
    neo:text "From his window he could hear the music of the geishas."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_985 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "7ae16741ef8005934e0407d901df8ff5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 8, sentence number 1 on page 38"^^xsd:string ;
    neo:text "‘Ah, I have it!’ he proclaimed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_986 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_984 ;
    neo:id "d9185125d9c617d786383938ca3d0608"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 9, sentence number 1 on page 38"^^xsd:string ;
    neo:text "The next evening, when his teacher asked him to illustrate the sound of one hand, Toyo began to play the music of the geishas."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_987 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_600 ;
    neo:id "95e266d8aaf0f9fdc749182bff452915"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 10, sentence number 1 on page 38"^^xsd:string ;
    neo:text "‘No, no,’ said Mokurai."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_988 a neo:Document ;
    neo:id "db0a2969f7ba45b56e361c9ea62d7d18"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 10, sentence number 2 on page 38"^^xsd:string ;
    neo:text "That will never do."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_989 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_990 ;
    neo:id "b015b3dcb7400db383f7e5f198802ffc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 10, sentence number 3 on page 38"^^xsd:string ;
    neo:text "That is not the sound of one hand."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_991 a neo:Document ;
    neo:id "eabbdb92237a5c9cb0438506fe0835c5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 10, sentence number 4 on page 38"^^xsd:string ;
    neo:text "You’ve not got it at all.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_992 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_759,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_993,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_994 ;
    neo:id "2389985d138da797bdffbd86ca950667"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 11, sentence number 1 on page 38"^^xsd:string ;
    neo:text "Thinking that such music might interrupt, Toyo moved his abode to a quiet place."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_995 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209 ;
    neo:id "99a44b8ef224b799382c71e1c2bf32d5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 11, sentence number 2 on page 38"^^xsd:string ;
    neo:text "He meditated again."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_996 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_997 ;
    neo:id "39a72255e713bcc3c8355f4113218940"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 11, sentence number 3 on page 38"^^xsd:string ;
    neo:text "‘What can the sound of one hand be?’ He happened to hear some water dripping."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_998 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "3a14150dd7bdbe308d290c7634d45b19"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 11, sentence number 4 on page 38"^^xsd:string ;
    neo:text "‘I have it,’ imagined Toyo."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_999 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_307,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_957 ;
    neo:id "ba08c3b129e287e6ddd819ca286c9293"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 21. The Sound of One Hand, paragraph number 12, sentence number 1 on page 38"^^xsd:string ;
    neo:text "When he next appeared before his teacher, Toyo imitated dripping water."^^xsd:string .

