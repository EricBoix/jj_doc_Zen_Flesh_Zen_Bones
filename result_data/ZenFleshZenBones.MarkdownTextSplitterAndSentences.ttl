        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3479 ;
    neo:id "a658862ab51be573557f65b3629c0e0a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 78, sentence number 2 on page 202"^^xsd:string ;
    neo:text "With mouth slightly open, keep mind in the middle of tongue."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4401 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4169,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4402,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "68c386f1f8e3a1eb45ab5898281be58b"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 78, sentence number 3 on page 202"^^xsd:string ;
    neo:text "Or, as breath comes silently in, feel the sound HH."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4403 a neo:Document ;
    neo:id "fe2297a92c34c323dbaf0904b64473fe"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 79, sentence number 1 on page 202"^^xsd:string ;
    neo:text "57."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4404 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1053,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1575,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4405 ;
    neo:id "b4550322d971b3fdd7dc65c0094fea80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 79, sentence number 2 on page 202"^^xsd:string ;
    neo:text "When on a bed or a seat, let yorself become weightless, beyond mind."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4406 a neo:Document ;
    neo:id "f07661e95af635f6a4c95fe0b7dbecdc"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 80, sentence number 1 on page 202"^^xsd:string ;
    neo:text "58."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4407 a neo:Document ;
    neo:id "bbad78c44cf0f8eb28959e77bff3a3bb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 80, sentence number 2 on page 202"^^xsd:string ;
    neo:text "In a moving vehicle, by rhythmically swaying, experience."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4408 a neo:Document ;
    neo:id "ef17cfbc4874fdf1a5031fc2da2b5e7c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 80, sentence number 3 on page 202"^^xsd:string ;
    neo:text "Or in a still vehicle, by letting yourself swing in slowing invisible circles."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4409 a neo:Document ;
    neo:id "f326b7d9fb2dc24590304fa452892004"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 81, sentence number 1 on page 202"^^xsd:string ;
    neo:text "59."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_441 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_442,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_443 ;
    neo:id "6f6cb009b6a0923e74adff5717947fb7"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 7, sentence number 1 on page 19"^^xsd:string ;
    neo:text "‘To think I fed that fellow for twenty years!’ exclaimed the old woman in anger.’ He showed no consideration for your need, no disposition to explain your condition."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4410 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4411,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_799,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_801 ;
    neo:id "1ce8287647bfeb7beb8cdade3f80c0eb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 81, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Simply by looking into the blue sky beyond clouds, the serenity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4412 a neo:Document ;
    neo:id "08eb51ebc09d3f60592314312fecdb55"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 82, sentence number 1 on page 202"^^xsd:string ;
    neo:text "60."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4413 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1870,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4156,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4414,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4415 ;
    neo:id "34f6c30333929d96f307e7566de5ac08"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 82, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Shakti, see all space as if already absorbed in your own head in the brilliance."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4416 a neo:Document ;
    neo:id "2e20bf81bb3259e7ca700131edd7f41c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 83, sentence number 1 on page 202"^^xsd:string ;
    neo:text "61."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4417 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4418,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4419,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_702,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_73 ;
    neo:id "319e9be9f90bd165eba131e86e93533d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 83, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Waking, sleeping, dreaming, know you as light."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4420 a neo:Document ;
    neo:id "11b94df22781ea836ec29e1c64e2f961"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 84, sentence number 1 on page 202"^^xsd:string ;
    neo:text "62."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4421 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_288,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_489 ;
    neo:id "8a55e4cb5360cdfacea3617ed9321d4a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 84, sentence number 2 on page 202"^^xsd:string ;
    neo:text "In rain during a black night, enter that blackness as the form of forms."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4423 a neo:Document ;
    neo:id "839c640fea8c4cd60f9bc157b912667a"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 85, sentence number 1 on page 202"^^xsd:string ;
    neo:text "63."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4424 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4422,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4425 ;
    neo:id "55e551a2094cc7fe6ad1f06705082322"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 85, sentence number 2 on page 202"^^xsd:string ;
    neo:text "When a moonless raining night is not present, close eyes and find blackness before you."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4426 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1706,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4422 ;
    neo:id "0ccc215c1be96ccd224defba7e9c4e56"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 85, sentence number 3 on page 202"^^xsd:string ;
    neo:text "Opening eyes, see blackness."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4427 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3794 ;
    neo:id "319f10600833c491fa1ad6c824a3ee42"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 85, sentence number 4 on page 202"^^xsd:string ;
    neo:text "So faults disappear forever."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4430 a neo:Document ;
    neo:id "b21dcf7bb379650752902c9dd7154751"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 86, sentence number 1 on page 203"^^xsd:string ;
    neo:text "64."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4431 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4432,
