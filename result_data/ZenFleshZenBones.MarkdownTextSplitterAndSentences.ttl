    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 70, sentence number 2 on page 201"^^xsd:string ;
    neo:text "0 lotus-eyed one, sweet of touch, when singing, seeing, tasting, be aware you are and discover the ever-living."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4371 a neo:Document ;
    neo:id "c4c5af239e836f3ce10f5f590d6a96c3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 71, sentence number 1 on page 202"^^xsd:string ;
    neo:text "49."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4372 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_1034,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4373 ;
    neo:id "54e4fc78749523fbd6d1c8f99c6102bb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 71, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Wherever satisfaction is found, in whatever act, actualize this."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4374 a neo:Document ;
    neo:id "f147c775d3c2a07eb736cbc44e4034d5"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 72, sentence number 1 on page 202"^^xsd:string ;
    neo:text "50."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4375 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_129,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4297,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4376 ;
    neo:id "f07250b1f86751a0bdd82b183f5fd3cb"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 72, sentence number 2 on page 202"^^xsd:string ;
    neo:text "At the point of sleep when sleep has not yet come and external wakefulness vanishes, at this point being is revealed."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4377 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_52 ;
    neo:id "0b9dfd160da89315222cd7bd0a188a83"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 72, sentence number 3 on page 202"^^xsd:string ;
    neo:text "[Lakshmanjoo says this is another of his favorites.]"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4378 a neo:Document ;
    neo:id "7bf67d29b92890cb48aff4b5a414acc3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 73, sentence number 1 on page 202"^^xsd:string ;
    neo:text "51."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4379 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3310,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3322,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4380 ;
    neo:id "282007687b79b1f34c17346d78c61af0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 73, sentence number 2 on page 202"^^xsd:string ;
    neo:text "In summer when you see the entire sky endlessly clear, enter such clarity."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4381 a neo:Document ;
    neo:id "e96d835ecf9d3dbefc82509ed96d5b85"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 74, sentence number 1 on page 202"^^xsd:string ;
    neo:text "52."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4382 a neo:Document ;
    neo:id "b128bcc3e268ce579f5a79b91dc1ead3"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 74, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Lie down as dead."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4383 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4384 ;
    neo:id "529dfb13be69d0b7872a64e4061fdec2"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 74, sentence number 3 on page 202"^^xsd:string ;
    neo:text "Enraged in wrath, stay so."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4385 a neo:Document ;
    neo:id "0345cfc68b92b4beebb4ec7f18738da0"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 74, sentence number 4 on page 202"^^xsd:string ;
    neo:text "Or stare without moving an eyelash."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4386 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4387,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4388 ;
    neo:id "d0a5d83f64d6439b7a8f719084d8da80"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 74, sentence number 5 on page 202"^^xsd:string ;
    neo:text "Or suck something and become the sucking."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4389 a neo:Document ;
    neo:id "951a3aed3794cf0a27a28106bb7eb985"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 75, sentence number 1 on page 202"^^xsd:string ;
    neo:text "53."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_439 a neo:Document ;
    neo:id "1f251148ce2820f80f1f8acf194e2c51"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 5, sentence number 2 on page 19"^^xsd:string ;
    neo:text "‘Nowhere is there any warmth.’"^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4390 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_2532,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4391,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_976 ;
    neo:id "051a68495a956fbe0318fbeef2277478"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 75, sentence number 2 on page 202"^^xsd:string ;
    neo:text "Without support for feet or hands, sit only on buttocks."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4393 a neo:Document ;
    neo:id "5c25f088a56d9d90def02a9958ca4fc6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 75, sentence number 3 on page 202"^^xsd:string ;
    neo:text "Suddenly, the centering."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4394 a neo:Document ;
    neo:id "50e25b797c673b7a3e14e0bb70ac527d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 76, sentence number 1 on page 202"^^xsd:string ;
    neo:text "54."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4395 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4264,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4396 ;
    neo:id "1512fb30f07a0b91fba7d9ca9a4070de"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 76, sentence number 2 on page 202"^^xsd:string ;
    neo:text "In an easy position, gradually pervade an area between the armpits into great peace."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4397 a neo:Document ;
    neo:id "f1c774f5f619edff8b90b5ad65f641ab"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 77, sentence number 1 on page 202"^^xsd:string ;
    neo:text "55."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4398 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_277,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4323 ;
    neo:id "6a95a3ec431bda5074acd891e0301ace"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 77, sentence number 2 on page 202"^^xsd:string ;
    neo:text "See as if for the first time a beauteous person or an ordinary object."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4399 a neo:Document ;
    neo:id "994dfb7c736e813da0c3f6acb855221f"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 78, sentence number 1 on page 202"^^xsd:string ;
    neo:text "56."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_440 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_209,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_369 ;
    neo:id "4b1f6e7d1b905205f69bed6605c1d793"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: 6. No Loving-Kindness, paragraph number 6, sentence number 1 on page 19"^^xsd:string ;
    neo:text "The girl returned and related what he had said."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4400 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_108,
