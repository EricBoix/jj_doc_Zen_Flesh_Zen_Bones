    neo:text "104."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4593 a neo:Document ;
    neo:id "775de8515aca94a944d1be29f30d7096"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 126, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Wherever your attention alights, at this very point, experience."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4594 a neo:Document ;
    neo:id "e5f812f6331607f16ba65c485005af3c"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 127, sentence number 1 on page 205"^^xsd:string ;
    neo:text "105."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4595 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3312,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_975 ;
    neo:id "96001bcde467a51f3097659e9a0526c6"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 127, sentence number 2 on page 205"^^xsd:string ;
    neo:text "Enter the sound of your name and, through this sound, all sounds."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4597 a neo:Document ;
    neo:id "b2f5fccd9be4f1c9209d9dec88922a0d"^^xsd:string ;
    neo:source "Source document: ZEN FLESH, ZEN BONES, Chapter: CENTERING, paragraph number 128, sentence number 1 on page 205"^^xsd:string ;
    neo:text "106."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4598 a neo:Document ;
