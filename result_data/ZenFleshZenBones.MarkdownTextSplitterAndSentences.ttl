    neo:text "48."^^xsd:string .

ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4366 a neo:Document ;
    neo:MENTIONS ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_3520,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4367,
        ex:node_4_97c2bd02_e99e_4762_96d1_819e4ffdc573_4368,
