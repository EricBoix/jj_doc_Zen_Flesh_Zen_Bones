# Neo4j server designation and associated credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

### LLM server designation and associate credential
LLM_MODEL_URL=https://your_favorite_server_CHANGE_ME/ollama/
# Credentials are handled through the OpenWebUI access key
LLM_API_KEY=sk-CHANGE_ME
# LLM name as known by the llama platform:
LLM_MODEL_NAME=llama3:70b_CHANGE_ME

### Optionnal: LLM Observability (Traceloop SDK → Grafana otel-lgtm)
# Base URL of the OTLP HTTP receiver served by Observability/docker-compose.yml 
# (the port value must match the value configured value). Note: this 
# self-managed backend requires no API key.
# TRACELOOP_BASE_URL=http://localhost:4318
